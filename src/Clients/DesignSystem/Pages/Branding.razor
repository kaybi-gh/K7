    <!-- App Manifests -->
    <section id="app-manifests" class="ds-section">
        <h2>App Manifests</h2>
        <p class="ds-description">Platform-specific app icons and banners used across different targets.</p>
        <div class="ds-brand-grid ds-brand-grid--manifests">
            <div class="ds-brand-card ds-brand-card--dark">
                <svg class="ds-brand-preview" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 32 32" style="width: 32px; height: 32px;" aria-hidden="true">
                    <rect width="32" height="32" fill="#0d0907" rx="6"/>
                    <g fill="#d9b060" transform="translate(3.65,8.8) scale(0.65)">
                        <path d="m 0,0 7.5,10 h 27.5 l 1.49,-2 c 2.474,-3.297 0.132,-8.002 -3.99,-8 z"/>
                        <path d="m 34.251,11 h -12.5 l -6.75,9 6.26,8.32 z"/>
                    </g>
                </svg>
                <span class="ds-brand-label">Favicon (32x32)</span>
            </div>
            <div class="ds-brand-card ds-brand-card--dark">
                <svg class="ds-brand-preview ds-brand-preview--appicon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 456 456" aria-hidden="true">
                    <rect width="456" height="456" fill="#0d0907" rx="96"/>
                    <g fill="#d9b060" transform="translate(118.5,155) scale(6)">
                        <path d="m 0,0 7.5,10 h 27.5 l 1.49,-2 c 2.474,-3.297 0.132,-8.002 -3.99,-8 z"/>
