            <div class="ds-brand-card ds-brand-card--dark ds-brand-card--wide">
                <svg class="ds-brand-preview ds-brand-preview--banner" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 180" aria-hidden="true">
                    <rect width="320" height="180" fill="#0d0907"/>
                    <g transform="translate(96,55)">
                        <path d="M0,0 L0,65 C0,69.802 6.115,71.839 9,68 L10,66.666 L10,0 Z" fill="#f3ecde"/>
                        <path d="M11,48.667 L11,65.334 L60,0 L47.5,0 Z" fill="#f3ecde"/>
                        <path d="M34.367,35.851 L28.131,44.167 L47.501,70.001 L60.001,70.001 Z" fill="#f3ecde"/>
                        <path d="M96.751,10 L89.251,0 L68.001,0 L60.501,10 Z" fill="#f3ecde"/>
                        <path d="M111.134,29.156 L104.881,20.831 L68.001,70.001 L80.501,70.001 Z" fill="#f3ecde"/>
                        <path d="M90.501,0 L98.001,10 L125.501,10 L126.991,8 C129.465,4.703 127.123,0 123.001,0 Z" fill="#d9b060"/>
                        <path d="M124.751,11 L112.251,11 L105.501,20 L111.761,28.32 Z" fill="#d9b060"/>
