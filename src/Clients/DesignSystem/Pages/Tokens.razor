@page "/tokens"

<PageTitle>Tokens - K7 Design System</PageTitle>

<div class="ds-page">
    <header class="ds-page-header">
        <h1>Design Tokens</h1>
        <p class="ds-lead">CSS custom properties that define the visual language of K7.</p>
    </header>

    <section class="ds-section">
        <h2>Brand Colors</h2>
        <div class="ds-token-grid">
            <div class="ds-token-swatch" style="background:var(--color-primary)"><span>--color-primary</span></div>
            <div class="ds-token-swatch" style="background:var(--color-primary-hover)"><span>--color-primary-hover</span></div>
            <div class="ds-token-swatch" style="background:var(--color-secondary)"><span>--color-secondary</span></div>
            <div class="ds-token-swatch" style="background:var(--color-accent)"><span>--color-accent</span></div>
        </div>
    </section>

    <section class="ds-section">
        <h2>Semantic Colors</h2>
        <div class="ds-token-grid">
            <div class="ds-token-swatch" style="background:var(--color-success)"><span>--color-success</span></div>
            <div class="ds-token-swatch" style="background:var(--color-warning)"><span>--color-warning</span></div>
            <div class="ds-token-swatch" style="background:var(--color-error)"><span>--color-error</span></div>
            <div class="ds-token-swatch" style="background:var(--color-info)"><span>--color-info</span></div>
        </div>
    </section>

    <section class="ds-section">
        <h2>Surface Colors</h2>
        <div class="ds-token-grid">
            <div class="ds-token-swatch ds-token-swatch--bordered" style="background:var(--color-bg)"><span>--color-bg</span></div>
            <div class="ds-token-swatch ds-token-swatch--bordered" style="background:var(--color-surface)"><span>--color-surface</span></div>
            <div class="ds-token-swatch ds-token-swatch--bordered" style="background:var(--color-surface-raised)"><span>--color-surface-raised</span></div>
            <div class="ds-token-swatch ds-token-swatch--bordered" style="background:var(--color-border)"><span>--color-border</span></div>
        </div>
    </section>

    <section class="ds-section">
        <h2>Text Colors</h2>
        <div class="ds-token-grid">
            <div class="ds-token-swatch ds-token-swatch--text" style="color:var(--color-text)"><span>--color-text</span></div>
            <div class="ds-token-swatch ds-token-swatch--text" style="color:var(--color-text-secondary)"><span>--color-text-secondary</span></div>
            <div class="ds-token-swatch ds-token-swatch--text" style="color:var(--color-text-disabled)"><span>--color-text-disabled</span></div>
        </div>
    </section>

    <section class="ds-section">
        <h2>Typography Scale</h2>
        <div class="ds-type-scale">
            <div><span style="font-size:var(--text-xs)">text-xs</span><code>--text-xs</code></div>
            <div><span style="font-size:var(--text-sm)">text-sm</span><code>--text-sm</code></div>
            <div><span style="font-size:var(--text-base)">text-base</span><code>--text-base</code></div>
            <div><span style="font-size:var(--text-md)">text-md</span><code>--text-md</code></div>
            <div><span style="font-size:var(--text-lg)">text-lg</span><code>--text-lg</code></div>
            <div><span style="font-size:var(--text-xl)">text-xl</span><code>--text-xl</code></div>
            <div><span style="font-size:var(--text-2xl)">text-2xl</span><code>--text-2xl</code></div>
            <div><span style="font-size:var(--text-3xl)">text-3xl</span><code>--text-3xl</code></div>
        </div>
    </section>

    <section class="ds-section">
        <h2>Border Radius</h2>
        <div class="ds-token-grid">
            <div class="ds-token-radius" style="border-radius:var(--radius-sm)"><span>--radius-sm</span></div>
            <div class="ds-token-radius" style="border-radius:var(--radius-md)"><span>--radius-md</span></div>
            <div class="ds-token-radius" style="border-radius:var(--radius-lg)"><span>--radius-lg</span></div>
            <div class="ds-token-radius" style="border-radius:var(--radius-xl)"><span>--radius-xl</span></div>
            <div class="ds-token-radius" style="border-radius:var(--radius-full)"><span>--radius-full</span></div>
        </div>
    </section>
</div>
