<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:K7.Clients.MAUI"
             xmlns:sharedPages="clr-namespace:K7.Clients.Shared.Pages;assembly=K7.Clients.Shared.Pages"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="K7.Clients.MAUI.BlazorPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <Grid x:Name="RootGrid">
        <!-- Native MediaElement (video) -->
        <toolkit:MediaElement x:Name="NativePlayer"
                              Aspect="AspectFit"
                              IsVisible="False"
                              ShouldAutoPlay="False"
                              HorizontalOptions="Fill"
                              VerticalOptions="Fill"
                              ShouldShowPlaybackControls="False"
                              InputTransparent="True" ZIndex="1"/>

        <!-- Native MediaElement (audio — hidden, background-capable) -->
        <toolkit:MediaElement x:Name="NativeAudioPlayer"
                              IsVisible="False"
                              ShouldAutoPlay="False"
                              ShouldShowPlaybackControls="False"
                              InputTransparent="True"
                              WidthRequest="0" HeightRequest="0" />
        
        <!-- Blazor overlay -->
        <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html"
                   BackgroundColor="Transparent" ZIndex="2">
            <BlazorWebView.RootComponents>
                <RootComponent Selector="#app" ComponentType="{x:Type sharedPages:Routes}" />
            </BlazorWebView.RootComponents>
        </BlazorWebView>
    </Grid>
</ContentPage>