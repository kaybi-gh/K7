<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:K7.Clients.MAUI"
             xmlns:sharedPages="clr-namespace:K7.Clients.Shared.UI.Pages;assembly=K7.Clients.Shared.UI"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="K7.Clients.MAUI.BlazorPage"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <Grid x:Name="RootGrid">
        <!-- Native MediaElement (video) -->
        <toolkit:MediaElement x:Name="NativePlayer"
                              Aspect="AspectFit"
                              IsVisible="False"
                              ShouldAutoPlay="False"
                              HorizontalOptions="Fill"
                              VerticalOptions="Fill"
                              ShouldShowPlaybackControls="False"
                              InputTransparent="True" ZIndex="1"/>

        <!-- Native MediaElement (audio - hidden, background-capable) -->
        <toolkit:MediaElement x:Name="NativeAudioPlayer"
                              IsVisible="False"
                              ShouldAutoPlay="False"
                              ShouldShowPlaybackControls="False"
                              InputTransparent="True"
                              WidthRequest="0" HeightRequest="0" />
        
        <!-- Blazor overlay -->
        <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html"
                   BackgroundColor="Transparent" ZIndex="2">
            <BlazorWebView.RootComponents>
                <RootComponent Selector="#app" ComponentType="{x:Type sharedPages:Routes}" />
            </BlazorWebView.RootComponents>
        </BlazorWebView>

        <!-- Close button for native player on Windows (overlay is not usable due to opaque WebView2) -->
        <Button x:Name="NativePlayerCloseButton"
                Text="&#x2715;"
                IsVisible="False"
                ZIndex="4"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="16"
                WidthRequest="40"
                HeightRequest="40"
                CornerRadius="20"
                BackgroundColor="#80000000"
                TextColor="White"
                FontSize="18"
                Clicked="OnNativePlayerCloseClicked" />
    </Grid>
</ContentPage>