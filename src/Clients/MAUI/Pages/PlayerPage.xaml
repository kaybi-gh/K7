<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:K7.Clients.MAUI"
             xmlns:sharedPages="clr-namespace:K7.Clients.Shared.Pages;assembly=K7.Clients.Shared.Pages"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="K7.Clients.MAUI.Pages.PlayerPage"
             Title="Free Player"
             Unloaded="OnPlayerPageUnloaded">

    <VerticalStackLayout>
        <Label Text="Media Player" FontSize="24" HorizontalOptions="Center"/>
        <toolkit:MediaElement x:Name="player"
                      Source="{Binding MediaElement.Source}"
                      ShouldAutoPlay="True"
                      ShouldShowPlaybackControls="True"
                      Aspect="AspectFill"
                      />
        <Button Text="Close" Clicked="OnCloseClicked"/>
    </VerticalStackLayout>

</ContentPage>