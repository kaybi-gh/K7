<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="K7.Clients.MAUI.SetupPage">

    <VerticalStackLayout Padding="20" VerticalOptions="Center" Spacing="12">
        <Label Text="K7" FontSize="32" HorizontalOptions="Center" FontAttributes="Bold" />
        <Label Text="Enter your K7 server URL:" />
        <Entry x:Name="BackendUrlEntry" Placeholder="https://k7.example.com" Keyboard="Url" />
        <Button Text="Connect" Clicked="OnValidateClicked" />
        <Label x:Name="InfoLabel" Text="" IsVisible="False" TextColor="Gray" />
    </VerticalStackLayout>

</ContentPage>
