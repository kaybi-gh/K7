<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">
	
  <PropertyGroup>
    <RootNamespace>K7.Clients.Web.Client</RootNamespace>
    <AssemblyName>K7.Clients.Web.Client</AssemblyName>
  </PropertyGroup>
	
  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <NoDefaultLaunchSettingsFile>true</NoDefaultLaunchSettingsFile>
    <StaticWebAssetProjectMode>Default</StaticWebAssetProjectMode>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" />
	  <PackageReference Include="MudBlazor" />
	  <PackageReference Include="System.Text.Json" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\Components\K7.Clients.Shared.Components.csproj" />
    <ProjectReference Include="..\..\Shared\Models\K7.Clients.Shared.Domain.csproj" />
    <ProjectReference Include="..\..\Shared\Pages\K7.Clients.Shared.Pages.csproj" />
    <ProjectReference Include="..\..\Shared\Services\K7.Clients.Shared.Services.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="wwwroot\appsettings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
