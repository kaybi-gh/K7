@using K7.Shared.Dtos
@inject IK7ServerService K7ServerService

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_authInfo is not null)
{
    <MudStack Spacing="4" Class="pa-4">
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" NoIcon="true">
            La configuration de l'authentification est définie dans <code>appsettings.json</code> et nécessite un redémarrage pour être modifiée.
        </MudAlert>

        <MudText Typo="Typo.h6">Authentification locale</MudText>
        <MudSimpleTable Elevation="0" Dense="true" Outlined="true">
            <tbody>
                <tr>
                    <td style="width: 300px;"><MudText Typo="Typo.body2">Connexion locale</MudText></td>
                    <td>
                        <MudChip T="string" Size="Size.Small" Color="@(_authInfo.LocalSignInEnabled ? Color.Success : Color.Default)">
                            @(_authInfo.LocalSignInEnabled ? "Activée" : "Désactivée")
                        </MudChip>
                    </td>
                </tr>
                <tr>
                    <td><MudText Typo="Typo.body2">Inscription locale</MudText></td>
                    <td>
                        <MudChip T="string" Size="Size.Small" Color="@(_authInfo.LocalRegistrationEnabled ? Color.Success : Color.Default)">
                            @(_authInfo.LocalRegistrationEnabled ? "Activée" : "Désactivée")
                        </MudChip>
                    </td>
                </tr>
            </tbody>
        </MudSimpleTable>

        <MudText Typo="Typo.h6">Authentification OIDC</MudText>
        <MudSimpleTable Elevation="0" Dense="true" Outlined="true">
            <tbody>
                <tr>
                    <td style="width: 300px;"><MudText Typo="Typo.body2">OIDC</MudText></td>
                    <td>
                        <MudChip T="string" Size="Size.Small" Color="@(_authInfo.OidcEnabled ? Color.Success : Color.Default)">
                            @(_authInfo.OidcEnabled ? "Activé" : "Désactivé")
                        </MudChip>
                    </td>
                </tr>
                @if (_authInfo.OidcEnabled)
                {
                    <tr>
                        <td><MudText Typo="Typo.body2">Fournisseur</MudText></td>
                        <td><MudText Typo="Typo.body2">@_authInfo.OidcDisplayName</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Typo="Typo.body2">Création automatique de compte</MudText></td>
                        <td>
                            <MudChip T="string" Size="Size.Small" Color="@(_authInfo.OidcAutomaticAccountCreation ? Color.Success : Color.Default)">
                                @(_authInfo.OidcAutomaticAccountCreation ? "Activée" : "Désactivée")
                            </MudChip>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        @if (!_authInfo.LocalSignInEnabled && _authInfo.OidcEnabled)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                La connexion locale est désactivée. Les utilisateurs seront automatiquement redirigés vers le fournisseur OIDC.
            </MudAlert>
        }
    </MudStack>
}

@code {
    private AuthenticationInfoDto? _authInfo;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _authInfo = await K7ServerService.GetAuthenticationInfoAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }
}
