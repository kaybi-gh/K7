@namespace K7.Clients.Shared.UI.Components
@typeparam TValue

<div class="k7-button-group" role="radiogroup" aria-label="@AriaLabel">
    @foreach (var option in Options)
    {
        var opt = option;
        var isActive = EqualityComparer<TValue>.Default.Equals(opt.Value, Value);
        <button type="button"
                class="k7-button-group-item focusable @(isActive ? "k7-button-group-item--active" : "")"
                role="radio"
                aria-checked="@isActive"
                @onclick="() => OnOptionClicked(opt.Value)">
            @if (opt.Icon is not null)
            {
                <K7Icon Icon="@opt.Icon" Size="sm" />
            }
            @if (opt.Label is not null)
            {
                <span>@opt.Label</span>
            }
        </button>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ButtonGroupOption<TValue>> Options { get; set; } = [];
    [Parameter] public TValue? Value { get; set; }
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }
    [Parameter] public string? AriaLabel { get; set; }

    private async Task OnOptionClicked(TValue value)
    {
        if (EqualityComparer<TValue>.Default.Equals(value, Value)) return;
        await ValueChanged.InvokeAsync(value);
    }
}
