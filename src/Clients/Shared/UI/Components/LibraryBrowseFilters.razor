@namespace K7.Clients.Shared.UI.Components
@using K7.Clients.Shared.Helpers
@using K7.Clients.Shared.Models
@using K7.Shared.Extensions
@using K7.Server.Domain.Enums
@inject IStringLocalizer<LibraryBrowseFilters> L

<K7Menu Class="@($"library-browse-filters {Class}".Trim())"
        Title="@L["Filters"]"
        Open="_menuOpen"
        OpenChanged="OnMenuOpenChanged">
    <ActivatorContent>
        <div class="library-browse-filters__activator focusable" tabindex="0" role="button" aria-label="@L["Filters"]">
            @if (HasActiveFilters)
            {
                <button type="button"
                        class="library-browse-filters__clear focusable"
                        aria-label="@L["ClearFilters"]"
                        @onclick="ClearFiltersAsync"
                        @onclick:stopPropagation="true">
                    <K7Icon Icon="@Phosphor.XCircle" Size="sm" />
                </button>
            }
            <span class="library-browse-filters__label">@ActiveFiltersLabel</span>
            <K7Icon Icon="@Phosphor.CaretDown" Size="sm" Class="library-browse-filters__caret" />
        </div>
    </ActivatorContent>
    <ChildContent>
        @if (HasActiveFilters)
        {
            <K7MenuItem OnClick="ClearFiltersAsync">
                @L["ClearFilters"]
            </K7MenuItem>
            <hr class="k7-menu-divider" />
        }
        @if (_submenu != QuickFilterSubmenu.None)
        {
            <K7MenuItem Icon="@Phosphor.CaretLeft" PreventClose="true" OnClick="() => _submenu = QuickFilterSubmenu.None">
                @S["Back"]
            </K7MenuItem>
            @switch (_submenu)
            {
                case QuickFilterSubmenu.Actor:
                    <div class="library-browse-filters__section-label">@L["FilterActor"]</div>
                    <div class="library-browse-filters__search">
                        <K7SearchSelect Value="@(_actorDraft ?? "")"
                                        ValueChanged="v => _actorDraft = v"
                                        CommitOnSelectOnly="true"
                                        OnDebouncedCommit="SetActorAsync"
                                        Variant="outlined"
                                        Placeholder="@L["SearchPlaceholderActor"]"
                                        SearchAsync="(text, ct) => SearchSuggestionsAsync(nameof(SmartPlaylistField.ActorName), text, ct)" />
                    </div>
                    break;
                case QuickFilterSubmenu.Studio:
                    <div class="library-browse-filters__section-label">@L["FilterStudio"]</div>
                    <div class="library-browse-filters__search">
                        <K7SearchSelect Value="@(_studioDraft ?? "")"
                                        ValueChanged="v => _studioDraft = v"
                                        CommitOnSelectOnly="true"
                                        OnDebouncedCommit="SetStudioAsync"
                                        Variant="outlined"
                                        Placeholder="@L["SearchPlaceholderStudio"]"
                                        SearchAsync='(text, ct) => SearchSuggestionsAsync("Studio", text, ct)' />
                    </div>
                    break;
                case QuickFilterSubmenu.Artist:
                    <div class="library-browse-filters__section-label">@L["FilterArtist"]</div>
                    <div class="library-browse-filters__search">
                        <K7SearchSelect Value="@(_artistDraft ?? "")"
                                        ValueChanged="v => _artistDraft = v"
                                        CommitOnSelectOnly="true"
                                        OnDebouncedCommit="SetArtistAsync"
                                        Variant="outlined"
                                        Placeholder="@L["SearchPlaceholderArtist"]"
                                        SearchAsync="(text, ct) => SearchSuggestionsAsync(nameof(SmartPlaylistField.ArtistName), text, ct)" />
                    </div>
                    break;
                case QuickFilterSubmenu.ContentRating:
                    <div class="library-browse-filters__section-label">@L["FieldContentRating"]</div>
                    <div class="library-browse-filters__menu">
                        @foreach (var rating in Tags!.GetValues(MetadataTagKind.ContentRating))
                        {
                            var selected = SelectedContentRatings.Contains(rating);
                            <button type="button"
                                    class="library-browse-filters__option focusable @(selected ? "library-browse-filters__option--selected" : "")"
                                    @onclick="() => ToggleContentRatingAsync(rating)">
                                <span class="library-browse-filters__option-label">@rating</span>
                                @if (selected)
                                {
                                    <K7Icon Icon="@Phosphor.Check" Size="sm" />
                                }
                            </button>
                        }
                    </div>
                    break;
                case QuickFilterSubmenu.Genres:
                    <div class="library-browse-filters__section-label">@L["FilterGenres"]</div>
                    <div class="library-browse-filters__menu">
                        @foreach (var genre in GenreTags)
                        {
                            var selected = SelectedGenres.Contains(genre.DisplayName);
                            <button type="button"
                                    class="library-browse-filters__option focusable @(selected ? "library-browse-filters__option--selected" : "")"
                                    @onclick="() => ToggleGenreAsync(genre.DisplayName)">
                                <span class="library-browse-filters__option-label">@GetGenreLabel(genre)</span>
                                @if (selected)
                                {
                                    <K7Icon Icon="@Phosphor.Check" Size="sm" />
                                }
                            </button>
                        }
                    </div>
                    break;
                case QuickFilterSubmenu.SonicSearch:
                    <div class="library-browse-filters__section-label">@L["FilterSonicSearch"]</div>
                    <p class="library-browse-filters__hint text-caption">@L["SonicSearchHint"]</p>
                    <div class="library-browse-filters__search">
                        <K7TextField @bind-Value="_intelligentSearchDraft"
                                     Placeholder="@L["SonicSearchPlaceholder"]"
                                     Variant="outlined" />
                        <K7Button Class="mt-2"
                                    Variant="K7ButtonVariant.Filled"
                                    Disabled="string.IsNullOrWhiteSpace(_intelligentSearchDraft)"
                                    OnClick="() => ApplyIntelligentSearchAsync(IntelligentSearchKind.Sonic)">
                            @L["ApplySearch"]
                        </K7Button>
                    </div>
                    break;
                case QuickFilterSubmenu.LyricsSearch:
                    <div class="library-browse-filters__section-label">@L["FilterLyricsSearch"]</div>
                    <p class="library-browse-filters__hint text-caption">@L["LyricsSearchHint"]</p>
                    <div class="library-browse-filters__search">
                        <K7TextField @bind-Value="_intelligentSearchDraft"
                                     Placeholder="@L["LyricsSearchPlaceholder"]"
                                     Variant="outlined" />
                        <K7Button Class="mt-2"
                                    Variant="K7ButtonVariant.Filled"
                                    Disabled="string.IsNullOrWhiteSpace(_intelligentSearchDraft)"
                                    OnClick="() => ApplyIntelligentSearchAsync(IntelligentSearchKind.Lyrics)">
                            @L["ApplySearch"]
                        </K7Button>
                    </div>
                    break;
            }
        }
        else
        {
            @if (ShowWatchFilters)
            {
                <div class="library-browse-filters__menu library-browse-filters__menu--section">
                    <button type="button"
                            class="library-browse-filters__option focusable @(!MediaBrowseFilterPresets.IsUnwatched(Filter) && !MediaBrowseFilterPresets.IsInProgress(Filter) ? "library-browse-filters__option--selected" : "")"
                            @onclick="() => SetPresetAsync(MediaBrowseFilterPresets.Empty)">
                        <span class="library-browse-filters__option-label">@L["WatchFilterAll"]</span>
                        @if (!MediaBrowseFilterPresets.IsUnwatched(Filter) && !MediaBrowseFilterPresets.IsInProgress(Filter))
                        {
                            <K7Icon Icon="@Phosphor.Check" Size="sm" />
                        }
                    </button>
                    <button type="button"
                            class="library-browse-filters__option focusable @(MediaBrowseFilterPresets.IsUnwatched(Filter) ? "library-browse-filters__option--selected" : "")"
                            @onclick="() => SetPresetAsync(MediaBrowseFilterPresets.Unwatched)">
                        <span class="library-browse-filters__option-label">@L["WatchFilterUnwatched"]</span>
                        @if (MediaBrowseFilterPresets.IsUnwatched(Filter))
                        {
                            <K7Icon Icon="@Phosphor.Check" Size="sm" />
                        }
                    </button>
                    <button type="button"
                            class="library-browse-filters__option focusable @(MediaBrowseFilterPresets.IsInProgress(Filter) ? "library-browse-filters__option--selected" : "")"
                            @onclick="() => SetPresetAsync(MediaBrowseFilterPresets.InProgress)">
                        <span class="library-browse-filters__option-label">@L["WatchFilterInProgress"]</span>
                        @if (MediaBrowseFilterPresets.IsInProgress(Filter))
                        {
                            <K7Icon Icon="@Phosphor.Check" Size="sm" />
                        }
                    </button>
                </div>
            }
            @if (ShowWatchFilters)
            {
                <hr class="k7-menu-divider" />
            }
            <div class="library-browse-filters__menu">
                @if (ShowVideoMetadataQuickFilters)
                {
                    <button type="button"
                            class="library-browse-filters__option focusable"
                            @onclick="() => OpenSubmenu(QuickFilterSubmenu.Actor)">
                        <span class="library-browse-filters__option-label">@GetActorMenuLabel()</span>
                        <K7Icon Icon="@Phosphor.CaretRight" Size="sm" Class="library-browse-filters__option-chevron" />
                    </button>
                    <button type="button"
                            class="library-browse-filters__option focusable"
                            @onclick="() => OpenSubmenu(QuickFilterSubmenu.Studio)">
                        <span class="library-browse-filters__option-label">@GetStudioMenuLabel()</span>
                        <K7Icon Icon="@Phosphor.CaretRight" Size="sm" Class="library-browse-filters__option-chevron" />
                    </button>
                    @if (HasContentRatings)
                    {
                        <button type="button"
                                class="library-browse-filters__option focusable"
                                @onclick="() => OpenSubmenu(QuickFilterSubmenu.ContentRating)">
                            <span class="library-browse-filters__option-label">@GetContentRatingMenuLabel()</span>
                            <K7Icon Icon="@Phosphor.CaretRight" Size="sm" Class="library-browse-filters__option-chevron" />
                        </button>
                    }
                }
                @if (ShowArtistQuickFilter)
                {
                    <button type="button"
                            class="library-browse-filters__option focusable"
                            @onclick="() => OpenSubmenu(QuickFilterSubmenu.Artist)">
                        <span class="library-browse-filters__option-label">@GetArtistMenuLabel()</span>
                        <K7Icon Icon="@Phosphor.CaretRight" Size="sm" Class="library-browse-filters__option-chevron" />
                    </button>
                }
                @if (ShowGenreQuickFilter)
                {
                    <button type="button"
                            class="library-browse-filters__option focusable"
                            @onclick="() => OpenSubmenu(QuickFilterSubmenu.Genres)">
                        <span class="library-browse-filters__option-label">@GetGenresMenuLabel()</span>
                        <K7Icon Icon="@Phosphor.CaretRight" Size="sm" Class="library-browse-filters__option-chevron" />
                    </button>
                }
                @if (ShowIntelligentSearchFilters)
                {
                    <button type="button"
                            class="library-browse-filters__option focusable"
                            @onclick="() => OpenSubmenu(QuickFilterSubmenu.SonicSearch)">
                        <span class="library-browse-filters__option-label">@L["FilterSonicSearch"]</span>
                        <K7Icon Icon="@Phosphor.CaretRight" Size="sm" Class="library-browse-filters__option-chevron" />
                    </button>
                    <button type="button"
                            class="library-browse-filters__option focusable"
                            @onclick="() => OpenSubmenu(QuickFilterSubmenu.LyricsSearch)">
                        <span class="library-browse-filters__option-label">@L["FilterLyricsSearch"]</span>
                        <K7Icon Icon="@Phosphor.CaretRight" Size="sm" Class="library-browse-filters__option-chevron" />
                    </button>
                }
                <button type="button"
                        class="library-browse-filters__option focusable"
                        @onclick="OpenAdvancedFiltersAsync">
                    <span class="library-browse-filters__option-label">@L["AdvancedFilters"]</span>
                </button>
            </div>
        }
    </ChildContent>
</K7Menu>
