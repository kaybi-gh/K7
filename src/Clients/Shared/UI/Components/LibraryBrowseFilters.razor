@namespace K7.Clients.Shared.UI.Components
@using K7.Clients.Shared.Enums
@inject IStringLocalizer<LibraryBrowseFilters> L

<K7Menu Class="@($"library-browse-filters {Class}".Trim())" Title="@L["Filters"]">
    <ActivatorContent>
        <div class="library-browse-filters__activator focusable" tabindex="0" role="button" aria-label="@L["Filters"]">
            @if (HasActiveFilters)
            {
                <button type="button"
                        class="library-browse-filters__clear focusable"
                        aria-label="@L["ClearFilters"]"
                        @onclick="ClearFiltersAsync"
                        @onclick:stopPropagation="true">
                    <K7Icon Icon="@Phosphor.XCircle" Size="sm" />
                </button>
            }
            <span class="library-browse-filters__label">@ActiveFiltersLabel</span>
            <K7Icon Icon="@Phosphor.CaretDown" Size="sm" Class="library-browse-filters__caret" />
        </div>
    </ActivatorContent>
    <ChildContent>
        @if (HasActiveFilters)
        {
            <K7MenuItem OnClick="ClearFiltersAsync">
                @L["ClearFilters"]
            </K7MenuItem>
            <hr class="k7-menu-divider" />
        }
        @if (ShowWatchFilters)
        {
            <div class="library-browse-filters__menu library-browse-filters__menu--section">
                <button type="button"
                        class="library-browse-filters__option focusable @(WatchFilter is LibraryBrowseWatchFilter.All ? "library-browse-filters__option--selected" : "")"
                        @onclick="() => SetWatchFilterAsync(LibraryBrowseWatchFilter.All)">
                    <span class="library-browse-filters__option-label">@L["WatchFilterAll"]</span>
                    @if (WatchFilter is LibraryBrowseWatchFilter.All)
                    {
                        <K7Icon Icon="@Phosphor.Check" Size="sm" />
                    }
                </button>
                <button type="button"
                        class="library-browse-filters__option focusable @(WatchFilter is LibraryBrowseWatchFilter.Unwatched ? "library-browse-filters__option--selected" : "")"
                        @onclick="() => SetWatchFilterAsync(LibraryBrowseWatchFilter.Unwatched)">
                    <span class="library-browse-filters__option-label">@L["WatchFilterUnwatched"]</span>
                    @if (WatchFilter is LibraryBrowseWatchFilter.Unwatched)
                    {
                        <K7Icon Icon="@Phosphor.Check" Size="sm" />
                    }
                </button>
                <button type="button"
                        class="library-browse-filters__option focusable @(WatchFilter is LibraryBrowseWatchFilter.InProgress ? "library-browse-filters__option--selected" : "")"
                        @onclick="() => SetWatchFilterAsync(LibraryBrowseWatchFilter.InProgress)">
                    <span class="library-browse-filters__option-label">@L["WatchFilterInProgress"]</span>
                    @if (WatchFilter is LibraryBrowseWatchFilter.InProgress)
                    {
                        <K7Icon Icon="@Phosphor.Check" Size="sm" />
                    }
                </button>
            </div>
        }
        @if (ShowWatchFilters && Genres.Count > 0)
        {
            <hr class="k7-menu-divider" />
        }
        @if (Genres.Count > 0)
        {
            <div class="library-browse-filters__section-label">@L["FilterGenres"]</div>
            <div class="library-browse-filters__menu">
                @foreach (var genre in Genres)
                {
                    var selected = SelectedGenres.Contains(genre.Name);
                    <button type="button"
                            class="library-browse-filters__option focusable @(selected ? "library-browse-filters__option--selected" : "")"
                            @onclick="() => ToggleGenreAsync(genre.Name)">
                        <span class="library-browse-filters__option-label">@GetGenreLabel(genre)</span>
                        @if (selected)
                        {
                            <K7Icon Icon="@Phosphor.Check" Size="sm" />
                        }
                    </button>
                }
            </div>
        }
    </ChildContent>
</K7Menu>
