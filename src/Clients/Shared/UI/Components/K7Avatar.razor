@namespace K7.Clients.Shared.UI.Components

<span class="k7-avatar @(Size == "sm" ? "k7-avatar--sm" : Size == "lg" ? "k7-avatar--lg" : Size == "xl" ? "k7-avatar--xl" : "") @(string.IsNullOrEmpty(Color) ? "" : $"color-{Color}") @Class">
    <span class="k7-avatar__clip" style="@ComputedStyle">
        @if (!string.IsNullOrEmpty(Image))
        {
            <img src="@Image" alt="@Alt" />
        }
        else if (!string.IsNullOrEmpty(DisplayLetter))
        {
            <span class="k7-avatar__letter">@DisplayLetter</span>
        }
        else
        {
            @ChildContent
        }
    </span>
    @if (!string.IsNullOrEmpty(Image) || !string.IsNullOrEmpty(DisplayLetter))
    {
        @ChildContent
    }
</span>
