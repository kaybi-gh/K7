@namespace K7.Clients.Shared.UI.Components

<label class="k7-switch-wrap focusable @Class" role="switch" aria-checked="@Value" tabindex="0" data-sn-focus-target=".k7-switch-track">
    <input type="checkbox"
           checked="@Value"
           disabled="@Disabled"
           tabindex="-1"
           @onchange="OnChange" />
    <span class="k7-switch-track">
        <span class="k7-switch-thumb"></span>
    </span>
    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="k7-label" style="margin-bottom:0;">@Label</span>
    }
</label>
