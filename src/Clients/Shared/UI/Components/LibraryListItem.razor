@using K7.Shared.Dtos.Entities.Medias

<LibraryBrowseListRow Actions="Actions">
    <a href="@Href" class="library-list-item focusable">
        @ThumbnailContent
        <div class="library-list-item-info">
            <p class="library-list-item-title">@Item.Title</p>
            @if (SecondaryText is not null)
            {
                <span class="library-list-item-secondary">@SecondaryText</span>
            }
        </div>
        @if (Actions is null)
        {
            <div class="library-list-item-end">
                @EndContent
            </div>
        }
    </a>
</LibraryBrowseListRow>

@code {
    private RenderFragment ThumbnailContent => @<text>
        @if (ThumbnailUrl is not null)
        {
            <K7Image Src="@ThumbnailUrl" Alt="@Item.Title" Width="48" ObjectFit="cover" Class="library-list-item-thumb rounded" loading="lazy" />
        }
        else
        {
            <div class="library-list-item-thumb-placeholder rounded">
                <K7Icon Icon="@Phosphor.Image" IconSize="@K7IconSize.Sm" />
            </div>
        }
    </text>;

    private RenderFragment EndContent => @<text>
        @if (Item.UserRating is > 0)
        {
            <span class="library-list-item-rating">@Item.UserRating</span>
        }
        @if (Progress is > 0 and < 100)
        {
            <K7ProgressBar Value="@Progress" Class="library-list-item-progress" />
        }
        else if (IsWatched)
        {
            <K7Icon Icon="@Phosphor.CheckCircle" Color="success" IconSize="@K7IconSize.Sm" />
        }
    </text>;
}
