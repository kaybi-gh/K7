@using K7.Clients.Shared.Enums
@typeparam TItem
@inject IStringLocalizer<SharedResource> S

<div class="browse-view">
    <div class="browse-view-toolbar">
        <div class="browse-view-toolbar-start">
            @ToolbarContent
        </div>
        <div class="browse-view-toolbar-end">
            @if (_availableModes.Count > 1)
            {
                @foreach (var mode in _availableModes)
                {
                    var m = mode;
                    <K7IconButton OnClick="() => SetViewModeAsync(m)" AriaLabel="@GetModeIcon(m)" Icon="@GetModeIcon(m)" />
                }
            }
            @if (_currentMode is BrowseViewMode.Grid)
            {
                <K7IconButton OnClick="() => _settingsOpen = !_settingsOpen" AriaLabel="settings" Icon="@Phosphor.SlidersHorizontal" />
            }
        </div>
    </div>

    @if (_settingsOpen && _currentMode is BrowseViewMode.Grid)
    {
        <div class="browse-view-settings">
            <label class="browse-view-settings-label">@S["ItemSize"]: @_itemWidth px</label>
            <K7Slider TValue="int" Value="_itemWidth" ValueChanged="OnItemWidthChanged" Step="10" Class="mx-4" />
            <label class="browse-view-settings-label">@S["Spacing"]: @_spacing px</label>
            <K7Slider TValue="int" Value="_spacing" ValueChanged="OnSpacingChanged" Step="2" Class="mx-4" />
        </div>
    }

    @if (Loading)
    {
        @if (LoadingContent is not null)
        {
            @LoadingContent
        }
        else
        {
            <div class="d-flex flex-col pa-16">
                <K7Spinner />
            </div>
        }
    }
    else if (Items is null || Items.Count == 0)
    {
        @if (EmptyContent is not null)
        {
            @EmptyContent
        }
        else
        {
            <div class="d-flex flex-col pa-16">
                <K7Icon Icon="@Phosphor.MagnifyingGlass" Style="font-size: 64px; opacity: 0.3;" />
            </div>
        }
    }
    else
    {
        @switch (_currentMode)
        {
            case BrowseViewMode.Grid when GridTemplate is not null:
                <div class="browse-view-grid"
                     style="--item-width: @(_itemWidth)px; --grid-gap: @(_spacing)px;"
                     @ref="_gridRef">
                    <Virtualize Items="_rows" Context="row" ItemSize="_estimatedRowHeight" OverscanCount="2">
                        <div class="browse-view-grid-row" style="grid-template-columns: repeat(@(CalculateColumnCount()), @(_itemWidth)px);">
                            @foreach (var item in row)
                            {
                                @GridTemplate(item)
                            }
                        </div>
                    </Virtualize>
                </div>
                break;

            case BrowseViewMode.Table when TableHeaderContent is not null && TableRowTemplate is not null:
                <div class="browse-view-table">
                    <table class="browse-view-table-el">
                        <thead>
                            <tr>
                                @TableHeaderContent
                            </tr>
                        </thead>
                        <tbody>
                            <Virtualize Items="Items" Context="item" ItemSize="48" OverscanCount="10">
                                @TableRowTemplate(item)
                            </Virtualize>
                        </tbody>
                    </table>
                </div>
                break;

            case BrowseViewMode.List when ListTemplate is not null:
                <div class="browse-view-list">
                    <Virtualize Items="Items" Context="item" ItemSize="ListItemHeight" OverscanCount="5">
                        @ListTemplate(item)
                    </Virtualize>
                </div>
                break;
        }

        @if (HasMore && OnLoadMore is not null)
        {
            <div class="browse-view-sentinel" @ref="_sentinelRef">
                <K7Spinner />
            </div>
        }
    }
</div>
