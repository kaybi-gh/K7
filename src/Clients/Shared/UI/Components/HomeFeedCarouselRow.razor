@namespace K7.Clients.Shared.UI.Components

@if (_loading)
{
    <Carousel Skeleton="true" Title="@Title">
        @for (var i = 0; i < 8; i++)
        {
            <CarouselItem>
                <MediaCard Skeleton="true" FooterVisible="true" />
            </CarouselItem>
        }
    </Carousel>
}
else if (_items.Count > 0)
{
    <Carousel Title="@Title">
        @foreach (var item in _items)
        {
            <CarouselItem @key="item.Id" ItemId="@GetCardElementId(item.Id)">
                <MediaCard Model="@item"
                           ElementId="@GetCardElementId(item.Id)"
                           Variant="@GetVariant(item)"
                           Href="@GetHref(item)"
                           OverlayEnabled="true"
                           ProgressEnabled="@ProgressEnabled"
                           WatchedStatusEnabled="@ProgressEnabled"
                           FooterVisible="true"
                           ExcludeMenuEnabled="_canExclude"
                           WatchStateMenuEnabled="_canSetWatchState"
                           IsAdmin="_isAdmin"
                           OnExcludeForSelf="() => ExcludeForSelf(item)"
                           OnExcludeForOthers="() => ExcludeForOthers(item)"
                           OnWatchStateChanged="RefreshAfterWatchStateChangeAsync"
                           OnFocused="() => OnCardFocused(item)" />
            </CarouselItem>
        }
    </Carousel>
}
