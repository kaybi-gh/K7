@namespace K7.Clients.Shared.UI.Components
@using System.Globalization
@using System.Text

@if (Values is not null && Values.Length > 0)
{
    @((MarkupString)BuildSvg())
}

@code {
    [Parameter] public double[]? Values { get; set; }
    [Parameter] public string[]? Labels { get; set; }
    [Parameter] public double Height { get; set; } = 100;
    [Parameter] public double GapPercent { get; set; } = 1;
    [Parameter] public double LabelHeight { get; set; } = 14;
    [Parameter] public double LabelFontSize { get; set; } = 5;
    [Parameter] public double CornerRadius { get; set; } = 1;

    private static string F(double v) => v.ToString("0.##", CultureInfo.InvariantCulture);

    private string BuildSvg()
    {
        if (Values is null || Values.Length == 0) return "";

        var count = Values.Length;
        var max = Values.Max();
        var barWidth = Math.Max(2.0, (100.0 - (count + 1) * GapPercent) / count);
        var step = barWidth + GapPercent;
        var xStart = GapPercent;
        var sb = new StringBuilder();

        sb.Append($"<svg viewBox=\"0 0 100 {F(Height)}\" preserveAspectRatio=\"none\" style=\"width:100%;height:{F(Height)}px;display:block;overflow:visible;\">");

        for (var i = 0; i < count; i++)
        {
            var val = Values[i];
            var barH = max > 0 ? val / max * (Height - LabelHeight) : 0;
            var x = xStart + i * step;
            var y = Height - LabelHeight - barH;

            sb.Append($"<rect x=\"{F(x)}\" y=\"{F(y)}\" width=\"{F(barWidth)}\" height=\"{F(barH)}\" rx=\"{F(CornerRadius)}\" fill=\"var(--color-accent)\" opacity=\"0.85\" />");

            if (Labels is not null && i < Labels.Length && LabelHeight > 0)
            {
                var labelX = x + barWidth / 2;
                var label = System.Net.WebUtility.HtmlEncode(Labels[i]);
                sb.Append($"<text x=\"{F(labelX)}\" y=\"{F(Height - 2)}\" text-anchor=\"middle\" font-size=\"{F(LabelFontSize)}\" fill=\"var(--color-text-secondary)\" font-family=\"inherit\">{label}</text>");
            }
        }

        sb.Append("</svg>");
        return sb.ToString();
    }
}
