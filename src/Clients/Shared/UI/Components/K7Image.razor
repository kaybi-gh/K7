@namespace K7.Clients.Shared.UI.Components

<div class="@WrapCssClass" style="@WrapStyle" role="@(ShowFallback && !string.IsNullOrEmpty(Alt) ? "img" : null)" aria-label="@(ShowFallback ? Alt : null)">
    @if (ShowFallback)
    {
        <div class="k7-img-fallback" aria-hidden="@(!string.IsNullOrEmpty(Alt))">
            <K7Icon Icon="@FallbackIcon" Class="k7-img-fallback-icon" />
        </div>
    }
    else
    {
        @if (ShowLoading)
        {
            <div class="k7-img-loading" aria-hidden="true">
                <K7Spinner Size="sm" />
            </div>
        }
        <img @ref="_imgRef"
             class="@ImageCssClass"
             src="@Src"
             alt="@Alt"
             loading="@Loading"
             @onload="OnLoad"
             @onerror="OnError"
             @attributes="ImageAttributes" />
    }
</div>
