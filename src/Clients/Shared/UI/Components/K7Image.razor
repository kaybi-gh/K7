@namespace K7.Clients.Shared.UI.Components

<img class="@CssClass"
     src="@Src"
     alt="@Alt"
     loading="@Loading"
     @attributes="MergedAttributes" />

@code {
    private string CssClass =>
        $"k7-img {ObjectFitClass} {(Fluid ? "k7-img--fluid" : "")} {Class}".Trim();

    private string ObjectFitClass => ObjectFit switch
    {
        "cover" => "k7-img--cover",
        "contain" => "k7-img--contain",
        "scale-down" => "k7-img--scale-down",
        _ => ""
    };

    private Dictionary<string, object?> MergedAttributes
    {
        get
        {
            var d = new Dictionary<string, object?>();
            if (Width > 0) d["width"] = Width;
            if (Height > 0) d["height"] = Height;
            if (!string.IsNullOrEmpty(Style)) d["style"] = Style;
            if (AdditionalAttributes is not null)
            {
                foreach (var kv in AdditionalAttributes)
                    d[kv.Key] = kv.Value;
            }

            return d;
        }
    }
}
