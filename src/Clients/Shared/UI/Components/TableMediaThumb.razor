@namespace K7.Clients.Shared.UI.Components
@using K7.Clients.Shared.UI.Helpers
@using K7.Server.Domain.Enums
@inject IK7ServerService ApiClient

@if (ResolvedImageUrl is not null)
{
    <div class="table-media-thumb" style="@ThumbStyle">
        <K7Image Src="@ResolvedImageUrl"
                 Alt=""
                 ObjectFit="contain"
                 Class="table-media-thumb__image rounded"
                 loading="lazy"
                 FallbackContent="@PlaceholderVisual" />
    </div>
}
else
{
    <div class="table-media-thumb table-media-thumb--placeholder" style="@ThumbStyle" aria-hidden="true">
        @PlaceholderVisual
    </div>
}

@code {
    private RenderFragment PlaceholderVisual => @<K7Icon Icon="@PlaceholderIcon" IconSize="@K7IconSize.Sm" />;
}
