@namespace K7.Clients.Shared.UI.Components

<span class="k7-chip @(Variant == "outlined" ? "k7-chip--outlined" : "") @(!string.IsNullOrEmpty(Color) ? $"k7-chip--{Color}" : "") @Class"
      style="@(string.IsNullOrEmpty(Style) ? null : Style)"
      role="@(OnClick.HasDelegate ? "button" : null)"
      tabindex="@(OnClick.HasDelegate ? "0" : null)"
      @onclick="OnClick">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <i class="ph ph-@Icon" style="font-size:0.85em;"></i>
    }
    @if (!string.IsNullOrEmpty(Text))
    {
        @Text
    }
    else
    {
        @ChildContent
    }
    @if (OnClose.HasDelegate)
    {
        <button class="k7-chip-close" @onclick="OnClose" @onclick:stopPropagation="true" type="button" aria-label="Remove">
            <i class="ph ph-x" style="font-size:0.75em;"></i>
        </button>
    }
</span>
