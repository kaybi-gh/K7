@namespace K7.Clients.Shared.UI.Components

<span class="k7-chip @(Variant == "outlined" ? "k7-chip--outlined" : "") @(!string.IsNullOrEmpty(Color) ? $"k7-chip--{Color}" : "") @(Size switch { "xs" => "k7-chip--xs", "sm" => "k7-chip--sm", "lg" => "k7-chip--lg", _ => "" }) @(OnClick.HasDelegate ? "k7-chip--clickable focusable" : "") @Class"
      style="@(string.IsNullOrEmpty(Style) ? null : Style)"
      role="@(OnClick.HasDelegate ? "button" : null)"
      tabindex="@(OnClick.HasDelegate ? "0" : null)"
      @onclick="OnClick"
      @onkeydown="OnKeyDown">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <K7Icon Icon="@ResolvedIcon" IconSize="@K7IconSize.Sm" Class="k7-chip__icon" />
    }
    @if (!string.IsNullOrEmpty(Text))
    {
        @Text
    }
    else
    {
        @ChildContent
    }
    @if (OnClose.HasDelegate)
    {
        <button class="k7-chip-close" @onclick="OnClose" @onclick:stopPropagation="true" type="button" aria-label="Remove">
            <K7Icon Icon="@Phosphor.X" IconSize="@K7IconSize.Xs" Class="k7-chip-close__icon" />
        </button>
    }
</span>
