
<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_excludedMedias.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">Aucun média masqué pour cet utilisateur.</MudText>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                @_excludedMedias.Count média(s) masqué(s). Cliquez sur la croix pour rétablir l'accès.
            </MudText>
            <MudList T="ExcludedMediaItem" Dense="true">
                @foreach (var media in _excludedMedias)
                {
                    <MudListItem T="ExcludedMediaItem">
                        <ChildContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    @if (!string.IsNullOrEmpty(media.PosterUrl))
                                    {
                                        <MudAvatar Rounded="true" Size="Size.Medium">
                                            <MudImage Src="@media.PosterUrl" loading="lazy" />
                                        </MudAvatar>
                                    }
                                    else
                                    {
                                        <MudAvatar Rounded="true" Size="Size.Medium" Color="Color.Dark">
                                            <MudIcon Icon="@Icons.Material.Filled.Movie" />
                                        </MudAvatar>
                                    }
                                    <MudText Typo="Typo.body2">@(media.Title ?? media.Id.ToString())</MudText>
                                </MudStack>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => RemoveExclusion(media))" />
                            </MudStack>
                        </ChildContent>
                    </MudListItem>
                }
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Enregistrer</MudButton>
    </DialogActions>
</MudDialog>
