<MudDialog>
    <DialogContent>
        <MudText>
            Voulez-vous vraiment supprimer <strong>@DisplayName</strong> ? Cette action est irréversible.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="Confirm">Supprimer</MudButton>
    </DialogActions>
</MudDialog>
