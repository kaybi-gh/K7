
<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Rôle actuel : <strong>@GetRoleLabel(Role)</strong>. Les cases cochées par défaut sont héritées du rôle.
        </MudText>
        <MudStack Spacing="1">
            @foreach (var capability in Enum.GetValues<Capability>())
            {
                var defaultEnabled = _defaultCaps.Contains(capability);
                var hasOverride = Overrides.ContainsKey(capability);
                var effectiveValue = hasOverride ? Overrides[capability] : defaultEnabled;

                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.body2">@GetCapabilityLabel(capability)</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        @if (hasOverride)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Undo" Size="Size.Small" Color="Color.Secondary"
                                           OnClick="@(() => RemoveOverride(capability))" aria-label="@S["Reset"]" />
                        }
                        <MudSwitch T="bool" Value="@effectiveValue" ValueChanged="@(v => SetOverride(capability, v, defaultEnabled))"
                                   Color="@(hasOverride ? Color.Warning : Color.Primary)" />
                    </MudStack>
                </MudStack>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@S["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Enregistrer</MudButton>
    </DialogActions>
</MudDialog>
