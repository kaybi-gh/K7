
<!--Médias restreints - @ProfileName-->
    <div class="k7-dialog-content">
        @if (_loading)
        {
            <K7ProgressBar Indeterminate="true" />
        }
        else if (_medias.Count == 0)
        {
            <p Color="secondary">Aucun média ne correspond aux règles de ce profil.</p>
        }
        else
        {
            <p class="text-sm mb-3"  Color="secondary" >
                @_medias.Count média(s) masqué(s) par ce profil@(_medias.Count >= 200 ? " (limité à 200)" : "").
            </p>
            <table class="k7-table k7-table--dense">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th style="width: 100px;">Type</th>
                        <th style="width: 80px;">Année</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var media in _medias)
                    {
                        <tr>
                            <td>@(media.Title ?? "-")</td>
                            <td><K7Chip Size="sm" Color="default">@FormatType(media.Type)</K7Chip></td>
                            <td>@(media.ReleaseYear?.ToString() ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Close">Fermer</K7Button>
    </div>
