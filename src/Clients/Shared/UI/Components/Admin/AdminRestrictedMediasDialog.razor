
<MudDialog>
    <TitleContent>Médias restreints — @ProfileName</TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_medias.Count == 0)
        {
            <MudText Typo="Typo.body1" Color="Color.Secondary">Aucun média ne correspond aux règles de ce profil.</MudText>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                @_medias.Count média(s) masqué(s) par ce profil@(_medias.Count >= 200 ? " (limité à 200)" : "").
            </MudText>
            <MudSimpleTable Dense="true" Hover="true" Bordered="true" Style="max-height: 400px; overflow-y: auto;">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th style="width: 100px;">Type</th>
                        <th style="width: 80px;">Année</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var media in _medias)
                    {
                        <tr>
                            <td>@(media.Title ?? "—")</td>
                            <td><MudChip T="string" Size="Size.Small" Color="Color.Default">@FormatType(media.Type)</MudChip></td>
                            <td>@(media.ReleaseYear?.ToString() ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Fermer</MudButton>
    </DialogActions>
</MudDialog>
