@inject IStringLocalizer<AdminGeneralPanel> L

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudStack Spacing="4" Class="pa-4">
        <div>
            <MudSelect T="string" Label="@L["DefaultLanguage"]" Value="@_defaultLanguage" ValueChanged="OnDefaultLanguageChanged">
                <MudSelectItem Value="@("fr")">Français</MudSelectItem>
                <MudSelectItem Value="@("en")">English</MudSelectItem>
            </MudSelect>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">@L["DefaultLanguageHelp"]</MudText>
        </div>
    </MudStack>
}
