
<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_users.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">Aucun utilisateur.</MudText>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                Activez ou désactivez l'accès à cette librairie pour chaque utilisateur.
            </MudText>
            <MudStack Spacing="1">
                @foreach (var user in _users)
                {
                    var hasAccess = !_excludedUserIds.Contains(user.Id);
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@(user.UserName ?? user.Email ?? "—")</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@user.Role</MudText>
                        </MudStack>
                        <MudSwitch T="bool" Value="@hasAccess" ValueChanged="@(v => ToggleAccess(user.Id, v))"
                                   Color="Color.Primary" />
                    </MudStack>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Enregistrer
        </MudButton>
    </DialogActions>
</MudDialog>
