@using K7.Server.Domain.Enums
@using K7.Shared.Dtos.Diagnostics
@inject IStringLocalizer<AdminDiagnosticsPanel> L
@inject IStringLocalizer<SharedResource> S

<div class="d-flex flex-col" style="gap: var(--space-4);">
    <div aria-live="polite">
        @if (_isLoadingSummary)
        {
            <K7ProgressBar Indeterminate="true" />
        }
        else if (_summaries is { Count: > 0 })
        {
            <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: var(--space-3);">
                <div class="surface cursor-pointer @(SummaryCardClass(null))" @onclick="@(() => OnSeverityFilterChanged(null))">
                    <div class="d-flex justify-between align-start">
                        <div class="d-flex flex-col" style="gap: var(--space-1);">
                            <span class="text-overline">@L["AllIssues"]</span>
                            <h3 class="summary-number">@_totalIssueCount</h3>
                            <span class="text-caption" style="color: var(--color-text-muted);">@string.Format(L["AcrossLibraries"], _summaries.Count)</span>
                        </div>
                        <i class="ph ph-chart-bar summary-icon"></i>
                    </div>
                </div>
                <div class="surface cursor-pointer @(SummaryCardClass("error"))" @onclick="@(() => OnSeverityFilterChanged("error"))">
                    <div class="d-flex justify-between align-start">
                        <div class="d-flex flex-col" style="gap: var(--space-1);">
                            <span class="text-overline">@L["SeverityErrors"]</span>
                            <h3 class="summary-number" style="color: var(--color-error);">@_errorCount</h3>
                            <span class="text-caption" style="color: var(--color-text-muted);">@L["ErrorsDescription"]</span>
                        </div>
                        <i class="ph ph-x-circle summary-icon" style="color: var(--color-error);"></i>
                    </div>
                </div>
                <div class="surface cursor-pointer @(SummaryCardClass("warning"))" @onclick="@(() => OnSeverityFilterChanged("warning"))">
                    <div class="d-flex justify-between align-start">
                        <div class="d-flex flex-col" style="gap: var(--space-1);">
                            <span class="text-overline">@L["SeverityWarnings"]</span>
                            <h3 class="summary-number" style="color: var(--color-warning);">@_warningCount</h3>
                            <span class="text-caption" style="color: var(--color-text-muted);">@L["WarningsDescription"]</span>
                        </div>
                        <i class="ph ph-warning summary-icon" style="color: var(--color-warning);"></i>
                    </div>
                </div>
                <div class="surface cursor-pointer @(SummaryCardClass("info"))" @onclick="@(() => OnSeverityFilterChanged("info"))">
                    <div class="d-flex justify-between align-start">
                        <div class="d-flex flex-col" style="gap: var(--space-1);">
                            <span class="text-overline">@L["SeverityInfo"]</span>
                            <h3 class="summary-number" style="color: var(--color-info);">@_infoCount</h3>
                            <span class="text-caption" style="color: var(--color-text-muted);">@L["InfoDescription"]</span>
                        </div>
                        <i class="ph ph-info summary-icon" style="color: var(--color-info);"></i>
                    </div>
                </div>
            </div>
        }
        else
        {
            <p class="text-sm pa-4 text-center" style="color: var(--color-text-muted);">@L["NoData"]</p>
        }
    </div>

    <div class="surface" style="padding: var(--space-4);">
        <div class="d-flex align-center justify-between mb-3">
            <div class="d-flex align-center" style="gap: var(--space-2);">
                <h6>@L["ItemsTitle"]</h6>
                @foreach (var chip in _activeFilterChips)
                {
                    <K7Chip Color="primary" OnClose="@(() => RemoveFilter(chip.Key))">@chip.Value</K7Chip>
                }
            </div>
            <div class="d-flex align-center" style="gap: var(--space-1);">
                @if (_selectedItems.Count > 0 && GetBulkFixAction() is not null)
                {
                    <K7Button Size="sm" Variant="filled" Color="primary" StartIcon="wrench" OnClick="BulkFixAsync" Disabled="_isBulkFixing">
                        @string.Format(L["FixSelected"], _selectedItems.Count)
                    </K7Button>
                }
                <K7Menu Icon="funnel" AriaLabel="@L["FilterBy"]">
                    <K7MenuItem OnClick="ClearFilters">
                        <p class="text-sm">@L["ClearFilters"]</p>
                    </K7MenuItem>
                    <hr class="k7-menu-divider" />
                    <K7MenuItem>
                        <K7Select TValue="Guid?" Value="_filterLibraryId" ValueChanged="OnLibraryFilterChanged" Label="@L["FilterLibrary"]" Clearable="true">
                            @if (_summaries is not null)
                            {
                                @foreach (var lib in _summaries)
                                {
                                    <K7SelectItem TValue="Guid?" Value="@lib.LibraryId">@lib.LibraryTitle</K7SelectItem>
                                }
                            }
                        </K7Select>
                    </K7MenuItem>
                    <K7MenuItem>
                        <K7Select TValue="DiagnosticEntityType?" Value="_filterEntityType" ValueChanged="OnEntityTypeFilterChanged" Label="@L["FilterEntityType"]" Clearable="true">
                            <K7SelectItem TValue="DiagnosticEntityType?" Value="DiagnosticEntityType.Media">@L["EntityTypeMedia"]</K7SelectItem>
                            <K7SelectItem TValue="DiagnosticEntityType?" Value="DiagnosticEntityType.IndexedFile">@L["EntityTypeIndexedFile"]</K7SelectItem>
                        </K7Select>
                    </K7MenuItem>
                    <K7MenuItem>
                        <K7Select TValue="DiagnosticIssue?" Value="_filterIssue" ValueChanged="OnIssueFilterChanged" Label="@L["FilterIssue"]" Clearable="true">
                            @foreach (var issue in Enum.GetValues<DiagnosticIssue>())
                            {
                                <K7SelectItem TValue="DiagnosticIssue?" Value="@issue">@GetIssueLabel(issue)</K7SelectItem>
                            }
                        </K7Select>
                    </K7MenuItem>
                </K7Menu>
                <button class="k7-icon-btn k7-icon-btn--sm ph ph-arrow-clockwise" type="button"  @onclick="LoadAsync" aria-label="@L["Refresh"]"><i class="k7-icon-btn k7-icon-btn--sm ph ph-arrow-clockwise" ></i></button>
            </div>
        </div>

        <div aria-live="polite">
            @if (_isLoadingItems)
            {
                <K7ProgressBar Indeterminate="true" />
            }
            else if (_items?.Items is null or { Count: 0 })
            {
                <div class="d-flex flex-col align-center pa-8">
                    <i class="ph ph-check-circle" style="font-size: 2rem; color: var(--color-text-muted);"></i>
                    <p class="text-sm mt-2" style="color: var(--color-text-muted);">@L["NoItems"]</p>
                </div>
            }
            else
            {
                <K7Table Items="_items.Items" TItem="DiagnosticItemDto" Hover="true" Dense="true">
                    <HeaderContent>
                        <th>@L["ColName"]</th>
                        <th>@L["ColLibrary"]</th>
                        <th>@L["ColIssues"]</th>
                        <th style="width: 160px; text-align: right;">@L["ColActions"]</th>
                    </HeaderContent>
                    <RowTemplate>
                        <td>
                            <div class="d-flex flex-col">
                                @if (context.MediaUrl is not null)
                                {
                                    <a href="@context.MediaUrl" class="text-sm">@context.EntityName</a>
                                }
                                else
                                {
                                    <p class="text-sm">@context.EntityName</p>
                                }
                                <span class="text-caption" style="color: var(--color-text-muted);">
                                    @(context.EntityType == DiagnosticEntityType.Media ? L["EntityTypeMedia"] : L["EntityTypeIndexedFile"])
                                </span>
                            </div>
                        </td>
                        <td><p class="text-sm">@context.LibraryTitle</p></td>
                        <td>
                            <div class="d-flex flex-col">
                                @foreach (var issue in context.Issues)
                                {
                                    <span class="text-sm" title="@GetIssueDetail(context, issue)" style="color: var(--color-@(GetIssueColor(issue)));">@GetIssueLabel(issue)</span>
                                }
                            </div>
                        </td>
                        <td class="actions-cell">
                            <div class="d-flex justify-end" style="gap: var(--space-1);">
                                @if (context.EntityType == DiagnosticEntityType.Media)
                                {
                                    <K7Button Size="sm" Variant="text" Color="primary" StartIcon="arrow-clockwise"
                                               OnClick="@(() => FixItemAsync(context.EntityId, DiagnosticFixAction.RefreshMetadata))">
                                        @L["ActionRefresh"]
                                    </K7Button>
                                    @if (context.MediaUrl is not null)
                                    {
                                        <K7Button Size="sm" Variant="text" Color="default" StartIcon="arrow-square-out" Href="@context.MediaUrl">
                                            @L["GoToMedia"]
                                        </K7Button>
                                    }
                                }
                                @if (context.EntityType == DiagnosticEntityType.IndexedFile)
                                {
                                    @if (context.Issues.Contains(DiagnosticIssue.MissingFileMetadata))
                                    {
                                        <K7Button Size="sm" Variant="text" Color="primary" StartIcon="code"
                                                   OnClick="@(() => FixItemAsync(context.EntityId, DiagnosticFixAction.ExtractFileMetadata))">
                                            @L["ActionExtract"]
                                        </K7Button>
                                    }
                                    @if (context.Issues.Contains(DiagnosticIssue.MissingHlsSegments))
                                    {
                                        <K7Button Size="sm" Variant="text" Color="primary" StartIcon="rows"
                                                   OnClick="@(() => FixItemAsync(context.EntityId, DiagnosticFixAction.ComputeHlsSegments))">
                                            @L["ActionHls"]
                                        </K7Button>
                                    }
                                }
                            </div>
                        </td>
                    </RowTemplate>
                </K7Table>

                @if ((_items.TotalPages ?? 1) > 1)
                {
                    <div class="d-flex justify-center mt-3" style="gap: var(--space-2);">
                        <button class="k7-btn k7-btn--outlined ph ph-caret-left" type="button"  @onclick="PreviousPage" disabled="@(_pageNumber <= 1)"><i class="k7-btn k7-btn--outlined ph ph-caret-left" ></i></button>
                        <span class="d-flex align-center" style="padding: 0 var(--space-3);">@_pageNumber / @(_items.TotalPages ?? 1)</span>
                        <button class="k7-btn k7-btn--outlined ph ph-caret-right" type="button"  @onclick="NextPage" disabled="@(_pageNumber >= (_items.TotalPages ?? 1))"><i class="k7-btn k7-btn--outlined ph ph-caret-right" ></i></button>
                    </div>
                }
            }
        </div>
    </div>
</div>
