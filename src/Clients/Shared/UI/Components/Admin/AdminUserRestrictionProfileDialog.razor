
<MudDialog>
    <TitleContent>Profil de restriction</TitleContent>
    <DialogContent>
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudSelect T="Guid?" @bind-Value="_selectedProfileId" Label="Profil de restriction"
                       Variant="Variant.Outlined" Clearable="true" AnchorOrigin="Origin.BottomCenter">
                @foreach (var profile in _profiles)
                {
                    <MudSelectItem T="Guid?" Value="@profile.Id">
                        @profile.Name
                        @if (!string.IsNullOrWhiteSpace(profile.Description))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary"> — @profile.Description</MudText>
                        }
                    </MudSelectItem>
                }
            </MudSelect>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="_isLoading">Valider</MudButton>
    </DialogActions>
</MudDialog>
