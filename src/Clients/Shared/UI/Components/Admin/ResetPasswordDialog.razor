@inject IStringLocalizer<ResetPasswordDialog> L
@inject IStringLocalizer<SharedResource> S

<MudDialog>
    <DialogContent>
        <MudStack Spacing="4" Class="mt-2">
            <MudTextField @bind-Value="_newPassword" Label="@L["NewPassword"]" Variant="Variant.Outlined"
                          InputType="InputType.Password" Required="true" RequiredError="@L["PasswordRequired"]" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_newPassword) || _isSubmitting)">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @L["ResetPassword"]
        </MudButton>
    </DialogActions>
</MudDialog>
