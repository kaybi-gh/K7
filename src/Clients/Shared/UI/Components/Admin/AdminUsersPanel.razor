@inject IStringLocalizer<AdminUsersPanel> L
@inject IStringLocalizer<SharedResource> S

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h6">@L["Title"]</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="OpenCreateUserDialog" aria-label="@L["AriaCreateUser"]">
        @L["CreateUserTitle"]
    </MudButton>
</MudStack>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_users.Count == 0)
{
    <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="0">
        <MudIcon Icon="@Icons.Material.Outlined.People" Size="Size.Large" Color="Color.Secondary" />
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-4">@L["Empty"]</MudText>
    </MudPaper>
}
else
{
    <MudSimpleTable Dense="true" Bordered="true" Hover="true">
        <thead>
            <tr>
                <th>@L["HeaderUser"]</th>
                <th>@L["HeaderRole"]</th>
                <th>@L["HeaderActive"]</th>
                <th>@L["HeaderCreatedAt"]</th>
                <th style="width: 100px;">@L["HeaderActions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in _users)
            {
                <tr style="@(!user.IsActive ? "opacity: 0.5;" : "")">
                    <td>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">@(user.UserName ?? "—")</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@(user.Email ?? "—")</MudText>
                        </MudStack>
                    </td>
                    <td>
                        @if (user.IsGuest)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@S["Guest"]</MudChip>
                        }
                        else
                        {
                            <MudSelect T="string" Value="@user.Role" ValueChanged="@(role => OnRoleChanged(user, role))"
                                       Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                                <MudSelectItem Value="@Roles.Administrator">@L["RoleAdministrator"]</MudSelectItem>
                                <MudSelectItem Value="@Roles.User">@L["RoleUser"]</MudSelectItem>
                            </MudSelect>
                        }
                    </td>
                    <td>
                        <MudSwitch T="bool" Value="@user.IsActive"
                                   ValueChanged="@(v => OnToggleActive(user, v))"
                                   Color="Color.Success" />
                    </td>
                    <td>@user.Created.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <MudStack Row="true" Spacing="1">
                            @if (!user.IsGuest)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Color="Color.Default"
                                               OnClick="@(() => OpenCapabilitiesDialog(user))" aria-label="@L["AriaCapabilities"]" />
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.VideoLibrary" Size="Size.Small" Color="Color.Default"
                                           OnClick="@(() => OpenLibraryExclusionsDialog(user))" aria-label="@L["AriaLibraries"]" />
                            <MudIconButton Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small" Color="Color.Default"
                                           OnClick="@(() => OpenMediaExclusionsDialog(user))" aria-label="@L["AriaHiddenMedia"]" />
                            <MudIconButton Icon="@Icons.Material.Filled.Shield" Size="Size.Small"
                                           Color="@(user.ContentRestrictionProfileId.HasValue ? Color.Warning : Color.Default)"
                                           OnClick="@(() => OpenRestrictionProfileDialog(user))" aria-label="@L["AriaRestrictionProfile"]" />
                            @if (!user.IsGuest && user.Id != _currentUserId)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Password" Size="Size.Small" Color="Color.Default"
                                               OnClick="@(() => OpenResetPasswordDialog(user))" aria-label="@L["AriaResetPassword"]" />
                                <MudIconButton Icon="@Icons.Material.Filled.MergeType" Size="Size.Small" Color="Color.Default"
                                               OnClick="@(() => OpenMergeUserDialog(user))" aria-label="@L["AriaMerge"]" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => ConfirmDelete(user))" aria-label="@L["AriaDelete"]" />
                            }
                        </MudStack>
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}
