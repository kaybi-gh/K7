@inject IStringLocalizer<AdminRestrictionsPanel> L
@inject IStringLocalizer<SharedResource> S

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h6">@L["Title"]</MudText>
    <MudStack Row="true" Spacing="2">
        <MudMenu Label="@L["CreateFromTemplate"]" Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Secondary"
                 Variant="Variant.Outlined" EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
            <MudMenuItem OnClick="@(() => CreateFromTemplate(Templates.ChildFriendly))">@L["TemplateChildFriendly"]</MudMenuItem>
            <MudMenuItem OnClick="@(() => CreateFromTemplate(Templates.Family12))">@L["TemplateFamily12"]</MudMenuItem>
            <MudMenuItem OnClick="@(() => CreateFromTemplate(Templates.Teen16))">@L["TemplateTeen16"]</MudMenuItem>
            <MudMenuItem OnClick="@(() => CreateFromTemplate(Templates.NoHorror))">@L["TemplateNoHorror"]</MudMenuItem>
        </MudMenu>
        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="OpenCreateDialog">@L["CreateProfile"]</MudButton>
    </MudStack>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_profiles.Count == 0)
{
    <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="0">
        <MudIcon Icon="@Icons.Material.Outlined.Shield" Size="Size.Large" Color="Color.Secondary" />
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-4">@L["Empty"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
            @L["EmptyDescription"]
        </MudText>
    </MudPaper>
}
else
{
    <MudGrid>
        @foreach (var profile in _profiles)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@profile.Name</MudText>
                            @if (!string.IsNullOrEmpty(profile.Description))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@profile.Description</MudText>
                            }
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary"
                                           OnClick="@(() => PreviewRestrictedMedias(profile))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => OpenEditDialog(profile))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => ConfirmDelete(profile))" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @L["ConditionPrefix"] @(profile.MatchCondition == RestrictionMatchCondition.Any ? L["MatchAny"] : L["MatchAll"])
                            </MudText>
                            @foreach (var rule in profile.Rules)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                    @FormatRule(rule)
                                </MudChip>
                            }
                            <MudText Typo="Typo.caption" Class="mt-2">
                                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Class="mr-1" />
                                @string.Format(L["AttachedUsers"], profile.UserCount)
                            </MudText>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}
