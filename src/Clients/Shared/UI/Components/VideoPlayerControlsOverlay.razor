@using K7.Clients.Shared.Models
@using K7.Server.Domain.Enums
@using K7.Shared.Dtos.Entities.Metadatas.Files.Tracks
@using Microsoft.JSInterop
@using System.Timers
@using System.Globalization
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable
@inject IPlayerService PlayerService
@inject IDeviceService DeviceService
@inject IStringLocalizer<VideoPlayerControlsOverlay> L

<div class="video-controls-overlay" tabindex="0" @ref="_overlayRef"
     @onmousemove="OnOverlayMouseMove" @onclick="OnOverlayTap" @ontouchstart="OnOverlayTap" @ontouchstart:preventDefault
     @onkeydown="OnKeyDown" @onkeydown:preventDefault="@_preventKeyDefault" @onkeydown:stopPropagation
     @onfocusin="OnFocusIn"
     style="@(_showOverlay || _isMenuOpen || _isMouseOverVolumeSlider ? "opacity: 1;" : "opacity: 0;")">

    <div class="controls-bar top" @onclick:stopPropagation @ontouchstart:stopPropagation @onmouseover="OnControlsBarMouseEnter" @onmouseout="OnControlsBarMouseOut">
        <MudIconButton Icon="@Icons.Material.Outlined.Close" Color="Color.Inherit" OnClick="OnCloseButtonClick" />
    </div>

    <div class="controls-bar bottom" @onclick:stopPropagation @ontouchstart:stopPropagation @onmouseover="OnControlsBarMouseEnter" @onmouseout="OnControlsBarMouseOut">
        <MudStack Row="true" StretchItems="StretchItems.Middle" AlignItems="AlignItems.Center" Style="width:100%">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudToggleIconButton Icon="@Icons.Material.Outlined.Pause"
                ToggledIcon="@Icons.Material.Outlined.PlayArrow" Color="Color.Inherit"
                Toggled="PlayerService.PlaybackState != Server.Domain.Enums.PlaybackState.Playing"
                ToggledChanged="TogglePlayPause" />

                @if (_deviceType == Server.Domain.Enums.DeviceType.Desktop)
                {
                    <MudItem>
                        <MudIconButton Icon="@GetVolumeIcon()" Color="Color.Inherit" OnClick="ToggleIsMuted" @onmouseover="OnVolumeButtonMouseOver" @onmouseout="OnVolumeButtonMouseOut" />
                        <MudPopover Class="volume-slider-popover"
                        Open="@_isVolumeSliderVisible"
                        @onmouseover="OnVolumeSliderMouseOver"
                        @onmouseout="OnVolumeSliderMouseOut"
                        AnchorOrigin="Origin.TopLeft"
                        TransformOrigin="Origin.BottomLeft"
                        Paper="false"
                        Style="z-index: 100005">
                            <div Class="volume-slider-container">
                                <MudSlider T="double"
                                Min="0"
                                Max="1"
                                Step="0.01"
                                Value="@PlayerService.Volume"
                                ValueChanged="PlayerService.SetVolume"
                                Immediate="true"
                                Class="volume-slider" />
                            </div>
                        </MudPopover>
                    </MudItem>
                }

                <span>@FormatTime(_isSeeking ? _seekTarget : PlayerService.CurrentTime) / @FormatTime(PlayerService.Duration)</span>
            </MudStack>

            <SeekBar IsVisible=@(_showOverlay || _isMenuOpen) OnDragChanged="OnSeekBarDragChanged" ThumbnailsUri="@(string.IsNullOrEmpty(ThumbnailsSource) ? null : new Uri(ThumbnailsSource, UriKind.RelativeOrAbsolute))" />

            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudMenu Icon="@Icons.Material.Outlined.Settings" AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.BottomRight"
                @bind-Open="_isMenuOpen" Color="Color.Inherit">
                    <MudMenu Label="@L["Audio"]" StartIcon="@Icons.Material.Outlined.Audiotrack">
                        @foreach (var track in PlayerService.AudioTracks)
                        {
                            <MudMenuItem OnClick="@(() => OnAudioTrackSelected(track))"
                                         Icon="@(PlayerService.SelectedAudioTrack?.Index == track.Index ? Icons.Material.Filled.CheckCircle : null)">
                                @($"{track.Language} - {track.Name} ({track.Codec} {track.ChannelLayout})")
                            </MudMenuItem>
                        }
                    </MudMenu>

                    <MudMenu Label="@L["Subtitles"]" StartIcon="@Icons.Material.Outlined.Subtitles">
                        <MudMenuItem OnClick="@(() => OnSubtitleTrackSelected(null))"
                                     Icon="@(PlayerService.SelectedSubtitleTrack is null ? Icons.Material.Filled.CheckCircle : null)">
                            @L["SubtitlesOff"]
                        </MudMenuItem> @* TODO - Maybe change the way disabling titles is done *@
                        @foreach (var track in PlayerService.SubtitleTracks)
                        {
                            <MudMenuItem OnClick="@(() => OnSubtitleTrackSelected(track))"
                                         Icon="@(PlayerService.SelectedSubtitleTrack?.Index == track.Index ? Icons.Material.Filled.CheckCircle : null)">
                                @($"{track.Language} - {track.Name}{(track.IsForced ? L["ForcedSuffix"] : "")} ({track.Codec})")
                            </MudMenuItem> // TODO - Maybe use only the track name
                        }
                    </MudMenu>
                    <MudMenu Label="@L["Quality"]" StartIcon="@Icons.Material.Outlined.Tune">
                        @foreach (var quality in PlayerService.AvailableQualities)
                        {
                            <MudMenuItem OnClick="@(() => OnQualitySelected(quality))"
                                         Icon="@(PlayerService.SelectedQuality == quality ? Icons.Material.Filled.CheckCircle : null)">
                                @quality.Label
                            </MudMenuItem>
                        }
                    </MudMenu>

                    <MudMenu Label="@L["Speed"]" StartIcon="@Icons.Material.Outlined.Speed">
                        @foreach (var speed in _playbackSpeedOptions)
                        {
                            <MudMenuItem OnClick="@(() => OnSpeedSelected(speed))"
                                         Icon="@(IsCurrentSpeed(speed) ? Icons.Material.Filled.CheckCircle : null)">
                                @(speed == 1.0 ? L["SpeedNormal"] : $"{speed}x")
                            </MudMenuItem>
                        }
                    </MudMenu>

                    <MudMenu Label="@L["AspectRatio"]" StartIcon="@Icons.Material.Outlined.AspectRatio">
                        @foreach (var mode in _aspectRatioOptions)
                        {
                            <MudMenuItem OnClick="@(() => OnAspectRatioSelected(mode))"
                                         Icon="@(PlayerService.AspectRatio == mode ? Icons.Material.Filled.CheckCircle : null)">
                                @GetAspectRatioLabel(mode)
                            </MudMenuItem>
                        }
                    </MudMenu>
                </MudMenu>

                @if (_deviceType == Server.Domain.Enums.DeviceType.Desktop)
                {
                    <MudToggleIconButton Icon="@Icons.Material.Filled.Fullscreen" ToggledIcon="@Icons.Material.Filled.FullscreenExit" Color="Color.Inherit" Toggled="PlayerService.IsFullScreen" ToggledChanged="ToggleFullscreen" />
                }
            </MudStack>
        </MudStack>
    </div>
</div>

@if (_hudText is not null)
{
    <div class="hud-indicator">
        <MudIcon Icon="@_hudIcon" Size="Size.Large" />
        <span>@_hudText</span>
    </div>
}

@code {
    [Parameter] public string? PosterImage { get; set; }
    [Parameter] public string? ThumbnailsSource { get; set; }
    [Parameter] public int ThumbnailsRows { get; set; } = 5;
    [Parameter] public int ThumbnailsCols { get; set; } = 5;
    [Parameter] public EventCallback<PlayerState> OnStateChange { get; set; }

    private DeviceType _deviceType;
    private bool _showOverlay = true;
    private bool _isMenuOpen = false;
    private bool _isMouseOverControlsBar = false;
    private bool _isMouseOverVolumeButton = false;
    private bool _isMouseOverVolumeSlider = false;
    private bool _isVolumeSliderVisible = false;
    private bool _preventKeyDefault = true;
    private Timer? _overlayVisibleTimer;
    private Timer? _seekDebounceTimer;
    private Timer? _hudTimer;
    private double _seekTarget;
    private double _seekOffset;
    private bool _isSeeking;
    private string? _hudText;
    private string _hudIcon = Icons.Material.Filled.FastForward;
    private ElementReference _overlayRef;
    private DotNetObjectReference<VideoPlayerControlsOverlay>? _dotNetRef;
    private static readonly TimeSpan _overlayTimeout = TimeSpan.FromMilliseconds(1500);
    private CancellationTokenSource? _volumePopoverHideDelayCts;

    private static readonly double[] _playbackSpeedOptions = [0.25, 0.5, 0.75, 1.0, 1.25, 1.5, 1.75, 2.0];
    private static readonly AspectRatioMode[] _aspectRatioOptions = [AspectRatioMode.Fit, AspectRatioMode.Fill, AspectRatioMode.Stretch];

    private void OnPlaybackStateChanged(PlaybackState state) => InvokeAsync(StateHasChanged);
    private void OnIsMutedChanged(bool isMuted) => InvokeAsync(StateHasChanged);
    private void OnVolumeChanged(double volume) => InvokeAsync(StateHasChanged);
    private void OnCurrentTimeChanged(double time) => InvokeAsync(StateHasChanged);
    private void OnPlaybackRateChanged(double rate) => InvokeAsync(StateHasChanged);
    private void OnIsFullScreenChanged(bool isFullScreen) => InvokeAsync(StateHasChanged);
    private void OnAudioTrackChanged(AudioFileTrackDto? track) => InvokeAsync(StateHasChanged);
    private void OnSubtitleTrackChanged(SubtitleFileTrackDto? track) => InvokeAsync(StateHasChanged);
    private void OnQualityChanged(VideoQualityOption? quality) => InvokeAsync(StateHasChanged);
    private void OnAspectRatioModeChanged(AspectRatioMode mode) => InvokeAsync(StateHasChanged);

    protected override async Task OnInitializedAsync()
    {
        _deviceType = await DeviceService.GetDeviceTypeAsync();
        _overlayVisibleTimer = new Timer(_overlayTimeout);
        _overlayVisibleTimer.Elapsed += OnOverlayTimerElapsed;
        _overlayVisibleTimer.Start();
        _seekDebounceTimer = new Timer(300) { AutoReset = false };
        _seekDebounceTimer.Elapsed += OnSeekDebounceElapsed;
        _hudTimer = new Timer(800) { AutoReset = false };
        _hudTimer.Elapsed += OnHudTimerElapsed;
        PlayerService.PlaybackStateChanged += OnPlaybackStateChanged;
        PlayerService.IsMutedChanged += OnIsMutedChanged;
        PlayerService.VolumeChanged += OnVolumeChanged;
        PlayerService.CurrentTimeChanged += OnCurrentTimeChanged;
        PlayerService.PlaybackRateChanged += OnPlaybackRateChanged;
        PlayerService.IsFullScreenChanged += OnIsFullScreenChanged;
        PlayerService.AudioTrackChanged += OnAudioTrackChanged;
        PlayerService.SubtitleTrackChanged += OnSubtitleTrackChanged;
        PlayerService.QualityChanged += OnQualityChanged;
        PlayerService.AspectRatioModeChanged += OnAspectRatioModeChanged;
        if (DeviceService.GetClientType() == ClientType.Web)
        {
            await JSRuntime.InvokeVoidAsync("hideBodyScroll", true);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("K7.registerVideoOverlay", _dotNetRef);
            await _overlayRef.FocusAsync();
        }
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        _preventKeyDefault = true;

        // Global shortcuts - always active
        switch (e.Code)
        {
            case "Space" or "MediaPlayPause":
                TogglePlayPause();
                ResetOverlayTimeout();
                return;
            case "Escape" or "BrowserBack" or "GoBack":
                if (_isMenuOpen)
                {
                    _ = CloseMenu();
                }
                else if (_showOverlay)
                {
                    _showOverlay = false;
                    _overlayVisibleTimer?.Stop();
                    _ = _overlayRef.FocusAsync();
                }
                else
                {
                    OnCloseButtonClick();
                }
                return;
            case "MediaStop":
                OnCloseButtonClick();
                return;
            case "KeyM":
                ToggleIsMuted();
                ResetOverlayTimeout();
                return;
            case "KeyF":
                ToggleFullscreen();
                ResetOverlayTimeout();
                return;
        }

        if (!_showOverlay)
        {
            // Overlay hidden: arrows control playback
            switch (e.Code)
            {
                case "Enter":
                    _showOverlay = true;
                    ResetOverlayTimeout(TimeSpan.FromSeconds(5));
                    _ = FocusByDirectionAsync("first");
                    return;
                case "ArrowLeft":
                    AccumulateSeek(-10);
                    return;
                case "ArrowRight":
                    AccumulateSeek(10);
                    return;
                case "ArrowUp":
                    AdjustVolume(0.1);
                    return;
                case "ArrowDown":
                    AdjustVolume(-0.1);
                    return;
            }
        }
        else
        {
            // Overlay visible: arrows navigate between focusable controls
            switch (e.Code)
            {
                case "ArrowLeft" or "ArrowUp":
                    _ = FocusByDirectionAsync("prev");
                    ResetOverlayTimeout();
                    return;
                case "ArrowRight" or "ArrowDown":
                    _ = FocusByDirectionAsync("next");
                    ResetOverlayTimeout();
                    return;
            }
        }

        // Unhandled key: let browser handle it
        _preventKeyDefault = false;
    }

    private async Task FocusByDirectionAsync(string direction)
    {
        await Task.Yield();
        await JSRuntime.InvokeVoidAsync("K7.focusDirection", _overlayRef, direction);
    }

    private void AccumulateSeek(double offset)
    {
        if (!_isSeeking)
        {
            _seekTarget = PlayerService.CurrentTime;
            _seekOffset = 0;
        }
        _seekOffset += offset;
        _seekTarget = Math.Clamp(PlayerService.CurrentTime + _seekOffset, 0, PlayerService.Duration);
        _isSeeking = true;
        _hudIcon = _seekOffset >= 0 ? Icons.Material.Filled.FastForward : Icons.Material.Filled.FastRewind;
        ShowHud($"{(_seekOffset >= 0 ? "+" : "")}{(int)_seekOffset}s");
        _seekDebounceTimer?.Stop();
        _seekDebounceTimer?.Start();
    }

    private void AdjustVolume(double delta)
    {
        var newVolume = Math.Clamp(PlayerService.Volume + delta, 0, 1);
        PlayerService.SetVolume(newVolume);
        _hudIcon = delta > 0 ? Icons.Material.Filled.VolumeUp : Icons.Material.Filled.VolumeDown;
        ShowHud($"{(int)Math.Round(newVolume * 100)}%");
    }

    private void ShowHud(string text)
    {
        _hudText = text;
        _hudTimer?.Stop();
        _hudTimer?.Start();
    }

    private void OnHudTimerElapsed(object? sender, ElapsedEventArgs args)
    {
        InvokeAsync(() =>
        {
            _hudText = null;
            StateHasChanged();
        });
    }

    private async void OnOverlayTimerElapsed(object? sender, ElapsedEventArgs args)
    {
        await InvokeAsync(async () =>
        {
            try
            {
                if (_isMenuOpen || _isSeeking) return;
                var focusInChild = await JSRuntime.InvokeAsync<bool>("K7.isFocusInOverlayChild", _overlayRef);
                if (focusInChild) return;
                _showOverlay = false;
                StateHasChanged();
                await _overlayRef.FocusAsync();
            }
            catch (ObjectDisposedException) { }
            catch (JSException) { }
        });
    }

    private void OnSeekDebounceElapsed(object? sender, ElapsedEventArgs args)
    {
        InvokeAsync(() =>
        {
            PlayerService.Seek(_seekTarget);
            _isSeeking = false;
            _seekOffset = 0;
            StateHasChanged();
        });
    }

    [JSInvokable]
    public async Task CloseMenu()
    {
        await Task.Delay(1);
        _isMenuOpen = false;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        await _overlayRef.FocusAsync();
        ResetOverlayTimeout(TimeSpan.FromSeconds(5));
    }

    public void ResetOverlayTimeout(TimeSpan? timeout = null)
    {
        _showOverlay = true;
        _overlayVisibleTimer?.Stop();
        if (timeout.HasValue && _overlayVisibleTimer is not null)
        {
            _overlayVisibleTimer.Interval = timeout.Value.TotalMilliseconds;
        }
        _overlayVisibleTimer?.Start();
    }

    private void OnCloseButtonClick()
    {
        PlayerService.Stop();
        PlayerService.HideAsync();
    }

    private void OnOverlayMouseMove(MouseEventArgs args)
    {
        if (_isMouseOverControlsBar || _isMenuOpen)
        {
            return;
        }

        _showOverlay = true;
        ResetOverlayTimeout();
    }

    private void OnFocusIn(FocusEventArgs args)
    {
        if (_showOverlay)
        {
            ResetOverlayTimeout();
        }
    }

    private void OnOverlayTap()
    {
        if (_showOverlay && !_isMouseOverControlsBar && !_isMenuOpen)
        {
            _showOverlay = false;
            _overlayVisibleTimer?.Stop();
        }
        else
        {
            _showOverlay = true;
            ResetOverlayTimeout(TimeSpan.FromSeconds(5));
        }
    }

    private void OnSeekBarDragChanged(bool draging)
    {
        if (draging)
        {
            ResetOverlayTimeout();
        }
    }

    private void OnControlsBarMouseEnter(MouseEventArgs args)
    {
        _overlayVisibleTimer?.Stop();
        _isMouseOverControlsBar = true;
        _showOverlay = true;
    }

    private void OnControlsBarMouseOut(MouseEventArgs args)
    {
        _isMouseOverControlsBar = false;
        _showOverlay = true;
        _overlayVisibleTimer?.Start();
    }

    private void OnVolumeButtonMouseOver(MouseEventArgs args)
    {
        _isMouseOverVolumeButton = true;
        _isVolumeSliderVisible = true;
    }

    private void OnVolumeButtonMouseOut(MouseEventArgs args)
    {
        _isMouseOverVolumeButton = false;
        HidePopover();
    }

    private void OnVolumeSliderMouseOver(MouseEventArgs args)
    {
        _isMouseOverVolumeSlider = true;
        _isVolumeSliderVisible = true;
    }

    private void OnVolumeSliderMouseOut(MouseEventArgs args)
    {
        _isMouseOverVolumeSlider = false;
        HidePopover();
    }

    private async void HidePopover()
    {
        _volumePopoverHideDelayCts?.Cancel();
        _volumePopoverHideDelayCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(500, _volumePopoverHideDelayCts.Token);
            if (!_isMouseOverVolumeButton && !_isMouseOverVolumeSlider)
            {
                _isVolumeSliderVisible = false;
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }

    private void OnSpeedSelected(double speed) => PlayerService.SetPlaybackRate(speed);
    private bool IsCurrentSpeed(double speed) => Math.Abs(PlayerService.PlaybackRate - speed) < 0.01;

    private void OnAspectRatioSelected(AspectRatioMode mode) => PlayerService.SetAspectRatioMode(mode);

    private string GetAspectRatioLabel(AspectRatioMode mode) => mode switch
    {
        AspectRatioMode.Fit => L["AspectRatioFit"],
        AspectRatioMode.Fill => L["AspectRatioFillCrop"],
        AspectRatioMode.Stretch => L["AspectRatioStretch"],
        _ => mode.ToString()
    };

    private async Task OnAudioTrackSelected(AudioFileTrackDto track)
    {
        if (PlayerService.SelectedAudioTrack?.Index == track.Index)
        {
            return;
        }

        await PlayerService.ChangeAudioTrackAsync(track);
    }

    private async Task OnSubtitleTrackSelected(SubtitleFileTrackDto? track)
    {
        if (PlayerService.SelectedSubtitleTrack?.Index == track?.Index)
        {
            return;
        }

        await PlayerService.ChangeSubtitleTrackAsync(track);
    }

    private async Task OnQualitySelected(VideoQualityOption quality)
    {
        if (PlayerService.SelectedQuality == quality)
        {
            return;
        }

        await PlayerService.ChangeQualityAsync(quality);
    }

    private void TogglePlayPause()
    {
        if (PlayerService.PlaybackState != PlaybackState.Playing)
        {
            PlayerService.Play();
        }
        else
        {
            PlayerService.Pause();
        }
    }

    private void ToggleIsMuted()
    {
        if (PlayerService.IsMuted)
        {
            PlayerService.IsMuted = false;
            PlayerService.Unmute();
        }
        else
        {
            PlayerService.IsMuted = true;
            PlayerService.Mute();
        }
    }

    private void ToggleFullscreen()
    {
        if (!PlayerService.IsFullScreen)
        {
            PlayerService.IsFullScreen = true;
            PlayerService.EnterFullScreen();
        }
        else
        {
            PlayerService.IsFullScreen = false;
            PlayerService.ExitFullScreen();
        }
    }

    private string FormatTime(double seconds)
    {
        var timeSpan = TimeSpan.FromSeconds(seconds);
        return timeSpan.Hours > 0
        ? $"{timeSpan.Hours:0}:{timeSpan.Minutes:00}:{timeSpan.Seconds:00}"
        : $"{timeSpan.Minutes:0}:{timeSpan.Seconds:00}";
    }

    private void HandleVolumeInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var volume))
        {
            PlayerService.SetVolume(volume);
        }
    }

    private string GetVolumeIcon()
    {
        if (PlayerService.IsMuted)
        {
            return Icons.Material.Filled.VolumeOff;
        }

        return PlayerService.Volume switch
        {
            0 => Icons.Material.Filled.VolumeMute,
            < 0.5d => Icons.Material.Filled.VolumeDown,
            >= 0.5d => Icons.Material.Filled.VolumeUp,
            _ => Icons.Material.Filled.VolumeMute
        };
    }

    public class PlayerState
    {
        public double CurrentTime { get; set; }
        public double Duration { get; set; }
        public bool IsPlaying { get; set; }
        public bool IsMuted { get; set; }
        public int Volume { get; set; }
        public bool IsFullscreen { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        _overlayVisibleTimer?.Dispose();
        _seekDebounceTimer?.Dispose();
        _hudTimer?.Dispose();
        _dotNetRef?.Dispose();
        try { await JSRuntime.InvokeVoidAsync("K7.unregisterVideoOverlay"); }
        catch (JSException) { }
        PlayerService.PlaybackStateChanged -= OnPlaybackStateChanged;
        PlayerService.IsMutedChanged -= OnIsMutedChanged;
        PlayerService.VolumeChanged -= OnVolumeChanged;
        PlayerService.CurrentTimeChanged -= OnCurrentTimeChanged;
        PlayerService.PlaybackRateChanged -= OnPlaybackRateChanged;
        PlayerService.IsFullScreenChanged -= OnIsFullScreenChanged;
        PlayerService.AudioTrackChanged -= OnAudioTrackChanged;
        PlayerService.SubtitleTrackChanged -= OnSubtitleTrackChanged;
        PlayerService.QualityChanged -= OnQualityChanged;
        PlayerService.AspectRatioModeChanged -= OnAspectRatioModeChanged;
        if (DeviceService.GetClientType() == ClientType.Web)
        {
            await JSRuntime.InvokeVoidAsync("hideBodyScroll", false);
        }
    }
}
