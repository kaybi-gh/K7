@namespace K7.Clients.Shared.UI.Components

@if (!string.IsNullOrEmpty(Href))
{
    <a href="@Href"
       class="k7-icon-btn focusable @(Size == "sm" ? "k7-icon-btn--sm" : Size == "lg" ? "k7-icon-btn--lg" : "") @(!string.IsNullOrEmpty(Color) ? $"k7-icon-btn--{Color}" : "") @Class"
       aria-label="@AriaLabel"
       @attributes="AdditionalAttributes">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else if (!string.IsNullOrEmpty(Icon))
        {
            <K7Icon Icon="@Icon" />
        }
    </a>
}
else
{
    <button type="@Type"
            class="k7-icon-btn focusable @(Size == "sm" ? "k7-icon-btn--sm" : Size == "lg" ? "k7-icon-btn--lg" : "") @(!string.IsNullOrEmpty(Color) ? $"k7-icon-btn--{Color}" : "") @Class"
            disabled="@Disabled"
            aria-label="@AriaLabel"
            @onclick="OnClick"
            @attributes="AdditionalAttributes">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else if (!string.IsNullOrEmpty(Icon))
        {
            <K7Icon Icon="@Icon" />
        }
    </button>
}
