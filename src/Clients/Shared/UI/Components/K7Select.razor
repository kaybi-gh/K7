@namespace K7.Clients.Shared.UI.Components
@typeparam TValue

<div class="k7-field @Class" style="@(string.IsNullOrEmpty(Style) ? null : Style)">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="k7-label" for="@_id">@Label</label>
    }
    <select id="@_id"
            class="k7-select"
            disabled="@Disabled"
            @onchange="OnChange">
        @if (Clearable && Value is null)
        {
            <option value="" selected>@(string.IsNullOrEmpty(Placeholder) ? "" : Placeholder)</option>
        }
        else if (Clearable)
        {
            <option value="">@(string.IsNullOrEmpty(Placeholder) ? "" : Placeholder)</option>
        }
        @ChildContent
    </select>
</div>
