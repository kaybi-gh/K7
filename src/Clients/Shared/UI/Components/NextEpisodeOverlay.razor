@using K7.Shared.Dtos.Entities.Medias
@inject IStringLocalizer<NextEpisodeOverlay> L

@if (_visible && _nextEpisode is not null)
{
    <div class="next-episode-overlay">
        <div class="next-episode-content">
            <div class="next-episode-center">
                @if (_stillUrl is not null)
                {
                    <K7Image Src="@_stillUrl"
                              Alt="@_nextEpisode.Title"
                              Class="next-episode-still"
                              ObjectFit="cover" />
                }
                <span class="text-caption next-episode-label" Color="secondary">
                    @L["NextEpisode"]
                </span>
                <h5>
                    S@(_nextEpisode.SeasonNumber.ToString("D2"))E@(_nextEpisode.EpisodeNumber.ToString("D2"))
                    @if (!string.IsNullOrEmpty(_nextEpisode.Title))
                    {
                        <span> &mdash; @_nextEpisode.Title</span>
                    }
                </h5>

                @if (_countdownSeconds > 0)
                {
                    <p class="mt-2" Color="secondary">
                        @string.Format(L["AutoPlayIn"], _countdownSeconds)
                    </p>
                }

                <div class="d-flex mt-4">
                    <K7Button Variant="filled"
                               Color="primary"
                               StartIcon="play"
                               Size="lg"
                               OnClick="PlayNextAsync">
                        @L["PlayNow"]
                    </K7Button>
                    <K7Button Variant="outlined"
                               Size="lg"
                               OnClick="Dismiss"
                               Style="color: white; border-color: rgba(255,255,255,0.3);">
                        @L["Dismiss"]
                    </K7Button>
                </div>
            </div>
        </div>
    </div>
}
