@using K7.Shared.Dtos.Entities.Medias
@inject IStringLocalizer<NextEpisodeOverlay> L

@if (_visible && _nextEpisode is not null)
{
    <div class="next-episode-overlay">
        <div class="next-episode-card">
            @if (_stillUrl is not null)
            {
                <MudImage Src="@_stillUrl"
                          Alt="@_nextEpisode.Title"
                          Class="next-episode-still"
                          ObjectFit="ObjectFit.Cover" />
            }
            else
            {
                <div class="next-episode-still-placeholder">
                    <MudIcon Icon="@Icons.Material.Filled.SkipNext" Style="font-size: 32px; opacity: 0.5;" />
                </div>
            }
            <div class="next-episode-info">
                <MudText Typo="Typo.caption" Color="Color.Secondary">@L["NextEpisode"]</MudText>
                <MudText Typo="Typo.subtitle2">
                    S@(_nextEpisode.SeasonNumber.ToString("D2"))E@(_nextEpisode.EpisodeNumber.ToString("D2"))
                </MudText>
                <MudText Typo="Typo.body2">@(_nextEpisode.Title ?? "")</MudText>
            </div>
            <div class="next-episode-actions">
                @if (_countdownSeconds > 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                        @string.Format(L["AutoPlayIn"], _countdownSeconds)
                    </MudText>
                }
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               Size="Size.Small"
                               OnClick="PlayNextAsync">
                        @L["PlayNow"]
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               OnClick="Dismiss">
                        @L["Dismiss"]
                    </MudButton>
                </MudStack>
            </div>
        </div>
    </div>
}
