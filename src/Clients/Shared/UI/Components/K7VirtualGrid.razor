@typeparam TItem

<div class="k7-virtual-grid"
     style="--item-width: @(ItemWidth)px; --grid-gap: @(Spacing)px; --row-height: @(_estimatedRowHeight)px;"
     @ref="_gridRef">
    @if (Items is not null)
    {
        @if (Items.Count == 0 && EmptyContent is not null)
        {
            @EmptyContent
        }
        else
        {
            <Virtualize Items="_rows" Context="row" ItemSize="_estimatedRowHeight"
                        OverscanCount="OverscanCount" @ref="_virtualizeRef">
                <div class="k7-virtual-grid-row"
                     style="grid-template-columns: repeat(@(CalculateColumnCount()), 1fr); height: @(_estimatedRowHeight)px;">
                    @foreach (var item in row)
                    {
                        @if (ItemTemplate is not null)
                        {
                            @ItemTemplate(item)
                        }
                    }
                </div>
            </Virtualize>
        }
    }
    else if (ItemsProvider is not null)
    {
        @if (_containerWidth > 0)
        {
            <Virtualize ItemsProvider="ProvideRowsAsync" Context="row" ItemSize="_estimatedRowHeight"
                        OverscanCount="OverscanCount" @ref="_virtualizeRef">
                <ItemContent>
                    <div class="k7-virtual-grid-row"
                         style="grid-template-columns: repeat(@(CalculateColumnCount()), 1fr); height: @(_estimatedRowHeight)px;">
                        @foreach (var item in row)
                        {
                            @if (ItemTemplate is not null)
                            {
                                @ItemTemplate(item)
                            }
                        }
                    </div>
                </ItemContent>
                <Placeholder>
                    <div class="k7-virtual-grid-row"
                         style="grid-template-columns: repeat(@(CalculateColumnCount()), 1fr); height: @(_estimatedRowHeight)px;">
                        @for (var i = 0; i < CalculateColumnCount(); i++)
                        {
                            @if (Placeholder is not null)
                            {
                                @Placeholder
                            }
                        }
                    </div>
                </Placeholder>
            </Virtualize>
        }
        else if (Placeholder is not null)
        {
            <div class="k7-virtual-grid-row"
                 style="grid-template-columns: repeat(auto-fill, minmax(@(ItemWidth)px, 1fr)); height: @(_estimatedRowHeight)px;">
                @for (var i = 0; i < 12; i++)
                {
                    @Placeholder
                }
            </div>
        }
    }
</div>
