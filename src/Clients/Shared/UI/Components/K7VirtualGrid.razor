@typeparam TItem

<div class="k7-virtual-grid"
     style="--item-width: @(ItemWidth)px; --grid-gap: @(EffectiveSpacing)px; --row-height: @(_estimatedRowHeight)px;"
     @ref="_gridRef">
    @if (Items is not null)
    {
        @if (Items.Count == 0 && EmptyContent is not null)
        {
            @EmptyContent
        }
        else
        {
            <Virtualize Items="_rows" Context="row" ItemSize="_estimatedRowHeight"
                        OverscanCount="OverscanCount" @ref="_virtualizeRef">
                <div class="k7-virtual-grid-row @(IsCompactGrid ? "k7-virtual-grid-row--compact" : "")"
                     style="@GetRowGridStyle()">
                    @foreach (var item in row)
                    {
                        @if (ItemTemplate is not null)
                        {
                            <div @key="item">
                                @ItemTemplate(item)
                            </div>
                        }
                    }
                </div>
            </Virtualize>
        }
    }
    else if (ItemsProvider is not null)
    {
        @if (_containerWidth > 0)
        {
            <Virtualize ItemsProvider="ProvideRowsAsync" Context="row" ItemSize="_estimatedRowHeight"
                        OverscanCount="OverscanCount" @ref="_virtualizeRef">
                <ItemContent>
                    <div class="k7-virtual-grid-row @(IsCompactGrid ? "k7-virtual-grid-row--compact" : "")"
                         style="@GetRowGridStyle()">
                        @foreach (var item in row)
                        {
                            @if (ItemTemplate is not null)
                            {
                                <div @key="item">
                                    @ItemTemplate(item)
                                </div>
                            }
                        }
                    </div>
                </ItemContent>
                <Placeholder>
                    <div class="k7-virtual-grid-row k7-virtual-grid-row--placeholder @(IsCompactGrid ? "k7-virtual-grid-row--compact" : "")"
                         style="@GetRowGridStyle()">
                        @for (var i = 0; i < CalculateColumnCount(); i++)
                        {
                            <div class="k7-virtual-grid-placeholder-cell">
                                <div class="k7-virtual-grid-placeholder-focus focusable"
                                     tabindex="0"
                                     role="presentation"
                                     aria-hidden="true"></div>
                            </div>
                        }
                    </div>
                </Placeholder>
            </Virtualize>
        }
        else
        {
            <div class="k7-virtual-grid-row k7-virtual-grid-row--placeholder @(IsCompactGrid ? "k7-virtual-grid-row--compact" : "")"
                 style="@GetRowGridStyle()" aria-hidden="true">
                @for (var i = 0; i < 12; i++)
                {
                    <div class="k7-virtual-grid-placeholder-cell"></div>
                }
            </div>
        }
    }
</div>
