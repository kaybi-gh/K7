@inject IRatingService K7ServerService
@inject IFeatureAccessService FeatureAccess

@if (_canRate)
{
    <span class="rating-stars" @onclick:stopPropagation="true">
        @for (int i = 1; i <= 5; i++)
        {
            var star = i;
            <button class="k7-icon-btn @(star <= StarCount ? "star--selected" : "")" type="button" @onclick="() => OnStarClick(star)" aria-label=""><i class="ph ph-star"></i></button>
        }
    </span>
}
