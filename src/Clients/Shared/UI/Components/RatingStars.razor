@inject IRatingService K7ServerService
@inject IFeatureAccessService FeatureAccess

@if (_canRate)
{
    <span class="rating-stars" @onclick:stopPropagation="true">
        @for (int i = 5; i >= 1; i--)
        {
            var star = i;
            <button class="k7-icon-btn @(star <= StarCount ? "star--selected" : "")" type="button" @onclick="() => OnStarClick(star)" aria-label="">
                <i class="@(star <= StarCount ? "ph-fill ph-star" : "ph ph-star")"></i>
            </button>
        }
    </span>
}
