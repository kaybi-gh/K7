@inject IRatingService K7ServerService
@inject IFeatureAccessService FeatureAccess

@if (_canRate)
{
    <span @ref="_element"
          class="rating-stars focusable"
          role="slider"
          data-sn-activatable
          aria-valuemin="0"
          aria-valuemax="5"
          aria-valuenow="@StarCount"
          aria-label="Rating"
          tabindex="0"
          @onclick:stopPropagation="true"
          @onkeydown="HandleKeyDown">
        @for (int i = 1; i <= 5; i++)
        {
            var star = i;
            <span class="rating-star @(IsFilled(star) ? "star--filled" : "")"
                  @onclick="() => OnStarClick(star)"
                  @onpointerover="() => OnPointerOver(star)"
                  @onpointerout="OnPointerOut">
                <K7Icon Icon="@(IsFilled(star) ? Phosphor.Fill.Star : Phosphor.Star)" />
            </span>
        }
    </span>
}
