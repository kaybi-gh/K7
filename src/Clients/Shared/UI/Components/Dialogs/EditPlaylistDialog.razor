@inject IStringLocalizer<EditPlaylistDialog> L
@inject IStringLocalizer<SharedResource> S

<MudDialog>
    <DialogContent>
        <MudStack Spacing="4" Class="mt-2">
            <MudTextField @bind-Value="Title"
                          Label="@L["NameLabel"]"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="@L["NameRequired"]"
                          MaxLength="200"
                          Immediate="true" />
            <MudTextField @bind-Value="Description"
                          Label="@L["DescriptionOptional"]"
                          Variant="Variant.Outlined"
                          Lines="3"
                          MaxLength="2000" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@S["Cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="SubmitAsync"
                   Disabled="@(string.IsNullOrWhiteSpace(Title) || _isSubmitting)">
            @if (_isSubmitting)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">@L["Saving"]</MudText>
            }
            else
            {
                <MudText>@S["Save"]</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>
