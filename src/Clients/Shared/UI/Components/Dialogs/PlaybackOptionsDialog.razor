@using K7.Shared.Dtos.Entities.Medias
@using K7.Shared.Dtos.Entities.Metadatas.Files
@using K7.Shared.Dtos.Entities.Metadatas.Files.Tracks
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<PlaybackOptionsDialog> L
@inject IStringLocalizer<SharedResource> S

<MudDialog>
    <DialogContent>
        <MudStack Spacing="4" data-nav-col>
            @if (Movie.IndexedFiles != null && Movie.IndexedFiles.Count > 1)
            {
                <MudSelect T="IndexedFileDto" @bind-Value="SelectedFile" Label="@L["File"]" Variant="Variant.Filled" FullWidth="true" ToStringFunc="@(f => f?.Name)">
                    @foreach (var file in Movie.IndexedFiles)
                    {
                        <MudSelectItem Value="@file">@file.Name</MudSelectItem>
                    }
                </MudSelect>
            }

            @if (videoMetadata != null)
            {
                <MudSelect T="AudioFileTrackDto" @bind-Value="SelectedAudioTrack" Label="@L["AudioTrack"]" Variant="Variant.Filled" FullWidth="true">
                    @if (videoMetadata.AudioTracks != null)
                    {
                        @foreach (var track in videoMetadata.AudioTracks)
                        {
                            <MudSelectItem Value="@track">@($"{track.Language} - {track.Name} - {track.Codec} {track.ChannelLayout}")</MudSelectItem>
                        }
                    }
                </MudSelect>

                <MudSelect T="SubtitleFileTrackDto" @bind-Value="SelectedSubtitleTrack" Label="@L["SubtitleTrack"]" Variant="Variant.Filled" FullWidth="true" Clearable="true">
                    @if (videoMetadata.SubtitleTracks != null)
                    {
                        @foreach (var track in videoMetadata.SubtitleTracks)
                        {
                            <MudSelectItem Value="@track">@($"{track.Language} - {track.Name} - {track.Codec}")</MudSelectItem>
                        }
                    }
                </MudSelect>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@S["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Play" Class="mx-2">@S["Play"]</MudButton>
    </DialogActions>
</MudDialog>