@inject IStringLocalizer<ReIdentifyDialog> L
@inject IStringLocalizer<SharedResource> S

<div class="k7-dialog-content">
        <div class="reidentify-form">
            <K7TextField @bind-Value="_searchQuery" Label="@L["TitleLabel"]" Variant="outlined" />

            <div class="reidentify-fields-row">
                <K7TextField Type="number" @bind-Value="_searchYear" Label="@L["YearOptionalLabel"]" Variant="outlined" Clearable="true" />
                <K7TextField @bind-Value="_searchProviderId" Label="@L["ProviderIdLabel"]" Variant="outlined" Clearable="true" />
            </div>

            <K7Button Class="reidentify-search-btn" Variant="filled" Color="primary" OnClick="SearchAsync" Disabled="_isSearching">
                <span>@L["SearchButton"]</span>
            </K7Button>

            @if (_isSearching)
            {
                <div class="reidentify-search-status" aria-live="polite">
                    <K7Spinner Size="sm" />
                    <span>@L["Searching"]</span>
                </div>
            }

            @if (_results != null)
            {
                if (!_results.Any())
                {
                    <span Color="warning">@L["NoResults"]</span>
                }
                else
                {
                    <ul class="k7-list">
                        @foreach (var result in _results)
                        {
                            <li class="focusable @(_selectedResult == result ? "selected" : "")"
                                tabindex="0"
                                role="button"
                                @onclick="() => SelectResult(result)"
                                @onkeydown="e => OnResultKeyDown(e, result)">
                                <div class="grid">
                                    <div>
                                        @if (!string.IsNullOrEmpty(result.PosterUrl))
                                        {
                                            <K7Image Src="@result.PosterUrl" ObjectFit="cover" Width="70" Class="rounded-lg" loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="surface d-flex align-center justify-center rounded-lg">
                                                <K7Icon Icon="@Phosphor.Circle" />
                                            </div>
                                        }
                                    </div>
                                    <div>
                                        <div class="d-flex flex-col">
                                            <p class="text-subtitle1"><b>@result.Title</b> @(result.Year.HasValue ? $"({result.Year})" : "")</p>
                                            <span class="text-caption" Color="secondary">@string.Format(L["ProviderAndId"], result.Provider, result.ExternalId)</span>
                                            <p class="text-sm" Style="overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">@result.Overview</p>
                                        </div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            }
        </div>
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">@S["Cancel"]</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="SubmitAsync" Disabled="@(_selectedResult == null || _isSubmitting)">
            @if (_isSubmitting)
            {
                <K7Spinner Size="sm" />
            }
            else
            {
                <span>@S["Confirm"]</span>
            }
        </K7Button>
    </div>
