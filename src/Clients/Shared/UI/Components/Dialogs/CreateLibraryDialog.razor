@inject IStringLocalizer<CreateLibraryDialog> L
@inject IStringLocalizer<SharedResource> S

<div class="k7-dialog-content">
        @* Step indicators *@
        <div class="d-flex mb-6">
            <K7Chip Color="@(_activeStep >= 0 ? "primary" : "default")" Size="sm">@L["Step1"]</K7Chip>
            <K7Icon Name="caret-right" Size="sm" />
            <K7Chip Color="@(_activeStep >= 1 ? "primary" : "default")" Size="sm">@L["Step2"]</K7Chip>
            <K7Icon Name="caret-right" Size="sm" />
            <K7Chip Color="@(_activeStep >= 2 ? "primary" : "default")" Size="sm">@L["Step3"]</K7Chip>
        </div>

        @* Step 1: Choose media type *@
        @if (_activeStep == 0)
        {
            <h6>@L["SelectContentType"]</h6>
            <div class="grid" style="grid-template-columns: repeat(3, 1fr); gap: var(--space-3);">
                <div>
                    <div class="k7-card k7-card--outlined @GetMediaTypeCardClass(LibraryMediaType.Movie)" Style="cursor: pointer;" tabindex="0" @onclick="() => SelectMediaType(LibraryMediaType.Movie)" @onkeydown="(e) => OnMediaTypeKeyDown(e, LibraryMediaType.Movie)">
                        <div class="d-flex flex-column align-center pa-6">
                            <K7Icon Name="film-strip" Size="lg" Color="@GetMediaTypeColor(LibraryMediaType.Movie)" />
                            <h6>@S["MediaTypeMovies"]</h6>
                            <p class="text-sm" Color="secondary">@L["MovieDescription"]</p>
                        </div>
                    </div>
                </div>
                <div>
                    <div class="k7-card k7-card--outlined @GetMediaTypeCardClass(LibraryMediaType.Serie)" Style="cursor: pointer;" tabindex="0" @onclick="() => SelectMediaType(LibraryMediaType.Serie)" @onkeydown="(e) => OnMediaTypeKeyDown(e, LibraryMediaType.Serie)">
                        <div class="d-flex flex-column align-center pa-6">
                            <K7Icon Name="television" Size="lg" Color="@GetMediaTypeColor(LibraryMediaType.Serie)" />
                            <h6>@S["MediaTypeSeries"]</h6>
                            <p class="text-sm" Color="secondary">@L["SeriesDescription"]</p>
                        </div>
                    </div>
                </div>
                <div>
                    <div class="k7-card k7-card--outlined @GetMediaTypeCardClass(LibraryMediaType.Music)" Style="cursor: pointer;" tabindex="0" @onclick="() => SelectMediaType(LibraryMediaType.Music)" @onkeydown="(e) => OnMediaTypeKeyDown(e, LibraryMediaType.Music)">
                        <div class="d-flex flex-column align-center pa-6">
                            <K7Icon Name="music-note" Size="lg" Color="@GetMediaTypeColor(LibraryMediaType.Music)" />
                            <h6>@S["MediaTypeMusic"]</h6>
                            <p class="text-sm" Color="secondary">@L["MusicDescription"]</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Step 2: Name and path *@
        @if (_activeStep == 1)
        {
            <div class="d-flex flex-col mt-2">
                <K7TextField @bind-Value="_title" Label="@L["NameLabel"]" Variant="outlined"
                              Required="true" RequiredError="@L["NameRequired"]"
                              Placeholder="@L["NamePlaceholder"]" />

                <div class="d-flex">
                    <K7TextField @bind-Value="_rootPath" Label="@L["PathLabel"]" Variant="outlined"
                                  Required="true" RequiredError="@L["PathRequired"]"
                                  Placeholder="@L["PathPlaceholder"]"
                                  HelperText="@L["PathHelper"]"
                                  Style="flex: 1;" />
                    <K7Button Variant="outlined" StartIcon="folder" OnClick="BrowseFolderAsync" Class="mb-6">
                        @L["Browse"]
                    </K7Button>
                </div>

                <K7Select TValue="string" @bind-Value="_selectedProvider" Label="@L["ProviderLabel"]" Variant="outlined">
                    @foreach (var provider in _availableProviders)
                    {
                        <K7SelectItem TValue="string" Value="@provider.ProviderName">@provider.ProviderName</K7SelectItem>
                    }
                </K7Select>

                <div class="d-flex align-center mt-2">
                    <K7Switch @bind-Value="_triggerIndexing" />
                    <label class="text-sm ml-2">@L["AutoIndex"]</label>
                </div>
            </div>
        }

        @* Step 3: Summary *@
        @if (_activeStep == 2)
        {
            <h6>@L["SummaryTitle"]</h6>
            <table class="k7-table k7-table--dense">
                <tbody>
                    <tr>
                        <td><strong>@S["Name"]</strong></td>
                        <td>@_title</td>
                    </tr>
                    <tr>
                        <td><strong>@S["Type"]</strong></td>
                        <td>
                            <K7Chip Color="primary" Size="sm">@GetMediaTypeLabel(_selectedMediaType)</K7Chip>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>@S["Path"]</strong></td>
                        <td><code>@_rootPath</code></td>
                    </tr>
                    <tr>
                        <td><strong>@L["ProviderLabel"]</strong></td>
                        <td>@_selectedProvider</td>
                    </tr>
                    <tr>
                        <td><strong>@L["AutoIndexSummary"]</strong></td>
                        <td>@(_triggerIndexing ? S["Yes"] : S["No"])</td>
                    </tr>
                </tbody>
            </table>

            @if (_isSubmitting)
            {
                <K7ProgressBar Indeterminate="true" />
            }
        }
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">@S["Cancel"]</K7Button>
        @if (_activeStep > 0)
        {
            <K7Button OnClick="PreviousStep" Variant="outlined">@S["Previous"]</K7Button>
        }
        @if (_activeStep < 2)
        {
            <K7Button Color="primary" Variant="filled" OnClick="NextStep" Disabled="!CanAdvance()">@S["Next"]</K7Button>
        }
        else
        {
            <K7Button Color="primary" Variant="filled" OnClick="SubmitAsync" Disabled="_isSubmitting">
                @if (_isSubmitting)
                {
                    <K7Spinner Size="sm" />
                    <span>@L["Creating"]</span>
                }
                else
                {
                    <span>@L["Submit"]</span>
                }
            </K7Button>
        }
    </div>
