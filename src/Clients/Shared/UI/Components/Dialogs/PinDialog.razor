<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="mt-2">
            <MudText Typo="Typo.body1">Enter PIN for <b>@UserName</b></MudText>
            <MudTextField @ref="_pinField"
                          @bind-Value="_pin"
                          Label="PIN"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          MaxLength="10"
                          Immediate="true"
                          OnKeyUp="OnKeyUp"
                          UserAttributes="@(new Dictionary<string, object> { ["inputmode"] = "numeric", ["pattern"] = "[0-9]*" })" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@string.IsNullOrEmpty(_pin)">
            OK
        </MudButton>
    </DialogActions>
</MudDialog>
