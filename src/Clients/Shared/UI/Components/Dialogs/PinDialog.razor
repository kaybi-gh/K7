@inject IStringLocalizer<PinDialog> L
@inject IStringLocalizer<SharedResource> S

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="mt-2">
            <MudText Typo="Typo.body1">@((MarkupString)string.Format(L["EnterForUser"], UserName))</MudText>
            <MudTextField @ref="_pinField"
                          @bind-Value="_pin"
                          Label="@L["PinLabel"]"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          MaxLength="10"
                          Immediate="true"
                          OnKeyUp="OnKeyUp"
                          UserAttributes="@(new Dictionary<string, object> { ["inputmode"] = "numeric", ["pattern"] = "[0-9]*" })" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@S["Cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@string.IsNullOrEmpty(_pin)">
            @S["Ok"]
        </MudButton>
    </DialogActions>
</MudDialog>
