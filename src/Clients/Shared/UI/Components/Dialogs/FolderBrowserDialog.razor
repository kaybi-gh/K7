@inject IStringLocalizer<FolderBrowserDialog> L
@inject IStringLocalizer<SharedResource> S

<div class="k7-dialog-content">
        <div class="d-flex flex-col">
            @* Current path display *@
            <K7TextField @bind-Value="_currentPath" Label="@L["PathLabel"]" Variant="outlined" ReadOnly="true" />

            @if (_isLoading)
            {
                <K7ProgressBar Indeterminate="true" />
            }

            @* Directory list *@
            <div class="folder-list">
                @if (!string.IsNullOrEmpty(_currentPath))
                {
                    <div class="folder-item focusable folder-item--parent"
                         tabindex="0"
                         role="button"
                         @onclick="NavigateUp">
                        <K7Icon Icon="@Phosphor.ArrowBendUpLeft"  IconSize="@K7IconSize.Sm" />
                        <span class="folder-item__name">..</span>
                    </div>
                }
                @if (_directories is { Count: > 0 })
                {
                    <Virtualize Items="_directories" Context="dir" ItemSize="40">
                        <div class="folder-item focusable @(_selectedEntry == dir ? "folder-item--selected" : "")"
                             tabindex="0"
                             role="button"
                             @onclick="() => NavigateInto(dir)">
                            <K7Icon Icon="@Phosphor.Folder" Color="warning"  IconSize="@K7IconSize.Sm" />
                            <span class="folder-item__name">@dir.Name</span>
                            <K7Icon Icon="@Phosphor.CaretRight"  IconSize="@K7IconSize.Sm" Class="folder-item__chevron" />
                        </div>
                    </Virtualize>
                }
                else if (_directories is { Count: 0 })
                {
                    <div class="folder-item folder-item--empty">
                        <span class="text-sm text-secondary">@L["NoSubfolders"]</span>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">@S["Cancel"]</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="Confirm" Disabled="@string.IsNullOrEmpty(GetSelectedPath())">
            @L["SelectFolder"]
        </K7Button>
    </div>
