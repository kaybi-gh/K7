@inject IStringLocalizer<FolderBrowserDialog> L
@inject IStringLocalizer<SharedResource> S

<div class="k7-dialog-content">
        <div class="d-flex flex-col">
            @* Current path display + parent navigation *@
            <div class="d-flex align-center">
                <button type="button" class="k7-icon-btn" @onclick="NavigateUp" aria-label="navigate up"><i class="ph ph-arrow-up"></i></button>
                <K7TextField @bind-Value="_currentPath" Label="@L["PathLabel"]" Variant="outlined" ReadOnly="true" />
            </div>

            @if (_isLoading)
            {
                <K7ProgressBar Indeterminate="true" />
            }

            @* Directory list *@
            <ul class="k7-list">
                @if (_directories != null)
                {
                    @foreach (var dir in _directories)
                    {
                        <li Value="dir" OnClick="() => SelectDirectory(dir)">
                            
                                <div class="d-flex align-center">
                                    <K7Icon Name="@Phosphor.Folder" Color="warning" Size="sm" />
                                    <span Style="flex: 1;">@dir.Name</span>
                                    <button type="button" class="k7-icon-btn" @onclick="() => NavigateInto(dir)" aria-label="navigate into"><i class="ph ph-caret-right"></i></button>
                                </div>
                            
                        </li>
                    }

                    @if (_directories.Count == 0)
                    {
                        <li Value="@((DirectoryEntryDto?)null)">
                            
                                <span Color="secondary" Typo="Typo.body2">@L["NoSubfolders"]</span>
                            
                        </li>
                    }
                }
            </ul>
        </div>
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">@S["Cancel"]</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="Confirm" Disabled="@string.IsNullOrEmpty(GetSelectedPath())">
            @L["SelectFolder"]
        </K7Button>
    </div>
