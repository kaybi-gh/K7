<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            @* Current path display + parent navigation *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Disabled="@string.IsNullOrEmpty(_currentPath)" OnClick="NavigateUp" Size="Size.Small" />
                <MudTextField @bind-Value="_currentPath" Label="Chemin" Variant="Variant.Outlined" ReadOnly="true" />
            </MudStack>

            @if (_isLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }

            @* Directory list *@
            <MudList T="DirectoryEntryDto" Style="max-height: 400px; overflow-y: auto;" Dense="true" SelectionMode="SelectionMode.SingleSelection" @bind-SelectedValue="_selectedEntry">
                @if (_directories != null)
                {
                    @foreach (var dir in _directories)
                    {
                        <MudListItem Value="dir" OnClick="() => SelectDirectory(dir)">
                            <ChildContent>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Warning" Size="Size.Small" />
                                    <MudText Style="flex: 1;">@dir.Name</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" OnClick="() => NavigateInto(dir)" />
                                </MudStack>
                            </ChildContent>
                        </MudListItem>
                    }

                    @if (_directories.Count == 0)
                    {
                        <MudListItem Value="@((DirectoryEntryDto?)null)">
                            <ChildContent>
                                <MudText Color="Color.Secondary" Typo="Typo.body2">Aucun sous-dossier</MudText>
                            </ChildContent>
                        </MudListItem>
                    }
                }
            </MudList>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm" Disabled="@string.IsNullOrEmpty(GetSelectedPath())">
            Sélectionner ce dossier
        </MudButton>
    </DialogActions>
</MudDialog>
