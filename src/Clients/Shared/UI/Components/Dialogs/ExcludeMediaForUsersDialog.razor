@inject IStringLocalizer<ExcludeMediaForUsersDialog> L
@inject IStringLocalizer<SharedResource> S

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                @string.Format(L["SelectUsers"], MediaTitle)
            </MudText>
            <MudStack Spacing="1">
                @foreach (var entry in _userStates)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@(entry.User.UserName ?? entry.User.Email ?? "—")</MudText>
                            @if (entry.User.IsGuest)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@S["Guest"]</MudText>
                            }
                        </MudStack>
                        <MudSwitch T="bool" Value="@entry.Excluded" ValueChanged="@(v => entry.Excluded = v)"
                                   Color="Color.Error" />
                    </MudStack>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@S["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            @S["Save"]
        </MudButton>
    </DialogActions>
</MudDialog>
