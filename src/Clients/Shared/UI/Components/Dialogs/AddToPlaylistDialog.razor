@using K7.Shared.Dtos.Entities.Playlists
@inject IPlaylistService K7ServerService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_playlists.Count == 0)
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-4">
                <MudText Typo="Typo.body1" Color="Color.Secondary">Aucune playlist</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateNewPlaylist">
                    Créer une playlist
                </MudButton>
            </MudStack>
        }
        else
        {
            <MudList T="LitePlaylistDto" Dense="true" Class="py-0">
                @foreach (var playlist in _playlists)
                {
                    <MudListItem T="LitePlaylistDto" OnClick="() => SelectPlaylist(playlist)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudIcon Icon="@Icons.Material.Filled.QueueMusic" Color="Color.Primary" />
                            <MudStack Spacing="0">
                                <MudText>@playlist.Title</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@playlist.ItemCount morceaux</MudText>
                            </MudStack>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
            <MudDivider Class="my-2" />
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="CreateNewPlaylist"
                       FullWidth="true">
                Nouvelle playlist
            </MudButton>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid MediaId { get; set; }

    private List<LitePlaylistDto> _playlists = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlaylists();
    }

    private async Task LoadPlaylists()
    {
        _loading = true;
        var result = await K7ServerService.GetPlaylistsAsync(1, 100);
        _playlists = result?.Items?.Where(p => !p.IsSmartPlaylist).ToList() ?? [];
        _loading = false;
    }

    private async Task SelectPlaylist(LitePlaylistDto playlist)
    {
        try
        {
            await K7ServerService.AddPlaylistItemAsync(playlist.Id, MediaId);
            Snackbar.Add($"Ajouté à « {playlist.Title} »", Severity.Success);
            MudDialog.Close(DialogResult.Ok(playlist.Id));
        }
        catch
        {
            Snackbar.Add("Erreur lors de l'ajout", Severity.Error);
        }
    }

    private async Task CreateNewPlaylist()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<CreatePlaylistDialog>("Nouvelle playlist", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: Guid newId })
        {
            // Add the track to the newly created playlist
            try
            {
                await K7ServerService.AddPlaylistItemAsync(newId, MediaId);
                Snackbar.Add("Ajouté à la nouvelle playlist", Severity.Success);
                MudDialog.Close(DialogResult.Ok(newId));
            }
            catch
            {
                Snackbar.Add("Playlist créée mais erreur lors de l'ajout", Severity.Warning);
                MudDialog.Close(DialogResult.Ok(newId));
            }
        }
        else
        {
            await LoadPlaylists();
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
