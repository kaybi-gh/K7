<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_playlists.Count == 0)
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-4">
                <MudText Typo="Typo.body1" Color="Color.Secondary">Aucune playlist</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateNewPlaylist">
                    Créer une playlist
                </MudButton>
            </MudStack>
        }
        else
        {
            <MudList T="LitePlaylistDto" Dense="true" Class="py-0">
                @foreach (var playlist in _playlists)
                {
                    <MudListItem T="LitePlaylistDto" OnClick="() => SelectPlaylist(playlist)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudIcon Icon="@Icons.Material.Filled.QueueMusic" Color="Color.Primary" />
                            <MudStack Spacing="0">
                                <MudText>@playlist.Title</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@playlist.ItemCount morceaux</MudText>
                            </MudStack>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
            <MudDivider Class="my-2" />
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="CreateNewPlaylist"
                       FullWidth="true">
                Nouvelle playlist
            </MudButton>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
    </DialogActions>
</MudDialog>
