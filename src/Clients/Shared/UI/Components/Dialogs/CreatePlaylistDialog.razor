<MudDialog>
    <DialogContent>
        <MudStack Spacing="4" Class="mt-2">
            <MudTextField @bind-Value="_title"
                          Label="Nom de la playlist"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Le nom est requis"
                          MaxLength="200"
                          Immediate="true" />
            <MudTextField @bind-Value="_description"
                          Label="Description (optionnelle)"
                          Variant="Variant.Outlined"
                          Lines="3"
                          MaxLength="2000" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="SubmitAsync"
                   Disabled="@(string.IsNullOrWhiteSpace(_title) || _isSubmitting)">
            @if (_isSubmitting)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Création...</MudText>
            }
            else
            {
                <MudText>Créer</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>
