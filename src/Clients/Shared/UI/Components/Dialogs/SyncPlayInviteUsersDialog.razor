@inject ISyncPlayService SyncPlay

<div class="k7-dialog-content">
    @if (SyncPlay.OnlineUsers.Count == 0 && _loading)
    {
        <div class="d-flex justify-center py-4">
            <K7Spinner />
        </div>
    }
    else if (SyncPlay.OnlineUsers.Count == 0)
    {
        <div class="d-flex justify-center py-4">
            <span class="text-on-surface-variant">No other users online</span>
        </div>
    }
    else
    {
        <div class="syncplay-invite-list">
            @foreach (var user in SyncPlay.OnlineUsers)
            {
                <div class="syncplay-invite-user">
                    <K7Avatar Size="sm" Letter="@(user.DisplayName.Length > 0 ? user.DisplayName[..1].ToUpperInvariant() : "?")" />
                    <div class="syncplay-invite-user-info">
                        <span class="syncplay-invite-name">@user.DisplayName</span>
                        @if (!string.IsNullOrEmpty(user.DeviceName))
                        {
                            <span class="syncplay-invite-device">- @user.DeviceName</span>
                        }
                    </div>
                    @if (user.IsInSyncPlayGroup)
                    {
                        <span class="syncplay-invite-badge">In group</span>
                    }
                    else if (_failedUsers.Contains(user.UserId))
                    {
                        <span class="syncplay-invite-badge error">
                            <K7Icon Icon="@Phosphor.Warning"  IconSize="@K7IconSize.Xs" />
                            Failed
                        </span>
                        <K7Button Variant="tonal" Size="sm" OnClick="@(() => InviteUser(user.UserId))">
                            <K7Icon Icon="@Phosphor.ArrowClockwise"  IconSize="@K7IconSize.Xs" />
                            Retry
                        </K7Button>
                    }
                    else if (_invitedUsers.Contains(user.UserId))
                    {
                        <span class="syncplay-invite-badge sent">
                            <K7Icon Icon="@Phosphor.Check"  IconSize="@K7IconSize.Xs" />
                            Sent
                        </span>
                    }
                    else
                    {
                        <K7Button Variant="tonal" Size="sm" OnClick="@(() => InviteUser(user.UserId))">
                            <K7Icon Icon="@Phosphor.UserPlus"  IconSize="@K7IconSize.Xs" />
                            Invite
                        </K7Button>
                    }
                </div>
            }
        </div>
    }
</div>
<div class="k7-dialog-actions">
    <K7Button OnClick="Close">Close</K7Button>
</div>
