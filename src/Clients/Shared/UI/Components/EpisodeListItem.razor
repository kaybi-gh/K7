@using K7.Shared.Dtos.Entities.Medias

<div class="episode-item @(IsExpanded ? "episode-item--expanded" : "")" tabindex="0" role="button" @onclick="OnToggleExpand" @onkeydown="OnKeyDown">
    <div class="episode-item-main">
        <div class="episode-still-container">
            @if (!string.IsNullOrEmpty(StillUrl))
            {
                <K7Image Src="@StillUrl"
                          Alt="@Episode.Title"
                          Class="rounded-lg"
                          Style="width: 160px; height: 90px;"
                          ObjectFit="cover"
                          loading="lazy" />
            }
            else
            {
                <div class="episode-still-placeholder">
                    <K7Icon Name="circle" Style="font-size: 24px; opacity: 0.3;" />
                </div>
            }
            @if (Episode.UserState is { ProgressPercentage: > 0 and < 100 })
            {
                <K7ProgressBar Value="@Episode.UserState.ProgressPercentage" />
            }
        </div>

        <div class="episode-info">
            <div class="d-flex align-center">
                <p class="text-sm" Color="secondary">@Episode.EpisodeNumber</p>
                <p class="text-subtitle2">@(Episode.Title ?? S["Untitled"])</p>
                @if (Episode.UserState?.IsCompleted == true)
                {
                    <K7Icon Name="check-circle" Color="success" Size="sm" />
                }
            </div>
            <div class="d-flex">
                @if (Episode.Duration.HasValue)
                {
                    <span class="text-caption" Color="secondary">@FormatDuration(Episode.Duration.Value)</span>
                }
            </div>
        </div>

        <button type="button" class="k7-icon-btn episode-expand-btn">
            <K7Icon Name="@(IsExpanded ? "caret-up" : "caret-down")" Size="sm" />
        </button>
    </div>

    @if (IsExpanded)
    {
        <div class="episode-detail">
            @if (_fullEpisode?.Overview is not null)
            {
                <p class="text-sm mb-2" Color="secondary">@_fullEpisode.Overview</p>
            }
            @if (_fullEpisode?.AirDate is not null)
            {
                <span class="text-caption" Color="secondary">@string.Format(S["AirDate"], _fullEpisode.AirDate.Value.ToString("d"))</span>
            }
            <div class="d-flex align-center mt-3">
                <K7Button Variant="filled"
                           Color="primary"
                           StartIcon="play"
                           OnClick="HandlePlay"
                           Size="sm">
                    @(Episode.UserState is { LastPlaybackPosition: > 0, IsCompleted: false } ? S["Resume"] : S["Play"])
                </K7Button>
                @if (_fullEpisode?.IndexedFiles is { Count: > 0 })
                {
                    <K7Menu Icon="dots-three" Size="sm">
                        <K7MenuItem Icon="file-zip" OnClick="OpenIndexedFilesDialogAsync">@S["IndexedVersions"]</K7MenuItem>
                    </K7Menu>
                }
            </div>
        </div>
    }
</div>
