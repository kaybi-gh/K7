<div class="d-flex flex-col carousel-wrapper" style="@Style">
    <div data-carousel @ref="_root">
        <div class="carousel-header">
            @if (Skeleton)
            {
                <K7Skeleton Shape="text" Width="330px" />
            }
            else
            {
                <h6>@Title</h6>
            }
        </div>
        <div class="carousel-viewport" data-carousel-viewport tabindex="-1">
            <div class="carousel-container">
                @ChildContent
            </div>
        </div>
    </div>
</div>
