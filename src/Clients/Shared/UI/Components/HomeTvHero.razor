@if (Model is not null)
{
    <div class="home-tv-hero__backdrop-fixed">
        <div class="home-tv-hero__backdrop @(UseSoftBackdrop ? "home-tv-hero__backdrop--soft" : "") @(_activeLayer == 0 ? "home-tv-hero__backdrop--active" : "")"
             style="background-image: @FormatBackdropCss(_layerUrls[0])" />
        <div class="home-tv-hero__backdrop @(UseSoftBackdrop ? "home-tv-hero__backdrop--soft" : "") @(_activeLayer == 1 ? "home-tv-hero__backdrop--active" : "")"
             style="background-image: @FormatBackdropCss(_layerUrls[1])" />
        <div class="home-tv-hero__gradient"></div>
    </div>
    <div class="home-tv-hero">
        <div class="home-tv-hero__content">
            <h2 class="home-tv-hero__title">@Model.Title</h2>
            @if (!string.IsNullOrEmpty(Model.AdditionalInformations))
            {
                <p class="home-tv-hero__subtitle">@Model.AdditionalInformations</p>
            }
            <div class="home-tv-hero__meta">
                @if (Model.ReleaseYear.HasValue)
                {
                    <span class="home-tv-hero__meta-item">@Model.ReleaseYear</span>
                }
                @if (!string.IsNullOrEmpty(Model.ContentRating))
                {
                    <span class="home-tv-hero__meta-item home-tv-hero__badge">@Model.ContentRating</span>
                }
                @if (Model.RuntimeMinutes.HasValue)
                {
                    <span class="home-tv-hero__meta-item">@FormatRuntime(Model.RuntimeMinutes.Value)</span>
                }
                @if (Model.Rating.HasValue)
                {
                    <span class="home-tv-hero__meta-item home-tv-hero__rating">
                        <K7Icon Icon="@Phosphor.Star"  IconSize="@K7IconSize.Sm" />
                        @Model.Rating.Value.ToString("0.#")/10
                    </span>
                }
            </div>
            @if (Model.Genres is { Count: > 0 })
            {
                <div class="home-tv-hero__genres">
                    @foreach (var genre in Model.Genres.Take(4))
                    {
                        <K7Chip Size="sm" Variant="outlined">@genre</K7Chip>
                    }
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.Overview))
            {
                <p class="home-tv-hero__overview">@TruncateOverview(Model.Overview)</p>
            }
        </div>
    </div>
}
