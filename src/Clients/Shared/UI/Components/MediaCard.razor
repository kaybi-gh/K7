@inject IFeatureAccessService FeatureAccess

@if (Skeleton)
{
    <div class="media-card @VariantClass">
        <div class="media-card-container">
            <K7Skeleton />
        </div>

        @if (FooterVisible)
        {
            <div class="media-card-footer mt-1">
                <div class="media-card-footer-skeleton">
                    <K7Skeleton Shape="text" Width="78%" Class="media-card-skeleton-title" />
                    <K7Skeleton Shape="text" Width="44%" Class="media-card-skeleton-subtitle" />
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="media-card @VariantClass @GetRootClass()" @onfocusin="OnFocused">
        <div class="media-card-container"
             data-longpress="@(LongPressEnabled ? "true" : null)"
             @ontouchstart="OnTouchStart"
             @ontouchmove="OnTouchMove"
             @ontouchend="OnTouchEnd"
             @ontouchcancel="OnTouchCancel"
             @oncontextmenu="OnContextMenu"
             @oncontextmenu:preventDefault="@LongPressEnabled">
            @if (!string.IsNullOrEmpty(Href))
            {
            <a class="media-card-link focusable"
               href="@Href"
               @onclick="OnLinkClick"
               @onclick:preventDefault="@_preventNextClick"
               @onkeydown="OnKeyDown"
               @onkeyup="OnKeyUp">
                @if (!string.IsNullOrEmpty(Model.PictureUrl))
                {
                    <K7Image Src="@Model.PictureUrl" Alt="@Model.Title" Class="rounded-lg" Fluid="true" ObjectFit="cover" loading="lazy" />
                }
                else
                {
                    <div class="media-card-placeholder rounded-lg">
                        <K7Icon Name="@PlaceholderIcon" Style="font-size: 48px; opacity: 0.3;" />
                    </div>
                }

                @if (WatchedStatusEnabled && Model.Watched && Variant != MediaCardVariant.Cover)
                {
                    <div class="media-card-watched">
                        <K7Icon Size="lg" Color="success" Icon="@Phosphor.Fill.CheckCircle" />
                    </div>
                }

                @if (Model.GroupCount > 1)
                {
                    <div class="media-card-group-count">
                        <K7Chip Style="padding: 0; justify-content: space-around; width: 32px; height: 32px" Size="sm" Color="dark" Variant="filled">@Model.GroupCount</K7Chip>
                    </div>
                }

                @if (ProgressEnabled && !ProgressBarIsHidden())
                {
                    <div class="media-card-progress-bar">
                        <K7ProgressBar Value="@Model.Progress" />
                    </div>
                }

                @if (OverlayEnabled)
                {
                    <div class="media-card-overlay">
                        <K7FabButton AriaLabel="Play" Icon="@Phosphor.Fill.Play" Focusable="false" />
                    </div>
                }
            </a>
            }
            else if (OverlayEnabled)
            {
            <div class="media-card-link focusable"
                 tabindex="0"
                 role="button"
                 aria-label="@Model.Title"
                 @onkeydown="OnKeyDown"
                 @onkeyup="OnKeyUp">
                @if (!string.IsNullOrEmpty(Model.PictureUrl))
                {
                    <K7Image Src="@Model.PictureUrl" Alt="@Model.Title" Class="rounded-lg" Fluid="true" ObjectFit="cover" loading="lazy" />
                }
                else
                {
                    <div class="media-card-placeholder rounded-lg">
                        <K7Icon Name="@PlaceholderIcon" Style="font-size: 48px; opacity: 0.3;" />
                    </div>
                }

                @if (WatchedStatusEnabled && Model.Watched && Variant != MediaCardVariant.Cover)
                {
                    <div class="media-card-watched">
                        <K7Icon Size="lg" Color="success" Icon="@Phosphor.Fill.CheckCircle" />
                    </div>
                }

                @if (Model.GroupCount > 1)
                {
                    <div class="media-card-group-count">
                        <K7Chip Style="padding: 0; justify-content: space-around; width: 32px; height: 32px" Size="sm" Color="dark" Variant="filled">@Model.GroupCount</K7Chip>
                    </div>
                }

                @if (ProgressEnabled && !ProgressBarIsHidden())
                {
                    <div class="media-card-progress-bar">
                        <K7ProgressBar Value="@Model.Progress" />
                    </div>
                }

                <div class="media-card-overlay">
                    <K7FabButton AriaLabel="Play" Icon="@Phosphor.Fill.Play" Focusable="false" />
                </div>
            </div>
            }
            else
            {
            <div class="media-card-link">
                @if (!string.IsNullOrEmpty(Model.PictureUrl))
                {
                    <K7Image Src="@Model.PictureUrl" Alt="@Model.Title" Class="rounded-lg" Fluid="true" ObjectFit="cover" loading="lazy" />
                }
                else
                {
                    <div class="media-card-placeholder rounded-lg">
                        <K7Icon Name="@PlaceholderIcon" Style="font-size: 48px; opacity: 0.3;" />
                    </div>
                }
            </div>
            }

            @if (LongPressEnabled)
            {
                <div class="media-card-menu @(_menuOpen ? "media-card-menu--open" : "")" data-longpress-target>
                    <K7Menu Open="_menuOpen" OpenChanged="OnMenuOpenChanged" Title="@Model.Title">
                        <ActivatorContent>
                            <K7IconButton Icon="@Phosphor.DotsThreeVertical" aria-label="Menu" Focusable="false" />
                        </ActivatorContent>
                        <ChildContent>
                            <MediaCardContextMenu Model="Model"
                                                  Href="Href"
                                                  ShowPlay="OverlayEnabled && !string.IsNullOrEmpty(Href)"
                                                  ShowRating="_showRating"
                                                  ShowPlaylist="_showPlaylist"
                                                  ShowCollection="_showCollection"
                                                  ShowWatchState="_watchStateMenuVisible"
                                                  ExcludeMenuEnabled="ExcludeMenuEnabled"
                                                  IsAdmin="IsAdmin"
                                                  BulkEpisodeCount="BulkEpisodeCount"
                                                  OnExcludeForSelf="OnExcludeForSelf"
                                                  OnExcludeForOthers="OnExcludeForOthers"
                                                  OnWatchStateChanged="OnWatchStateChanged" />
                        </ChildContent>
                    </K7Menu>
                </div>
            }

        </div>

        @if (FooterVisible)
        {
            <div class="media-card-footer mt-1">
                <div class="d-flex flex-col">
                    <span class="media-card-title"><span class="media-card-title-inner">@Model.Title</span></span>
                    <span class="media-card-subtitle"><span class="media-card-subtitle-inner">@Model.AdditionalInformations</span></span>
                </div>
            </div>
        }
    </div>
}
