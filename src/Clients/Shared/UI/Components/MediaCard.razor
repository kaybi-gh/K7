@inject IStringLocalizer<MediaCard> L

@if (Skeleton)
{
    <div class="media-card @VariantClass">
        <div class="media-card-container">
            <K7Skeleton />
        </div>

        @if (FooterVisible)
        {
            <div class="media-card-footer">
                <div class="d-flex flex-col">
                    <K7Skeleton Shape="text" Width="80%" />
                    <K7Skeleton Shape="text" Width="50%" />
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="media-card @VariantClass" @onfocusin="OnFocused">
        <div class="media-card-container" data-longpress="@(ExcludeMenuEnabled ? "true" : null)">
            <a class="media-card-link focusable" href="@Href">
                @if (!string.IsNullOrEmpty(Model.PictureUrl))
                {
                    <K7Image Src="@Model.PictureUrl" Alt="@Model.Title" Class="rounded-lg" Style="height: 100%;" Fluid="true" ObjectFit="cover" loading="lazy" />
                }
                else
                {
                    <div class="media-card-placeholder rounded-lg">
                        <K7Icon Name="@PlaceholderIcon" Style="font-size: 48px; opacity: 0.3;" />
                    </div>
                }

                @if (WatchedStatusEnabled && Model.Watched && Variant != MediaCardVariant.Cover)
                {
                    <div class="media-card-watched">
                        <K7Icon Size="sm" class="ma-1" Color="success" Icon="@Phosphor.CheckCircle" />
                    </div>
                }

                @if (Model.GroupCount > 1)
                {
                    <div class="media-card-group-count">
                        <K7Chip Size="sm" Color="dark" Variant="filled">@Model.GroupCount</K7Chip>
                    </div>
                }

                @if (ProgressEnabled && !ProgressBarIsHidden())
                {
                    <div class="media-card-progress-bar">
                        <K7ProgressBar Value="@Model.Progress" />
                    </div>
                }

                @if (OverlayEnabled)
                {
                    <div class="media-card-overlay">
                        <K7FabButton AriaLabel="Play" Icon="@Phosphor.Play" Focusable="false" />
                    </div>
                }
            </a>

            @if (ExcludeMenuEnabled)
            {
                <div class="media-card-menu @(_menuOpen ? "media-card-menu--open" : "")" data-longpress-target>
                    <K7Menu Open="_menuOpen" OpenChanged="OnMenuOpenChanged">
                        <ActivatorContent>
                            <K7IconButton Icon="@Phosphor.DotsThreeVertical" aria-label="Menu" Focusable="false" />
                        </ActivatorContent>
                        <ChildContent>
                            <K7MenuItem Icon="eye-slash" OnClick="OnExcludeForSelf">@L["HideForMe"]</K7MenuItem>
                            @if (IsAdmin)
                            {
                                <K7MenuItem Icon="circle" OnClick="OnExcludeForOthers">@L["HideForUser"]</K7MenuItem>
                            }
                        </ChildContent>
                    </K7Menu>
                </div>
            }
        </div>

        @if (FooterVisible)
        {
            <div class="media-card-footer mt-1">
                <div class="d-flex flex-col">
                    <span class="media-card-title"><span class="media-card-title-inner">@Model.Title</span></span>
                    <span class="media-card-subtitle">@Model.AdditionalInformations</span>
                </div>
            </div>
        }
    </div>
}
