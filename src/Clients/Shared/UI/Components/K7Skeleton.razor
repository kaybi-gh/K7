@namespace K7.Clients.Shared.UI.Components

@if (Shape == "circle")
{
    <span class="k7-skeleton k7-skeleton--circle @Class"
          style="width: @Width; height: @Height; @Style"></span>
}
else if (Shape == "text")
{
    <span class="k7-skeleton k7-skeleton--text @Class"
          style="@(string.IsNullOrEmpty(Width) ? string.Empty : $"width:{Width};") @(string.IsNullOrEmpty(Height) ? string.Empty : $"height:{Height};") @Style"></span>
}
else
{
    <span class="k7-skeleton @Class"
          style="display:block; @(string.IsNullOrEmpty(Width) ? string.Empty : $"width:{Width};") @(string.IsNullOrEmpty(Height) ? string.Empty : $"height:{Height};") @Style"></span>
}
