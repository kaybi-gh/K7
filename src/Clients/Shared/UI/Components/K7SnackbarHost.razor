@namespace K7.Clients.Shared.UI.Components
@implements IDisposable

<div class="k7-snackbar-host" aria-live="polite" aria-atomic="false">
    @foreach (var msg in _messages)
    {
        <div class="k7-toast k7-toast--@msg.Severity.ToString().ToLower()" @key="msg.Id" role="alert">
            <span class="k7-toast-accent" aria-hidden="true"></span>
            <K7Icon Icon="@GetIcon(msg.Severity)" />
            <span class="k7-toast-msg">@msg.Message</span>
            <K7IconButton Icon="@Phosphor.X" Class="k7-toast-close" aria-label="Dismiss" OnClick="() => Remove(msg)" />
        </div>
    }
</div>
