@namespace K7.Clients.Shared.UI.Components
@using K7.Server.Domain.Enums
@using K7.Shared.Dtos.Rules
@inject IStringLocalizer<K7RuleEditor> L

<div class="k7-rule-editor @Class">
    @RenderGroup(_root, null, -1)
</div>

@code {
    private RenderFragment RenderGroup(EditGroup group, EditGroup? parent, int indexInParent) => __builder =>
    {
        <div class="k7-rule-group @(parent is not null ? "k7-rule-group--nested" : "")">
            <div class="k7-rule-group-header">
                <K7Select TValue="RuleMatchCondition" Value="group.MatchCondition"
                           ValueChanged="(v) => OnMatchConditionChanged(group, v)"
                           Variant="outlined" Style="width: 120px;">
                    <K7SelectItem Value="RuleMatchCondition.All">@L["MatchAll"]</K7SelectItem>
                    <K7SelectItem Value="RuleMatchCondition.Any">@L["MatchAny"]</K7SelectItem>
                </K7Select>

                @if (parent is not null)
                {
                    <K7IconButton Icon="@Phosphor.X" Size="sm" Color="error"
                                   OnClick="() => RemoveItem(parent, indexInParent)" />
                }
            </div>

            <div class="k7-rule-group-items">
                @for (var i = 0; i < group.Items.Count; i++)
                {
                    var index = i;
                    var item = group.Items[index];

                    @if (item is EditRule rule)
                    {
                        <div class="k7-rule-item">
                            @{ var descriptor = GetDescriptor(rule.Field); }

                            <K7Select TValue="string" Value="rule.Field"
                                       ValueChanged="(v) => OnFieldChanged(group, index, v)"
                                       Variant="outlined" Style="min-width: 160px;">
                                @foreach (var field in FieldDescriptors)
                                {
                                    <K7SelectItem Value="field.FieldName">@field.DisplayName</K7SelectItem>
                                }
                            </K7Select>

                            <K7Select TValue="RuleOperator" Value="rule.Operator"
                                       ValueChanged="(v) => OnOperatorChanged(group, index, v)"
                                       Variant="outlined" Style="min-width: 140px;">
                                @if (descriptor is not null)
                                {
                                    @foreach (var op in descriptor.Operators)
                                    {
                                        <K7SelectItem Value="op">@GetOperatorLabel(op)</K7SelectItem>
                                    }
                                }
                            </K7Select>

                            @if (!IsUnaryOperator(rule.Operator))
                            {
                                @if (descriptor?.ValueType == RuleFieldValueType.Select && descriptor.Options is not null)
                                {
                                    <K7Select TValue="string" Value="@(rule.Value ?? "")"
                                               ValueChanged="(v) => OnValueChanged(group, index, v)"
                                               Variant="outlined" Style="min-width: 140px;">
                                        @foreach (var opt in descriptor.Options)
                                        {
                                            <K7SelectItem Value="opt.Value">@opt.Label</K7SelectItem>
                                        }
                                    </K7Select>
                                }
                                else
                                {
                                    <K7TextField TValue="string" Value="@(rule.Value ?? "")"
                                                  ValueChanged="(v) => OnValueChanged(group, index, v)"
                                                  Variant="outlined"
                                                  Type="@GetInputType(descriptor)"
                                                  Style="min-width: 140px;" />
                                }
                            }

                            <K7IconButton Icon="@Phosphor.X" Size="sm" Color="error"
                                           OnClick="() => RemoveItem(group, index)" />
                        </div>
                    }
                    else if (item is EditGroup nested)
                    {
                        @RenderGroup(nested, group, index)
                    }
                }
            </div>

            <div class="k7-rule-group-actions">
                <K7Button Variant="text" Color="primary" StartIcon="@Phosphor.Plus"
                           OnClick="() => AddRule(group)">
                    @L["AddRule"]
                </K7Button>
                <K7Button Variant="text" Color="secondary" StartIcon="@Phosphor.FolderPlus"
                           OnClick="() => AddGroup(group)">
                    @L["AddGroup"]
                </K7Button>
            </div>
        </div>
    };
}
