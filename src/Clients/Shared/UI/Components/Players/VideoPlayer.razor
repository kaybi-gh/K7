@using K7.Clients.Shared.Interfaces
@inject IJSRuntime JSRuntime
@inject IPlayerService PlayerService
@inject IDeviceService DeviceService
@inject IK7ServerService K7ServerService
@inject IRemoteControlService RemoteControl
@inject ISyncPlayService SyncPlay
@inject IK7Snackbar Snackbar
@inject IStringLocalizer<SharedResource> S

@if (RemoteControl.IsControlling && !RemoteControl.IsAudio)
{
    <div class="video-container">
        <RemoteControlPanel OnResumeRequested="OnResumeHere" />
    </div>
}
else if (PlayerService.IsVisible)
{
    var isNative = DeviceService.GetClientType() == Server.Domain.Enums.ClientType.Native;
    var usesWebVideoOnNative = isNative && WindowsVideoPlayback.UsesWebVideoPlayer;
    var containerClass = isNative && !usesWebVideoOnNative ? "video-container native-overlay" : "video-container";
    if (_syncPlaySidebarOpen)
    {
        containerClass += " syncplay-sidebar-open";
    }

    <div class="@containerClass" @ref="_videoContainer" @onkeydown="OnContainerKeyDown"
         @onclick="OnVideoPlayerRootClick"
         data-sn-layer="@(_syncPlaySidebarOpen ? "overlay" : null)"
         data-sn-layer-close=".video-player-close-btn">
        <div class="video-main">
            <VideoPlayerControlsOverlay ThumbnailsSource="@ThumbnailsSource" OnSyncPlayToggle="ToggleSyncPlaySidebar" SyncPlaySidebarOpen="_syncPlaySidebarOpen" ContainerRef="_videoContainer" />
            @if (SyncPlay.IsInGroup && SyncPlay.ShowReactions)
            {
                <SyncPlayReactionOverlay />
            }
            @if (DeviceService.GetClientType() == Server.Domain.Enums.ClientType.Web
                 || usesWebVideoOnNative)
            {
            <video id="video-player" class="video-js" @ref="_player">
                @* Omit <source> when resuming mid-stream so Video.js does not start buffering
                   segment 0 before changeSourceAndSeek / #EXT-X-START can apply. *@
                @if (!string.IsNullOrEmpty(SourceUri) && PlayerService.Source?.PendingSeekTime is null)
                {
                    <source src="@SourceUri" type="@SourceMimeType" />
                }
                <p class="vjs-no-js">
                    To view this video please enable JavaScript, and consider upgrading to a
                    web browser that
                    <a href="https://videojs.com/html5-video-support/" target="_blank">supports HTML5 video</a>
                </p>
            </video>
            }
            <NextEpisodeOverlay />
        </div>
        @if (_syncPlaySidebarOpen)
        {
            <div class="video-syncplay-sidebar">
                <SyncPlayOverlay />
            </div>
        }
    </div>
}
