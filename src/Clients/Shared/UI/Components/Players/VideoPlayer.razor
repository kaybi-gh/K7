@using K7.Clients.Shared.Interfaces
@inject IJSRuntime JSRuntime
@inject IPlayerService PlayerService
@inject IDeviceService DeviceService
@inject IK7ServerService K7ServerService

@if (PlayerService.IsVisible)
{
    @* On Windows Native, the WebView2 is opaque (WinUI3 bug) so the MediaElement
       is placed in front with native controls - no Blazor overlay needed. *@
    var useNativeControls = DeviceService.GetClientType() == Server.Domain.Enums.ClientType.Native
        && System.OperatingSystem.IsWindows();

    if (!useNativeControls)
    {
        var isNative = DeviceService.GetClientType() == Server.Domain.Enums.ClientType.Native;
        var containerClass = isNative ? "video-container native-overlay" : "video-container";

        <div class="@containerClass" @ref="_videoContainer">
            <VideoPlayerControlsOverlay ThumbnailsSource="@ThumbnailsSource" />
            @if (DeviceService.GetClientType() == Server.Domain.Enums.ClientType.Web)
            {
            <video id="video-player" class="video-js" @ref="_player">
                @if (!string.IsNullOrEmpty(SourceUri))
                {
                    <source src="@SourceUri" type="@SourceMimeType" />
                }
                <p class="vjs-no-js">
                    To view this video please enable JavaScript, and consider upgrading to a
                    web browser that
                    <a href="https://videojs.com/html5-video-support/" target="_blank">supports HTML5 video</a>
                </p>
            </video>
            }
            <NextEpisodeOverlay />
            <SkipSegmentOverlay MediaId="@PlayerService.Source?.MediaId" />
        </div>
    }
}
