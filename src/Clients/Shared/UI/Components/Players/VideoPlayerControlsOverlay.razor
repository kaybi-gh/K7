@using K7.Clients.Shared.Models
@using K7.Clients.Shared.UI.Components.Dialogs
@using K7.Server.Domain.Enums
@using K7.Shared
@using K7.Shared.Dtos.Entities.Metadatas.Files.Tracks
@using K7.Shared.Interfaces
@using Microsoft.JSInterop
@using System.Timers
@using System.Globalization
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable
@inject IPlayerService PlayerService
@inject IDeviceService DeviceService
@inject IBrightnessService BrightnessService
@inject IVolumeService VolumeService
@inject ICastOrchestrationService CastOrchestration
@inject K7HubClient HubClient
@inject K7.Clients.Shared.Interfaces.ISpatialNavService SpatialNav
@inject IRemoteControlService RemoteControl
@inject IDeviceStorageService DeviceStorage
@inject ISyncPlayService SyncPlay
@inject IUserPreferencesService UserPreferencesService
@inject IMediaService MediaService
@inject IStringLocalizer<SharedResource> S

<div class="video-controls-overlay @(IsOverlayVisible ? "controls-visible" : "controls-hidden")" tabindex="0" @ref="_overlayRef"
     data-sn-layer="@(SyncPlaySidebarOpen ? null : "overlay")"
     data-sn-layer-close=".video-player-close-btn"
     @onmousemove="OnOverlayMouseMove" @onclick="OnOverlayTap"
     @ontouchstart="OnTouchStart" @ontouchstart:preventDefault
     @ontouchmove="OnTouchMove" @ontouchmove:preventDefault="@_swipeGestureActive"
     @ontouchend="OnTouchEnd" @ontouchend:preventDefault
     @onkeydown="OnKeyDown" @onkeydown:stopPropagation
     @onfocusin="OnFocusIn">

    <div class="controls-bar top d-flex align-right" @onclick:stopPropagation @ontouchstart:stopPropagation @ontouchmove:stopPropagation @ontouchend:stopPropagation @onmouseover="OnControlsBarMouseEnter" @onmouseout="OnControlsBarMouseOut">
        <K7IconButton Icon="@Phosphor.X" OnClick="OnCloseButtonClick" AriaLabel="Close" Class="video-player-close-btn" />
    </div>

    <div class="controls-bar bottom" @onclick:stopPropagation @ontouchstart:stopPropagation @ontouchmove:stopPropagation @ontouchend:stopPropagation @onmouseover="OnControlsBarMouseEnter" @onmouseout="OnControlsBarMouseOut">
        <div class="controls-bar-row">
            <div class="controls-bar-left">
                <K7IconButton Icon="@(PlayerService.PlaybackState != Server.Domain.Enums.PlaybackState.Playing ? Phosphor.Play : Phosphor.Pause)" OnClick="TogglePlayPause" AriaLabel="Play pause" Class="play-pause-btn" />

                @if (_deviceType == Server.Domain.Enums.DeviceType.Desktop)
                {
                    <div class="volume-control" @onmouseover="OnVolumeSliderMouseOver" @onmouseout="OnVolumeSliderMouseOut">
                        <K7IconButton Icon="@GetVolumeIcon()" OnClick="ToggleIsMuted" AriaLabel="Volume" />
                        @if (_isVolumeSliderVisible)
                        {
                            <div class="volume-slider-popover">
                                <div class="volume-slider-container">
                                    <K7Slider TValue="double"
                                    Min="0" Max="1"
                                    Step="0.01"
                                    Immediate="true"
                                    Value="@PlayerService.Volume"
                                    ValueChanged="PlayerService.SetVolume"
                                    Class="volume-slider" />
                                </div>
                            </div>
                        }
                    </div>
                }

                <span class="time-display">@FormatTime(_isSeeking ? _seekTarget : PlayerService.CurrentTime) / @FormatTime(PlayerService.Duration)</span>
            </div>

            <div class="controls-bar-seek">
                <SeekBar IsVisible=@(_showOverlay || _isMenuOpen)
                         OnDragChanged="OnSeekBarDragChanged"
                         ThumbnailsUri="@(string.IsNullOrEmpty(ThumbnailsSource) ? null : new Uri(ThumbnailsSource, UriKind.RelativeOrAbsolute))"
                         Chapters="@GetSeekBarChapters()" />
            </div>

            <div class="controls-bar-right">
                <PlaybackSettingsMenu @ref="_playbackSettingsMenu" @bind-Open="_isMenuOpen" />

                        <PlayOnDevicePicker CastDeviceSelected="OnCastDeviceSelected" RemoteDeviceSelected="OnRemoteDeviceSelected" />

                        @if (SyncPlay.IsInGroup)
                        {
                            <K7IconButton Icon="@Phosphor.UsersThree" OnClick="@OnSyncPlayToggle" AriaLabel="SyncPlay" Color="@(SyncPlaySidebarOpen ? "active" : "")" />
                        }

                    @if (_deviceType == Server.Domain.Enums.DeviceType.Desktop)
                    {
                        <K7IconButton Icon="@(PlayerService.IsFullScreen ? Phosphor.CornersIn : Phosphor.CornersOut)" OnClick="ToggleFullscreen" AriaLabel="Toggle fullscreen" />
                    }
                </div>
        </div>
    </div>

    <SkipSegmentOverlay @ref="_skipOverlay" MediaId="@PlayerService.Source?.MediaId" ControlsVisible="@IsOverlayVisible" />
</div>

@if (_hudText is not null)
{
    <div class="hud-indicator">
        <K7Icon Name="@_hudIcon"  IconSize="@K7IconSize.Lg" />
        <span>@_hudText</span>
    </div>
}

@if (_doubleTapSide is not null)
{
    <div class="double-tap-ripple @(_doubleTapSide)" />
}

@if (_brightnessOverlayOpacity > 0)
{
    <div class="brightness-overlay" style="opacity: @(_brightnessOverlayOpacity.ToString(CultureInfo.InvariantCulture))" />
}

@if (_swipeGestureActive)
{
    <div class="swipe-indicator @(_swipeSide == SwipeSide.Left ? "left" : "right")">
        <K7Icon Name="@_hudIcon"  IconSize="@K7IconSize.Lg" />
        <div class="swipe-bar-container">
            <div class="swipe-bar-fill" style="height: @(_swipeBarPercent.ToString(CultureInfo.InvariantCulture))%" />
        </div>
        <span>@_hudText</span>
    </div>
}
