@page "/movies/{id}"
@using K7.Shared.Dtos.Entities.PersonRoles
@using K7.Shared.Dtos.Entities.Metadatas.Files;
@using Microsoft.AspNetCore.Components.Authorization
@inject IK7ServerService k7ServerService
@inject IPlayerService PlayerService
@inject IDeviceStorageService DeviceStorageService
@inject PlaybackProgressTracker PlaybackProgressTracker
@inject IFeatureAccessService FeatureAccess
@inject AuthenticationStateProvider AuthenticationStateProvider
<PageTitle>@_movie?.Title</PageTitle>
<MudBreakpointProvider OnBreakpointChanged="ScreenResized" />

@if (isLoading)
{
    <div>
        <MudGrid Justify="Justify.SpaceEvenly" Style="max-width:100%;" Spacing="0">
            <MudItem xs="12" sm="4" lg="1">
                <MudStack AlignItems="AlignItems.Center">
                    <MediaPoster Skeleton="true" />
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="6" lg="5">
                <MudStack AlignItems="@(_isSmallDevice ? AlignItems.Center : AlignItems.Start)">
                    <MudSkeleton Animation="Animation.Wave" Height="50px" Width="200px" />
                    <MudStack Row="true">
                        <MudSkeleton Animation="Animation.Wave" Height="100%" Width="50px" />
                        <MudSkeleton Animation="Animation.Wave" Height="100%" Width="30px" />
                    </MudStack>
                    <MudStack Row="true">
                        <MudRating />
                    </MudStack>
                    <MudGrid>
                        @for (int i = 0; i < 3; i++)
                        {
                            <MudItem>
                                <MudSkeleton Animation="Animation.Wave" Height="100%" Width="30px" />
                            </MudItem>
                        }
                    </MudGrid>
                    <MudStack Row="true">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="30px" Width="30px" Class="ml-3 mb-2" />
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="30px" Width="30px" Class="ml-3 mb-2" />
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="30px" Width="30px" Class="ml-3 mb-2" />
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="30px" Width="30px" Class="ml-3 mb-2" />
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="30px" Width="30px" Class="ml-3 mb-2" />
                    </MudStack>
                    <MudStack>
                        <div class="overview-container mx-4">
                            <MudSkeleton Animation="Animation.Wave" Height="150px" Width="200px" />
                        </div>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd">
                            <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="30px" Width="30px" Class="ml-3 mb-2" />
                        </MudStack>
                    </MudStack>
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="12" lg="12">
                <HorizontalScrollableStack Skeleton="true">
                    @for (int i = 0; i < 10; i++)
                    {
                        <HorizontalScrollableStackItem>
                            <PersonRole Skeleton="true" />
                        </HorizontalScrollableStackItem>
                    }
                </HorizontalScrollableStack>
            </MudItem>
        </MudGrid>
    </div>
}
else
{
    @if (_movie != null)
    {
        <div class="hero-page-stack">
            <MudStack Class="pa-10" Style="height: 100%;" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd">
                <div class="background-image" style="--background-picture: url(@k7ServerService.GetAbsoluteUri(k7ServerService.GetAbsoluteUri(_movie.Pictures?.FirstOrDefault(x => x.Type == Server.Domain.Enums.MetadataPictureType.Backdrop)?.GetUri(Server.Domain.Enums.MetadataPictureSize.Medium)?.OriginalString)?.AbsoluteUri)?.AbsoluteUri)" />
                @if (k7ServerService.GetAbsoluteUri(_movie.Pictures?.FirstOrDefault(x => x.Type == Server.Domain.Enums.MetadataPictureType.Logo)?.GetUri(Server.Domain.Enums.MetadataPictureSize.Small)?.OriginalString)?.AbsoluteUri is string logoUri)
                {
                    <MudImage Style="max-width: 80vw;" Height="150" ObjectFit="ObjectFit.ScaleDown" Src="@logoUri"></MudImage>
                }
                else
                {
                    <MudText Typo="Typo.h4">@_movie.Title</MudText>
                }
                <MudStack Row="true">
                    @foreach (var genre in _movie.Genres ?? [])
                    {
                        <MudChip T="string" Label="true" Variant="Variant.Outlined" Size="Size.Small">@genre</MudChip>
                    }
                </MudStack>
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudText Style="font-size: 20px;" Typo="Typo.overline">@_movie.ReleaseDate!.Value.Year</MudText>
                    |
                    <MudText Style="font-size: 20px; text-wrap: nowrap;" Typo="Typo.overline">@($"{(int)((VideoFileMetadataDto)_movie.IndexedFiles!.First().FileMetadata!).Duration.TotalHours}h {((VideoFileMetadataDto)_movie.IndexedFiles!.First().FileMetadata!).Duration.Minutes:D2}min")</MudText>
                </MudStack>
                @*<MudText Style="font-style: italic; font-size: 20px; font-family: initial;">
                “@_movie.TagLine”
            </MudText>*@
                @*<MudStack Row="true">
                <MudRating SelectedValue="@Convert.ToInt32(_movie.Ratings?.FirstOrDefault(x => x.Source == Server.Domain.Enums.RatingSource.MetadataProvider)?.Value ?? 0)" />
            </MudStack>*@
                <MudStack Row="true" data-nav-row>
                    <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PlayArrow" Color="Color.Primary" OnClick="PlayAsync">Play</MudButton>
                    <MudIconButton Icon="@Icons.Material.Filled.LocalMovies" aria-label="trailer"></MudIconButton>
                    <AuthorizeView Roles="User,Administrator">
                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" aria-label="mark-as-shown"></MudIconButton>
                    </AuthorizeView>
                    <AuthorizeView Roles="Administrator">
                        <MudIconButton Icon="@Icons.Material.Filled.FindReplace" title="Re-Identify" aria-label="re-identify" OnClick="OpenMediaReIdentifyDialogAsync"></MudIconButton>
                        <MudIconButton Icon="@Icons.Material.Filled.Settings" aria-label="settings"></MudIconButton>
                    </AuthorizeView>
                    <MudIconButton Icon="@Icons.Material.Filled.MoreHoriz" aria-label="more-actions"></MudIconButton>
                </MudStack>
                <MudIcon Style="position: absolute; left: 50%; top: 90vh;" Size="Size.Medium" Icon="@Icons.Material.Filled.KeyboardArrowDown" />
            </MudStack>
        </div>
        <div>
            <MudStack AlignItems="@(_isSmallDevice? AlignItems.Center: AlignItems.Start)" Class="px-10">
                <MudStack Style="width: 100%;">
                    <MudSelect @bind-Value="_selectedVideoFileTrack" Label="Video track" Variant="Variant.Filled" FullWidth="true">
                        @foreach (var track in ((VideoFileMetadataDto)_movie.IndexedFiles!.First().FileMetadata!).VideoTracks ?? [])
                        {
                            <MudSelectItem Value="@track">@($"{track.Codec} - {track.Width}x{track.Height}")</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect @bind-Value="_selectedAudioFileTrack" Label="Audio track" Variant="Variant.Filled" FullWidth="true">
                        @foreach (var track in ((VideoFileMetadataDto)_movie.IndexedFiles!.First().FileMetadata!).AudioTracks ?? [])
                        {
                            <MudSelectItem Value="@track">@($"{track.Language} - {track.Name} - {track.Codec} {track.ChannelLayout}")</MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>
            </MudStack>
            <MudStack Class="pa-10">
                <MudText Typo="Typo.h6">Overview</MudText>
                <MudText Typo="Typo.body2">@_movie.Overview</MudText>
            </MudStack>
            <MudGrid Justify="Justify.SpaceEvenly" Style="max-width:100%;" Spacing="0">
                <MudItem xs="12" sm="12" lg="12">
                    <HorizontalScrollableStack Title="Casting and crew">
                        @foreach (var cast in (_movie.PersonRoles ?? []).Where(x => x.Person != null).OrderBy(x => x.Order == null).ThenBy(x => x.Order))
                        {
                            <HorizontalScrollableStackItem>
                                <PersonRole LitePersonRoleDto="@cast" />
                            </HorizontalScrollableStackItem>
                        }
                    </HorizontalScrollableStack>
                </MudItem>
            </MudGrid>

            <MudStack Class="pa-10">
                <MudText Typo="Typo.h6">Versions / Fichiers Indexés</MudText>
                <MudGrid>
                    @foreach (var file in _movie.IndexedFiles ?? [])
                    {
                        var vMeta = file.FileMetadata as VideoFileMetadataDto;
                        <MudItem xs="12" sm="6">
                            <MudPaper Class="pa-4" Outlined="true">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudStack Spacing="0" Style="overflow: hidden;">
                                        <MudText Typo="Typo.body1" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@file.Name">@file.Name</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@file.Path">@file.Path</MudText>
                                        @if (vMeta != null)
                                        {
                                            <MudText Typo="Typo.caption">
                                                @($"{vMeta.VideoResolution} | {(int)vMeta.Duration.TotalHours}h {vMeta.Duration.Minutes:D2}min | {file.Size / (1024 * 1024):N0} MB")
                                            </MudText>
                                        }
                                    </MudStack>
                                    <MudIconButton Icon="@Icons.Material.Filled.FindReplace" title="Ré-identifier ce fichier" OnClick="@(() => OpenFileReIdentifyDialogAsync(file.Id))" />
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudStack>
        </div>
    }
}
