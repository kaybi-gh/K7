@page "/movies/{id}"
@using K7.Server.Domain.Enums
@using K7.Shared.Dtos.Entities.PersonRoles
@using K7.Shared.Dtos.Entities.Metadatas.Files;
@using Microsoft.AspNetCore.Components.Authorization
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject IPlayerService PlayerService
@inject IDeviceStorageService DeviceStorageService
@inject PlaybackProgressTracker PlaybackProgressTracker
@inject IFeatureAccessService FeatureAccess
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IStringLocalizer<Movie> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@_movie?.Title</PageTitle>
@if (isLoading)
{
    <div class="hero-page-stack">
        <div class="d-flex flex-col pa-10" style="height: 100%;">
            <K7Skeleton Width="300px" />
            
            <div class="d-flex">
                <K7Skeleton Width="80px" />
                <K7Skeleton Width="80px" />
                <K7Skeleton Width="80px" />
            </div>
            
            <div class="d-flex align-center">
                <K7Skeleton Width="50px" />
                <span>|</span>
                <K7Skeleton Width="100px" />
            </div>
            
            <div class="d-flex flex-col pa-10">
                <K7Skeleton Width="100px" />
                <K7Skeleton Width="600px" />
                <K7Skeleton Width="500px" />
                <K7Skeleton Width="550px" />
            </div>
            
            <div class="d-flex">
                <K7Skeleton Width="100px" />
                <K7Skeleton Shape="circle" />
                <K7Skeleton Shape="circle" />
                <K7Skeleton Shape="circle" />
                <K7Skeleton Shape="circle" />
            </div>
            <K7Icon Style="position: absolute; left: 50%; top: 90vh;" Size="md" Name="caret-down" />
        </div>
    </div>
    <div>
        <div class="d-flex flex-col px-10">
            <div class="d-flex flex-col" style="width: 100%;">
                <K7Skeleton Width="100%" />
                <K7Skeleton Width="100%" />
            </div>
        </div>
        <Carousel Skeleton="true" Title="@L["CastingAndCrew"]">
            @for (int i = 0; i < 10; i++)
            {
                <CarouselItem>
                    <PersonRole Skeleton="true" />
                </CarouselItem>
            }
        </Carousel>
    </div>
}
else
{
    @if (_movie != null)
    {
        <div class="movie-page">
        <div class="background-image" style="--background-picture: url(@apiClient.GetAbsoluteUri(apiClient.GetAbsoluteUri(_movie.Pictures?.FirstOrDefault(x => x.Type == Server.Domain.Enums.MetadataPictureType.Backdrop)?.GetUri(Server.Domain.Enums.MetadataPictureSize.Medium)?.OriginalString)?.AbsoluteUri)?.AbsoluteUri)" />
        <div class="movie-main">
        <div class="hero-page-stack">
            <div class="d-flex flex-col pa-10" style="gap: 8px;">
                @if (apiClient.GetAbsoluteUri(_movie.Pictures?.FirstOrDefault(x => x.Type == Server.Domain.Enums.MetadataPictureType.Logo)?.GetUri(Server.Domain.Enums.MetadataPictureSize.Medium)?.OriginalString)?.AbsoluteUri is string logoUri)
                {
                    <K7Image Style="max-height: 180px; max-width: 500px;" ObjectFit="scale-down" Src="@logoUri"></K7Image>
                }
                else
                {
                    <h2 Style="font-weight: 800; letter-spacing: -1px; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">@_movie.Title?.ToUpper()</h2>  
                }
                <div class="d-flex align-center" style="gap: 8px;">
                    @if (@_movie.Ratings?.FirstOrDefault(x => x.Source == RatingSource.MetadataProvider)?.Value is double externalRating)
                    {
                        <K7Chip Size="sm" Icon="star" Color="primary" Variant="filled" Style="font-weight: 700;">@externalRating.ToString("N1")</K7Chip>
                    }
                    <div class="d-flex" style="gap: 4px;">
                        @foreach (var genre in _movie.Genres ?? [])
                        {
                            <K7Chip Variant="text" Size="sm" Style="opacity: 0.9; font-weight: 600;">@genre</K7Chip>
                        }
                    </div>
                    @if (_movie.Studios?.Count > 0)
                    {
                        <span class="text-caption" Style="opacity: 0.4;">|</span>
                        <div class="d-flex" style="gap: 4px;">
                            @foreach (var studio in _movie.Studios)
                            {
                                var s = studio;
                                <K7Chip Variant="text" Size="sm" Style="opacity: 0.9; font-weight: 600;" OnClick="() => NavigateToStudio(s)">@studio</K7Chip>
                            }
                        </div>
                    }
                    <span class="text-caption" Style="opacity: 0.4;">|</span>
                    <div class="d-flex">
                        @if (_movie.ReleaseDate.HasValue)
                        {
                            <p class="text-sm" Style="opacity: 0.9; font-weight: 600;">@_movie.ReleaseDate.Value.Year</p>
                        }
                        @if (_movie.ReleaseDate.HasValue && _movie.IndexedFiles != null && _movie.IndexedFiles.Any() && _movie.IndexedFiles.First().FileMetadata is VideoFileMetadataDto)
                        {
                            <p class="text-sm" Style="opacity: 0.5;">&bull;</p>
                        }
                        @if (_movie.IndexedFiles != null && _movie.IndexedFiles.Any() && _movie.IndexedFiles.First().FileMetadata is VideoFileMetadataDto vMetaDuration)
                        {
                            <p class="text-sm" Style="opacity: 0.9; font-weight: 600;">@string.Format(S["DurationHoursMinutes"], (int)vMetaDuration.Duration.TotalHours, vMetaDuration.Duration.Minutes)</p>
                        }
                    </div>
                </div>
                
                @if (!string.IsNullOrWhiteSpace(_movie.TagLine))
                {
                    <p class="text-subtitle1 mt-2" Style="font-style: italic; opacity: 0.8; font-weight: 500;">
                        "@_movie.TagLine"
                    </p>
                }

                <div class="d-flex flex-col py-3 overview-clickable focusable" style="max-width: 800px;" tabindex="0" role="button" @onclick="OpenSynopsisDialogAsync">
                    <p Style="opacity: 0.85; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; font-size: 1.05rem;">
                        @_movie.Overview
                    </p>
                </div>

                <div class="d-flex mt-4">
                    <K7Button Disabled="@(_movie.IndexedFiles == null || !_movie.IndexedFiles.Any())" 
                               Variant="filled" 
                               StartIcon="@Phosphor.Play" 
                               Color="primary" 
                               Size="lg"
                               Style="border-radius: 8px; font-weight: 800; padding: 10px 32px; letter-spacing: 0.5px;"
                               OnClick="PlayAsync">@S["Play"]</K7Button>   
                               
                    <K7IconButton Icon="@Phosphor.Sliders" OnClick="OpenPlaybackOptionsAsync" AriaLabel="playback-options" />
                    @if (_movie.Trailers?.Count > 0)
                    {
                        <K7IconButton Icon="@Phosphor.FilmSlate" OnClick="OpenTrailerAsync" AriaLabel="trailer" />
                    }
                    
                    @if (_selectedFile is not null)
                    {
                        <DownloadButton IndexedFileId="_selectedFile.Id"
                                        MediaId="_movie!.Id"
                                        Title="@(_movie.Title ?? string.Empty)"
                                        MediaType="MediaType.Movie"
                                        CoverUrl="@(apiClient.GetAbsoluteUri(_movie.Pictures?.FirstOrDefault(x => x.Type == Server.Domain.Enums.MetadataPictureType.Poster)?.GetUri(Server.Domain.Enums.MetadataPictureSize.Small)?.OriginalString)?.AbsoluteUri)"
                                        VideoMetadata="@(_selectedFile.FileMetadata as VideoFileMetadataDto)"
                                        AudioTrackIndex="_selectedAudioFileTrack?.Index"
                                        SubtitleTrackIndices="@(_selectedSubtitleFileTrack is not null ? [_selectedSubtitleFileTrack.Index] : null)" />
                    }

                    <AuthorizeView Roles="User,Administrator">
                        <K7IconButton Icon="@Phosphor.CheckCircle" AriaLabel="mark-as-shown" />
                    </AuthorizeView>

                    <K7Menu>
                        <ActivatorContent>
                            <K7IconButton Icon="@Phosphor.DotsThree" AriaLabel="more-actions" />
                        </ActivatorContent>
                        <ChildContent>
                            <AuthorizeView Roles="Administrator">
                                <K7MenuItem Icon="magnifying-glass" OnClick="OpenMediaReIdentifyDialogAsync">@L["ReIdentify"]</K7MenuItem>
                                <K7MenuItem Icon="arrow-clockwise" OnClick="RefreshMetadataAsync">@L["RefreshMetadata"]</K7MenuItem>
                            </AuthorizeView>
                            <K7MenuItem Icon="file-zip" OnClick="OpenIndexedFilesDialogAsync">@L["IndexedVersions"]</K7MenuItem>
                        </ChildContent>
                    </K7Menu>
                </div>
            </div>
        </div>

        @if ((_movie.PersonRoles?.Count ?? 0) > 0)
        {
            <div class="movie-scroll-hint">
                <K7Icon Icon="@Phosphor.CaretDown" />
            </div>
        }
        </div>

        @if ((_movie.PersonRoles?.Count ?? 0) > 0)
        {
            <Carousel Title="@L["CastingAndCrew"]">
                @foreach (var cast in (_movie.PersonRoles ?? []).Where(x => x.Person != null).OrderBy(x => x.Order == null).ThenBy(x => x.Order))
                {
                    <CarouselItem @key="cast.Id">
                        <PersonRole LitePersonRoleDto="@cast" />
                    </CarouselItem>
                }
            </Carousel>
        }

        @if (_similarMedia.Count > 0)
        {
            <Carousel Title="@L["SimilarMedia"]">
                @foreach (var media in _similarMedia)
                {
                    <CarouselItem @key="media.Id">
                        <MediaCard Model="media"
                                   Href="@($"/movies/{media.Id}")"
                                   OverlayEnabled="true"
                                   FooterVisible="true" />
                    </CarouselItem>
                }
            </Carousel>
        }
        </div>
    }
}
