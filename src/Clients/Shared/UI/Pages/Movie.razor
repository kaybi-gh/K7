@page "/movies/{id}"
@using K7.Shared.Dtos.Entities.PersonRoles
@using K7.Shared.Dtos.Entities.Metadatas.Files;
@using Microsoft.AspNetCore.Components.Authorization
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject IPlayerService PlayerService
@inject IDeviceStorageService DeviceStorageService
@inject PlaybackProgressTracker PlaybackProgressTracker
@inject IFeatureAccessService FeatureAccess
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IStringLocalizer<Movie> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@_movie?.Title</PageTitle>
<MudBreakpointProvider OnBreakpointChanged="ScreenResized" />

@if (isLoading)
{
    <div class="hero-page-stack">
        <MudStack Class="pa-10" Style="height: 100%;" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd">
            <MudSkeleton Animation="Animation.Wave" Height="150px" Width="300px" />
            
            <MudStack Row="true">
                <MudSkeleton Animation="Animation.Wave" Height="30px" Width="80px" />
                <MudSkeleton Animation="Animation.Wave" Height="30px" Width="80px" />
                <MudSkeleton Animation="Animation.Wave" Height="30px" Width="80px" />
            </MudStack>
            
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="50px" />
                <MudText>|</MudText>
                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="100px" />
            </MudStack>
            
            <MudStack Class="pa-10" AlignItems="AlignItems.Center">
                <MudSkeleton Animation="Animation.Wave" Height="30px" Width="100px" />
                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="600px" />
                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="500px" />
                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="550px" />
            </MudStack>
            
            <MudStack Row="true">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Animation="Animation.Wave" Height="36px" Width="100px" />
                <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="40px" Width="40px" />
                <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="40px" Width="40px" />
                <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="40px" Width="40px" />
                <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="40px" Width="40px" />
            </MudStack>
            <MudIcon Style="position: absolute; left: 50%; top: 90vh;" Size="Size.Medium" Icon="@Icons.Material.Filled.KeyboardArrowDown" />
        </MudStack>
    </div>
    <div>
        <MudStack AlignItems="AlignItems.Center" Class="px-10">
            <MudStack Style="width: 100%;">
                <MudSkeleton Animation="Animation.Wave" Height="50px" Width="100%" />
                <MudSkeleton Animation="Animation.Wave" Height="50px" Width="100%" />
            </MudStack>
        </MudStack>
        <MudGrid Justify="Justify.SpaceEvenly" Style="max-width:100%;" Spacing="0" Class="mt-6">
            <MudItem xs="12" sm="12" lg="12">
                <Carousel Skeleton="true" Title="@L["CastingAndCrew"]">
                    @for (int i = 0; i < 10; i++)
                    {
                        <CarouselItem>
                            <PersonRole Skeleton="true" />
                        </CarouselItem>
                    }
                </Carousel>
            </MudItem>
        </MudGrid>
    </div>
}
else
{
    @if (_movie != null)
    {
        <div class="hero-page-stack">
            <MudStack Class="pa-10" Style="height: 100%;" AlignItems="AlignItems.Start" Justify="Justify.FlexEnd">
                <div class="background-image" style="--background-picture: url(@apiClient.GetAbsoluteUri(apiClient.GetAbsoluteUri(_movie.Pictures?.FirstOrDefault(x => x.Type == Server.Domain.Enums.MetadataPictureType.Backdrop)?.GetUri(Server.Domain.Enums.MetadataPictureSize.Medium)?.OriginalString)?.AbsoluteUri)?.AbsoluteUri)" />
                @if (apiClient.GetAbsoluteUri(_movie.Pictures?.FirstOrDefault(x => x.Type == Server.Domain.Enums.MetadataPictureType.Logo)?.GetUri(Server.Domain.Enums.MetadataPictureSize.Medium)?.OriginalString)?.AbsoluteUri is string logoUri)
                {
                    <MudImage Style="max-width: 80vw;" Height="200" ObjectFit="ObjectFit.ScaleDown" Src="@logoUri"></MudImage>
                }
                else
                {
                    <MudText Typo="Typo.h2" Style="font-weight: 800; letter-spacing: -1px; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">@_movie.Title?.ToUpper()</MudText>  
                }
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
                    @if (@_movie.Ratings?.FirstOrDefault(x => x.Source == RatingSource.MetadataProvider)?.Value is double externalRating)
                    {
                        <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Star" Label="true" Color="Color.Primary" Variant="Variant.Filled" Style="font-weight: 700;">@externalRating.ToString("N1")</MudChip>
                    }
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        @foreach (var genre in _movie.Genres ?? [])
                        {
                            <MudChip T="string" Label="true" Variant="Variant.Text" Size="Size.Small" Style="opacity: 0.9; font-weight: 600;">@genre</MudChip>
                        }
                    </MudStack>
                    <MudText Typo="Typo.caption" Style="opacity: 0.4;">|</MudText>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        @if (_movie.ReleaseDate.HasValue)
                        {
                            <MudText Typo="Typo.body2" Style="opacity: 0.9; font-weight: 600;">@_movie.ReleaseDate.Value.Year</MudText>
                        }
                        @if (_movie.ReleaseDate.HasValue && _movie.IndexedFiles != null && _movie.IndexedFiles.Any() && _movie.IndexedFiles.First().FileMetadata is VideoFileMetadataDto)
                        {
                            <MudText Typo="Typo.body2" Style="opacity: 0.5;">&bull;</MudText>
                        }
                        @if (_movie.IndexedFiles != null && _movie.IndexedFiles.Any() && _movie.IndexedFiles.First().FileMetadata is VideoFileMetadataDto vMetaDuration)
                        {
                            <MudText Typo="Typo.body2" Style="opacity: 0.9; font-weight: 600;">@string.Format(S["DurationHoursMinutes"], (int)vMetaDuration.Duration.TotalHours, vMetaDuration.Duration.Minutes)</MudText>
                        }
                    </MudStack>
                </MudStack>
                
                @if (!string.IsNullOrWhiteSpace(_movie.TagLine))
                {
                    <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-style: italic; opacity: 0.8; font-weight: 500;">
                        "@_movie.TagLine"
                    </MudText>
                }

                <MudStack Class="py-3 overview-clickable" Style="max-width: 800px;" tabindex="0" @onclick="OpenSynopsisDialogAsync" @onkeydown="HandleOverviewKeyDown">
                    <MudText Typo="Typo.body1" Style="opacity: 0.85; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; font-size: 1.05rem;">
                        @_movie.Overview
                    </MudText>
                </MudStack>

                <MudStack Row="true" data-nav-row Class="mt-4" Spacing="3" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                    <MudButton Disabled="@(_movie.IndexedFiles == null || !_movie.IndexedFiles.Any())" 
                               Variant="Variant.Filled" 
                               StartIcon="@Icons.Material.Filled.PlayArrow" 
                               Color="Color.Primary" 
                               Size="Size.Large"
                               DropShadow="false"
                               Style="border-radius: 8px; font-weight: 800; padding: 10px 32px; letter-spacing: 0.5px;"
                               OnClick="PlayAsync">@S["Play"]</MudButton>   
                               
                    <MudIconButton Icon="@Icons.Material.Filled.Tune" aria-label="playback-options" OnClick="OpenPlaybackOptionsAsync"></MudIconButton>
                    <MudIconButton Icon="@Icons.Material.Filled.LocalMovies" aria-label="trailer"></MudIconButton>
                    
                    <AuthorizeView Roles="User,Administrator">
                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircleOutline" aria-label="mark-as-shown"></MudIconButton>
                    </AuthorizeView>

                    <MudMenu Icon="@Icons.Material.Filled.MoreHoriz" aria-label="more-actions" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" ListClass="pa-2">
                        <AuthorizeView Roles="Administrator">
                            <MudMenuItem Icon="@Icons.Material.Filled.FindReplace" OnClick="OpenMediaReIdentifyDialogAsync">@L["ReIdentify"]</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Refresh" OnClick="RefreshMetadataAsync">@L["RefreshMetadata"]</MudMenuItem>
                        </AuthorizeView>
                        <MudMenuItem Icon="@Icons.Material.Filled.FolderZip" OnClick="OpenIndexedFilesDialogAsync">@L["IndexedVersions"]</MudMenuItem>
                    </MudMenu>
                </MudStack>
                <MudIcon Style="position: absolute; left: 50%; top: 90vh;" Size="Size.Medium" Icon="@Icons.Material.Filled.KeyboardArrowDown" />
            </MudStack>
        </div>
        <div>
            <MudGrid Justify="Justify.SpaceEvenly" Style="max-width:100%;" Spacing="0">
                <MudItem xs="12" sm="12" lg="12">
                    <Carousel Title="@L["CastingAndCrew"]">
                        @foreach (var cast in (_movie.PersonRoles ?? []).Where(x => x.Person != null).OrderBy(x => x.Order == null).ThenBy(x => x.Order))
                        {
                            <CarouselItem @key="cast.Id">
                                <PersonRole LitePersonRoleDto="@cast" />
                            </CarouselItem>
                        }
                    </Carousel>
                </MudItem>
            </MudGrid>
        </div>
    }
}
