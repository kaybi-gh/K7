@page "/movies/{id}"
@using K7.Shared.Dtos.Entities.PersonRoles
@using K7.Shared.Dtos.Entities.Metadatas.Files;
@using Microsoft.AspNetCore.Components.Authorization
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject IPlayerService PlayerService
@inject IDeviceStorageService DeviceStorageService
@inject PlaybackProgressTracker PlaybackProgressTracker
@inject IFeatureAccessService FeatureAccess
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IStringLocalizer<Movie> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@_movie?.Title</PageTitle>
<MudBreakpointProvider OnBreakpointChanged="ScreenResized" />

@if (isLoading)
{
    <div class="hero-page-stack">
        <MudStack Class="pa-10" Style="height: 100%;" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd">
            <MudSkeleton Animation="Animation.Wave" Height="150px" Width="300px" />
            
            <MudStack Row="true">
                <MudSkeleton Animation="Animation.Wave" Height="30px" Width="80px" />
                <MudSkeleton Animation="Animation.Wave" Height="30px" Width="80px" />
                <MudSkeleton Animation="Animation.Wave" Height="30px" Width="80px" />
            </MudStack>
            
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="50px" />
                <MudText>|</MudText>
                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="100px" />
            </MudStack>
            
            <MudStack Class="pa-10" AlignItems="AlignItems.Center">
                <MudSkeleton Animation="Animation.Wave" Height="30px" Width="100px" />
                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="600px" />
                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="500px" />
                <MudSkeleton Animation="Animation.Wave" Height="20px" Width="550px" />
            </MudStack>
            
            <MudStack Row="true">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Animation="Animation.Wave" Height="36px" Width="100px" />
                <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="40px" Width="40px" />
                <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="40px" Width="40px" />
                <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="40px" Width="40px" />
                <MudSkeleton SkeletonType="SkeletonType.Circle" Animation="Animation.Wave" Height="40px" Width="40px" />
            </MudStack>
            <MudIcon Style="position: absolute; left: 50%; top: 90vh;" Size="Size.Medium" Icon="@Icons.Material.Filled.KeyboardArrowDown" />
        </MudStack>
    </div>
    <div>
        <MudStack AlignItems="AlignItems.Center" Class="px-10">
            <MudStack Style="width: 100%;">
                <MudSkeleton Animation="Animation.Wave" Height="50px" Width="100%" />
                <MudSkeleton Animation="Animation.Wave" Height="50px" Width="100%" />
            </MudStack>
        </MudStack>
        <MudGrid Justify="Justify.SpaceEvenly" Style="max-width:100%;" Spacing="0" Class="mt-6">
            <MudItem xs="12" sm="12" lg="12">
                <Carousel Skeleton="true" Title="@L["CastingAndCrew"]">
                    @for (int i = 0; i < 10; i++)
                    {
                        <CarouselItem>
                            <PersonRole Skeleton="true" />
                        </CarouselItem>
                    }
                </Carousel>
            </MudItem>
        </MudGrid>
    </div>
}
else
{
    @if (_movie != null)
    {
        <div class="hero-page-stack">
            <MudStack Class="pa-10" Style="height: 100%;" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd">
                <div class="background-image" style="--background-picture: url(@apiClient.GetAbsoluteUri(apiClient.GetAbsoluteUri(_movie.Pictures?.FirstOrDefault(x => x.Type == Server.Domain.Enums.MetadataPictureType.Backdrop)?.GetUri(Server.Domain.Enums.MetadataPictureSize.Medium)?.OriginalString)?.AbsoluteUri)?.AbsoluteUri)" />
                @if (apiClient.GetAbsoluteUri(_movie.Pictures?.FirstOrDefault(x => x.Type == Server.Domain.Enums.MetadataPictureType.Logo)?.GetUri(Server.Domain.Enums.MetadataPictureSize.Small)?.OriginalString)?.AbsoluteUri is string logoUri)
                {
                    <MudImage Style="max-width: 80vw;" Height="150" ObjectFit="ObjectFit.ScaleDown" Src="@logoUri"></MudImage>
                }
                else
                {
                    <MudText Typo="Typo.h4">@_movie.Title</MudText>
                }
                <MudStack Row="true">
                    @foreach (var genre in _movie.Genres ?? [])
                    {
                        <MudChip T="string" Label="true" Variant="Variant.Outlined" Size="Size.Small">@genre</MudChip>
                    }
                </MudStack>
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    @if (_movie.ReleaseDate.HasValue)
                    {
                        <MudText Style="font-size: 20px;" Typo="Typo.overline">@_movie.ReleaseDate.Value.Year</MudText>
                        <MudText>|</MudText>
                    }
                    @if (_movie.IndexedFiles != null && _movie.IndexedFiles.Any() && _movie.IndexedFiles.First().FileMetadata is VideoFileMetadataDto vMetaDuration)
                    {
                        <MudText Style="font-size: 20px; text-wrap: nowrap;" Typo="Typo.overline">@string.Format(S["DurationHoursMinutes"], (int)vMetaDuration.Duration.TotalHours, vMetaDuration.Duration.Minutes)</MudText>
                    }
                </MudStack>
                <MudStack>
                    <MudText Typo="Typo.body2">@_movie.Overview</MudText>
                </MudStack>
                @*<MudText Style="font-style: italic; font-size: 20px; font-family: initial;">
                “@_movie.TagLine”
            </MudText>*@
                @*<MudStack Row="true">
                <MudRating SelectedValue="@Convert.ToInt32(_movie.Ratings?.FirstOrDefault(x => x.Source == Server.Domain.Enums.RatingSource.MetadataProvider)?.Value ?? 0)" />
            </MudStack>*@
                <MudStack Row="true" data-nav-row>
                    <MudButton Disabled="@(_movie.IndexedFiles == null || !_movie.IndexedFiles.Any())" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PlayArrow" Color="Color.Primary" OnClick="PlayAsync">@S["Play"]</MudButton>
                    <MudIconButton Icon="@Icons.Material.Filled.LocalMovies" aria-label="trailer"></MudIconButton>
                    <AuthorizeView Roles="User,Administrator">
                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" aria-label="mark-as-shown"></MudIconButton>
                    </AuthorizeView>
                    <AuthorizeView Roles="Administrator">
                        <MudIconButton Icon="@Icons.Material.Filled.FindReplace" title="@L["ReIdentify"]" aria-label="re-identify" OnClick="OpenMediaReIdentifyDialogAsync"></MudIconButton>
                        <MudIconButton Icon="@Icons.Material.Filled.Settings" aria-label="settings"></MudIconButton>
                    </AuthorizeView>
                    <MudIconButton Icon="@Icons.Material.Filled.MoreHoriz" aria-label="more-actions"></MudIconButton>
                </MudStack>
                <MudIcon Style="position: absolute; left: 50%; top: 90vh;" Size="Size.Medium" Icon="@Icons.Material.Filled.KeyboardArrowDown" />
            </MudStack>
        </div>
        <div>
            @if (_movie.IndexedFiles != null && _movie.IndexedFiles.Any() && _movie.IndexedFiles.First().FileMetadata is VideoFileMetadataDto vMetaTracks)
            {
                <MudStack AlignItems="@(_isSmallDevice? AlignItems.Center: AlignItems.Start)" Class="px-10">
                    <MudStack Style="width: 100%;">
                        <MudSelect @bind-Value="_selectedVideoFileTrack" Label="@L["VideoTrack"]" Variant="Variant.Filled" FullWidth="true">
                            @foreach (var track in vMetaTracks.VideoTracks ?? [])
                            {
                                <MudSelectItem Value="@track">@($"{track.Codec} - {track.Width}x{track.Height}")</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect @bind-Value="_selectedAudioFileTrack" Label="@L["AudioTrack"]" Variant="Variant.Filled" FullWidth="true">
                            @foreach (var track in vMetaTracks.AudioTracks ?? [])
                            {
                                <MudSelectItem Value="@track">@($"{track.Language} - {track.Name} - {track.Codec} {track.ChannelLayout}")</MudSelectItem>
                            }
                        </MudSelect>
                    </MudStack>
                </MudStack>
            }
            <MudGrid Justify="Justify.SpaceEvenly" Style="max-width:100%;" Spacing="0">
                <MudItem xs="12" sm="12" lg="12">
                    <Carousel Title="@L["CastingAndCrew"]">
                        @foreach (var cast in (_movie.PersonRoles ?? []).Where(x => x.Person != null).OrderBy(x => x.Order == null).ThenBy(x => x.Order))
                        {
                            <CarouselItem @key="cast.Id">
                                <PersonRole LitePersonRoleDto="@cast" />
                            </CarouselItem>
                        }
                    </Carousel>
                </MudItem>
            </MudGrid>

            <MudStack Class="pa-10">
                <MudText Typo="Typo.h6">@L["IndexedVersions"]</MudText>
                <MudGrid>
                    @foreach (var file in _movie.IndexedFiles ?? [])
                    {
                        var vMeta = file.FileMetadata as VideoFileMetadataDto;
                        <MudItem @key="file.Id" xs="12" sm="6">
                            <MudPaper Class="pa-4" Outlined="true">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudStack Spacing="0" Style="overflow: hidden;">
                                        <MudText Typo="Typo.body1" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@file.Name">@file.Name</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@file.Path">@file.Path</MudText>
                                        @if (vMeta != null)
                                        {
                                            <MudText Typo="Typo.caption">
                                                @($"{vMeta.VideoResolution} | {string.Format(S["DurationHoursMinutes"], (int)vMeta.Duration.TotalHours, vMeta.Duration.Minutes)} | {file.Size / (1024 * 1024):N0} MB")
                                            </MudText>
                                        }
                                    </MudStack>
                                    <MudIconButton Icon="@Icons.Material.Filled.FindReplace" title="@L["ReIdentifyFile"]" OnClick="@(() => OpenFileReIdentifyDialogAsync(file.Id))" />
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudStack>
        </div>
    }
}
