@implements IDisposable
@using K7.Shared.Dtos.Entities
@using K7.Server.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager
@inject SidebarService SidebarService
@inject ICustomAuthenticationStateProvider CustomAuthenticationStateProvider
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILibraryService K7ServerService
@inject IDeviceService DeviceService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Sidebar> L

<MudDrawer @bind-Open="@SidebarService.IsOpen" Fixed="true" Elevation="0" Breakpoint="Breakpoint.Xs" Variant="DrawerVariant.Mini" data-nav-column="sidebar">
    <MudStack AlignItems="AlignItems.Center">
        <MudToggleIconButton @bind-Toggled="@SidebarService.IsOpen"
            Icon="@Icons.Material.Filled.Menu" title="@(SidebarService.IsOpen ? "Off" : "On")"
            ToggledIcon="@Icons.Material.Filled.Close" />
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-4">
            <MudIcon Color="Color.Primary" Size="Size.Large" Icon="@Icons.Material.TwoTone.Cyclone" />
            @if (SidebarService.IsOpen)
            {
                <MudText Color="Color.Primary" Typo="Typo.h6">K7</MudText>
            }
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center">
            @if (SidebarService.IsOpen)
            {
                <MudTextField Class="sidebar-search-bar mx-4" UnderLine="false" Label="@L["Search"]" DebounceInterval="500" OnDebounceIntervalElapsed="Search" @bind-Value="@_debouncedText" Variant="Variant.Filled" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" />
            }
            else
            {
                <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.Search" />
            }
        </MudStack>
    </MudStack>
    <MudNavMenu Bordered="true" Style="width: 100%;">
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">@L["Home"]</MudNavLink>
        @foreach (var library in _libraries)
        {
            <MudNavLink @key="library.Id" Href="@($"/library/{library.Id}")" Match="NavLinkMatch.All" Icon="@GetLibraryIcon(library.MediaType)">@library.Title</MudNavLink>
        }
        <MudNavGroup Title="@L["Music"]" Icon="@Icons.Material.Filled.MusicNote" Expanded="false">
            <MudNavLink Href="/music/artists" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Person">@L["Artists"]</MudNavLink>
            <MudNavLink Href="/music/albums" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Album">@L["Albums"]</MudNavLink>
            <MudNavLink Href="/music/tracks" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AudioFile">@L["Tracks"]</MudNavLink>
            <AuthorizeView Roles="User,Administrator">
                <MudNavLink Href="/playlists" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.QueueMusic">@L["Playlists"]</MudNavLink>
            </AuthorizeView>
            <MudNavLink Href="/music/radio" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Radio">@L["Radio"]</MudNavLink>
            <AuthorizeView Roles="User,Administrator">
                <MudNavLink Href="/music/stats" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.BarChart">@L["Stats"]</MudNavLink>
            </AuthorizeView>

        </MudNavGroup>
    </MudNavMenu>
    <MudSpacer />
    <MudNavMenu Bordered="true" Style="width: 100%;">
        <AuthorizeView>
            <MudNavLink Href="/settings" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Settings">@L["Settings"]</MudNavLink>
        </AuthorizeView>
        <AuthorizeView Roles="Administrator">
            <MudNavLink Href="/admin" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AdminPanelSettings">@L["Admin"]</MudNavLink>
        </AuthorizeView>
    </MudNavMenu>

    <AuthorizeView>
        <Authorized>
            @if (!SidebarService.IsOpen)
            {
                <MudStack Justify="Justify.SpaceAround" AlignItems="AlignItems.Center" Class="py-4">
                    <MudBadge Dot="true" Color="@_badgeColor" Overlap="true" Bordered="true" BadgeClass="connection-badge" title="@_badgeTitle">
                        <MudAvatar Color="Color.Primary">K</MudAvatar>
                    </MudBadge>
                </MudStack>
            }
            else
            {
                <MudPaper Class="px-8 py-4 ma-4">
                    <MudStack Row="true">
                        <MudBadge Dot="true" Color="@_badgeColor" Overlap="true" Bordered="true" BadgeClass="connection-badge" title="@_badgeTitle">
                            <MudAvatar Color="Color.Primary">K</MudAvatar>
                        </MudBadge>
                        <MudStack Justify="Justify.Center" Spacing="0">
                            <MudText Typo="Typo.body1">@context.User.Identity?.Name</MudText>
                            <MudStack Row="true" Spacing="1">
                                @if (DeviceService.GetClientType() != ClientType.Web)
                                {
                                    <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.SwitchAccount" OnClick="SwitchUser" title="@L["SwitchUser"]" />
                                }
                                <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.Logout" OnClick="Logout" title="@L["Logout"]" />
                            </MudStack>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
        </Authorized>
        <NotAuthorized>
            <MudStack Justify="Justify.SpaceAround" AlignItems="AlignItems.Center" Class="py-4">
                <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.Login" OnClick="Login" />
            </MudStack>
        </NotAuthorized>
    </AuthorizeView>
    
</MudDrawer>