@implements IDisposable
@using K7.Shared.Dtos.Entities
@using K7.Server.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager
@inject SidebarService SidebarService
@inject ICustomAuthenticationStateProvider CustomAuthenticationStateProvider
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILibraryService K7ServerService
@inject IDeviceService DeviceService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Sidebar> L

<aside class="sidebar @(SidebarService.IsOpen ? "open" : "")" data-nav-column="sidebar">
    <div class="sidebar-header">
        <button class="sidebar-toggle btn-icon" @onclick="ToggleSidebar" title="@(SidebarService.IsOpen ? L["Collapse"] : L["Expand"])">
            <K7Icon Name="@(SidebarService.IsOpen ? "x" : "list")" />
        </button>
        <a href="/" class="sidebar-logo">
            <K7Icon Name="hurricane" Size="K7IconSize.Large" />
            <span class="sidebar-logo-text">K7</span>
        </a>
        @if (SidebarService.IsOpen)
        {
            <div class="sidebar-search px-2" style="width:100%">
                <input class="sidebar-search-input"
                       type="search"
                       placeholder="@L["Search"]"
                       value="@_debouncedText"
                       @oninput="OnSearchInput" />
            </div>
        }
        else
        {
            <button class="btn-icon btn-icon--accent" @onclick="OpenSearch" title="@L["Search"]">
                <K7Icon Name="magnifying-glass" />
            </button>
        }
    </div>

    <nav class="sidebar-nav">
        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
            <span class="nav-icon"><K7Icon Name="house" /></span>
            <span class="nav-label">@L["Home"]</span>
        </NavLink>
        @foreach (var library in _libraries)
        {
            <NavLink @key="library.Id" class="nav-link" href="@($"/library/{library.Id}")" Match="NavLinkMatch.All">
                <span class="nav-icon"><K7Icon Name="@GetLibraryIcon(library.MediaType)" /></span>
                <span class="nav-label">@library.Title</span>
            </NavLink>
        }

        <details class="nav-group">
            <summary class="nav-group-toggle">
                <span class="nav-icon"><K7Icon Name="music-notes" /></span>
                <span class="nav-label">@L["Music"]</span>
                <K7Icon Name="caret-down" class="nav-group-arrow" />
            </summary>
            <div class="nav-group-items">
                <NavLink class="nav-link" href="/music/artists" Match="NavLinkMatch.All">
                    <span class="nav-icon"><K7Icon Name="user" /></span>
                    <span class="nav-label">@L["Artists"]</span>
                </NavLink>
                <NavLink class="nav-link" href="/music/albums" Match="NavLinkMatch.All">
                    <span class="nav-icon"><K7Icon Name="vinyl-record" /></span>
                    <span class="nav-label">@L["Albums"]</span>
                </NavLink>
                <NavLink class="nav-link" href="/music/tracks" Match="NavLinkMatch.All">
                    <span class="nav-icon"><K7Icon Name="music-note" /></span>
                    <span class="nav-label">@L["Tracks"]</span>
                </NavLink>
                <AuthorizeView Roles="User,Administrator">
                    <NavLink class="nav-link" href="/playlists" Match="NavLinkMatch.All">
                        <span class="nav-icon"><K7Icon Name="queue" /></span>
                        <span class="nav-label">@L["Playlists"]</span>
                    </NavLink>
                </AuthorizeView>
                <NavLink class="nav-link" href="/music/radio" Match="NavLinkMatch.All">
                    <span class="nav-icon"><K7Icon Name="radio" /></span>
                    <span class="nav-label">@L["Radio"]</span>
                </NavLink>
                <AuthorizeView Roles="User,Administrator">
                    <NavLink class="nav-link" href="/music/stats" Match="NavLinkMatch.All">
                        <span class="nav-icon"><K7Icon Name="chart-bar" /></span>
                        <span class="nav-label">@L["Stats"]</span>
                    </NavLink>
                </AuthorizeView>
            </div>
        </details>
    </nav>

    <nav class="sidebar-nav" style="flex: none">
        <AuthorizeView>
            <NavLink class="nav-link" href="/settings" Match="NavLinkMatch.All">
                <span class="nav-icon"><K7Icon Name="gear" /></span>
                <span class="nav-label">@L["Settings"]</span>
            </NavLink>
        </AuthorizeView>
        <AuthorizeView Roles="Administrator">
            <NavLink class="nav-link" href="/admin" Match="NavLinkMatch.All">
                <span class="nav-icon"><K7Icon Name="shield-check" /></span>
                <span class="nav-label">@L["Admin"]</span>
            </NavLink>
        </AuthorizeView>
    </nav>

    <div class="sidebar-footer">
        <AuthorizeView>
            <Authorized>
                <div class="sidebar-user">
                    <div class="avatar" title="@context.User.Identity?.Name">
                        @(context.User.Identity?.Name?[0].ToString().ToUpperInvariant() ?? "?")
                        <span class="connection-badge connection-badge--@_badgeClass" title="@_badgeTitle"></span>
                    </div>
                    <div class="sidebar-user-info">
                        <p class="sidebar-user-name">@context.User.Identity?.Name</p>
                        <div class="sidebar-user-actions">
                            @if (DeviceService.GetClientType() != ClientType.Web)
                            {
                                <button class="btn-icon btn-icon--accent" @onclick="SwitchUser" title="@L["SwitchUser"]">
                                    <K7Icon Name="user-switch" />
                                </button>
                            }
                            <button class="btn-icon" @onclick="Logout" title="@L["Logout"]">
                                <K7Icon Name="sign-out" />
                            </button>
                        </div>
                    </div>
                </div>
            </Authorized>
            <NotAuthorized>
                <button class="btn-icon btn-icon--accent" @onclick="Login" title="@L["Login"]">
                    <K7Icon Name="sign-in" />
                </button>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</aside>