@page "/series/{SerieId}/seasons/{SeasonNumber:int}"
@using K7.Shared.Dtos.Entities.Medias
@using K7.Shared.Dtos.Entities.PersonRoles
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject IFederationService FederationService
@inject NavigationManager NavigationManager
@inject IPlayerService PlayerService
@inject PlaybackProgressTracker PlaybackProgressTracker
@inject IFeatureAccessService FeatureAccess
@inject IDeviceService DeviceService
@inject IStringLocalizer<SerieSeason> L
@inject IStringLocalizer<SharedResource> S
@inject IJSRuntime JSRuntime
@inject IK7DialogService DialogService
@inject MediaCacheStore CacheStore
@inject IK7Snackbar Snackbar
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>@_pageTitle</PageTitle>

@if (_loading)
{
    <div class="d-flex flex-col pa-16">
        <K7Spinner />
    </div>
}
else if (_season is not null && _isTv)
{
    <div @ref="_seasonTvRoot" class="season-tv @(HasDisplayableCast ? "season-tv--scrollable" : "")" data-tv-scroll>
        <MediaPageBackdrop ImageUrl="@(_previousStillUrl ?? _backdropUrl)"
                           SecondaryImageUrl="@(_focusedStillUrl ?? _backdropUrl)"
                           SecondaryImageKey="@_focusedStillUrl"
                           DominantColor="@_dominantColor"
                           ScrollTarget="@_seasonTvRoot" />

        <div class="season-tv-main" data-tv-scroll-zone="main">
            <div class="tv-hero">
                <div class="tv-back-button">
                    <K7Button StartIcon="@Phosphor.ArrowLeft"
                               Color="secondary"
                               Variant="filled"
                               Href="@($"/series/{SerieId}")">
                        @L["BackToSerie"]
                    </K7Button>
                </div>

                <div class="tv-details">
                    <K7Image Class="tv-logo"
                             ObjectFit="scale-down"
                             Src="@_logoUrl"
                             Alt="">
                        <FallbackContent>
                            <h3 class="media-logo-title">@_season.SerieTitle?.ToUpper()</h3>
                        </FallbackContent>
                    </K7Image>

                    <div class="tv-episode-info">
                        @if (_focusedEpisode is not null)
                        {
                            <span class="tv-episode-label">
                                @string.Format(L["EpisodeNumber"], _focusedEpisode.EpisodeNumber)
                            </span>
                            <h3 class="tv-episode-title">@_focusedEpisode.Title</h3>

                            @if (_focusedEpisode.ReleaseDate is not null)
                            {
                                <span class="tv-episode-date text-sm">@_focusedEpisode.ReleaseDate.Value.ToString("d MMMM yyyy")</span>
                            }

                            <div class="tv-episode-overview overview-clickable focusable" tabindex="0" role="button" @onclick="OpenSynopsisDialogAsync">
                                <p>@(_focusedEpisode.Overview ?? "")</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="tv-carousel-area" data-tv-scroll-zone="episodes">
                <h2 class="tv-season-title">@(_season.SeasonNumber == 0 ? L["Specials"] : string.Format(L["SeasonNumber"], _season.SeasonNumber))</h2>
                <Carousel @ref="_tvCarousel" Title="@L["EpisodeList"]">
                    @foreach (var episode in _episodes)
                    {
                        var ep = episode;
                        <div class="carousel-item"
                             data-carousel-item
                             @key="ep.Id"
                             @onfocusin="() => OnTvEpisodeFocus(ep)"
                             @onclick="() => PlayEpisodeAsync(ep)"
                             @onclick:preventDefault="true"
                             @onkeydown="e => OnTvEpisodeKeyDown(e, ep)"
                             id="ep-@ep.EpisodeNumber">
                            <MediaCard Model="@(new MediaCardViewModel
                                       {
                                           Id = ep.Id.ToString(),
                                           Kind = MediaCardKind.Episode,
                                           Title = ep.Title,
                                           AdditionalInformations = string.Format(L["EpisodeNumber"], ep.EpisodeNumber),
                                           PictureUrl = GetEpisodeStillUrl(ep),
                                           Progress = ep.UserState?.ProgressPercentage ?? 0,
                                           Watched = ep.UserState?.IsCompleted ?? false,
                                       })"
                                       Variant="MediaCardVariant.Backdrop"
                                       FooterVisible="true"
                                       ProgressEnabled="true"
                                       OverlayEnabled="true"
                                       WatchedStatusEnabled="true" />
                        </div>
                    }
                </Carousel>
            </div>

            @if (HasDisplayableCast)
            {
                <div class="season-tv-scroll-hint">
                    <K7Icon Icon="@Phosphor.CaretDown" />
                </div>
            }
        </div>

        @if (HasDisplayableCast)
        {
            <div class="season-tv-page-content" data-tv-scroll-zone="below">
                <Carousel Title="@L["CastingAndCrew"]">
                    @foreach (var cast in _focusedEpisodeDisplayableCast)
                    {
                        <CarouselItem @key="cast.Key">
                            <PersonRole LitePersonRoleDto="@cast.PrimaryRole" SubtitleOverride="@cast.MergedSubtitle" />
                        </CarouselItem>
                    }
                </Carousel>
            </div>
        }
    </div>
}
else if (_season is not null)
{
    <MediaPageContent Class="season-detail-wash"
                      FullWash="true"
                      DominantColor="@_dominantColor"
                      Tinted="@(_dominantColor is not null)">
        <div class="season-detail-page">
            <K7BackButton />

            <div class="season-header">
                <div class="season-header-info">
                    <K7Image Class="season-logo"
                             ObjectFit="scale-down"
                             Src="@_logoUrl"
                             Alt="">
                        <FallbackContent>
                            <h3 class="media-logo-title">@_season.SerieTitle</h3>
                        </FallbackContent>
                    </K7Image>

                    <div class="season-title-row">
                        <div class="season-title-group">
                            <h4 class="season-title">
                                @(_season.SeasonNumber == 0 ? L["Specials"] : string.Format(L["SeasonNumber"], _season.SeasonNumber))
                            </h4>

                            @if (_allSeasonNumbers.Count > 1)
                            {
                                <K7Menu Title="@L["ChooseSeason"]">
                                    <ActivatorContent>
                                        <K7IconButton Icon="@Phosphor.CaretDown" AriaLabel="@L["ChooseSeason"]" Size="sm" />
                                    </ActivatorContent>
                                    <ChildContent>
                                        @foreach (var sn in _allSeasonNumbers)
                                        {
                                            var seasonNum = sn;
                                            <K7MenuItem Icon="@(seasonNum == SeasonNumber ? "check" : "")"
                                                        OnClick="() => GoToSeason(seasonNum)">
                                                @(seasonNum == 0 ? L["Specials"] : string.Format(L["SeasonNumber"], seasonNum))
                                            </K7MenuItem>
                                        }
                                    </ChildContent>
                                </K7Menu>
                            }
                        </div>

                        @if (_canRate)
                        {
                            <div class="season-user-rating" @onclick:stopPropagation="true">
                                <RatingStars MediaId="_season.Id" Value="_seasonUserRating" Size="md" />
                            </div>
                        }

                        <div class="season-actions">
                        <DownloadAllButton Items="GetDownloadRequests()" Size="sm" />

                        <AuthorizeView Roles="User,Administrator">
                            <K7Menu>
                                <ActivatorContent>
                                    <K7IconButton Icon="@Phosphor.CheckCircle" AriaLabel="mark-season-watched" Size="sm" />
                                </ActivatorContent>
                                <ChildContent>
                                    <K7MenuItem Icon="check-circle" OnClick="MarkSeasonWatchedAsync">@L["MarkSeasonWatched"]</K7MenuItem>
                                    <K7MenuItem Icon="circle" OnClick="MarkSeasonUnwatchedAsync">@L["MarkSeasonUnwatched"]</K7MenuItem>
                                </ChildContent>
                            </K7Menu>
                        </AuthorizeView>

                        <AuthorizeView Roles="Administrator">
                            <K7Menu>
                                <ActivatorContent>
                                    <K7IconButton Icon="@Phosphor.DotsThreeVertical" AriaLabel="more-actions" />
                                </ActivatorContent>
                                <ChildContent>
                                    <K7MenuItem Icon="television" OnClick="NavigateToSerie">@L["BackToSerie"]</K7MenuItem>
                                    <K7MenuItem Icon="pencil-simple" OnClick="OpenEditMetadataDialogAsync">@L["EditMetadata"]</K7MenuItem>
                                    @if (!_isFederated)
                                    {
                                        <K7MenuItem Icon="waveform" OnClick="DetectIntrosOutrosAsync">@L["DetectIntrosOutros"]</K7MenuItem>
                                    }
                                </ChildContent>
                            </K7Menu>
                        </AuthorizeView>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_season.Overview))
                    {
                        <p class="season-overview overview-clickable focusable"
                           tabindex="0"
                           role="button"
                           @onclick="OpenSeasonOverviewDialogAsync">
                            @_season.Overview
                        </p>
                    }
                </div>
            </div>

            <div class="season-episodes">
                @foreach (var episode in _episodes)
                {
                    <div id="ep-@episode.EpisodeNumber">
                        <EpisodeListItem @key="episode.Id"
                                         Episode="episode"
                                         StillUrl="@GetEpisodeStillUrl(episode)"
                                         Href="@($"/series/{SerieId}/seasons/{SeasonNumber}/episodes/{episode.EpisodeNumber}")"
                                         OnPlay="PlayEpisodeAsync"
                                         OnWatchStateChanged="OnEpisodeWatchStateChangedAsync" />
                    </div>
                }
            </div>
        </div>
    </MediaPageContent>
}
