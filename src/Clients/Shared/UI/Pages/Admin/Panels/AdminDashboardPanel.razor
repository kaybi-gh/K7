@page "/admin/dashboard"
@layout AdminLayout
@inject IStringLocalizer<AdminDashboardPanel> L
@implements IDisposable

<div class="admin-dashboard">
    <div class="dashboard-header">
        <h5>@L["Title"]</h5>
    </div>

    <div class="dashboard-kpis">
        <NavLink href="/admin/users" class="dashboard-kpi dashboard-kpi--link focusable">
            <K7Paper Outlined="true" Class="dashboard-kpi__inner">
                <span class="text-overline">@L["OnlineUsersKpi"]</span>
                <h3 class="dashboard-kpi__value">@OnlineUsersCount</h3>
            </K7Paper>
        </NavLink>
        <NavLink href="/admin/diagnostics" class="dashboard-kpi dashboard-kpi--link focusable">
            <K7Paper Outlined="true" Class="dashboard-kpi__inner">
                <span class="text-overline">@L["DiagnosticsKpi"]</span>
                <div class="dashboard-kpi__severity-counts" aria-label="@L["DiagnosticsKpi"]">
                    <span class="dashboard-kpi__severity-count dashboard-kpi__value--error">@_errorCount</span>
                    <span class="dashboard-kpi__severity-separator" aria-hidden="true">/</span>
                    <span class="dashboard-kpi__severity-count dashboard-kpi__value--warning">@_warningCount</span>
                    <span class="dashboard-kpi__severity-separator" aria-hidden="true">/</span>
                    <span class="dashboard-kpi__severity-count dashboard-kpi__value--info">@_infoCount</span>
                </div>
            </K7Paper>
        </NavLink>
        <NavLink href="/admin/background-tasks" class="dashboard-kpi dashboard-kpi--link focusable">
            <K7Paper Outlined="true" Class="dashboard-kpi__inner">
                <span class="text-overline">@L["BackgroundTasksKpi"]</span>
                <h3 class="dashboard-kpi__value">@_runningTaskCount</h3>
            </K7Paper>
        </NavLink>
    </div>

    <AdminActiveStreamsSection />

    <ServerHealthCharts Snapshots="_metricSnapshots" />

    <DashboardDiskVolumesSection Volumes="DiskVolumes" />
</div>
