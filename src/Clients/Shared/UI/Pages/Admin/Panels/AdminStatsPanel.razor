@page "/admin/stats"
@layout AdminLayout
@inject IServerInfoService K7ServerService
@inject IUserAdminService UserAdminService
@inject IStringLocalizer<AdminStatsPanel> L

<div class="d-flex pa-4" style="width: 100%; flex-wrap: wrap; gap: 8px;">
    <h5 class="mr-4">@L["Title"]</h5>

    <K7Select TValue="Guid?" Value="_selectedUserId" ValueChanged="OnUserChanged" Label="@L["User"]" Clearable="true"
              ToStringFunc="@(id => id is null ? L["AllUsers"] : _users.FirstOrDefault(u => u.Id == id)?.DisplayName ?? L["AllUsers"])"
              Style="min-width: 200px; max-width: 300px;">
        @foreach (var user in _users)
        {
            <K7SelectItem TValue="Guid?" Value="@user.Id">@(user.DisplayName ?? user.UserName ?? user.Email)</K7SelectItem>
        }
    </K7Select>

    <div class="d-flex">
        <K7Chip Value="@("week")" Variant="@(_selectedPeriod == "week" ? "filled" : "outlined")" Color="primary" OnClick="@(() => OnPeriodChanged("week"))">@L["Week"]</K7Chip>
        <K7Chip Value="@("month")" Variant="@(_selectedPeriod == "month" ? "filled" : "outlined")" Color="primary" OnClick="@(() => OnPeriodChanged("month"))">@L["Month"]</K7Chip>
        <K7Chip Value="@("year")" Variant="@(_selectedPeriod == "year" ? "filled" : "outlined")" Color="primary" OnClick="@(() => OnPeriodChanged("year"))">@L["Year"]</K7Chip>
        <K7Chip Value="@("all")" Variant="@(_selectedPeriod == "all" ? "filled" : "outlined")" Color="primary" OnClick="@(() => OnPeriodChanged("all"))">@L["AllTime"]</K7Chip>
    </div>

    <div class="d-flex">
        <K7Chip Value="@("")" Variant="@(_selectedMediaType == "" ? "filled" : "outlined")" Color="primary" OnClick="@(() => OnMediaTypeChanged(""))">@L["All"]</K7Chip>
        <K7Chip Value="@("3")" Variant="@(_selectedMediaType == "3" ? "filled" : "outlined")" Color="primary" OnClick="@(() => OnMediaTypeChanged("3"))">@L["Music"]</K7Chip>
        <K7Chip Value="@("1")" Variant="@(_selectedMediaType == "1" ? "filled" : "outlined")" Color="primary" OnClick="@(() => OnMediaTypeChanged("1"))">@L["Movies"]</K7Chip>
        <K7Chip Value="@("5")" Variant="@(_selectedMediaType == "5" ? "filled" : "outlined")" Color="primary" OnClick="@(() => OnMediaTypeChanged("5"))">@L["TVShows"]</K7Chip>
    </div>
</div>

@if (_loading)
{
    <div class="d-flex flex-col pa-16">
        <K7Spinner />
    </div>
}
else if (_stats is null)
{
    <div class="d-flex flex-col pa-16">
        <K7Icon Name="chart-bar" Style="font-size: 64px; opacity: 0.3;" />
        <h6 Color="default" Style="opacity: 0.5;">@L["NoData"]</h6>
    </div>
}
else
{
    <div class="pa-4">
        <div class="grid">
            <div>
                <div class="surface pa-4">
                    <div class="d-flex flex-col">
                        <K7Icon Name="timer" Size="lg" Color="primary" />
                        <h4 Color="primary">@_stats.TotalWatchTimeHours h</h4>
                        <p class="text-sm" Color="secondary">@L["WatchTime"]</p>
                    </div>
                </div>
            </div>
            <div>
                <div class="surface pa-4">
                    <div class="d-flex flex-col">
                        <K7Icon Name="play-circle" Size="lg" Color="primary" />
                        <h4 Color="primary">@_stats.TotalPlays</h4>
                        <p class="text-sm" Color="secondary">@L["TotalPlays"]</p>
                    </div>
                </div>
            </div>
            <div>
                <div class="surface pa-4">
                    <div class="d-flex flex-col">
                        <K7Icon Name="music-notes" Size="lg" Color="primary" />
                        <h4 Color="primary">@_stats.UniqueItemsPlayed</h4>
                        <p class="text-sm" Color="secondary">@L["UniqueItems"]</p>
                    </div>
                </div>
            </div>
        </div>

        @if (_playsOverTimeData.Count > 1)
        {
            <div class="surface pa-4 mb-6">
                <h6>@L["PlaysOverTime"]</h6>
                <ApexChart TItem="ChartDataPoint" Options="_areaChartOptions" Height="180">
                    <ApexPointSeries TItem="ChartDataPoint"
                                     Items="_playsOverTimeData"
                                     SeriesType="SeriesType.Area"
                                     XValue="@(p => p.Label)"
                                     YValue="@(p => p.Value)" />
                </ApexChart>
            </div>
        }

        <div class="grid">
            @if (_hourData.Count > 0)
            {
                <div>
                    <div class="surface pa-4">
                        <h6>@L["ByHourOfDay"]</h6>
                        <ApexChart TItem="ChartDataPoint" Options="_barChartOptions" Height="200">
                            <ApexPointSeries TItem="ChartDataPoint"
                                             Items="_hourData"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(p => p.Label)"
                                             YValue="@(p => p.Value)" />
                        </ApexChart>
                    </div>
                </div>
            }
            @if (_dowData.Count > 0)
            {
                <div>
                    <div class="surface pa-4">
                        <h6>@L["ByDayOfWeek"]</h6>
                        <ApexChart TItem="ChartDataPoint" Options="_barChartOptions" Height="200">
                            <ApexPointSeries TItem="ChartDataPoint"
                                             Items="_dowData"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(p => p.Label)"
                                             YValue="@(p => p.Value)" />
                        </ApexChart>
                    </div>
                </div>
            }
        </div>

        <div class="grid">
            @if (_genreData.Count > 0)
            {
                <div>
                    <div class="surface pa-4">
                        <h6>@L["TopGenres"]</h6>
                        <ApexChart TItem="ChartDataPoint" Options="_donutChartOptions" Height="250">
                            <ApexPointSeries TItem="ChartDataPoint"
                                             Items="_genreData"
                                             SeriesType="SeriesType.Donut"
                                             XValue="@(p => p.Label)"
                                             YValue="@(p => p.Value)" />
                        </ApexChart>
                    </div>
                </div>
            }
            @if (_deviceData.Count > 0)
            {
                <div>
                    <div class="surface pa-4">
                        <h6>@L["TopDevices"]</h6>
                        <ApexChart TItem="ChartDataPoint" Options="_donutChartOptions" Height="250">
                            <ApexPointSeries TItem="ChartDataPoint"
                                             Items="_deviceData"
                                             SeriesType="SeriesType.Donut"
                                             XValue="@(p => p.Label)"
                                             YValue="@(p => p.Value)" />
                        </ApexChart>
                    </div>
                </div>
            }
        </div>

        <div class="grid">
            @if (_stats.TopItems.Count > 0)
            {
                <div>
                    <h6>@L["TopItems"]</h6>
                    <ul class="k7-list">
                        @foreach (var (item, index) in _stats.TopItems.Select((a, i) => (a, i)))
                        {
                            <li>
                                <div class="d-flex align-center">
                                    <p class="text-sm" Color="secondary" Style="min-width: 24px;">@(index + 1).</p>
                                    <span>@item.Name</span>
                                    <div class="flex-1"></div>
                                    <K7Chip Size="sm" Color="primary" Variant="outlined">@item.PlayCount</K7Chip>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }

            @if (_stats.TopArtists.Count > 0)
            {
                <div>
                    <h6>@L["TopArtists"]</h6>
                    <ul class="k7-list">
                        @foreach (var (artist, index) in _stats.TopArtists.Select((a, i) => (a, i)))
                        {
                            <li>
                                <div class="d-flex align-center">
                                    <p class="text-sm" Color="secondary" Style="min-width: 24px;">@(index + 1).</p>
                                    <span>@artist.Name</span>
                                    <div class="flex-1"></div>
                                    <K7Chip Size="sm" Color="primary" Variant="outlined">@artist.PlayCount</K7Chip>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }

            @if (_stats.TopAlbums.Count > 0)
            {
                <div>
                    <h6>@L["TopAlbums"]</h6>
                    <ul class="k7-list">
                        @foreach (var (album, index) in _stats.TopAlbums.Select((a, i) => (a, i)))
                        {
                            <li>
                                <div class="d-flex align-center">
                                    <p class="text-sm" Color="secondary" Style="min-width: 24px;">@(index + 1).</p>
                                    <span>@album.Name</span>
                                    <div class="flex-1"></div>
                                    <K7Chip Size="sm" Color="primary" Variant="outlined">@album.PlayCount</K7Chip>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }

            @if (_stats.TopShows.Count > 0)
            {
                <div>
                    <h6>@L["TopShows"]</h6>
                    <ul class="k7-list">
                        @foreach (var (show, index) in _stats.TopShows.Select((s, i) => (s, i)))
                        {
                            <li>
                                <div class="d-flex align-center">
                                    <p class="text-sm" Color="secondary" Style="min-width: 24px;">@(index + 1).</p>
                                    <span>@show.Name</span>
                                    <div class="flex-1"></div>
                                    <K7Chip Size="sm" Color="primary" Variant="outlined">@show.PlayCount</K7Chip>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>
}
