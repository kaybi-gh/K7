@page "/admin/restrictions"
@layout AdminLayout
@inject IStringLocalizer<AdminRestrictionsPanel> L
@inject IStringLocalizer<SharedResource> S

<div class="d-flex align-center justify-between mb-4">
    <h6>@L["Title"]</h6>
    <div class="d-flex">
        <K7Menu>
            <ActivatorContent>
                <K7Button Variant="outlined" Color="secondary" StartIcon="sparkle" EndIcon="caret-down">@L["CreateFromTemplate"]</K7Button>
            </ActivatorContent>
            <ChildContent>
                <K7MenuItem OnClick="@(() => CreateFromTemplate(Templates.ChildFriendly))">@L["TemplateChildFriendly"]</K7MenuItem>
                <K7MenuItem OnClick="@(() => CreateFromTemplate(Templates.Family12))">@L["TemplateFamily12"]</K7MenuItem>
                <K7MenuItem OnClick="@(() => CreateFromTemplate(Templates.Teen16))">@L["TemplateTeen16"]</K7MenuItem>
                <K7MenuItem OnClick="@(() => CreateFromTemplate(Templates.NoHorror))">@L["TemplateNoHorror"]</K7MenuItem>
            </ChildContent>
        </K7Menu>
        <K7Button StartIcon="@Phosphor.Plus" Variant="filled" Color="primary"
                   OnClick="OpenCreateDialog">@L["CreateProfile"]</K7Button>
    </div>
</div>

@if (_loading)
{
    <K7ProgressBar Indeterminate="true" />
}
else if (_profiles.Count == 0)
{
    <div class="surface pa-8 d-flex flex-column align-center">
        <K7Icon Name="prohibition" Size="lg" Color="secondary" />
        <h6 Color="secondary" class="mt-4">@L["Empty"]</h6>
        <p class="text-sm mt-2"  Color="secondary" >
            @L["EmptyDescription"]
        </p>
    </div>
}
else
{
    <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-4);">
        @foreach (var profile in _profiles)
        {
            <div>
                <div class="k7-card">
                    <div class="k7-card-header">
                        <div class="k7-card-header-content">
                            <h6>@profile.Name</h6>
                            @if (!string.IsNullOrEmpty(profile.Description))
                            {
                                <p class="text-sm" Color="secondary">@profile.Description</p>
                            }
                        </div>
                        <div class="k7-card-header-actions">
                            <button type="button" class="k7-icon-btn" @onclick="@(() => PreviewRestrictedMedias(profile))" aria-label="preview"><i class="ph ph-eye"></i></button>
                            <button type="button" class="k7-icon-btn" @onclick="@(() => OpenEditDialog(profile))" aria-label="edit"><i class="ph ph-pencil"></i></button>
                            <button type="button" class="k7-icon-btn" @onclick="@(() => ConfirmDelete(profile))" aria-label="delete"><i class="ph ph-trash"></i></button>
                        </div>
                    </div>
                    <div class="k7-card-content">
                        <div class="d-flex flex-col">
                            <span class="text-caption" Color="secondary">
                                @L["ConditionPrefix"] @(profile.MatchCondition == RestrictionMatchCondition.Any ? L["MatchAny"] : L["MatchAll"])
                            </span>
                            @foreach (var rule in profile.Rules)
                            {
                                <K7Chip Size="sm" Color="default">
                                    @FormatRule(rule)
                                </K7Chip>
                            }
                            <span class="text-caption mt-2">
                                <K7Icon Name="users" Size="sm" Class="mr-1" />
                                @string.Format(L["AttachedUsers"], profile.UserCount)
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
