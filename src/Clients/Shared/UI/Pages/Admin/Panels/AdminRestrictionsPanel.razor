@page "/admin/restrictions"
@layout AdminLayout
@using K7.Server.Domain.Enums
@using K7.Shared.Dtos.Restrictions
@using K7.Shared.Dtos.Rules
@inject IStringLocalizer<AdminRestrictionsPanel> L
@inject IStringLocalizer<SharedResource> S

<BrowseView TItem="ContentRestrictionProfileDto" Items="_profiles" Loading="_loading"
            DefaultItemWidth="280" DefaultSpacing="16"
            GridItemAspectRatio="0.7f" GridFooterHeight="60"
            SingleColumnOnMobile="true">
    <ToolbarContent>
        <h6>@L["Title"]</h6>
        <div style="flex:1"></div>
        <K7Menu>
            <ActivatorContent>
                <K7Button Variant="outlined" Color="secondary" StartIcon="sparkle" EndIcon="caret-down">@L["CreateFromTemplate"]</K7Button>
            </ActivatorContent>
            <ChildContent>
                <K7MenuItem OnClick="@(() => CreateFromTemplate(Templates.ChildFriendly))">@L["TemplateChildFriendly"]</K7MenuItem>
                <K7MenuItem OnClick="@(() => CreateFromTemplate(Templates.Family12))">@L["TemplateFamily12"]</K7MenuItem>
                <K7MenuItem OnClick="@(() => CreateFromTemplate(Templates.Teen16))">@L["TemplateTeen16"]</K7MenuItem>
                <K7MenuItem OnClick="@(() => CreateFromTemplate(Templates.NoHorror))">@L["TemplateNoHorror"]</K7MenuItem>
            </ChildContent>
        </K7Menu>
        <K7Button StartIcon="@Phosphor.Plus" Variant="filled" Color="primary"
                   OnClick="OpenCreateDialog">@L["CreateProfile"]</K7Button>
    </ToolbarContent>
    <EmptyContent>
        <div class="empty-state">
            <K7Icon Icon="@Phosphor.Prohibit" Style="font-size: 64px; opacity: 0.3;" />
            <h6 class="empty-state__title">@L["Empty"]</h6>
            <p class="empty-state__hint">@L["EmptyDescription"]</p>
        </div>
    </EmptyContent>
    <GridTemplate Context="profile">
        <K7Paper Outlined="true" Style="display:flex;flex-direction:column;gap:12px;height:100%">
            <div class="restriction-card__header">
                <K7Icon Icon="@Phosphor.Prohibit"  IconSize="@K7IconSize.Lg" Color="primary" />
                <div class="restriction-card__title">
                    <h6>@profile.Name</h6>
                    @if (!string.IsNullOrEmpty(profile.Description))
                    {
                        <span class="restriction-card__description">@profile.Description</span>
                    }
                </div>
            </div>
            <div class="restriction-card__rules">
                <span class="restriction-card__condition">
                    @L["ConditionPrefix"] @(profile.RuleFilter.MatchCondition == RuleMatchCondition.Any ? L["MatchAny"] : L["MatchAll"])
                </span>
                @foreach (var rule in profile.RuleFilter.Items.OfType<ConditionRuleItemDto>())
                {
                    <K7Chip Size="sm" Color="default">
                        @FormatRule(rule)
                    </K7Chip>
                }
            </div>
            <span class="restriction-card__users">
                <K7Icon Name="users"  IconSize="@K7IconSize.Sm" />
                @string.Format(L["AttachedUsers"], profile.UserCount)
            </span>
            <div class="restriction-card__actions">
                <K7IconButton Icon="@Phosphor.Eye" OnClick="@(() => PreviewRestrictedMedias(profile))" AriaLabel="preview" />
                <K7IconButton Icon="@Phosphor.Pencil" OnClick="@(() => OpenEditDialog(profile))" AriaLabel="edit" />
                <K7IconButton Icon="@Phosphor.Trash" OnClick="@(() => ConfirmDelete(profile))" AriaLabel="delete" />
            </div>
        </K7Paper>
    </GridTemplate>
</BrowseView>
