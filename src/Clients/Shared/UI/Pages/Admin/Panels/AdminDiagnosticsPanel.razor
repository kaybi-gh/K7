@page "/admin/diagnostics"
@layout AdminLayout
@using K7.Server.Domain.Enums
@using K7.Shared.Dtos.Diagnostics
@inject IStringLocalizer<AdminDiagnosticsPanel> L
@inject IStringLocalizer<SharedResource> S

<div class="full-bleed-page">
    <div class="data-page-toolbar diagnostics-toolbar">
        <div class="diagnostics-toolbar__row">
        <K7FilterMenu HasActiveFilters="@HasActiveFilters"
                      ActiveLabel="@GetActiveFiltersLabel()"
                      OnClear="ClearFiltersAsync">
            <K7FilterMenuRoot>
                <K7FilterMenuSection>
                    <div class="k7-filter-menu__section-label">@L["FilterSeverity"]</div>
                    <K7FilterMenuPick Label="@L["AllIssues"]" Selected="@(_selectedSeverity is null)" OnClick="@(() => OnSeverityFilterChanged(null))" />
                    <K7FilterMenuPick Label="@FormatFilterLabel(L["SeverityErrors"], _errorCount)" Selected="@(_selectedSeverity == "error")" OnClick="@(() => OnSeverityFilterChanged("error"))" />
                    <K7FilterMenuPick Label="@FormatFilterLabel(L["SeverityWarnings"], _warningCount)" Selected="@(_selectedSeverity == "warning")" OnClick="@(() => OnSeverityFilterChanged("warning"))" />
                    <K7FilterMenuPick Label="@FormatFilterLabel(L["SeverityInfo"], _infoCount)" Selected="@(_selectedSeverity == "info")" OnClick="@(() => OnSeverityFilterChanged("info"))" />
                    <hr class="k7-menu-divider" />
                </K7FilterMenuSection>
                <K7FilterMenuGroup SubmenuKey="library" Title="@L["FilterLibrary"]">
                    <ChildContent>
                        <K7FilterMenuNav SubmenuKey="library" Label="@GetLibraryMenuLabel()" />
                    </ChildContent>
                    <SubmenuContent>
                        <K7FilterMenuPick Label="@L["AllIssues"]" Selected="@(!_filterLibraryId.HasValue)" OnClick="@(() => OnLibraryFilterChanged(null))" />
                        @if (_summaries is not null)
                        {
                            @foreach (var lib in _summaries)
                            {
                                var libraryId = lib.LibraryId;
                                <K7FilterMenuPick Label="@FormatFilterLabel(lib.LibraryTitle, GetLibraryIssueCount(lib))" Selected="@(_filterLibraryId == libraryId)" OnClick="@(() => OnLibraryFilterChanged(libraryId))" />
                            }
                        }
                    </SubmenuContent>
                </K7FilterMenuGroup>
                <K7FilterMenuGroup SubmenuKey="entityType" Title="@L["FilterEntityType"]">
                    <ChildContent>
                        <K7FilterMenuNav SubmenuKey="entityType" Label="@GetEntityTypeMenuLabel()" />
                    </ChildContent>
                    <SubmenuContent>
                        <K7FilterMenuPick Label="@L["AllIssues"]" Selected="@(!_filterEntityType.HasValue)" OnClick="@(() => OnEntityTypeFilterChanged(null))" />
                        <K7FilterMenuPick Label="@FormatFilterLabel(L["EntityTypeMedia"], GetEntityTypeCount(DiagnosticEntityType.Media))" Selected="@(_filterEntityType == DiagnosticEntityType.Media)" OnClick="@(() => OnEntityTypeFilterChanged(DiagnosticEntityType.Media))" />
                        <K7FilterMenuPick Label="@FormatFilterLabel(L["EntityTypeIndexedFile"], GetEntityTypeCount(DiagnosticEntityType.IndexedFile))" Selected="@(_filterEntityType == DiagnosticEntityType.IndexedFile)" OnClick="@(() => OnEntityTypeFilterChanged(DiagnosticEntityType.IndexedFile))" />
                        <K7FilterMenuPick Label="@FormatFilterLabel(L["EntityTypeLibrary"], GetEntityTypeCount(DiagnosticEntityType.Library))" Selected="@(_filterEntityType == DiagnosticEntityType.Library)" OnClick="@(() => OnEntityTypeFilterChanged(DiagnosticEntityType.Library))" />
                    </SubmenuContent>
                </K7FilterMenuGroup>
                <K7FilterMenuGroup SubmenuKey="issue" Title="@L["FilterIssue"]">
                    <ChildContent>
                        <K7FilterMenuNav SubmenuKey="issue" Label="@GetIssueMenuLabel()" />
                    </ChildContent>
                    <SubmenuContent>
                        <K7FilterMenuPick Label="@L["AllIssues"]" Selected="@(!_filterIssue.HasValue)" OnClick="@(() => OnIssueFilterChanged(null))" />
                        @foreach (var issue in Enum.GetValues<DiagnosticIssue>())
                        {
                            var current = issue;
                            <K7FilterMenuPick Label="@FormatFilterLabel(GetIssueLabel(current), GetIssueCount(current))" Selected="@(_filterIssue == current)" OnClick="@(() => OnIssueFilterChanged(current))" />
                        }
                    </SubmenuContent>
                </K7FilterMenuGroup>
            </K7FilterMenuRoot>
        </K7FilterMenu>

        <div class="data-page-toolbar__end diagnostics-toolbar__end">
            <K7ResultCount Count="_totalCount" />
            @if (_filterIssue is not null && GetBulkFixAction() is not null && _totalCount > 0)
            {
                <K7Button Class="diagnostics-toolbar__bulk-fix" Size="sm" Variant="filled" Color="primary" StartIcon="@Phosphor.Wrench"
                          OnClick="QueueAllFixesAsync" Disabled="_isQueueingAllFixes">
                    @string.Format(L["QueueAllFixes"], _totalCount)
                </K7Button>
            }
            @if (_selectedItems.Count > 0 && GetBulkFixAction() is not null)
            {
                <K7Button Class="diagnostics-toolbar__bulk-fix" Size="sm" Variant="filled" Color="primary" StartIcon="@Phosphor.Wrench" OnClick="BulkFixAsync" Disabled="_isBulkFixing">
                    @string.Format(L["FixSelected"], _selectedItems.Count)
                </K7Button>
            }
            <K7IconButton Icon="@Phosphor.ArrowClockwise" Size="sm" OnClick="LoadAsync" AriaLabel="@L["Refresh"]" />
            <K7IconButton Icon="@Phosphor.Columns" OnClick="OnColumnPickerClick" AriaLabel="@S["ToggleColumns"]" />
        </div>
        </div>
    </div>

    <div class="data-page-body" aria-live="polite">
        @if (_isLoadingSummary)
        {
            <K7ProgressBar Indeterminate="true" />
        }
        else if (_summaries is null or { Count: 0 })
        {
            <p class="text-sm pa-4 text-center" style="color: var(--color-text-muted);">@L["NoData"]</p>
        }
        else
        {
            <K7DataTable @key="_tableKey" TItem="DiagnosticItemDto" ServerData="LoadServerDataAsync" @ref="_tableRef"
                         RowHeight="64" ShowToolbar="false" Surface="false" Height="100%">
                <K7DataColumn TItem="DiagnosticItemDto" Title="@L["ColName"]" Hideable="false">
                    <CellTemplate>
                        <div class="diagnostics-name-cell">
                            @if (context.MediaUrl is not null)
                            {
                                <a href="@context.MediaUrl" class="text-sm diagnostics-name-cell__title">@context.EntityName</a>
                            }
                            else
                            {
                                <span class="text-sm diagnostics-name-cell__title">@context.EntityName</span>
                            }
                            <span class="text-caption diagnostics-name-cell__meta" style="color: var(--color-text-muted);">
                                @(context.EntityType switch
                                {
                                    DiagnosticEntityType.Media => L["EntityTypeMedia"],
                                    DiagnosticEntityType.Library => L["EntityTypeLibrary"],
                                    _ => L["EntityTypeIndexedFile"]
                                })
                            </span>
                        </div>
                    </CellTemplate>
                </K7DataColumn>
                <K7DataColumn TItem="DiagnosticItemDto" Title="@L["ColLibrary"]" Property="@(i => i.LibraryTitle)" />
                <K7DataColumn TItem="DiagnosticItemDto" Title="@L["ColIssues"]">
                    <CellTemplate>
                        @{
                            var issue = context.Issues[0];
                        }
                        <span class="text-sm diagnostics-issues-cell" title="@GetIssueDetail(context, issue)" style="color: var(--color-@(GetIssueColor(issue)));">
                            @GetIssueLabel(issue)
                        </span>
                    </CellTemplate>
                </K7DataColumn>
                <K7DataColumn TItem="DiagnosticItemDto" Title="@L["ColActions"]" Width="128px" Hideable="false">
                    <CellTemplate>
                        @{
                            var issue = context.Issues[0];
                            var fixAction = GetFixActionForIssue(issue);
                            var showReIdentify = SupportsIndexedFileReIdentify(context, issue);
                        }
                        <div class="diagnostics-actions-cell">
                            @if (showReIdentify)
                            {
                                <K7IconButton Icon="@Phosphor.MagnifyingGlass" Size="sm"
                                              OnClick="@(() => OpenReIdentifyDialogAsync(context))"
                                              AriaLabel="@L["ActionReidentify"]" />
                            }
                            @if (fixAction is { } action)
                            {
                                <K7IconButton Icon="@GetFixActionIcon(action)" Size="sm"
                                              OnClick="@(() => FixItemAsync(context.EntityId, action))"
                                              AriaLabel="@GetFixActionLabel(action)" />
                            }
                            @if (context.MediaUrl is not null)
                            {
                                <K7IconButton Icon="@Phosphor.ArrowSquareOut" Size="sm" Href="@context.MediaUrl" AriaLabel="@L["GoToMedia"]" />
                            }
                        </div>
                    </CellTemplate>
                </K7DataColumn>
            </K7DataTable>
        }
    </div>
</div>
