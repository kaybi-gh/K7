@inject IStringLocalizer<AdminActiveStreamsPanel> L
@inject IServerInfoService K7ServerService
@implements IDisposable

<div class="d-flex pa-4" style="width: 100%">
    <h5>@L["Title"]</h5>
    <button type="button" class="k7-icon-btn" @onclick="FetchStreamsAsync" aria-label="@L["Title"]"><i class="ph ph-arrow-clockwise"></i></button>
</div>

@if (_loading)
{
    <div class="d-flex flex-col pa-16">
        <K7Spinner />
    </div>
}
else if (_streams is null || _streams.Count == 0)
{
    <div class="d-flex flex-col pa-16">
        <K7Icon Name="circle" Style="font-size: 64px; opacity: 0.3;" />
        <h6 Color="default" Style="opacity: 0.5;">@L["NoActiveStreams"]</h6>
    </div>
}
else
{
    <div class="pa-4">
        <K7Table Items="@_streams">
            <HeaderContent>
                <th>@L["User"]</th>
                <th>@L["Media"]</th>
                <th>@L["Device"]</th>
                <th>@L["Progress"]</th>
                <th>@L["StartedAt"]</th>
            </HeaderContent>
            <RowTemplate Context="stream">
                <td DataLabel="@L["User"]">@(stream.UserName ?? "-")</td>
                <td DataLabel="@L["Media"]">
                    @if (stream.MediaId.HasValue && GetMediaRoute(stream) is string route)
                    {
                        <a href="@route">@stream.MediaTitle</a>
                    }
                    else
                    {
                        @(stream.MediaTitle ?? "-")
                    }
                </td>
                <td DataLabel="@L["Device"]">@(stream.DeviceName ?? "-")</td>
                <td DataLabel="@L["Progress"]">
                    @if (stream.Duration > 0)
                    {
                        <K7ProgressBar Value="@(stream.Position / stream.Duration * 100)" />
                    }
                </td>
                <td DataLabel="@L["StartedAt"]">@stream.StartedAt.ToLocalTime().ToString("g")</td>
            </RowTemplate>
        </K7Table>
    </div>
}
