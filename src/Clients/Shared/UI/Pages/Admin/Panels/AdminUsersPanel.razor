@page "/admin/users"
@layout AdminLayout
@inject IStringLocalizer<AdminUsersPanel> L
@inject IStringLocalizer<SharedResource> S

<div class="d-flex align-center justify-between mb-4">
    <h6>@L["Title"]</h6>
    <K7Button Variant="filled" Color="primary" StartIcon="@Phosphor.UserPlus"
               OnClick="OpenCreateUserDialog" aria-label="@L["AriaCreateUser"]">
        @L["CreateUserTitle"]
    </K7Button>
</div>

@if (_isLoading)
{
    <K7ProgressBar Indeterminate="true" />
}
else if (_users.Count == 0)
{
    <div class="surface pa-8 d-flex flex-column align-center">
        <K7Icon Name="users" Size="lg" Color="secondary" />
        <h6 Color="secondary" class="mt-4">@L["Empty"]</h6>
    </div>
}
else
{
    <table class="k7-table k7-table--dense">
        <thead>
            <tr>
                <th>@L["HeaderUser"]</th>
                <th>@L["HeaderRole"]</th>
                <th>@L["HeaderActive"]</th>
                <th>@L["HeaderCreatedAt"]</th>
                <th style="width: 100px;">@L["HeaderActions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in _users)
            {
                <tr style="@(!user.IsActive ? "opacity: 0.5;" : "")">
                    <td>
                        <div class="d-flex flex-col">
                            <p>@(user.UserName ?? "-")</p>
                            <span class="text-caption" Color="secondary">@(user.Email ?? "-")</span>
                        </div>
                    </td>
                    <td>
                        @if (user.IsGuest)
                        {
                            <K7Chip Size="sm" Color="default">@S["Guest"]</K7Chip>
                        }
                        else
                        {
                            <K7Select TValue="string" Value="@user.Role" ValueChanged="@(role => OnRoleChanged(user, role))"
                                       Variant="outlined">
                                <K7SelectItem Value="@Roles.Administrator">@L["RoleAdministrator"]</K7SelectItem>
                                <K7SelectItem Value="@Roles.User">@L["RoleUser"]</K7SelectItem>
                            </K7Select>
                        }
                    </td>
                    <td>
                        <K7Switch Value="@user.IsActive"
                                   ValueChanged="@(v => OnToggleActive(user, v))" />
                    </td>
                    <td>@user.Created.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <div class="d-flex">
                            @if (!user.IsGuest)
                            {
                                <button type="button" class="k7-icon-btn" @onclick="@(() => OpenCapabilitiesDialog(user))" aria-label="@L["AriaCapabilities"]"><i class="ph ph-sliders"></i></button>
                            }
                            <button type="button" class="k7-icon-btn" @onclick="@(() => OpenLibraryExclusionsDialog(user))" aria-label="@L["AriaLibraries"]"><i class="ph ph-video-camera"></i></button>
                            <button type="button" class="k7-icon-btn" @onclick="@(() => OpenMediaExclusionsDialog(user))" aria-label="@L["AriaHiddenMedia"]"><i class="ph ph-eye-slash"></i></button>
                            <button type="button" class="k7-icon-btn" @onclick="@(() => OpenRestrictionProfileDialog(user))" aria-label="@L["AriaRestrictionProfile"]"><i class="ph ph-shield"></i></button>
                            @if (!user.IsGuest && user.Id != _currentUserId)
                            {
                                <button type="button" class="k7-icon-btn" @onclick="@(() => OpenResetPasswordDialog(user))" aria-label="@L["AriaResetPassword"]"><i class="ph ph-key"></i></button>
                                <button type="button" class="k7-icon-btn" @onclick="@(() => OpenMergeUserDialog(user))" aria-label="@L["AriaMerge"]"><i class="ph ph-git-merge"></i></button>
                                <button type="button" class="k7-icon-btn" @onclick="@(() => ConfirmDelete(user))" aria-label="@L["AriaDelete"]"><i class="ph ph-trash"></i></button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
