@page "/admin/background-tasks"
@layout AdminLayout
@using K7.Server.Domain.Enums
@implements IDisposable
@inject IStringLocalizer<AdminBackgroundTasksPanel> L
@inject IStringLocalizer<SharedResource> S

<div class="d-flex flex-col" style="gap: var(--space-4);">
    <div aria-live="polite">
        @if (_summary is not null)
        {
            <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: var(--space-2);">
                <div class="surface cursor-pointer summary-card focusable" tabindex="0" role="button" @onclick="@(() => OnStatusFilterChanged(null))">
                    <h5>@_summary.TotalCount</h5>
                    <span class="text-caption" style="color: var(--color-text-muted);">@L["FilterAll"]</span>
                </div>
                @foreach (var status in _allStatuses)
                {
                    var count = _summary.StatusCounts.FirstOrDefault(s => s.Status == status)?.Count ?? 0;
                    <div class="surface cursor-pointer summary-card focusable" tabindex="0" role="button" @onclick="@(() => OnStatusFilterChanged(status))">
                        <div class="d-flex align-center" style="gap: var(--space-2);">
                            <K7Icon Name="@GetStatusIcon(status)" Size="sm" />
                            <h5>@count</h5>
                        </div>
                        <span class="text-caption" style="color: var(--color-text-muted);">@GetStatusLabel(status)</span>
                    </div>
                }
            </div>
        }
    </div>

    <K7ExpansionPanel>
        <TitleContent>@L["SettingsTitle"]</TitleContent>
        <ChildContent>
            @if (_settings is not null)
            {
                <div class="d-flex flex-col" style="gap: var(--space-3);">
                    <K7TextField TValue="int" Type="number" @bind-Value="_workerCount" Label="@L["WorkerCountLabel"]" />

                    @if (_settings.ConcurrencyGroups.Count > 0)
                    {
                        <h6>@L["ConcurrencyGroupsTitle"]</h6>
                        @foreach (var group in _settings.ConcurrencyGroups)
                        {
                            var name = group.Name;
                            <div class="d-flex align-center" style="gap: var(--space-2);">
                                <span class="text-sm" style="min-width: 140px;">@name</span>
                                <K7TextField TValue="int" Type="number" Value="GetGroupLimit(name)"
                                             ValueChanged="@(v => SetGroupLimit(name, v))"
                                             Label="@L["GroupLimit"]" Style="max-width: 100px;" />
                                <span class="text-caption" style="color: var(--color-text-muted);">@L["GroupActive"]: @group.ActiveCount</span>
                            </div>
                        }
                    }

                    <div>
                        <K7Button OnClick="SaveSettingsAsync" Disabled="_isSavingSettings">@L["Save"]</K7Button>
                    </div>
                </div>
            }
        </ChildContent>
    </K7ExpansionPanel>

    <K7DataTable @key="_tableKey" TItem="BackgroundTaskDto" ServerData="LoadServerDataAsync" @ref="_tableRef" Height="60vh">
        <K7DataColumn TItem="BackgroundTaskDto" Title="@L["ColName"]" Hideable="false">
            <CellTemplate>
                <span class="text-sm">@GetTaskTypeLabel(context.Name)</span>
                @if (!string.IsNullOrEmpty(context.ErrorDetails))
                {
                    <p class="text-caption" style="color: var(--color-error);">@context.ErrorDetails</p>
                }
            </CellTemplate>
        </K7DataColumn>
        <K7DataColumn TItem="BackgroundTaskDto" Title="@L["ColStatus"]" Hideable="false">
            <CellTemplate>
                <div class="d-flex align-center" style="gap: var(--space-1);">
                    <K7Icon Name="@GetStatusIcon(context.Status)" Size="sm" Style="@GetStatusIconStyle(context.Status)" />
                    <span class="text-sm" style="@GetStatusTextStyle(context.Status)">@GetStatusLabel(context.Status)</span>
                </div>
            </CellTemplate>
        </K7DataColumn>
        <K7DataColumn TItem="BackgroundTaskDto" Title="@L["ColAttempts"]" Property="@(t => $"{t.AttemptCount} / {t.MaxAttempts}")" Width="100px" />
        <K7DataColumn TItem="BackgroundTaskDto" Title="@L["ColDate"]">
            <CellTemplate><span class="text-sm">@FormatRelativeTime(context.Created)</span></CellTemplate>
        </K7DataColumn>
        <K7DataColumn TItem="BackgroundTaskDto" Title="@L["ColDuration"]" Width="100px">
            <CellTemplate><span class="text-sm">@(context.Duration.HasValue ? FormatDuration(context.Duration.Value) : "-")</span></CellTemplate>
        </K7DataColumn>
        <K7DataColumn TItem="BackgroundTaskDto" Title="@L["ColGroup"]" Property="@(t => t.ConcurrencyGroup ?? "-")" />
        <K7DataColumn TItem="BackgroundTaskDto" Title="" Width="50px" Hideable="false">
            <CellTemplate>
                <K7IconButton Icon="@Phosphor.Info" OnClick="@(() => OpenDetailDialog(context))" AriaLabel="detail" />
            </CellTemplate>
        </K7DataColumn>
    </K7DataTable>
</div>