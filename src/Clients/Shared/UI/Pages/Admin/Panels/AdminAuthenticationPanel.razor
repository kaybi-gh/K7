@page "/admin/authentication"
@layout AdminLayout
@inject IStringLocalizer<AdminAuthenticationPanel> L
@inject IStringLocalizer<SharedResource> S

@if (_isLoading)
{
    <K7ProgressBar Indeterminate="true" />
}
else if (_authInfo is not null)
{
    <div class="d-flex flex-col pa-4">
        <K7Alert Severity="K7Severity.Info" Variant="outlined" NoIcon="true">
            @L["ConfigInfo"]
        </K7Alert>

        <h6>@L["LocalAuthTitle"]</h6>
        <table class="k7-table k7-table--dense">
            <tbody>
                <tr>
                    <td style="width: 300px;"><p class="text-sm">@L["LocalSignin"]</p></td>
                    <td>
                        <K7Chip Size="sm" Color="@(_authInfo.LocalSignInEnabled ? "success" : "default")">
                            @(_authInfo.LocalSignInEnabled ? S["EnabledFeminine"] : S["DisabledFeminine"])
                        </K7Chip>
                    </td>
                </tr>
                <tr>
                    <td><p class="text-sm">@L["LocalRegistration"]</p></td>
                    <td>
                        <K7Chip Size="sm" Color="@(_authInfo.LocalRegistrationEnabled ? "success" : "default")">
                            @(_authInfo.LocalRegistrationEnabled ? S["EnabledFeminine"] : S["DisabledFeminine"])
                        </K7Chip>
                    </td>
                </tr>
            </tbody>
        </table>

        <h6>@L["OidcTitle"]</h6>
        <table class="k7-table k7-table--dense">
            <tbody>
                <tr>
                    <td style="width: 300px;"><p class="text-sm">@L["Oidc"]</p></td>
                    <td>
                        <K7Chip Size="sm" Color="@(_authInfo.OidcEnabled ? "success" : "default")">
                            @(_authInfo.OidcEnabled ? S["Enabled"] : S["Disabled"])
                        </K7Chip>
                    </td>
                </tr>
                @if (_authInfo.OidcEnabled)
                {
                    <tr>
                        <td><p class="text-sm">@L["Provider"]</p></td>
                        <td><p class="text-sm">@_authInfo.OidcDisplayName</p></td>
                    </tr>
                    <tr>
                        <td><p class="text-sm">@L["AutoAccountCreation"]</p></td>
                        <td>
                            <K7Chip Size="sm" Color="@(_authInfo.OidcAutomaticAccountCreation ? "success" : "default")">
                                @(_authInfo.OidcAutomaticAccountCreation ? S["EnabledFeminine"] : S["DisabledFeminine"])
                            </K7Chip>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!_authInfo.LocalSignInEnabled && _authInfo.OidcEnabled)
        {
            <K7Alert Severity="K7Severity.Warning" Variant="outlined">
                @L["LocalSigninDisabledWarning"]
            </K7Alert>
        }
    </div>
}
