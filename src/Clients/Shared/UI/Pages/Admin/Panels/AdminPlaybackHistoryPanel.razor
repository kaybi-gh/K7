@page "/admin/playback-history"
@layout AdminLayout
@using K7.Clients.Shared.UI.Helpers
@inject IServerInfoService K7ServerService
@inject IUserAdminService UserAdminService
@inject IStringLocalizer<AdminPlaybackHistoryPanel> L
@inject IStringLocalizer<SharedResource> S

<div class="full-bleed-page">
    <div class="data-page-toolbar">
        <h5 class="data-page-toolbar__title">@L["Title"]</h5>

        <K7Select TValue="Guid?" Class="history-user-select data-toolbar-field"
                  Value="_selectedUserId" ValueChanged="OnUserChanged" Clearable="true"
                  ToStringFunc="@(id => id is null ? L["AllUsers"] : _users.FirstOrDefault(u => u.Id == id)?.DisplayName ?? _users.FirstOrDefault(u => u.Id == id)?.UserName ?? L["AllUsers"])"
                  FullWidth="false">
            @foreach (var user in _users)
            {
                var userLabel = user.DisplayName ?? user.UserName ?? user.Email;
                <K7SelectItem TValue="Guid?" Value="@user.Id" Text="@userLabel">@userLabel</K7SelectItem>
            }
        </K7Select>

        <K7ButtonGroup TValue="string" Options="_mediaTypeOptions" Value="_selectedMediaType" ValueChanged="OnMediaTypeChanged" AriaLabel="@L["MediaType"]" />

        <div class="data-page-toolbar__end">
            <K7ResultCount Count="_totalCount" />
            <K7IconButton Icon="@Phosphor.Columns" OnClick="OnColumnPickerClick" AriaLabel="@S["ToggleColumns"]" />
        </div>
    </div>

    <div class="data-page-body">
        <K7DataTable @key="_tableKey" TItem="PlaybackHistoryItemDto" ServerData="LoadServerDataAsync"
                     RowHeight="48" @ref="_tableRef" OnRowClick="OnRowClicked" ShowToolbar="false" Surface="false" Height="100%">
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Date"]" Width="140px">
                <CellTemplate>
                    <div class="history-date-cell">
                        <span>@context.StartedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                        <span class="text-muted">@context.StartedAt.ToLocalTime().ToString("HH:mm")</span>
                    </div>
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["User"]" Width="100px" VisibleOnMobile="false">
                <CellTemplate>
                    <div class="d-flex align-center" style="gap: var(--space-2);">
                        <K7Avatar Size="sm">@((context.UserName ?? "?")[..1].ToUpperInvariant())</K7Avatar>
                        <span class="text-sm">@(context.UserName ?? "-")</span>
                    </div>
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["SharedProfile"]" Width="120px" VisibleOnMobile="false">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.SharedProfileName))
                    {
                        <K7Chip Size="sm" Color="secondary" Variant="outlined">@context.SharedProfileName</K7Chip>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["MediaTitle"]" Hideable="false">
                <CellTemplate>
                    <LibraryTableMediaTitle ImageUrl="@context.ImageUrl"
                                            MediaType="@context.MediaType"
                                            Title="@(context.MediaTitle ?? "-")"
                                            Href="@context.MediaUrl"
                                            LinkClass="history-title"
                                            StopPropagation="true">
                        <span class="history-badge history-badge--@(context.IsCompleted ? "success" : "warning")">
                            @(context.IsCompleted ? L["Watched"] : L["Incomplete"])
                        </span>
                    </LibraryTableMediaTitle>
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Type"]" Width="110px" VisibleOnMobile="false">
                <CellTemplate>
                    <span class="text-sm">@MediaTypeLabelHelper.Format(context.MediaType, S)</span>
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Library"]" Width="130px" VisibleOnMobile="false">
                <CellTemplate>
                    <span class="text-sm">@(context.LibraryName ?? "-")</span>
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Device"]" Property="@(i => i.DeviceName ?? "-")" Width="140px" VisibleOnMobile="false" />
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Quality"]" Width="120px" VisibleOnMobile="false">
                <CellTemplate>
                    @if (context.StreamQuality is { } sq)
                    {
                        <span class="history-badge history-badge--@(sq.IsTranscode == true ? "transcode" : "direct")">
                            @(sq.IsTranscode == true ? L["Transcode"] : L["Direct"])
                        </span>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Subtitles"]" Width="130px" VisibleOnMobile="false">
                <CellTemplate>
                    @if (context.StreamQuality is { } sq && (sq.SubtitleTrackTitle is not null || sq.SubtitleTrackLanguage is not null))
                    {
                        <span class="text-sm">@FormatSubtitleLabel(sq)</span>
                    }
                    else
                    {
                        <span class="text-muted">@L["SubtitlesOff"]</span>
                    }
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Duration"]" Width="90px">
                <CellTemplate>@FormatDuration(context.TotalWatchedSeconds)</CellTemplate>
            </K7DataColumn>
        </K7DataTable>
    </div>

    @if (_selectedItem is not null)
    {
        <StreamDetailSidebar Model="BuildDetailModel(_selectedItem)" OnClose="CloseDetail" />
    }
</div>
