@page "/admin/library-groups"
@layout AdminLayout
@using K7.Shared.Dtos.Entities
@inject IStringLocalizer<AdminLibraryGroupsPanel> L
@inject IStringLocalizer<SharedResource> S

<BrowseView TItem="LibraryGroupDto"
            Items="_groups"
            Loading="_isLoading"
            DefaultItemWidth="320"
            DefaultSpacing="16"
            GridItemAspectRatio="null"
            PersistenceKey="admin-library-groups">
    <ToolbarContent>
        <h6>@L["Title"]</h6>
    </ToolbarContent>
    <GridTemplate Context="group">
        <K7Paper Outlined="true" Style="display:flex;flex-direction:column;gap:12px;height:100%">
            <div class="group-card__header">
                <div class="group-card__cover-placeholder">
                    <K7Icon Icon="@GetGroupIcon(group)" Size="lg" />
                </div>
                <div class="group-card__title">
                    <h6>@group.Title</h6>
                    <K7Chip Size="sm" Color="default">@GetMediaTypeLabel(group.MediaType)</K7Chip>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(group.Description))
            {
                <p class="group-card__description">@group.Description</p>
            }
            <div class="group-card__info">
                @{
                    var libraryTitles = GetLibraryTitles(group);
                }
                @foreach (var libraryTitle in libraryTitles)
                {
                    <span>@libraryTitle</span>
                }
                @if (libraryTitles.Count == 0)
                {
                    <span>@L["NoLibraries"]</span>
                }
            </div>
            <div style="flex:1"></div>
            <div class="group-card__actions">
                <K7Button Variant="text" Size="sm" StartIcon="@Phosphor.PencilSimple" OnClick="@(() => OpenEditDialog(group))">
                    @L["Edit"]
                </K7Button>
                <K7Button Variant="text" Size="sm" Color="error" StartIcon="@Phosphor.Trash" OnClick="@(() => ConfirmDelete(group))">
                    @S["Delete"]
                </K7Button>
            </div>
        </K7Paper>
    </GridTemplate>
</BrowseView>
