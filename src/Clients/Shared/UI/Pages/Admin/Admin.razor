@page "/admin"
@page "/admin/{Tab}"
@inject IStringLocalizer<Admin> L
@inject IStringLocalizer<SharedResource> S
@inject NavigationManager NavigationManager

<AuthorizeView Roles="Administrator">
    <Authorized>
        <PageTitle>@L["PageTitle"]</PageTitle>

        <MudText Typo="Typo.h4" Class="mb-4">@L["PageTitle"]</MudText>

        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true"
                 ActivePanelIndex="@_activePanelIndex" ActivePanelIndexChanged="OnActivePanelIndexChanged">
            <MudTabPanel Text="@L["TabGeneral"]" Icon="@Icons.Material.Filled.Settings">
                <AdminGeneralPanel />
            </MudTabPanel>

            <MudTabPanel Text="@L["TabLibraries"]" Icon="@Icons.Material.Filled.VideoLibrary">
                <AdminLibrariesPanel />
            </MudTabPanel>

            <MudTabPanel Text="@L["TabUsers"]" Icon="@Icons.Material.Filled.People">
                <AdminUsersPanel />
            </MudTabPanel>

            <MudTabPanel Text="@L["TabDevices"]" Icon="@Icons.Material.Filled.Devices">
                <AdminDevicesPanel />
            </MudTabPanel>

            <MudTabPanel Text="@L["TabRestrictions"]" Icon="@Icons.Material.Filled.Shield">
                <AdminRestrictionsPanel />
            </MudTabPanel>

            <MudTabPanel Text="@L["TabAuthentication"]" Icon="@Icons.Material.Filled.Security">
                <AdminAuthenticationPanel />
            </MudTabPanel>

            <MudTabPanel Text="@L["TabBackgroundTasks"]" Icon="@Icons.Material.Filled.Queue">
                <AdminBackgroundTasksPanel />
            </MudTabPanel>
        </MudTabs>
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="pa-16">
            <MudStack AlignItems="AlignItems.Center" Spacing="4">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Warning" />
                <MudText Typo="Typo.h5">@S["AccessDenied"]</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">@S["NoPermission"]</MudText>
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary">@S["GoToHome"]</MudButton>
            </MudStack>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>
