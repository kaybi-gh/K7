@using K7.Server.Domain.Enums
@inject IStringLocalizer<AdminUserCapabilitiesDialog> L
@inject IStringLocalizer<SharedResource> S

<div class="k7-dialog-content">
        <p class="exclusions__hint">
            @string.Format(L["RoleHint"], GetRoleLabel(Role))
        </p>
        <K7CheckboxList TItem="Capability"
                        Items="Enum.GetValues<Capability>()"
                        IsChecked="@(cap => Overrides.TryGetValue(cap, out var v) ? v : _defaultCaps.Contains(cap))"
                        CheckedChanged="@(e => SetOverride(e.Item, e.Checked, _defaultCaps.Contains(e.Item)))">
            <ItemTemplate Context="cap">
                <span class="exclusions__name">@GetCapabilityLabel(cap)</span>
                @if (Overrides.ContainsKey(cap))
                {
                    <K7IconButton Icon="@Phosphor.XCircle" OnClick="@(() => RemoveOverride(cap))" AriaLabel="@L["RemoveOverride"]" />
                }
            </ItemTemplate>
        </K7CheckboxList>
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">@S["Cancel"]</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="Submit">@S["Save"]</K7Button>
    </div>
