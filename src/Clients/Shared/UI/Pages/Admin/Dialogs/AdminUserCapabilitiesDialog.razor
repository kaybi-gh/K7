
<div class="k7-dialog-content">
        <p class="text-sm mb-3" Color="secondary">
            Rôle actuel : <strong>@GetRoleLabel(Role)</strong>. Les cases cochées par défaut sont héritées du rôle.
        </p>
        <div class="d-flex flex-col">
            @foreach (var capability in Enum.GetValues<Capability>())
            {
                var defaultEnabled = _defaultCaps.Contains(capability);
                var hasOverride = Overrides.ContainsKey(capability);
                var effectiveValue = hasOverride ? Overrides[capability] : defaultEnabled;

                <div class="d-flex align-center justify-between">
                    <p class="text-sm">@GetCapabilityLabel(capability)</p>
                    <div class="d-flex align-center">
                        @if (hasOverride)
                        {
                            <K7IconButton Icon="@Phosphor.XCircle" OnClick="@(() => RemoveOverride(capability))" AriaLabel="remove override" />
                        }
                        <K7Switch Value="@effectiveValue" ValueChanged="@(v => SetOverride(capability, v, defaultEnabled))" />
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">@S["Cancel"]</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="Submit">Enregistrer</K7Button>
    </div>
