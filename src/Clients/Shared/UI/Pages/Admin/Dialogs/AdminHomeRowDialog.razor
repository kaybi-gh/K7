<div class="k7-dialog-content">
    <div class="d-flex flex-col gap-3 mt-2">
        <K7TextField @bind-Value="_title" Label="Titre" Required="true" Variant="outlined" />
        <K7Switch @bind-Value="_continueWatching" Label="Reprise de lecture" />

        @if (!_continueWatching)
        {
            @if (Libraries.Count > 0)
            {
                <div>
                    <p class="text-sm mb-1">Biblioth&egrave;ques</p>
                    <K7CheckboxList TItem="LibraryDto"
                                      Items="Libraries"
                                      IsChecked="@(lib => _libraryIds.Contains(lib.Id))"
                                      CheckedChanged="@(e => ToggleLibrary(e.Item.Id, e.Checked))"
                                      ItemLabel="@(lib => lib.Title)" />
                </div>
            }

            <div>
                <p class="text-sm mb-1">Types de m&eacute;dia</p>
                <K7CheckboxList TItem="MediaType"
                                  Items="_availableMediaTypes"
                                  IsChecked="@(type => _mediaTypes.Contains(type))"
                                  CheckedChanged="@(e => ToggleMediaType(e.Item, e.Checked))"
                                  ItemLabel="@(GetMediaTypeLabel)" />
                <p class="text-xs mt-1" style="color: var(--color-text-secondary);">Laisser vide pour afficher tous les types.</p>
            </div>

            <div class="k7-field">
                <label class="k7-label">Tri</label>
                <select class="k7-select" @bind="_orderBy">
                    <option value="CreatedDesc">Ajout r&eacute;cent (d&eacute;croissant)</option>
                    <option value="CreatedAsc">Ajout ancien (croissant)</option>
                    <option value="TitleAsc">Titre (A-Z)</option>
                    <option value="TitleDesc">Titre (Z-A)</option>
                    <option value="ReleaseDateDesc">Date de sortie (r&eacute;cente)</option>
                    <option value="ReleaseDateAsc">Date de sortie (ancienne)</option>
                    <option value="LastInteractedDesc">R&eacute;cemment regard&eacute;</option>
                    <option value="PopularityDesc">Popularit&eacute;</option>
                    <option value="LocalRatingDesc">Mieux not&eacute;</option>
                    <option value="PlayCountDesc">Plus regard&eacute;</option>
                </select>
            </div>
        }

        <div class="k7-field">
            <label class="k7-label">Affichage</label>
            <select class="k7-select" @bind="_displayType">
                <option value="Carousel">Carrousel</option>
            </select>
        </div>

        <div class="k7-field">
            <label class="k7-label">Nombre d'&eacute;l&eacute;ments</label>
            <select class="k7-select" @bind="_pageSize">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>
    </div>
</div>
<div class="k7-dialog-actions">
    <K7Button OnClick="Cancel">Annuler</K7Button>
    <K7Button Color="primary" Variant="filled" OnClick="Submit"
              Disabled="@(string.IsNullOrWhiteSpace(_title))">
        Enregistrer
    </K7Button>
</div>
