
<div class="k7-dialog-content">
        @if (_loading)
        {
            <K7ProgressBar Indeterminate="true" />
        }
        else
        {
            <p class="text-sm mb-3" Color="secondary">
                Décochez les librairies auxquelles l'utilisateur ne doit pas avoir accès.
            </p>
            <div class="d-flex flex-col">
                @foreach (var library in _libraries)
                {
                    var excluded = _excludedIds.Contains(library.Id);
                    <div class="d-flex align-center justify-between">
                        <p class="text-sm">@library.Title</p>
                        <K7Switch Value="@(!excluded)" ValueChanged="@(v => ToggleExclusion(library.Id, !v))" />
                    </div>
                }
            </div>
        }
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">Annuler</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="Submit">Enregistrer</K7Button>
    </div>
