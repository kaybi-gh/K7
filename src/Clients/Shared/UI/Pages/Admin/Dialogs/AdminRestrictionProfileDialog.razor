
<div class="k7-dialog-content">
        <div class="d-flex flex-col">
            <K7TextField @bind-Value="Name" Label="Nom" Required="true" Variant="outlined" />
            <K7TextField @bind-Value="Description" Label="Description" Variant="outlined" Lines="2" />

            <K7Select TValue="RestrictionMatchCondition" @bind-Value="MatchCondition" Label="Condition"
                       Variant="outlined">
                <K7SelectItem Value="RestrictionMatchCondition.Any">Au moins une règle (OU)</K7SelectItem>
                <K7SelectItem Value="RestrictionMatchCondition.All">Toutes les règles (ET)</K7SelectItem>
            </K7Select>

            <p class="text-subtitle2 mt-2">Règles (contenu correspondant sera masqué)</p>

            @for (var i = 0; i < Rules.Count; i++)
            {
                var index = i;
                <div class="d-flex align-center">
                    <K7Select TValue="RestrictionField" Value="Rules[index].Field"
                               ValueChanged="@(v => OnFieldChanged(index, v))"
                               Label="Champ" Variant="outlined" Style="min-width: 140px;">
                        <K7SelectItem Value="RestrictionField.Genre">Genre</K7SelectItem>
                        <K7SelectItem Value="RestrictionField.ContentRating">Classification</K7SelectItem>
                        <K7SelectItem Value="RestrictionField.ReleaseYear">Année de sortie</K7SelectItem>
                    </K7Select>

                    <K7Select TValue="RestrictionOperator" @bind-Value="Rules[index].Operator"
                               Label="Opérateur" Variant="outlined" Style="min-width: 160px;">
                        @foreach (var op in GetOperatorsForField(Rules[index].Field))
                        {
                            <K7SelectItem Value="op">@FormatOperator(op)</K7SelectItem>
                        }
                    </K7Select>

                    @if (Rules[index].Operator is not RestrictionOperator.IsEmpty and not RestrictionOperator.IsNotEmpty)
                    {
                        <K7TextField @bind-Value="Rules[index].Value" Label="Valeur"
                                      Variant="outlined" />
                    }

                    <button type="button" class="k7-icon-btn" Name="x" Size="sm" Color="error"
                                   OnClick="@(() => Rules.RemoveAt(index))" ></button>
                </div>
            }

            <K7Button StartIcon="plus" Variant="text" Color="primary"
                       OnClick="AddRule" Class="align-self-start">
                Ajouter une règle
            </K7Button>
        </div>
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">Annuler</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(Name) || Rules.Count == 0 || _saving)">
            @if (_saving) { <K7Spinner Size="sm" /> }
            Enregistrer
        </K7Button>
    </div>
