@inject IStringLocalizer<CreateUserDialog> L
@inject IStringLocalizer<SharedResource> S

<div class="k7-dialog-content">
        <div class="d-flex flex-col mt-2">
            <K7TextField @bind-Value="_username" Label="@L["Username"]" Variant="outlined"
                          Required="true" RequiredError="@L["UsernameRequired"]" />
            <K7TextField @bind-Value="_password" Label="@L["Password"]" Variant="outlined"
                          Type="password" HelperText="@L["PasswordHelper"]" />
            <K7Select TValue="string" @bind-Value="_role" Label="@L["Role"]" Variant="outlined">
                <K7SelectItem Value="@("User")" Text="@S["RoleUser"]">@S["RoleUser"]</K7SelectItem>
                <K7SelectItem Value="@("Administrator")" Text="@S["RoleAdministrator"]">@S["RoleAdministrator"]</K7SelectItem>
            </K7Select>
        </div>
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">@L["Cancel"]</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_username) || _isSubmitting)">
            @if (_isSubmitting)
            {
                <K7Spinner Size="sm" />
            }
            @L["Create"]
        </K7Button>
    </div>
