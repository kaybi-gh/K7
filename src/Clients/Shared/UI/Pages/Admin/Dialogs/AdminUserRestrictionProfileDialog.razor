
<!--Profil de restriction-->
    <div class="k7-dialog-content">
        @if (_isLoading)
        {
            <K7ProgressBar Indeterminate="true" />
        }
        else
        {
            <K7Select TValue="Guid?" @bind-Value="_selectedProfileId" Label="Profil de restriction"
                       Variant="outlined" Clearable="true">
                @foreach (var profile in _profiles)
                {
                    <K7SelectItem TValue="Guid?" Value="@profile.Id">
                        @profile.Name
                        @if (!string.IsNullOrWhiteSpace(profile.Description))
                        {
                            <span class="text-caption" Color="secondary"> - @profile.Description</span>
                        }
                    </K7SelectItem>
                }
            </K7Select>
        }
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">Annuler</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="Submit" Disabled="_isLoading">Valider</K7Button>
    </div>
