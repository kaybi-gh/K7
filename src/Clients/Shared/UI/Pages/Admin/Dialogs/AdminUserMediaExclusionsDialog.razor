
<div class="k7-dialog-content">
        @if (_loading)
        {
            <K7ProgressBar Indeterminate="true" />
        }
        else if (_excludedMedias.Count == 0)
        {
            <p class="text-sm" Color="secondary">Aucun média masqué pour cet utilisateur.</p>
        }
        else
        {
            <p class="text-sm mb-3"  Color="secondary" >
                @_excludedMedias.Count média(s) masqué(s). Cliquez sur la croix pour rétablir l'accès.
            </p>
            <ul class="k7-list">
                @foreach (var media in _excludedMedias)
                {
                    <li>
                        
                            <div class="d-flex align-center justify-between">
                                <div class="d-flex align-center">
                                    @if (!string.IsNullOrEmpty(media.PosterUrl))
                                    {
                                        <K7Avatar Size="md">
                                            <K7Image Src="@media.PosterUrl" Alt="@media.Title" loading="lazy" />
                                        </K7Avatar>
                                    }
                                    else
                                    {
                                        <K7Avatar Size="md">
                                            <K7Icon Name="film-strip" />
                                        </K7Avatar>
                                    }
                                    <p class="text-sm">@(media.Title ?? media.Id.ToString())</p>
                                </div>
                                <button type="button" class="k7-icon-btn" Name="x" Size="sm" Color="error"
                                               OnClick="@(() => RemoveExclusion(media))" ></button>
                            </div>
                        
                    </li>
                }
            </ul>
        }
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">Annuler</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="Submit">Enregistrer</K7Button>
    </div>
