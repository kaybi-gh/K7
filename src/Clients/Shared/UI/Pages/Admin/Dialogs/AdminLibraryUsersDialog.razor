
<div class="k7-dialog-content">
        @if (_loading)
        {
            <K7ProgressBar Indeterminate="true" />
        }
        else if (_users.Count == 0)
        {
            <p class="text-sm" Color="secondary">Aucun utilisateur.</p>
        }
        else
        {
            <p class="text-sm mb-3" Color="secondary">
                Activez ou désactivez l'accès à cette librairie pour chaque utilisateur.
            </p>
            <div class="d-flex flex-col">
                @foreach (var user in _users)
                {
                    var hasAccess = !_excludedUserIds.Contains(user.Id);
                    <div class="d-flex align-center justify-between">
                        <div class="d-flex flex-col">
                            <div class="d-flex align-center gap-1">
                                <p class="text-sm">@(user.UserName ?? user.Email ?? "-")</p>
                                @if (IsSelfExcluded(user))
                                {
                                    <K7Chip Size="sm" Color="secondary" Variant="outlined">auto</K7Chip>
                                }
                            </div>
                            <span class="text-caption" Color="secondary">@user.Role</span>
                        </div>
                        <K7Switch Value="@hasAccess" ValueChanged="@(v => ToggleAccess(user.Id, v))" />
                    </div>
                }
            </div>
        }
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">Annuler</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="Submit" Disabled="_saving">
            @if (_saving) { <K7Spinner Size="sm" /> }
            Enregistrer
        </K7Button>
    </div>
