@inject IStringLocalizer<ResetPasswordDialog> L
@inject IStringLocalizer<SharedResource> S

<div class="k7-dialog-content">
        <div class="d-flex flex-col mt-2">
            <K7TextField @bind-Value="_newPassword" Label="@L["NewPassword"]" Variant="outlined"
                          Type="password" Required="true" RequiredError="@L["PasswordRequired"]" />
        </div>
    </div>
    <div class="k7-dialog-actions">
        <K7Button OnClick="Cancel">@L["Cancel"]</K7Button>
        <K7Button Color="primary" Variant="filled" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_newPassword) || _isSubmitting)">
            @if (_isSubmitting)
            {
                <K7Spinner Size="sm" />
            }
            @L["ResetPassword"]
        </K7Button>
    </div>
