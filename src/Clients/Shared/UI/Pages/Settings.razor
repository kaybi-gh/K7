@page "/settings"
@using System.Security.Claims
@inject ThemeService ThemeService
@inject IDeviceService DeviceService
@inject IUserAdminService K7ServerService
@inject IK7ServerService ApiClient
@inject IDialogService DialogService
@inject ILocalUserService LocalUserService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Settings> L
@inject IStringLocalizer<SharedResource> S
@inject IJSRuntime JSRuntime
@inject IDeviceStorageService DeviceStorageService
<PageTitle>@L["PageTitle"]</PageTitle>

<MudSwitch @bind-Value="@ThemeService.DarkModeEnabled" Color="Color.Primary" Class="ma-4" T="bool" Label="@L["DarkMode"]" />
<MudSelect T="ThemeWrapper" Label="@L["Theme"]" @bind-Value="@ThemeService.ThemeWrapper">
    @foreach (var themeWrapper in Themes.Collection)
    {
        <MudSelectItem Value="@themeWrapper">@themeWrapper?.Name</MudSelectItem>
    }
</MudSelect>

<MudSelect T="string" Label="@L["Language"]" Value="@_currentCulture" ValueChanged="OnCultureChanged">
    <MudSelectItem Value="@("fr")">Fran\u00e7ais</MudSelectItem>
    <MudSelectItem Value="@("en")">English</MudSelectItem>
</MudSelect>

<MudSelect T="string" Label="@L["NextEpisodeBehavior"]" Value="@_nextEpisodeBehavior" ValueChanged="OnNextEpisodeBehaviorChanged">
    <MudSelectItem Value="@("AutoPlay")">@L["NextEpisodeAutoPlay"]</MudSelectItem>
    <MudSelectItem Value="@("ButtonOnly")">@L["NextEpisodeButtonOnly"]</MudSelectItem>
    <MudSelectItem Value="@("Off")">@L["NextEpisodeOff"]</MudSelectItem>
</MudSelect>

@if (DeviceService.GetClientType() == Server.Domain.Enums.ClientType.Web)
{
    <MudTextField @bind-Value="@_backendUrl" Label="@L["ServerUrl"]" ReadOnly="true" Variant="Variant.Text" />
}
else
{
    <MudTextField @bind-Value="@_backendUrl" Label="@L["ServerUrl"]" ReadOnly="true" Variant="Variant.Text" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Delete" OnAdornmentClick="ChangeBackendUrl" />
}

<MudText>@L["FormFactor"]: @_deviceType</MudText>
<MudText>@L["Hdr"]: @_hdrSupport</MudText>

<MudDivider Class="my-4" />
<MudText Typo="Typo.h6" Class="mb-2">@L["Pin"]</MudText>
@if (_hasPin)
{
    <MudText Typo="Typo.body2" Class="mb-2">@L["PinSet"]</MudText>
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ChangePin">@L["ChangePin"]</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="RemovePin">@L["RemovePin"]</MudButton>
    </MudStack>
}
else
{
    <MudText Typo="Typo.body2" Class="mb-2">@L["PinNotSet"]</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SetPin">@L["SetPin"]</MudButton>
}
@if (_pinError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mt-2">@_pinError</MudAlert>
}
@if (_pinSuccess is not null)
{
    <MudAlert Severity="Severity.Success" Class="mt-2">@_pinSuccess</MudAlert>
}

<MudExpansionPanels>
    <MudExpansionPanel Text="@L["SupportedCodecs"]" MaxHeight="1000">
        <ul>
            @if (_supportedMediaFormats != null)
            {
                foreach (var supportedMediaFormat in _supportedMediaFormats)
                {
                    <li>@supportedMediaFormat.Id</li>
                }
            }
            else
            {
                <p>Loading...</p>
            }
        </ul>
    </MudExpansionPanel>
</MudExpansionPanels>
