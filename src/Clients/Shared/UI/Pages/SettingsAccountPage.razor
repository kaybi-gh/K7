@page "/settings/account"
@layout SettingsLayout
@using System.Security.Claims
@inject IUserAdminService UserService
@inject IK7ServerService ApiClient
@inject ILocalUserService LocalUserService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SettingsAccountPage> L
@inject IStringLocalizer<SharedResource> S
@inject IJSRuntime JSRuntime
@inject IK7DialogService DialogService

<PageTitle>@L["PageTitle"]</PageTitle>

<h4 class="mb-4">@L["PageTitle"]</h4>

<div class="pa-4">
    @* Avatar Section *@
    <section class="settings-section mb-4">
        <h6 class="mb-2">@L["Avatar"]</h6>
        <div class="d-flex align-center gap-3">
            <K7Avatar Image="@_avatarUrl" Letter="@_avatarLetter" Size="xl" Alt="@_displayName" />
            <div class="d-flex gap-2">
                <K7Button Variant="outlined" OnClick="UploadAvatar">@L["UploadAvatar"]</K7Button>
                @if (!string.IsNullOrEmpty(_avatarUrl))
                {
                    <K7Button Variant="text" Color="error" OnClick="RemoveAvatar">@L["RemoveAvatar"]</K7Button>
                }
            </div>
        </div>
        <InputFile @ref="_fileInput" OnChange="OnFileSelected" accept="image/*" style="display:none" />
        @if (_avatarError is not null)
        {
            <K7Alert Severity="K7Severity.Error" Class="mt-2">@_avatarError</K7Alert>
        }
    </section>

    <hr class="k7-divider my-4" />

    @* Display Name Section *@
    <section class="settings-section mb-4">
        <h6 class="mb-2">@L["DisplayName"]</h6>
        <K7TextField @bind-Value="@_displayName" Label="@L["DisplayName"]" MaxLength="50" />
        @if (_displayName != _originalDisplayName)
        {
            <K7Button Variant="outlined" OnClick="SaveDisplayName" Class="mt-2">@S["Save"]</K7Button>
        }
        @if (_profileSuccess is not null)
        {
            <K7Alert Severity="K7Severity.Success" Class="mt-2">@_profileSuccess</K7Alert>
        }
        @if (_profileError is not null)
        {
            <K7Alert Severity="K7Severity.Error" Class="mt-2">@_profileError</K7Alert>
        }
    </section>

    <hr class="k7-divider my-4" />

    @* Email Section *@
    @if (_email is not null && _hasPassword)
    {
        <section class="settings-section mb-4">
            <h6 class="mb-2">@L["Email"]</h6>
            <K7TextField @bind-Value="@_newEmail" Label="@L["Email"]" />
            @if (_newEmail != _email)
            {
                <K7TextField @bind-Value="@_emailPassword" Label="@L["CurrentPassword"]" Type="password" Class="mt-2" />
                <K7Button Variant="outlined" OnClick="SaveEmail" Class="mt-2">@S["Save"]</K7Button>
            }
            @if (_emailError is not null)
            {
                <K7Alert Severity="K7Severity.Error" Class="mt-2">@_emailError</K7Alert>
            }
            @if (_emailSuccess is not null)
            {
                <K7Alert Severity="K7Severity.Success" Class="mt-2">@_emailSuccess</K7Alert>
            }
        </section>

        <hr class="k7-divider my-4" />
    }

    @* Password Section *@
    <section class="settings-section mb-4">
        <h6 class="mb-2">@L["Password"]</h6>
        <p class="text-sm mb-2">@(_hasPassword ? L["PasswordSet"] : L["NoPasswordSet"])</p>
        <K7Button Variant="outlined" OnClick="OpenPasswordDialog">
            @(_hasPassword ? L["ChangePassword"] : L["SetPassword"])
        </K7Button>
        @if (_passwordError is not null)
        {
            <K7Alert Severity="K7Severity.Error" Class="mt-2">@_passwordError</K7Alert>
        }
        @if (_passwordSuccess is not null)
        {
            <K7Alert Severity="K7Severity.Success" Class="mt-2">@_passwordSuccess</K7Alert>
        }
    </section>

    <hr class="k7-divider my-4" />

    @* PIN Section *@
    <section class="settings-section mb-4">
        <h6 class="mb-2">@L["Pin"]</h6>
        @if (_hasPin)
        {
            <p class="text-sm mb-2">@L["PinSet"]</p>
            <div class="d-flex gap-2">
                <K7Button Variant="outlined" OnClick="ChangePin">@L["ChangePin"]</K7Button>
                <K7Button Variant="text" Color="error" OnClick="RemovePin">@L["RemovePin"]</K7Button>
            </div>
        }
        else
        {
            <p class="text-sm mb-2">@L["PinNotSet"]</p>
            <K7Button Variant="outlined" OnClick="SetPin">@L["SetPin"]</K7Button>
        }
        @if (_pinError is not null)
        {
            <K7Alert Severity="K7Severity.Error" Class="mt-2">@_pinError</K7Alert>
        }
        @if (_pinSuccess is not null)
        {
            <K7Alert Severity="K7Severity.Success" Class="mt-2">@_pinSuccess</K7Alert>
        }
    </section>

    <hr class="k7-divider my-4" />

    @* Language Section *@
    <section class="settings-section mb-4">
        <h6 class="mb-2">@L["Language"]</h6>
        <K7LanguageSelect Value="@_currentCulture" ValueChanged="OnCultureChanged" Label="@L["Language"]" Languages="SupportedLanguages.Interface" />
    </section>

    <hr class="k7-divider my-4" />

    @* Login Methods Section *@
    @if (_loginMethods is not null)
    {
        <section class="settings-section mb-4">
            <h6 class="mb-2">@L["LoginMethods"]</h6>
            @if (_loginMethods.ExternalLogins.Count > 0)
            {
                <ul class="login-methods-list">
                    @foreach (var login in _loginMethods.ExternalLogins)
                    {
                        <li class="d-flex align-center justify-space-between py-2">
                            <span>@(login.ProviderDisplayName ?? login.Provider)</span>
                            <K7Button Variant="text" Color="error" Size="small"
                                      Disabled="@(!login.CanUnlink)"
                                      OnClick="@(() => UnlinkLogin(login.Provider))">
                                @L["Unlink"]
                            </K7Button>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-sm text-muted">@L["NoExternalLogins"]</p>
            }
            @if (_loginMethodsError is not null)
            {
                <K7Alert Severity="K7Severity.Error" Class="mt-2">@_loginMethodsError</K7Alert>
            }
        </section>

        <hr class="k7-divider my-4" />
    }

    @* Danger Zone *@
    <section class="settings-section mb-4">
        <h6 class="mb-2 text-error">@L["DangerZone"]</h6>
        <p class="text-sm mb-2">@L["DeleteAccountWarning"]</p>
        <K7Button Variant="filled" Color="error" OnClick="DeleteAccount">@L["DeleteAccount"]</K7Button>
        @if (_deleteError is not null)
        {
            <K7Alert Severity="K7Severity.Error" Class="mt-2">@_deleteError</K7Alert>
        }
    </section>
</div>
