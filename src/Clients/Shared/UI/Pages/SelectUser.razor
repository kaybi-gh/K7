@page "/select-user"
@layout Layout.EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject IStringLocalizer<SelectUser> L

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="d-flex align-center justify-center" Style="min-height:80vh;">
    <MudStack Spacing="6" AlignItems="AlignItems.Center" Style="width:100%; max-width:700px;">
        <MudText Typo="Typo.h4">@L["PageTitle"]</MudText>

        @if (_loading)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-2" Style="width:100%;">
                @_error
            </MudAlert>
        }

        <MudGrid Justify="Justify.Center" Spacing="4" data-nav-grid="true">
            @foreach (var user in _users)
            {
                <MudItem @key="user.IdentityUserId">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2"
                              tabindex="0"
                              @onclick="() => SelectUserAsync(user)"
                              @onkeydown="(e) => OnUserKeyDown(e, user)"
                              Class="cursor-pointer pa-4 rounded-lg select-user-card"
                              Style="transition: background 0.15s; min-width: 120px;">
                        <MudAvatar Size="Size.Large" Color="Color.Primary"
                                   Style="width:80px; height:80px; font-size:2rem;">
                            @GetInitials(user.UserName)
                        </MudAvatar>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.Center">
                            <MudText Typo="Typo.body1" Align="Align.Center">@user.UserName</MudText>
                            @if (user.PinHash is not null)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Secondary" />
                            }
                        </MudStack>
                    </MudStack>
                </MudItem>
            }

            <MudItem>
                <MudStack AlignItems="AlignItems.Center" Spacing="2"
                          tabindex="0"
                          @onclick="AddUserAsync"
                          @onkeydown="OnAddUserKeyDown"
                          Class="cursor-pointer pa-4 rounded-lg select-user-card"
                          Style="transition: background 0.15s; min-width: 120px;">
                    <MudAvatar Size="Size.Large" Color="Color.Default"
                               Style="width:80px; height:80px; font-size:2rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Large" />
                    </MudAvatar>
                    <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">@L["AddServer"]</MudText>
                </MudStack>
            </MudItem>
        </MudGrid>

        @if (_users.Count > 0)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-4">
                <MudSwitch T="bool" Value="_singleUserMode" ValueChanged="OnSingleUserModeChanged"
                           Color="Color.Primary" Label="@L["SingleUserMode"]" />
            </MudStack>
        }
    </MudStack>
</MudContainer>
