@page "/select-user"
@layout Layout.EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject IStringLocalizer<SelectUser> L

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="container">
    <div class="d-flex flex-col" style="width:100%; max-width:700px;">
        <h4>@L["PageTitle"]</h4>

        @if (_loading)
        {
            <K7Spinner />
        }
        else if (_error is not null)
        {
            <K7Alert Severity="K7Severity.Error" Variant="filled" Class="mt-2" Style="width:100%;">
                @_error
            </K7Alert>
        }

        <div class="grid">
            @foreach (var user in _users)
            {
                <div>
                    <div class="d-flex flex-col cursor-pointer pa-4 rounded-lg select-user-card"
                         tabindex="0" role="button"
                         @onclick="() => SelectUserAsync(user)"
                         @onkeydown="(e) => OnUserKeyDown(e, user)"
                         style="min-width: 120px;">
                        <K7Avatar Size="lg" Color="primary"
                                   Style="width:80px; height:80px; font-size:2rem;">
                            @GetInitials(user.UserName)
                        </K7Avatar>
                        <div class="d-flex align-center">
                            <p>@user.UserName</p>
                            @if (user.PinHash is not null)
                            {
                                <K7Icon Name="lock" Size="sm" Color="secondary" />
                            }
                        </div>
                    </div>
                </div>
            }

            <div>
                <div class="d-flex flex-col cursor-pointer pa-4 rounded-lg select-user-card"
                     tabindex="0" role="button"
                     @onclick="AddUserAsync"
                     @onkeydown="OnAddUserKeyDown"
                     style="min-width: 120px;">
                    <K7Avatar Size="lg" Color="default"
                               Style="width:80px; height:80px; font-size:2rem;">
                        <K7Icon Name="plus" Size="lg" />
                    </K7Avatar>
                    <p>@L["AddServer"]</p>
                </div>
            </div>
        </div>

        @if (_users.Count > 0)
        {
            <div class="d-flex align-center mt-4">
                <K7Switch Value="_singleUserMode" ValueChanged="OnSingleUserModeChanged"
                           Label="@L["SingleUserMode"]" />
            </div>
        }
    </div>
</div>
