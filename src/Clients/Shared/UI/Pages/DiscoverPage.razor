@page "/discover"
@using K7.Server.Domain.Enums
@using K7.Shared.Dtos.Requests
@inject IMediaService MediaService
@inject IK7ServerService ApiClient
@inject IStringLocalizer<DiscoverPage> L
@inject IStringLocalizer<SharedResource> S

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="discover-page page-scrollable">
    @if (_loading)
    {
        <div class="d-flex flex-col pa-16">
            <K7Spinner />
        </div>
    }
    else if (_items.Count == 0)
    {
        <div class="discover-empty">
            <K7Icon Name="sparkle" Class="discover-empty-icon" />
            <p class="discover-empty-text">@L["EmptyState"]</p>
        </div>
    }
    else
    {
        <div class="discover-header">
            <h4 class="discover-title">@L["PageTitle"]</h4>
            <p class="discover-subtitle">@L["Subtitle"]</p>
        </div>

        <div class="discover-grid">
            @foreach (var item in _items)
            {
                <MediaCard Model="item"
                           Href="@GetHref(item)"
                           OverlayEnabled="true"
                           FooterVisible="true" />
            }
        </div>
    }
</div>
