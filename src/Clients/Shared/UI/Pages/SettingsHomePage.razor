@page "/settings/home"
@layout SettingsLayout
@inject IStringLocalizer<Settings> L
@inject IStringLocalizer<SharedResource> S

<PageTitle>@L["HomePageTitle"]</PageTitle>

<h4 class="mb-4">@L["HomePageTitle"]</h4>

@if (_isLoading)
{
    <K7ProgressBar Indeterminate="true" />
}
else
{
    <div class="d-flex flex-col gap-4">
        <p class="text-sm" Color="secondary">@L["HomePageDescription"]</p>

        <div class="d-flex flex-col gap-2">
            @for (var i = 0; i < _rows.Count; i++)
            {
                var row = _rows[i];
                var isFirst = i == 0;
                var isLast = i == _rows.Count - 1;
                <K7Paper Outlined="true" Elevation="0" Class="pa-3 d-flex align-center justify-between gap-3">
                    <div class="d-flex align-center gap-2">
                        <div class="d-flex flex-col gap-1">
                            <K7IconButton Icon="@Phosphor.ArrowUp" Disabled="@isFirst"
                                    OnClick="() => MoveUp(row)" AriaLabel="@L["MoveUp"]" />
                            <K7IconButton Icon="@Phosphor.ArrowDown" Disabled="@isLast"
                                    OnClick="() => MoveDown(row)" AriaLabel="@L["MoveDown"]" />
                        </div>
                        <span class="text-sm">@GetRowTitle(row.Title)</span>
                    </div>
                    <K7Switch Value="@row.IsVisible" ValueChanged="@(v => row.IsVisible = v)" />
                </K7Paper>
            }
        </div>

        <div class="d-flex justify-between">
            <K7Button Color="secondary" Variant="outlined" OnClick="ResetLayout" Disabled="_saving">
                @L["HomeResetLayout"]
            </K7Button>
            <K7Button Color="primary" Variant="filled" OnClick="SaveLayout" Disabled="_saving">
                @if (_saving) { <K7Spinner Size="sm" /> }
                @S["Save"]
            </K7Button>
        </div>

        <K7ExpansionPanel>
            <TitleContent>@L["PreviewTitle"]</TitleContent>
            <ChildContent>
                <div class="d-flex justify-end mb-2">
                    <K7Button Color="secondary" Variant="text" StartIcon="@Phosphor.ArrowClockwise"
                              OnClick="RefreshPreviewAsync" Disabled="_previewLoading">
                        @L["PreviewRefresh"]
                    </K7Button>
                </div>
                <HomeLayoutPreview @ref="_preview" Rows="_rows" />
            </ChildContent>
        </K7ExpansionPanel>
    </div>
}
