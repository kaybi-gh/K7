@inject IServerInfoService K7ServerService
@inject IStringLocalizer<PlaybackHistory> L

<div class="d-flex align-center gap-2 pa-4" style="width: 100%; flex-wrap: wrap;">
    <h5 class="mr-4">@L["PageTitle"]</h5>
    <K7Chip Value="@("")" Variant="@(_selectedMediaType == "" ? "filled" : "outlined")" Color="primary" OnClick='() => OnMediaTypeChanged("")'>@L["All"]</K7Chip>
    <K7Chip Value="@("3")" Variant="@(_selectedMediaType == "3" ? "filled" : "outlined")" Color="primary" OnClick='() => OnMediaTypeChanged("3")'>@L["Music"]</K7Chip>
    <K7Chip Value="@("1")" Variant="@(_selectedMediaType == "1" ? "filled" : "outlined")" Color="primary" OnClick='() => OnMediaTypeChanged("1")'>@L["Movies"]</K7Chip>
    <K7Chip Value="@("5")" Variant="@(_selectedMediaType == "5" ? "filled" : "outlined")" Color="primary" OnClick='() => OnMediaTypeChanged("5")'>@L["TVShows"]</K7Chip>
</div>

@if (_loading)
{
    <div class="d-flex flex-col pa-16">
        <K7Spinner />
    </div>
}
else if (_history is null || _history.Items.Count == 0)
{
    <div class="d-flex flex-col pa-16">
        <K7Icon Name="clock-counter-clockwise" Style="font-size: 64px; opacity: 0.3;" />
        <h6 Color="default" Style="opacity: 0.5;">@L["NoHistory"]</h6>
    </div>
}
else
{
    <div class="pa-4">
        <K7Table Items="@_history.Items">
            <HeaderContent>
                <th>@L["Title"]</th>
                <th>@L["Type"]</th>
                <th>@L["Date"]</th>
                <th>@L["Duration"]</th>
                <th>@L["Device"]</th>
                <th>@L["Status"]</th>
            </HeaderContent>
            <RowTemplate Context="item">
                <td DataLabel="@L["Title"]">@item.MediaTitle</td>
                <td DataLabel="@L["Type"]">@item.MediaType</td>
                <td DataLabel="@L["Date"]">@item.StartedAt.ToLocalTime().ToString("g")</td>
                <td DataLabel="@L["Duration"]">@FormatDuration(item.TotalWatchedSeconds)</td>
                <td DataLabel="@L["Device"]">@(item.DeviceName ?? "-")</td>
                <td DataLabel="@L["Status"]">
                    @if (item.IsCompleted)
                    {
                        <K7Icon Name="check-circle" Color="success" Size="sm" />
                    }
                    else
                    {
                        <K7Icon Name="pause-circle" Color="warning" Size="sm" />
                    }
                </td>
            </RowTemplate>
        </K7Table>

        @if (_history.TotalCount > _history.PageSize)
        {
            <div class="d-flex justify-center mt-4">
                <div class="d-flex align-center gap-2">
                    <K7IconButton Icon="@Phosphor.CaretLeft" Disabled="@(_currentPage <= 1)" OnClick="@(() => OnPageChanged(_currentPage - 1))" />
                    <span class="text-sm">@_currentPage / @((int)Math.Ceiling((double)_history.TotalCount / _history.PageSize))</span>
                    <K7IconButton Icon="@Phosphor.CaretRight" Disabled="@(_currentPage >= (int)Math.Ceiling((double)_history.TotalCount / _history.PageSize))" OnClick="@(() => OnPageChanged(_currentPage + 1))" />
                </div>
            </div>
        }
    </div>
}
