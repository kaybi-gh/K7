@using K7.Clients.Shared.UI.Helpers
@inject IServerInfoService K7ServerService
@inject IStringLocalizer<PlaybackHistory> L
@inject IStringLocalizer<SharedResource> S

<div class="full-bleed-page playback-history-page">
    <div class="data-page-toolbar">
        <h5 class="data-page-toolbar__title">@L["PageTitle"]</h5>
        <K7ButtonGroup TValue="string" Options="_periodOptions" Value="_selectedPeriod" ValueChanged="OnPeriodChanged" AriaLabel="@L["Period"]" />
        @if (_selectedPeriod == "custom")
        {
            <K7DateRangePicker From="_fromDate" To="_toDate" RangeChanged="OnDateRangeChanged"
                               Label="@L["PickDates"]" HintSelectEnd="@L["SelectEndDate"]" />
        }
        <K7ButtonGroup TValue="string" Options="_mediaTypeOptions" Value="_selectedMediaType" ValueChanged="OnMediaTypeChanged" AriaLabel="@L["MediaType"]" />
        <div class="data-page-toolbar__end">
            <K7ResultCount Count="_totalCount" />
            <K7IconButton Icon="@Phosphor.Columns" OnClick="OnColumnPickerClick" AriaLabel="@S["ToggleColumns"]" />
        </div>
    </div>

    <div class="data-page-body">
        <K7DataTable @key="_tableKey" TItem="PlaybackHistoryItemDto" ServerData="LoadServerDataAsync" @ref="_tableRef"
                     RowHeight="48" ShowToolbar="false" Surface="false" Height="100%">
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Date"]" Width="140px">
                <CellTemplate>
                    <div class="playback-history-date-cell">
                        <span>@context.StartedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                        <span class="text-muted">@context.StartedAt.ToLocalTime().ToString("HH:mm")</span>
                    </div>
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Title"]" Hideable="false">
                <CellTemplate>
                    <LibraryTableMediaTitle ImageUrl="@context.ImageUrl"
                                            MediaType="@context.MediaType"
                                            Title="@(context.MediaTitle ?? S["Untitled"])"
                                            Href="@context.MediaUrl" />
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Type"]" Width="110px" VisibleOnMobile="false">
                <CellTemplate>
                    <span class="text-sm">@MediaTypeLabelHelper.Format(context.MediaType, S)</span>
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["SharedProfile"]" VisibleOnMobile="false">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.SharedProfileName))
                    {
                        <K7Chip Size="sm" Color="secondary" Variant="outlined">@context.SharedProfileName</K7Chip>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Duration"]" Width="90px">
                <CellTemplate>@FormatDuration(context.TotalWatchedSeconds)</CellTemplate>
            </K7DataColumn>
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Device"]" Property="@(i => i.DeviceName ?? "-")" VisibleOnMobile="false" />
            <K7DataColumn TItem="PlaybackHistoryItemDto" Title="@L["Status"]" Width="80px" VisibleOnMobile="false">
                <CellTemplate>
                    @if (context.IsCompleted)
                    {
                        <K7Icon Icon="@Phosphor.CheckCircle" Style="color: var(--color-success);"  IconSize="@K7IconSize.Sm" />
                    }
                    else
                    {
                        <K7Icon Icon="@Phosphor.PauseCircle" Style="color: var(--color-warning);"  IconSize="@K7IconSize.Sm" />
                    }
                </CellTemplate>
            </K7DataColumn>
        </K7DataTable>
    </div>
</div>
