@inject IServerInfoService K7ServerService
@inject K7.Clients.Shared.Services.K7HubClient K7HubClient
@inject IStringLocalizer<WatchStats> L
@implements IDisposable

<MudStack Row="true" Style="width: 100%" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="pa-4">
    <MudText Typo="Typo.h5">@L["PageTitle"]</MudText>
    <MudStack Row="true" Spacing="2">
        <MudChipSet T="string" SelectionMode="SelectionMode.SingleSelection" SelectedValue="@_selectedPeriod" SelectedValueChanged="OnPeriodChanged">
            <MudChip T="string" Value="@("week")" Variant="Variant.Outlined">@L["Week"]</MudChip>
            <MudChip T="string" Value="@("month")" Variant="Variant.Outlined">@L["Month"]</MudChip>
            <MudChip T="string" Value="@("year")" Variant="Variant.Outlined">@L["Year"]</MudChip>
            <MudChip T="string" Value="@("all")" Variant="Variant.Outlined">@L["AllTime"]</MudChip>
        </MudChipSet>
    </MudStack>
</MudStack>

<MudStack Row="true" Class="px-4 mb-4" Spacing="2">
    <MudChipSet T="string" SelectionMode="SelectionMode.SingleSelection" SelectedValue="@_selectedMediaType" SelectedValueChanged="OnMediaTypeChanged">
        <MudChip T="string" Value="@("")" Variant="Variant.Filled" Color="Color.Primary">@L["All"]</MudChip>
        <MudChip T="string" Value="@("3")" Variant="Variant.Outlined">@L["Music"]</MudChip>
        <MudChip T="string" Value="@("1")" Variant="Variant.Outlined">@L["Movies"]</MudChip>
        <MudChip T="string" Value="@("5")" Variant="Variant.Outlined">@L["TVShows"]</MudChip>
    </MudChipSet>
</MudStack>

@if (_loading)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-16">
        <MudProgressCircular Indeterminate="true" />
    </MudStack>
}
else if (_stats is null)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-16">
        <MudIcon Icon="@Icons.Material.Outlined.BarChart" Style="font-size: 64px; opacity: 0.3;" />
        <MudText Typo="Typo.h6" Color="Color.Default" Style="opacity: 0.5;">@L["NoData"]</MudText>
    </MudStack>
}
else
{
    <div class="pa-4">
        <MudGrid Spacing="4" Class="mb-6">
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Large" Color="Color.Primary" />
                        <MudText Typo="Typo.h4" Color="Color.Primary">@_stats.TotalWatchTimeHours h</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["WatchTime"]</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Large" Color="Color.Primary" />
                        <MudText Typo="Typo.h4" Color="Color.Primary">@_stats.TotalPlays</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["TotalPlays"]</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.LibraryMusic" Size="Size.Large" Color="Color.Primary" />
                        <MudText Typo="Typo.h4" Color="Color.Primary">@_stats.UniqueItemsPlayed</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["UniqueItems"]</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @if (_stats.PlaysOverTime.Count > 1)
        {
            <MudPaper Class="pa-4 mb-6" Elevation="0" Outlined="true">
                <MudText Typo="Typo.h6" Class="mb-2">@L["PlaysOverTime"]</MudText>
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@_playsOverTimeSeries"
                          ChartLabels="@_playsOverTimeLabels"
                          Width="100%" Height="250px" />
            </MudPaper>
        }

        <MudGrid Spacing="4" Class="mb-6">
            @if (_stats.PlaysByHourOfDay.Count > 0)
            {
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.h6" Class="mb-2">@L["ByHourOfDay"]</MudText>
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_hourSeries"
                                  ChartLabels="@_hourLabels"
                                  Width="100%" Height="200px" />
                    </MudPaper>
                </MudItem>
            }
            @if (_stats.PlaysByDayOfWeek.Count > 0)
            {
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.h6" Class="mb-2">@L["ByDayOfWeek"]</MudText>
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_dowSeries"
                                  ChartLabels="@_dowLabels"
                                  Width="100%" Height="200px" />
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        <MudGrid Spacing="4">
            @if (_stats.TopItems.Count > 0)
            {
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" Class="mb-2">@L["TopItems"]</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var (item, index) in _stats.TopItems.Select((a, i) => (a, i)))
                        {
                            <MudListItem T="string">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="min-width: 24px;">@(index + 1).</MudText>
                                    <MudText>@item.Name</MudText>
                                    <MudSpacer />
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@item.PlayCount</MudChip>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudItem>
            }

            @if (_stats.TopArtists.Count > 0)
            {
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" Class="mb-2">@L["TopArtists"]</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var (artist, index) in _stats.TopArtists.Select((a, i) => (a, i)))
                        {
                            <MudListItem T="string">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="min-width: 24px;">@(index + 1).</MudText>
                                    <MudText>@artist.Name</MudText>
                                    <MudSpacer />
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@artist.PlayCount</MudChip>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudItem>
            }

            @if (_stats.TopAlbums.Count > 0)
            {
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" Class="mb-2">@L["TopAlbums"]</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var (album, index) in _stats.TopAlbums.Select((a, i) => (a, i)))
                        {
                            <MudListItem T="string">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="min-width: 24px;">@(index + 1).</MudText>
                                    <MudText>@album.Name</MudText>
                                    <MudSpacer />
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@album.PlayCount</MudChip>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudItem>
            }

            @if (_stats.TopShows.Count > 0)
            {
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" Class="mb-2">@L["TopShows"]</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var (show, index) in _stats.TopShows.Select((s, i) => (s, i)))
                        {
                            <MudListItem T="string">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="min-width: 24px;">@(index + 1).</MudText>
                                    <MudText>@show.Name</MudText>
                                    <MudSpacer />
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@show.PlayCount</MudChip>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudItem>
            }

            @if (_stats.TopGenres.Count > 0)
            {
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" Class="mb-2">@L["TopGenres"]</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var (genre, index) in _stats.TopGenres.Select((g, i) => (g, i)))
                        {
                            <MudListItem T="string">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="min-width: 24px;">@(index + 1).</MudText>
                                    <MudText>@genre.Genre</MudText>
                                    <MudSpacer />
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@genre.PlayCount</MudChip>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudItem>
            }
            @if (_stats.TopDevices.Count > 0)
            {
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" Class="mb-2">@L["TopDevices"]</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var (device, index) in _stats.TopDevices.Select((d, i) => (d, i)))
                        {
                            <MudListItem T="string">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="min-width: 24px;">@(index + 1).</MudText>
                                    <MudText>@device.Name</MudText>
                                    <MudSpacer />
                                    <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined">@device.PlayCount</MudChip>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudItem>
            }
        </MudGrid>
    </div>
}
