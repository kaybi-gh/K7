@page "/series/{Id}"
@using K7.Shared.Dtos.Entities.Medias
@using K7.Shared.Dtos.Entities.PersonRoles
@using K7.Server.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Serie> L
@inject IStringLocalizer<SharedResource> S

<PageTitle>@_serie?.Title</PageTitle>

@if (_loading)
{
    <div class="serie-page">
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-16">
            <MudProgressCircular Indeterminate="true" />
        </MudStack>
    </div>
}
else if (_serie is not null)
{
    <div class="serie-page">
        @if (_backdropUrl is not null)
        {
            <div class="background-image" style="--background-picture: url('@_backdropUrl')" />
        }

        <div class="serie-hero">
            <MudStack Class="pa-10" Style="height: 100%;" AlignItems="AlignItems.Start" Justify="Justify.FlexEnd">
                @if (_logoUrl is not null)
                {
                    <img src="@_logoUrl" alt="@_serie.Title" style="height: 180px; max-width: 80vw; object-fit: scale-down; object-position: left center;" />
                }
                else
                {
                    <MudText Typo="Typo.h2" Class="serie-title">@_serie.Title?.ToUpper()</MudText>
                }

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
                    @if (_serie.Ratings?.FirstOrDefault(x => x.Source == RatingSource.MetadataProvider)?.Value is double externalRating)
                    {
                        <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Star" Label="true" Color="Color.Primary" Variant="Variant.Filled" Style="font-weight: 700;">@externalRating.ToString("N1")</MudChip>
                    }
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        @foreach (var genre in _serie.Genres ?? [])
                        {
                            <MudChip T="string" Label="true" Variant="Variant.Text" Size="Size.Small" Style="opacity: 0.9; font-weight: 600;">@genre</MudChip>
                        }
                    </MudStack>
                    @if (!string.IsNullOrEmpty(_serie.ContentRating))
                    {
                        <MudChip T="string" Label="true" Variant="Variant.Outlined" Size="Size.Small">@_serie.ContentRating</MudChip>
                    }
                    <MudText Typo="Typo.caption" Style="opacity: 0.4;">|</MudText>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        @if (_serie.ReleaseDate.HasValue)
                        {
                            <MudText Typo="Typo.body2" Style="opacity: 0.9; font-weight: 600;">@_serie.ReleaseDate.Value.Year</MudText>
                        }
                        @if (!string.IsNullOrEmpty(_serie.Status))
                        {
                            <MudText Typo="Typo.body2" Style="opacity: 0.5;">&bull;</MudText>
                            <MudText Typo="Typo.body2" Style="opacity: 0.9; font-weight: 600;">@_serie.Status</MudText>
                        }
                        @if (!string.IsNullOrEmpty(_serie.Network))
                        {
                            <MudText Typo="Typo.body2" Style="opacity: 0.5;">&bull;</MudText>
                            <MudText Typo="Typo.body2" Style="opacity: 0.9; font-weight: 600;">@_serie.Network</MudText>
                        }
                    </MudStack>
                </MudStack>

                @if (!string.IsNullOrEmpty(_serie.Overview))
                {
                    <MudText Typo="Typo.body1" Class="mt-2" Style="opacity: 0.85; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; font-size: 1.05rem; max-width: 800px;">
                        @_serie.Overview
                    </MudText>
                }

                <MudStack Row="true" data-nav-row Class="mt-4" Spacing="3" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                    <MudButton Disabled="@(_seasons.Count == 0)"
                               Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               Color="Color.Primary"
                               Size="Size.Large"
                               DropShadow="false"
                               Style="border-radius: 8px; font-weight: 800; padding: 10px 32px; letter-spacing: 0.5px;"
                               OnClick="WatchAsync">@S["Play"]</MudButton>

                    <MudIconButton Icon="@Icons.Material.Filled.LocalMovies" aria-label="trailer" />

                    <AuthorizeView Roles="User,Administrator">
                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircleOutline" aria-label="mark-as-watched" />
                    </AuthorizeView>

                    <MudMenu Icon="@Icons.Material.Filled.MoreHoriz" aria-label="more-actions" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" ListClass="pa-2">
                        <AuthorizeView Roles="Administrator">
                            <MudMenuItem Icon="@Icons.Material.Filled.FindReplace" OnClick="OpenMediaReIdentifyDialogAsync">@L["ReIdentify"]</MudMenuItem>
                        </AuthorizeView>
                    </MudMenu>
                </MudStack>
            </MudStack>
        </div>

        @if (_seasons.Count > 0)
        {
            <Carousel Title="@L["Seasons"]">
                @foreach (var season in _seasons)
                {
                    <CarouselItem @key="season.Id">
                        <SeasonCard Season="season"
                                    PosterUrl="@GetSeasonPosterUrl(season)"
                                    OnClick="() => NavigateToSeason(season)" />
                    </CarouselItem>
                }
            </Carousel>
        }

        @if ((_serie.PersonRoles?.Count ?? 0) > 0)
        {
            <Carousel Title="@L["CastingAndCrew"]">
                @foreach (var cast in _serie.PersonRoles!.Where(x => x.Person != null).OrderBy(x => x.Order == null).ThenBy(x => x.Order))
                {
                    <CarouselItem @key="cast.Id">
                        <PersonRole LitePersonRoleDto="@cast" />
                    </CarouselItem>
                }
            </Carousel>
        }
    </div>
}
