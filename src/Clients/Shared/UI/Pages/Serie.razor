@page "/series/{Id}"
@using K7.Shared.Dtos.Entities.Medias
@using K7.Shared.Dtos.Entities.PersonRoles
@using K7.Server.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Serie> L
@inject IStringLocalizer<SharedResource> S

<PageTitle>@_serie?.Title</PageTitle>

@if (_loading)
{
    <div class="serie-page">
        <div class="d-flex flex-col pa-16">
            <K7Spinner />
        </div>
    </div>
}
else if (_serie is not null)
{
    <div class="serie-page" style="@(_dominantColor is not null ? $"--serie-dominant-color: {_dominantColor};" : "")">
        @if (_backdropUrl is not null)
        {
            <div class="background-image" style="--background-picture: url('@_backdropUrl')" />
        }

        <div class="serie-main">
            <K7BackButton />
            <div class="serie-hero">
                <div class="d-flex flex-col pa-10" style="height: 100%; justify-content: flex-end; gap: 8px;">
                <K7Image Class="serie-logo"
                         ObjectFit="scale-down"
                         Src="@_logoUrl"
                         Alt="">
                    <FallbackContent>
                        <h2 class="media-logo-title">@_serie.Title?.ToUpper()</h2>
                    </FallbackContent>
                </K7Image>

                <div class="serie-meta">
                    <div class="serie-ratings">
                        @if (_serie.Ratings?.FirstOrDefault(x => x.Source == RatingSource.MetadataProvider)?.Value is double externalRating)
                        {
                            <K7Chip Size="sm" Icon="star" Color="primary" Variant="filled" Style="font-weight: 700;">@externalRating.ToString("N1")</K7Chip>
                        }
                        @if (!string.IsNullOrEmpty(_serie.ContentRating))
                        {
                            <K7Chip Variant="outlined" Size="sm">@_serie.ContentRating</K7Chip>
                        }
                    </div>

                    <div class="serie-genres">
                        @foreach (var genre in (_serie.Genres ?? []).Take(2))
                        {
                            <K7Chip Variant="text" Size="sm" Style="opacity: 0.9; font-weight: 600;">@genre</K7Chip>
                        }
                    </div>
                    @if (_serie.Studios?.Count > 0)
                    {
                        <span class="text-caption serie-meta-separator">|</span>
                        <div class="serie-studios">
                            @foreach (var studio in _serie.Studios.Take(3))
                            {
                                var s = studio;
                                <K7Chip Variant="text" Size="sm" Style="opacity: 0.9; font-weight: 600;" OnClick="() => NavigateToStudio(s)">@studio</K7Chip>
                            }
                        </div>
                    }

                    <div class="d-flex align-center">
                        @if (_serie.ReleaseDate.HasValue)
                        {
                            <p class="text-sm" Style="opacity: 0.9; font-weight: 600;">@_serie.ReleaseDate.Value.Year</p>
                        }
                        @if (!string.IsNullOrEmpty(_serie.Status))
                        {
                            <p class="text-sm" Style="opacity: 0.5;">&bull;</p>
                            <p class="text-sm" Style="opacity: 0.9; font-weight: 600;">@_serie.Status</p>
                        }
                        @if (!string.IsNullOrEmpty(_serie.Network))
                        {
                            <p class="text-sm" Style="opacity: 0.5;">&bull;</p>
                            <p class="text-sm" Style="opacity: 0.9; font-weight: 600;">@_serie.Network</p>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_serie.Overview))
                {
                    <div class="d-flex flex-col py-3 mt-2 overview-clickable focusable" style="max-width: 800px;" tabindex="0" role="button" @onclick="OpenSynopsisDialogAsync">
                        <p class="serie-overview">
                            @_serie.Overview
                        </p>
                    </div>
                }

                <div class="d-flex mt-6 serie-actions">
                    <div class="d-flex serie-actions-primary">
                        <K7Button Disabled="@(_seasons.Count == 0)"
                                   Variant="filled"
                                   StartIcon="@Phosphor.Play"
                                   Color="primary"
                                   Size="lg"
                                   Style="border-radius: 8px; font-weight: 800; padding: 10px 32px; letter-spacing: 0.5px;"
                                   OnClick="WatchAsync">@S["Play"]</K7Button>
                    </div>

                    <div class="serie-actions-secondary">
                        @if (_serie.Trailers?.Count > 0)
                        {
                            <K7IconButton Icon="@Phosphor.FilmSlate" OnClick="OpenTrailerAsync" AriaLabel="trailer" />
                        }

                        <AuthorizeView Roles="User,Administrator">
                            <K7Menu>
                                <ActivatorContent>
                                    <K7IconButton Icon="@Phosphor.CheckCircle" AriaLabel="mark-as-watched" />
                                </ActivatorContent>
                                <ChildContent>
                                    <K7MenuItem Icon="check-circle" OnClick="MarkSerieWatchedAsync">@L["MarkSerieWatched"]</K7MenuItem>
                                    <K7MenuItem Icon="circle" OnClick="MarkSerieUnwatchedAsync">@L["MarkSerieUnwatched"]</K7MenuItem>
                                </ChildContent>
                            </K7Menu>
                        </AuthorizeView>

                        <K7Menu>
                            <ActivatorContent>
                                <K7IconButton Icon="@Phosphor.DotsThreeVertical" AriaLabel="more-actions" />
                            </ActivatorContent>
                            <ChildContent>
                                <AuthorizeView Roles="Administrator">
                                    <K7MenuItem Icon="magnifying-glass" OnClick="OpenMediaReIdentifyDialogAsync">@L["ReIdentify"]</K7MenuItem>
                                    <K7MenuItem Icon="arrow-clockwise" OnClick="RefreshMetadataAsync">@L["RefreshMetadata"]</K7MenuItem>
                                    <K7MenuItem Icon="pencil-simple" OnClick="OpenEditMetadataDialogAsync">@L["EditMetadata"]</K7MenuItem>
                                </AuthorizeView>
                            </ChildContent>
                        </K7Menu>
                    </div>
                </div>
            </div>
        </div>

        @if ((_serie.PersonRoles?.Count ?? 0) > 0 || _seasons.Count > 0)
        {
            <div class="serie-scroll-hint">
                <K7Icon Icon="@Phosphor.CaretDown" />
            </div>
        }
        </div>

        @if (_seasons.Count > 0)
        {
            <Carousel Title="@L["Seasons"]">
                @foreach (var season in _seasons)
                {
                    <CarouselItem @key="season.Id">
                        <MediaCard Model="@(new MediaCardViewModel
                                   {
                                       Id = season.Id.ToString(),
                                       Kind = MediaCardKind.Season,
                                       Title = season.SeasonNumber == 0 ? S["Specials"] : string.Format(S["SeasonNumber"], season.SeasonNumber),
                                       AdditionalInformations = string.Format(S["EpisodeCount"], season.EpisodeCount),
                                       PictureUrl = GetSeasonPosterUrl(season),
                                       Watched = season.UserState?.IsCompleted ?? false,
                                       Progress = season.UserState?.ProgressPercentage ?? 0,
                                   })"
                                   Variant="MediaCardVariant.Poster"
                                   Href="@($"/series/{Id}/seasons/{season.SeasonNumber}")"
                                   FooterVisible="true"
                                   OverlayEnabled="true"
                                   ProgressEnabled="true"
                                   WatchedStatusEnabled="true"
                                   WatchStateMenuEnabled="true"
                                   BulkEpisodeCount="@season.EpisodeCount"
                                   OnWatchStateChanged="ReloadSerieAsync" />
                    </CarouselItem>
                }
            </Carousel>
        }

        @if ((_serie.PersonRoles?.Count ?? 0) > 0)
        {
            <Carousel Title="@L["CastingAndCrew"]">
                @foreach (var cast in _serie.PersonRoles!.Where(x => x.Person != null).OrderBy(x => x.Order == null).ThenBy(x => x.Order))
                {
                    <CarouselItem @key="cast.Id">
                        <PersonRole LitePersonRoleDto="@cast" />
                    </CarouselItem>
                }
            </Carousel>
        }

        @if (_similarMedia.Count > 0)
        {
            <Carousel Title="@L["SimilarMedia"]">
                @foreach (var media in _similarMedia)
                {
                    <CarouselItem @key="media.Id">
                        <MediaCard Model="media"
                                   Href="@($"/series/{media.Id}")"
                                   OverlayEnabled="true"
                                   WatchStateMenuEnabled="true"
                                   FooterVisible="true" />
                    </CarouselItem>
                }
            </Carousel>
        }
    </div>
}
