@page "/sign-in"
@layout Layout.EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject IStringLocalizer<Welcome> L
@inject IStringLocalizer<SharedResource> S

<PageTitle>@L["PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height:80vh;">
    <MudPaper Class="pa-8" Elevation="4" Style="width:100%; max-width:480px;">
        <MudStack Spacing="4" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h4">K7</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                @L["WelcomeHeading"]
            </MudText>

            <MudDivider Class="my-2" Style="width:100%;" />

            @if (_loading)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["SignInPrompt"]</MudText>
            }
            else if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-2" Style="width:100%;">
                    @_error
                </MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           FullWidth="true" OnClick="SignInAsync">
                    @S["TryAgain"]
                </MudButton>
            }
            else
            {
                @if (_serverInfoError is not null)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Text" Dense="true" Class="mt-2" Style="width:100%;">
                        @_serverInfoError
                    </MudAlert>
                }

                <MudButton @ref="_signInButton" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           FullWidth="true" OnClick="SignInAsync">
                    @S["SignIn"]
                </MudButton>

                @if (_guestEnabled)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Large"
                               FullWidth="true" OnClick="ContinueAsGuestAsync">
                        @S["Guest"]
                    </MudButton>
                }
            }
        </MudStack>
    </MudPaper>
</MudContainer>
