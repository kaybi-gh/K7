@page "/"
@inject IStringLocalizer<Home> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@L["PageTitle"]</PageTitle>

<div class="home-page">
    @if (_heroItems.Count > 0)
    {
        <div class="home-bg" aria-hidden="true">
            @foreach (var (item, i) in _heroItems.Select((x, idx) => (x, idx)))
            {
                var src = item.BackdropUrl;
                <div class="home-bg-img @(i == _activeHeroIndex ? "home-bg-img--active" : "")">
                    @if (src is not null)
                    {
                        <img src="@src" alt="" loading="@(i == 0 ? "eager" : "lazy")" />
                    }
                </div>
            }
        </div>
    }

    @if (isLoading)
    {
        <HeroSection Skeleton="true" FullBleed="true" />
        @for (int i = 0; i < 3; i++)
        {
            <Carousel Skeleton="true">
                @for (int j = 0; j < 10; j++)
                {
                    <CarouselItem>
                        <MediaCard Skeleton="true" FooterVisible="true" />
                    </CarouselItem>
                }
            </Carousel>
        }
    }
    else
    {
        var hasAnyCarousel = _rows.Any(r =>
            r.Items.Count > 0 &&
            (!r.Config.ContinueWatching || _canTrackProgress) &&
            r.Config.DisplayType != HomeRowDisplayType.Hero);

        @if (_heroItems.Count > 0)
        {
            <HeroSection Items="_heroItems" HrefProvider="GetHref" FullBleed="true"
                         OnActiveIndexChanged="OnHeroActiveIndexChanged" />
        }

        @foreach (var (row, items) in _rows)
        {
            @if (items.Count > 0 && (!row.ContinueWatching || _canTrackProgress) && row.DisplayType != HomeRowDisplayType.Hero)
            {
                @RenderCarousel(L[row.Title], items, _canTrackProgress, _canTrackProgress)
            }
        }

        @if (_heroItems.Count == 0 && !hasAnyCarousel)
        {
            <div class="home-empty-state">
                <K7Icon Icon="@Phosphor.FilmSlate" Style="font-size: 64px; opacity: 0.2;" />
                <p class="home-empty-state__title">@L["EmptyStateTitle"]</p>
                <p class="home-empty-state__subtitle">@L["EmptyStateSubtitle"]</p>
            </div>
        }
    }
</div>

@{ RenderFragment RenderCarousel(string title, List<MediaCardViewModel> items, bool progress, bool watched)
{
    return @<Carousel Title="@title">
        @foreach (var item in items)
        {
            <CarouselItem @key="item.Id">
                <MediaCard Model="@item"
                           Variant="GetVariant(item)"
                           Href="@GetHref(item)"
                           OverlayEnabled="item.Kind != MediaCardKind.Cover"
                           ProgressEnabled="progress"
                           WatchedStatusEnabled="watched"
                           FooterVisible="true"
                           ExcludeMenuEnabled="_canExclude"
                           IsAdmin="_isAdmin"
                           OnExcludeForSelf="() => ExcludeForSelf(item)"
                           OnExcludeForOthers="() => ExcludeForOthers(item)" />
            </CarouselItem>
        }
    </Carousel>;
} }
