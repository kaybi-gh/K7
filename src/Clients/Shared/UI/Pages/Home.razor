@page "/"
@inject IStringLocalizer<Home> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@L["PageTitle"]</PageTitle>

<div class="home-page @(_isTv ? "home-page--tv" : "")">
    @if (_isOffline)
    {
        <div class="home-offline-banner">
            <K7Icon Icon="@Phosphor.WifiSlash" Style="font-size: 48px; opacity: 0.4;" />
            <p class="home-offline-banner__title">@L["OfflineTitle"]</p>
            <p class="home-offline-banner__subtitle">@L["OfflineSubtitle"]</p>
            <K7Button Href="/my-space/downloads" Variant="filled" Color="primary">
                @L["GoToDownloads"]
            </K7Button>
        </div>
    }
    else if (_isTv)
    {
        <HomeTvHero Model="_focusedItem" />
    }
    @if (isLoading)
    {
        @if (_isTv)
        {
            <VerticalCarousel>
                @for (int i = 0; i < 3; i++)
                {
                    <Carousel Skeleton="true">
                        @for (int j = 0; j < 10; j++)
                        {
                            <CarouselItem>
                                <MediaCard Skeleton="true" FooterVisible="true" />
                            </CarouselItem>
                        }
                    </Carousel>
                }
            </VerticalCarousel>
        }
        else
        {
            @for (int i = 0; i < 3; i++)
            {
                <Carousel Skeleton="true">
                    @for (int j = 0; j < 10; j++)
                    {
                        <CarouselItem>
                            <MediaCard Skeleton="true" FooterVisible="true" />
                        </CarouselItem>
                    }
                </Carousel>
            }
        }
    }
    else
    {
        var hasAnyCarousel = _rows.Any(r =>
            r.Items.Count > 0 &&
            (!r.Config.ContinueWatching || _canTrackProgress));

        @if (_isTv)
        {
            <VerticalCarousel>
                @foreach (var (row, items) in _rows)
                {
                    @if (items.Count > 0 && (!row.ContinueWatching || _canTrackProgress))
                    {
                        @RenderCarousel(GetRowTitle(row.Title), items, _canTrackProgress, _canTrackProgress, row.ContinueWatching)
                    }
                }
            </VerticalCarousel>
        }
        else
        {
            @foreach (var (row, items) in _rows)
            {
                @if (items.Count > 0 && (!row.ContinueWatching || _canTrackProgress))
                {
                    @RenderCarousel(GetRowTitle(row.Title), items, _canTrackProgress, _canTrackProgress, row.ContinueWatching)
                }
            }
        }

        @if (!hasAnyCarousel)
        {
            <K7EmptyState Icon="@Phosphor.FilmSlate" Title="@L["EmptyStateTitle"]" Subtitle="@L["EmptyStateSubtitle"]" />
        }
    }
</div>

@{ RenderFragment RenderCarousel(string title, List<MediaCardViewModel> items, bool progress, bool watched, bool continueWatching = false)
{
    return @<Carousel Title="@title">
        @foreach (var item in items)
        {
            <CarouselItem @key="item.Id">
                <MediaCard Model="@item"
                           Variant="GetVariant(item)"
                           Href="@GetHref(item)"
                           OverlayEnabled="true"
                           ProgressEnabled="progress"
                           WatchedStatusEnabled="watched"
                           FooterVisible="true"
                           ExcludeMenuEnabled="_canExclude"
                           ContinueWatchingMenuEnabled="continueWatching && _canTrackProgress"
                           WatchStateMenuEnabled="_canSetWatchState"
                           IsAdmin="_isAdmin"
                           OnFocused="() => OnItemFocused(item)"
                           OnExcludeForSelf="() => ExcludeForSelf(item)"
                           OnExcludeForOthers="() => ExcludeForOthers(item)"
                           OnDismissFromContinueWatching="() => DismissFromContinueWatching(item)" />
            </CarouselItem>
        }
    </Carousel>;
} }
