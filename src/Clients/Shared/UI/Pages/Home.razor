@page "/"
<PageTitle>Home</PageTitle>

@if (isLoading)
{
    @for (int i = 0; i < 3; i++)
    {
        <Carousel Skeleton="true">
            @for (int i = 0; i < 10; i++)
            {
                <CarouselItem>
                    <MediaPoster Skeleton="true" FooterVisible="true" />
                </CarouselItem>
            }
        </Carousel>
    }
}
else
{
    @if (_canTrackProgress && continueWatchingMedias.Count > 0)
    {
        <Carousel Title="Continue watching">
            @foreach (var item in continueWatchingMedias)
            {
                <CarouselItem>
                    @if (item.Kind == MediaPosterKind.Album)
                    {
                        <MediaCover Model="@item" Href="@($"/music/albums/{item.Id}")" FooterVisible="true" />
                    }
                    else
                    {
                        <MediaPoster Model="@item" OverlayEnabled="true" ProgressEnabled="true" WatchedStatusEnabled="true" FooterVisible="true"/>
                    }
                </CarouselItem>
            }
        </Carousel>
    }

    <Carousel Title="Recently added">
        @foreach (var item in recentlyAddedMedias)
        {
            <CarouselItem>
                @if (item.Kind == MediaPosterKind.Album)
                {
                    <MediaCover Model="@item" Href="@($"/music/albums/{item.Id}")" FooterVisible="true" />
                }
                else
                {
                    <MediaPoster Model="@item" OverlayEnabled="true" ProgressEnabled="_canTrackProgress" WatchedStatusEnabled="_canTrackProgress" FooterVisible="true"/>
                }
            </CarouselItem>
        }
    </Carousel>

    <Carousel Title="Recently released">
        @foreach (var item in recentlyReleasedMedias)
        {
            <CarouselItem>
                @if (item.Kind == MediaPosterKind.Album)
                {
                    <MediaCover Model="@item" Href="@($"/music/albums/{item.Id}")" FooterVisible="true" />
                }
                else
                {
                    <MediaPoster Model="@item" OverlayEnabled="true" ProgressEnabled="_canTrackProgress" WatchedStatusEnabled="_canTrackProgress" FooterVisible="true"/>
                }
            </CarouselItem>
        }
    </Carousel>

    @if (_canTrackProgress)
    {
        <Carousel Title="Last played">
            @foreach (var item in lastPlayedMedias)
            {
                <CarouselItem>
                    @if (item.Kind == MediaPosterKind.Album)
                    {
                        <MediaCover Model="@item" Href="@($"/music/albums/{item.Id}")" FooterVisible="true" />
                    }
                    else
                    {
                        <MediaPoster Model="@item" OverlayEnabled="true" ProgressEnabled="true" WatchedStatusEnabled="true" FooterVisible="true"/>
                    }
                </CarouselItem>
            }
        </Carousel>
    }
}
