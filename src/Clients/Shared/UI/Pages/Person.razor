@page "/persons/{Id}"
@using K7.Server.Domain.Enums
@using K7.Shared.Dtos.Entities.Medias
@using K7.Shared.Dtos.Entities.Persons
@using K7.Shared.Dtos.Entities.PersonRoles
@using K7.Clients.Shared.UI.Components.Dialogs
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject IStringLocalizer<Person> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@_person?.Name</PageTitle>

@if (_loading)
{
    <div class="person-page">
        <div class="d-flex flex-col pa-16">
            <K7Spinner />
        </div>
    </div>
}
else if (_person is not null)
{
    <div @ref="_scrollRoot" class="person-page">
        @if (_backdropUrls.Count > 0)
        {
            <div class="person-backdrops">
                @for (int i = 0; i < _backdropUrls.Count; i++)
                {
                    var idx = i;
                    <div class="person-backdrop @(idx == _activeBackdropIndex ? "person-backdrop--active" : "")"
                         style="background-image: url('@_backdropUrls[idx]')" />
                }
            </div>
        }

        <MediaPageBackdrop ScrollTarget="@_scrollRoot" />

        <div class="person-main">
            <K7BackButton />
            <div class="person-hero">
                <div class="person-hero-content">
                    <div class="person-portrait">
                        <K7Image Src="@(_portraitUrl ?? PersonPlaceholderSrc)"
                                 Alt="@_person.Name"
                                 Fluid="true"
                                 ObjectFit="cover">
                            <FallbackContent>
                                <K7Image Src="@PersonPlaceholderSrc"
                                         Alt="@_person.Name"
                                         Fluid="true"
                                         ObjectFit="cover"
                                         ShowLoadingState="false" />
                            </FallbackContent>
                        </K7Image>
                    </div>

                    <div class="person-info">
                        <div class="person-name-row">
                            <h3 class="person-name">@_person.Name</h3>
                            <K7Menu>
                                <ActivatorContent>
                                    <K7IconButton Icon="@Phosphor.DotsThreeVertical" AriaLabel="more-actions" Size="sm" />
                                </ActivatorContent>
                                <ChildContent>
                                    <AuthorizeView Roles="Administrator">
                                        <K7MenuItem Icon="arrow-clockwise" OnClick="RefreshMetadataAsync">@L["RefreshMetadata"]</K7MenuItem>
                                        <K7MenuItem Icon="pencil-simple" OnClick="OpenEditMetadataDialogAsync">@L["EditMetadata"]</K7MenuItem>
                                    </AuthorizeView>
                                </ChildContent>
                            </K7Menu>
                        </div>

                        <div class="person-meta">
                            @if (_person.Birthday.HasValue)
                            {
                                <div class="person-meta-item">
                                    <K7Icon Name="cake"  IconSize="@K7IconSize.Sm" Class="person-meta-icon" />
                                    <span>@_person.Birthday.Value.ToString("d MMMM yyyy")</span>
                                    @if (_person.Deathday is null)
                                    {
                                        <span class="person-meta-secondary">(@Age(_person.Birthday.Value) @L["YearsOld"])</span>
                                    }
                                </div>
                            }
                            @if (_person.Deathday.HasValue)
                            {
                                <div class="person-meta-item">
                                    <span class="person-meta-secondary">&#x2020;</span>
                                    <span>@_person.Deathday.Value.ToString("d MMMM yyyy")</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(_person.BirthPlace))
                            {
                                <div class="person-meta-item">
                                    <K7Icon Name="map-pin"  IconSize="@K7IconSize.Sm" Class="person-meta-icon" />
                                    <span>@_person.BirthPlace</span>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(_person.Biography))
                        {
                            <div class="person-bio overview-clickable focusable" tabindex="0" role="button" @onclick="OpenBioDialogAsync">
                                <p class="person-bio-text">@_person.Biography</p>
                            </div>
                        }

                    </div>
                </div>
            </div>

            @if (_discography.Count > 0 || _medias.Count > 0)
            {
                <div class="person-scroll-hint" aria-hidden="true">
                    <K7Icon Icon="@Phosphor.CaretDown" />
                </div>
            }
        </div>

        @if (_discography.Count > 0 || _medias.Count > 0)
        {
            <MediaPageContent>
            <div class="person-content">
                @if (_discography.Count > 0)
                {
                    <Carousel Title="@L["Discography"]">
                        @foreach (var album in _discography)
                        {
                            <CarouselItem @key="album.Id">
                                <MediaCard Model="album"
                                           Variant="MediaCardVariant.Cover"
                                           Href="@($"/music/albums/{album.Id}")"
                                           OverlayEnabled="true"
                                           FooterVisible="true" />
                            </CarouselItem>
                        }
                    </Carousel>
                }

                @if (_medias.Count > 0)
                {
                    <Carousel Title="@L["Filmography"]">
                        @foreach (var media in _medias)
                        {
                            <CarouselItem @key="media.Id">
                                <MediaCard Model="media"
                                           Variant="@GetFilmographyVariant(media)"
                                           Href="@GetFilmographyHref(media)"
                                           OverlayEnabled="true"
                                           ProgressEnabled="_canTrackProgress"
                                           WatchedStatusEnabled="_canTrackProgress"
                                           FooterVisible="true"
                                           ExcludeMenuEnabled="_canExclude"
                                           WatchStateMenuEnabled="_canSetWatchState"
                                           IsAdmin="_isAdmin"
                                           OnExcludeForSelf="() => ExcludeForSelf(media)"
                                           OnExcludeForOthers="() => ExcludeForOthers(media)" />
                            </CarouselItem>
                        }
                    </Carousel>
                }

                @if (_knownFor.Count > 0)
                {
                    <Carousel Title="@L["KnownFor"]">
                        @foreach (var item in _knownFor)
                        {
                            <CarouselItem @key="item.ExternalId">
                                <MediaCard Model="@(new MediaCardViewModel { Id = item.ExternalId, Title = item.Title, PictureUrl = item.PosterUrl, AdditionalInformations = item.Year?.ToString() })"
                                           FooterVisible="true"
                                           ContextMenuEnabled="false" />
                            </CarouselItem>
                        }
                    </Carousel>
                }
            </div>
            </MediaPageContent>
        }
    </div>
}
