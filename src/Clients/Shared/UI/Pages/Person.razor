@page "/persons/{Id}"
@using K7.Server.Domain.Enums
@using K7.Shared.Dtos.Entities.Medias
@using K7.Shared.Dtos.Entities.PersonRoles
@using K7.Clients.Shared.UI.Components.Dialogs
@implements IDisposable
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject IDialogService DialogService
@inject IStringLocalizer<Person> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@_person?.Name</PageTitle>

@if (_loading)
{
    <div class="person-page">
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-16">
            <MudProgressCircular Indeterminate="true" />
        </MudStack>
    </div>
}
else if (_person is not null)
{
    <div class="person-page">
        @if (_backdropUrls.Count > 0)
        {
            <div class="person-backdrops">
                @for (int i = 0; i < _backdropUrls.Count; i++)
                {
                    var idx = i;
                    <div class="person-backdrop @(idx == _activeBackdropIndex ? "person-backdrop--active" : "")"
                         style="background-image: url('@_backdropUrls[idx]')" />
                }
            </div>
        }

        <div class="person-hero">
            <div class="person-hero-content">
                <div class="person-portrait">
                    @if (_portraitUrl is not null)
                    {
                        <img src="@_portraitUrl" alt="@_person.Name" class="person-portrait-img" />
                    }
                    else
                    {
                        <div class="person-portrait-placeholder">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size: 64px; opacity: 0.3;" />
                        </div>
                    }
                </div>

                <div class="person-info">
                    <MudText Typo="Typo.h3" Class="person-name">@_person.Name</MudText>

                    <MudStack Row="true" Spacing="4" Wrap="Wrap.Wrap" Class="mt-3">
                        @if (_person.Birthday.HasValue)
                        {
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Outlined.Cake" Size="Size.Small" Style="opacity:0.55" />
                                <MudText Typo="Typo.body2">@_person.Birthday.Value.ToString("d MMMM yyyy")</MudText>
                                @if (_person.Deathday is null)
                                {
                                    <MudText Typo="Typo.body2" Style="opacity:0.6;">(@Age(_person.Birthday.Value) @L["YearsOld"])</MudText>
                                }
                            </MudStack>
                        }
                        @if (_person.Deathday.HasValue)
                        {
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.body2" Style="opacity:0.5;">†</MudText>
                                <MudText Typo="Typo.body2">@_person.Deathday.Value.ToString("d MMMM yyyy")</MudText>
                            </MudStack>
                        }
                        @if (!string.IsNullOrEmpty(_person.BirthPlace))
                        {
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Outlined.Place" Size="Size.Small" Style="opacity:0.55" />
                                <MudText Typo="Typo.body2">@_person.BirthPlace</MudText>
                            </MudStack>
                        }
                    </MudStack>

                    @if (!string.IsNullOrEmpty(_person.Biography))
                    {
                        <div class="person-bio overview-clickable" tabindex="0" @onclick="OpenBioDialogAsync" @onkeydown="HandleBioKeyDown">
                            <MudText Typo="Typo.body1" Style="opacity: 0.85; line-height: 1.7; display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;">@_person.Biography</MudText>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (_discography.Count > 0)
        {
            <Carousel Title="@L["Discography"]">
                @foreach (var album in _discography)
                {
                    <CarouselItem @key="album.Id">
                        <MediaCard Model="album"
                                   Href="@($"/music/albums/{album.Id}")"
                                   FooterVisible="true" />
                    </CarouselItem>
                }
            </Carousel>
        }

        @if (_medias.Count > 0)
        {
            <Carousel Title="@L["Filmography"]">
                @foreach (var media in _medias)
                {
                    <CarouselItem @key="media.Id">
                        <MediaCard Model="media"
                                   Href="@(media.Kind == MediaCardKind.Serie ? $"/series/{media.Id}" : $"/movies/{media.Id}")"
                                   OverlayEnabled="true"
                                   ProgressEnabled="true"
                                   WatchedStatusEnabled="true"
                                   FooterVisible="true" />
                    </CarouselItem>
                }
            </Carousel>
        }
    </div>
}
