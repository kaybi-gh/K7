@page "/search"
@inject IStringLocalizer<SearchPage> L
@inject IStringLocalizer<SharedResource> S
@using K7.Shared.Dtos.Entities.Medias
@using K7.Shared.Dtos.Entities.Persons
@using K7.Shared.Dtos.Search
@using K7.Server.Domain.Enums
@using K7.Clients.Shared.Mappings
@using K7.Clients.Shared.Models

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="search-page page-scrollable">
    <div class="search-page__header">
        <K7TextField @bind-Value="_query"
                      Adornment="start"
                      AdornmentIcon="@Phosphor.MagnifyingGlass"
                      Placeholder="@L["TypeHint"]"
                      Variant="outlined"
                      Clearable="true"
                      Class="search-page__input"
                      DebounceInterval="300"
                      OnDebounceIntervalElapsed="@((string? v) => OnQueryDebounced(v))" />
    </div>

    @if (string.IsNullOrWhiteSpace(_query) || _query.Length < 2)
    {
        <div class="search-page__empty">
            <K7Icon Icon="@Phosphor.MagnifyingGlass" Style="font-size: 64px; opacity: 0.2;" />
            <p class="text-sm" Color="secondary">@L["EnterQuery"]</p>
        </div>
    }
    else if (_loading)
    {
        <div class="search-page__loading">
            <K7Spinner />
            <p class="text-sm" Color="secondary">@L["Loading"]</p>
        </div>
    }
    else if (_result is null || (_movieResults.Count == 0 && _serieResults.Count == 0 && _musicResults.Count == 0 && _result.PersonResults.Count == 0 && _result.CharacterResults.Count == 0))
    {
        <div class="search-page__empty">
            <K7Icon Icon="@Phosphor.SmileyMeh" Style="font-size: 64px; opacity: 0.2;" />
            <p class="text-sm" Color="secondary">@string.Format(L["NoResults"], _query)</p>
        </div>
    }
    else
    {
        @if (_movieResults.Count > 0)
        {
            <Carousel Title="@L["Movies"]" ShowLoopBack="false">
                @foreach (var media in _movieResults)
                {
                    var card = media.ToCardViewModel(ApiClient, n => string.Format(S["SeasonNumber"], n));
                    @if (card is not null)
                    {
                        <CarouselItem>
                            <MediaCard Model="card"
                                        Variant="@GetVariant(card)"
                                        Href="@GetMediaHref(media)"
                                        FooterVisible="true"
                                        OverlayEnabled="true" />
                        </CarouselItem>
                    }
                }
            </Carousel>
        }

        @if (_serieResults.Count > 0)
        {
            <Carousel Title="@L["Series"]" ShowLoopBack="false">
                @foreach (var media in _serieResults)
                {
                    var card = media.ToCardViewModel(ApiClient, n => string.Format(S["SeasonNumber"], n));
                    @if (card is not null)
                    {
                        <CarouselItem>
                            <MediaCard Model="card"
                                        Variant="@GetVariant(card)"
                                        Href="@GetMediaHref(media)"
                                        FooterVisible="true"
                                        OverlayEnabled="true" />
                        </CarouselItem>
                    }
                }
            </Carousel>
        }

        @if (_musicResults.Count > 0)
        {
            <Carousel Title="@L["Music"]" ShowLoopBack="false">
                @foreach (var media in _musicResults)
                {
                    var card = media.ToCardViewModel(ApiClient, n => string.Format(S["SeasonNumber"], n));
                    @if (card is not null)
                    {
                        <CarouselItem>
                            <MediaCard Model="card"
                                        Variant="@GetVariant(card)"
                                        Href="@GetMediaHref(media)"
                                        FooterVisible="true"
                                        OverlayEnabled="true" />
                        </CarouselItem>
                    }
                }
            </Carousel>
        }

        @if (_result.PersonResults.Count > 0)
        {
            <Carousel Title="@L["Persons"]" ShowLoopBack="false">
                @foreach (var person in _result.PersonResults)
                {
                    <CarouselItem>
                        <a href="/persons/@person.Id" class="search-person-card focusable">
                            <K7Avatar Image="@GetPersonPictureUrl(person)"
                                       Alt="@person.Name"
                                       Size="lg" />
                            <div class="search-person-card__footer">
                                <span class="search-person-card__name">@person.Name</span>
                            </div>
                        </a>
                    </CarouselItem>
                }
            </Carousel>
        }

        @if (_result.CharacterResults.Count > 0)
        {
            <Carousel Title="@L["Characters"]" ShowLoopBack="false">
                @foreach (var character in _result.CharacterResults)
                {
                    <CarouselItem>
                        <a href="/persons/@character.PersonId" class="search-person-card focusable">
                            <K7Avatar Image="@GetCharacterPictureUrl(character)"
                                       Alt="@character.PersonName"
                                       Size="lg" />
                            <div class="search-person-card__footer">
                                <span class="search-person-card__name">@character.CharacterName</span>
                                <span class="search-person-card__sub">@character.MediaTitle</span>
                            </div>
                        </a>
                    </CarouselItem>
                }
            </Carousel>
        }
    }
</div>
