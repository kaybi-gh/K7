@page "/explore"
@layout ExploreLayout
@using K7.Clients.Shared.Helpers
@using K7.Clients.Shared.Interfaces
@inject ILibraryService LibraryService
@inject IStringLocalizer<ExplorePage> L
@inject NavigationManager NavigationManager

<PageTitle>@PageTitleText</PageTitle>

@if (LibraryGroupId.HasValue)
{
    @* Group feed content is hosted by FeedHubPageHost (keep-alive). *@
}
else if (_loading)
{
    <div class="explore-page page-scrollable">
        <div class="d-flex flex-col pa-16">
            <K7Spinner />
        </div>
    </div>
}
else if (_libraryGroups.Count == 0)
{
    <div class="explore-page page-scrollable">
        <K7EmptyState Title="@L["NoLibraryGroups"]" />
    </div>
}
else
{
    <div class="explore-page page-scrollable">
        <section class="explore-groups">
            @foreach (var group in _libraryGroups)
            {
                var (gs, ge, ic) = LibraryGroupCardColors.GetRgbaColors(group);
                var icon = !string.IsNullOrEmpty(group.Icon) ? group.Icon : GetLibraryIconName(group.MediaType);
                var imageUrl = group.CoverPictureId.HasValue ? $"/api/metadata-pictures/{group.CoverPictureId}?size=Medium" : null;
                <K7CategoryCard @key="group.Id"
                                Title="@group.Title"
                                Description="@(group.Description ?? "")"
                                Icon="@icon"
                                GradientStart="@gs"
                                IconColor="@ic"
                                ImageUrl="@imageUrl"
                                DominantColor="@group.CoverDominantColor"
                                CardColor="@group.CardColor"
                                Class="k7-category-card--lg"
                                OnClick="@(() => NavigationManager.NavigateTo($"/explore?library-group={group.Id}"))" />
            }
            @if (_showSocialDirectory)
            {
                <K7CategoryCard Title="@L["OtherUsers"]"
                                Description="@L["OtherUsersDesc"]"
                                Icon="users"
                                GradientStart="rgba(60,40,80,0.85)"
                                IconColor="rgba(120,80,160,0.6)"
                                Class="k7-category-card--lg"
                                OnClick="@(() => NavigationManager.NavigateTo("/users"))" />
            }
        </section>
    </div>
}
