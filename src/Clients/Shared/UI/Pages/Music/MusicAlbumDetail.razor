@page "/music/albums/{Id}"
@using K7.Shared.Dtos.Entities.Medias
@using K7.Shared.Dtos.Entities.PersonRoles
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject IStringLocalizer<MusicAlbumDetail> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@_album?.Title</PageTitle>

@if (_album is not null)
{
    <div class="album-detail-page">
        @if (_coverUrl is not null)
        {
            <div class="background-image" style="--background-picture: url('@_coverUrl')" />
        }

        <div class="album-header">
            <div class="album-header-cover">
                @if (_coverUrl is not null)
                {
                    <K7Image Src="@_coverUrl"
                              Alt="@_album.Title"
                              Class="album-detail-cover"
                              ObjectFit="cover" />
                }
                else
                {
                    <div class="album-detail-cover-placeholder">
                        <K7Icon Name="vinyl-record"
                                 Style="font-size: 64px; opacity: 0.3;" />
                    </div>
                }
            </div>

            <div class="album-header-info">
                <p class="text-overline album-type-label">@L["AlbumType"]</p>
                <h3 class="album-detail-title">@_album.Title</h3>

                <div class="album-artists">
                    @foreach (var artist in _artists)
                    {
                        <a href="@($"/music/artists/{artist.Id}")" class="album-artist-link focusable">
                            @artist.Name
                        </a>
                    }
                </div>

                <div class="album-meta">
                    @if (_album.ReleaseDate.HasValue)
                    {
                        <span>@_album.ReleaseDate.Value.Year</span>
                    }
                    @if (_trackCount > 0)
                    {
                        <span>&bull;</span>
                        <span>@string.Format(L["TrackCount"], _trackCount)</span>
                    }
                    @if (_totalDuration > 0)
                    {
                        <span>&bull;</span>
                        <span>@FormatTotalDuration(_totalDuration)</span>
                    }
                </div>

                @if (_album.Genres?.Any() == true)
                {
                    <div class="album-genres">
                        @foreach (var genre in _album.Genres)
                        {
                            <K7Chip Variant="text" Size="sm">@genre</K7Chip>
                        }
                    </div>
                }

                <div class="album-actions">
                    <K7Button Variant="filled"
                               Color="primary"
                               StartIcon="@Phosphor.Play"
                               Size="lg"
                               OnClick="PlayAll">
                        @S["PlayAll"]
                    </K7Button>
                    <K7Button Variant="outlined"
                               Color="primary"
                               StartIcon="@Phosphor.Shuffle"
                               OnClick="ShuffleAll">
                        @S["Shuffle"]
                    </K7Button>
                    @if (_artists.Count > 0)
                    {
                        <K7Button Variant="text"
                                   StartIcon="@Phosphor.User"
                                   Href="@($"/music/artists/{_artists[0].Id}")">
                            @L["GoToArtist"]
                        </K7Button>
                    }
                </div>
            </div>
        </div>

        <div class="album-tracklist">
            @foreach (var discGroup in _tracksByDisc)
            {
                @if (_tracksByDisc.Count > 1)
                {
                    <p class="text-subtitle1 disc-header">@string.Format(L["DiscHeader"], discGroup.Key)</p>
                }

                <K7Table Items="discGroup.Value"
                          TItem="TrackViewModel"
                          OnRowClick="@(args => OnTrackClick(args))"
                          RowClass="cursor-pointer">
                    <HeaderContent>
                        <th class="col-track-number">#</th>
                        <th>@S["Title"]</th>
                        <th class="col-duration">
                            <K7Icon Name="clock" Size="sm" />
                        </th>
                        <th class="col-rating"></th>
                        <th class="col-actions"></th>
                    </HeaderContent>
                    <RowTemplate>
                        <td>
                            @if (context.IsPlaying)
                            {
                                <K7Icon Name="equalizer"
                                         Size="sm"
                                         Color="primary" />
                            }
                            else
                            {
                                <span class="track-number">@context.TrackNumber</span>
                            }
                        </td>
                        <td>
                            <div class="track-title-cell">
                                <span class="@(context.IsPlaying ? "track-playing" : "")">
                                    @context.Title
                                </span>
                                @if (!string.IsNullOrEmpty(context.ArtistName))
                                {
                                    <span class="text-caption track-artist">@context.ArtistName</span>
                                }
                            </div>
                        </td>
                        <td class="col-duration">
                            <span class="track-duration">@FormatTime(context.Duration)</span>
                        </td>
                        <td>
                            <RatingStars MediaId="context.Id" Value="context.UserRating" Size="sm" />
                        </td>
                        <td>
                            <TrackContextMenu Track="BuildQueueItem(context)" />
                        </td>
                    </RowTemplate>
                </K7Table>
            }

            @if (!string.IsNullOrEmpty(_album.Overview))
            {
                <div class="album-overview">
                    <p class="text-subtitle1 mb-2">@S["About"]</p>
                    <p class="text-sm album-overview-text">@_album.Overview</p>
                </div>
            }
        </div>
    </div>
}
else if (_loading)
{
    <div class="d-flex flex-col pa-16">
        <K7Spinner />
    </div>
}
