@page "/music/albums/{Id}"
@using K7.Shared.Dtos.Entities.Medias
@using K7.Shared.Dtos.Entities.PersonRoles
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject IStringLocalizer<MusicAlbumDetail> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@_album?.Title</PageTitle>

@if (_album is not null)
{
    <div class="album-detail-page">
        @if (_coverUrl is not null)
        {
            <div class="album-hero-bg" style="background-image: url('@_coverUrl')"></div>
        }

        <div class="album-header">
            <div class="album-header-cover">
                @if (_coverUrl is not null)
                {
                    <K7Image Src="@_coverUrl"
                              Alt="@_album.Title"
                              Class="album-detail-cover"
                              ObjectFit="cover" />
                }
                else
                {
                    <div class="album-detail-cover-placeholder">
                        <K7Icon Name="vinyl-record"
                                 Style="font-size: 64px; opacity: 0.3;" />
                    </div>
                }
            </div>

            <div class="album-header-info">
                <p class="text-overline">@L["AlbumType"]</p>
                <h4 class="album-detail-title">@_album.Title</h4>

                <div class="d-flex align-center mt-1">
                    @foreach (var artist in _artists)
                    {
                        <a href="@($"/music/artists/{artist.PersonId}")" class="album-artist-link">
                            <p class="text-subtitle1" Color="primary">@artist.Name</p>
                        </a>
                    }
                </div>

                <div class="d-flex align-center mt-1">
                    @if (_album.ReleaseDate.HasValue)
                    {
                        <p class="text-sm" Color="secondary">@_album.ReleaseDate.Value.Year</p>
                    }
                    @if (_trackCount > 0)
                    {
                        <p class="text-sm" Color="secondary">@string.Format(L["TrackCount"], _trackCount)</p>
                    }
                    @if (_totalDuration > 0)
                    {
                        <p class="text-sm" Color="secondary">· @FormatTotalDuration(_totalDuration)</p>
                    }
                </div>

                @if (_album.Genres?.Any() == true)
                {
                    <div class="d-flex mt-2">
                        @foreach (var genre in _album.Genres)
                        {
                            <K7Chip Variant="outlined" Size="sm">@genre</K7Chip>
                        }
                    </div>
                }

                <div class="d-flex mt-3">
                    <K7Button Variant="filled"
                               Color="primary"
                               StartIcon="play"
                               OnClick="PlayAll">
                        @S["PlayAll"]
                    </K7Button>
                    <K7Button Variant="outlined"
                               Color="primary"
                               StartIcon="shuffle"
                               OnClick="ShuffleAll">
                        @S["Shuffle"]
                    </K7Button>
                </div>
            </div>
        </div>

        <div class="album-tracklist">
            @foreach (var discGroup in _tracksByDisc)
            {
                @if (_tracksByDisc.Count > 1)
                {
                    <p class="text-subtitle1 disc-header">@string.Format(L["DiscHeader"], discGroup.Key)</p>
                }

                <K7Table Items="discGroup.Value"
                          TItem="TrackViewModel"
                          OnRowClick="@(args => OnTrackClick(args))"
                          RowClass="cursor-pointer">
                    <HeaderContent>
                        <th Style="width: 50px;">#</th>
                        <th>@S["Title"]</th>
                        <th Style="width: 100px; text-align: right;">
                            <K7Icon Name="clock" Size="sm" />
                        </th>
                        <th Style="width: 130px;"></th>
                        <th Style="width: 50px;"></th>
                    </HeaderContent>
                    <RowTemplate>
                        <td>
                            @if (context.IsPlaying)
                            {
                                <K7Icon Name="equalizer"
                                         Size="sm"
                                         Color="primary" />
                            }
                            else
                            {
                                <p class="text-sm" Color="secondary">@context.TrackNumber</p>
                            }
                        </td>
                        <td>
                            <div class="d-flex flex-col">
                                <span Style="@(context.IsPlaying ? "color: var(--color-accent);" : "")">
                                    @context.Title
                                </span>
                                @if (!string.IsNullOrEmpty(context.ArtistName))
                                {
                                    <span class="text-caption" Color="secondary">@context.ArtistName</span>
                                }
                            </div>
                        </td>
                        <td Style="text-align: right;">
                            <p class="text-sm" Color="secondary">@FormatTime(context.Duration)</p>
                        </td>
                        <td>
                            <K7.Clients.Shared.UI.Components.RatingStars MediaId="context.Id" Value="context.UserRating" Size="sm" />
                        </td>
                        <td>
                            <K7.Clients.Shared.UI.Components.TrackContextMenu Track="BuildQueueItem(context)" />
                        </td>
                    </RowTemplate>
                </K7Table>
            }
        </div>

        @if (!string.IsNullOrEmpty(_album.Overview))
        {
            <div class="album-overview">
                <p class="text-subtitle1 mb-2">@S["About"]</p>
                <p class="text-sm" Color="secondary">@_album.Overview</p>
            </div>
        }
    </div>
}
else if (_loading)
{
    <div class="d-flex flex-col pa-16">
        <K7Spinner />
    </div>
}
