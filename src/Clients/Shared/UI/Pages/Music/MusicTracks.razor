@page "/music/tracks"
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject IStringLocalizer<MusicTracks> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@L["PageTitle"]</PageTitle>

<div class="d-flex pa-4" style="width: 100%">
    <h5>@L["PageTitle"]</h5>
    <div class="d-flex align-center">
        <K7TextField TValue="string"
                      @bind-Value="_searchText"
                      Placeholder="@L["SearchPlaceholder"]"
                      Variant="outlined"
                      Adornment="start"
                      AdornmentIcon="@Phosphor.MagnifyingGlass"
                      DebounceInterval="400"
                      OnDebounceIntervalElapsed="OnSearchChanged"
                      Style="max-width: 300px;" />
    </div>
</div>

@if (_loading)
{
    <div class="d-flex flex-col pa-16">
        <K7Spinner />
    </div>
}
else if (_tracks.Count == 0)
{
    <div class="d-flex flex-col pa-16">
        <K7Icon Icon="@Phosphor.MusicNote" Style="font-size: 64px; opacity: 0.3;" />
        <h6 Color="default" Style="opacity: 0.5;">@L["None"]</h6>
    </div>
}
else
{
    <div class="pa-4">
        <K7Table Items="_tracks"
                  TItem="TrackViewModel"
                  OnRowClick="@(args => OnTrackClick(args))"
                  RowClass="cursor-pointer">
            <HeaderContent>
                <th>@S["Title"]</th>
                <th>@S["Artist"]</th>
                <th>@S["Album"]</th>
                <th style="width: 80px;"><K7Icon Icon="@Phosphor.Clock" Size="sm" /></th>
                <th style="width: 130px;"></th>
                <th style="width: 50px;"></th>
            </HeaderContent>
            <RowTemplate>
                <td>
                    <div class="d-flex align-center">
                        @if (context.IsPlaying)
                        {
                            <K7Icon Icon="@Phosphor.Equalizer" Size="sm" Color="primary" />
                        }
                        <span Style="@(context.IsPlaying ? "color: var(--color-accent);" : "")">@context.Title</span>
                    </div>
                </td>
                <td>
                    @if (context.ArtistPersonId.HasValue)
                    {
                        <a href="@($"/music/artists/{context.ArtistPersonId}")" class="track-link" @onclick:stopPropagation="true">
                            <p class="text-sm" Color="secondary">@context.ArtistName</p>
                        </a>
                    }
                    else
                    {
                        <p class="text-sm" Color="secondary">@context.ArtistName</p>
                    }
                </td>
                <td>
                    <a href="@($"/music/albums/{context.AlbumId}")" class="track-link" @onclick:stopPropagation="true">
                        <p class="text-sm" Color="secondary">@context.AlbumTitle</p>
                    </a>
                </td>
                <td>
                    <p class="text-sm" Color="secondary">@FormatTime(context.Duration)</p>
                </td>
                <td>
                    <RatingStars MediaId="context.Id" Value="context.UserRating" Size="sm" />
                </td>
                <td>
                    <TrackContextMenu Track="BuildQueueItem(context)" />
                </td>
            </RowTemplate>
        </K7Table>
    </div>
}
