@page "/music/stats"
@inject IServerInfoService K7ServerService
@inject K7.Clients.Shared.Services.K7HubClient K7HubClient
@inject IStringLocalizer<MusicStats> L
@implements IDisposable
<PageTitle>@L["PageTitle"]</PageTitle>

<div class="page-scrollable">
<div class="d-flex pa-4" style="width: 100%">
    <h5>@L["PageTitle"]</h5>
</div>

@if (_loading)
{
    <div class="d-flex flex-col pa-16">
        <K7Spinner />
    </div>
}
else if (_stats is null)
{
    <div class="d-flex flex-col pa-16">
        <K7Icon Name="chart-bar" Style="font-size: 64px; opacity: 0.3;" />
        <h6 Color="default" Style="opacity: 0.5;">@L["NoData"]</h6>
        <p class="text-sm" Color="secondary">Écoutez de la musique pour voir apparaître vos statistiques.</p>
    </div>
}
else
{
    <div class="pa-4">
        <div class="grid">
            <div>
                <div class="surface pa-4">
                    <div class="d-flex flex-col">
                        <K7Icon Name="circle" Size="lg" Color="primary" />
                        <h4 Color="primary">@_stats.TotalListeningHours h</h4>
                        <p class="text-sm" Color="secondary">Temps d'écoute</p>
                    </div>
                </div>
            </div>
            <div>
                <div class="surface pa-4">
                    <div class="d-flex flex-col">
                        <K7Icon Name="play-circle" Size="lg" Color="primary" />
                        <h4 Color="primary">@_stats.TotalCompletedPlays</h4>
                        <p class="text-sm" Color="secondary">Écoutes complètes</p>
                    </div>
                </div>
            </div>
            <div>
                <div class="surface pa-4">
                    <div class="d-flex flex-col">
                        <K7Icon Name="music-notes" Size="lg" Color="primary" />
                        <h4 Color="primary">@_stats.UniqueTracksPlayed</h4>
                        <p class="text-sm" Color="secondary">Morceaux différents</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid">
            @if (_stats.TopArtists.Count > 0)
            {
                <div>
                    <h6>@L["TopArtists"]</h6>
                    <ul class="k7-list">
                        @foreach (var (artist, index) in _stats.TopArtists.Select((a, i) => (a, i)))
                        {
                            <li>
                                <div class="d-flex align-center">
                                    <p class="text-sm" Color="secondary" Style="min-width: 24px;">@(index + 1).</p>
                                    <span>@artist.Name</span>
                                    <div class="flex-1"></div>
                                    <K7Chip Size="sm" Color="primary" Variant="outlined">@artist.PlayCount écoutes</K7Chip>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }

            @if (_stats.TopAlbums.Count > 0)
            {
                <div>
                    <h6>@L["TopAlbums"]</h6>
                    <ul class="k7-list">
                        @foreach (var (album, index) in _stats.TopAlbums.Select((a, i) => (a, i)))
                        {
                            <li>
                                <div class="d-flex align-center">
                                    <p class="text-sm" Color="secondary" Style="min-width: 24px;">@(index + 1).</p>
                                    <span>@album.Name</span>
                                    <div class="flex-1"></div>
                                    <K7Chip Size="sm" Color="primary" Variant="outlined">@album.PlayCount écoutes</K7Chip>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }

            @if (_stats.TopTracks.Count > 0)
            {
                <div>
                    <h6>@L["TopTracks"]</h6>
                    <ul class="k7-list">
                        @foreach (var (track, index) in _stats.TopTracks.Select((t, i) => (t, i)))
                        {
                            <li>
                                <div class="d-flex align-center">
                                    <p class="text-sm" Color="secondary" Style="min-width: 24px;">@(index + 1).</p>
                                    <span>@track.Name</span>
                                    <div class="flex-1"></div>
                                    <K7Chip Size="sm" Color="primary" Variant="outlined">@track.PlayCount écoutes</K7Chip>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }

            @if (_stats.TopGenres.Count > 0)
            {
                <div>
                    <h6>@L["TopGenres"]</h6>
                    <ul class="k7-list">
                        @foreach (var (genre, index) in _stats.TopGenres.Select((g, i) => (g, i)))
                        {
                            <li>
                                <div class="d-flex align-center">
                                    <p class="text-sm" Color="secondary" Style="min-width: 24px;">@(index + 1).</p>
                                    <span>@genre.Genre</span>
                                    <div class="flex-1"></div>
                                    <K7Chip Size="sm" Color="secondary" Variant="outlined">@genre.PlayCount écoutes</K7Chip>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>
}
</div>
