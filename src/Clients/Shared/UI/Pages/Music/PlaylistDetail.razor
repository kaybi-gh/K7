@page "/playlists/{Id}"
@using K7.Shared.Dtos.Entities.Playlists
@inject IPlaylistService K7ServerService
@inject IK7ServerService ApiClient
@inject IStringLocalizer<PlaylistDetail> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@(_playlist?.Title ?? "Playlist")</PageTitle>

@if (_playlist is not null)
{
    <div class="playlist-detail-page">
        <div class="playlist-header">
            <div class="playlist-header-cover">
                @if (_coverUrl is not null)
                {
                    <K7Image Src="@_coverUrl"
                              Alt="@_playlist.Title"
                              Width="180"
                              ObjectFit="cover"
                              Class="rounded" />
                }
                else
                {
                    <div class="playlist-cover-placeholder-large">
                        <K7Icon Name="queue" Style="font-size: 64px; opacity: 0.3;" />
                    </div>
                }
            </div>

            <div class="playlist-header-info">
                <p class="text-overline">@L["Header"]</p>
                <h4>@_playlist.Title</h4>

                @if (!string.IsNullOrEmpty(_playlist.Description))
                {
                    <p class="text-sm mt-1"  Color="secondary" >@_playlist.Description</p>
                }

                <p class="text-sm mt-1"  Color="secondary" >
                    @_playlist.ItemCount @S["Tracks"]
                    @if (_totalDuration > 0)
                    {
                        <text> · @FormatTotalDuration(_totalDuration)</text>
                    }
                </p>

                <div class="d-flex mt-3">
                    <K7Button Variant="filled"
                               Color="primary"
                               StartIcon="@Phosphor.Play"
                               OnClick="PlayAll"
                               Disabled="@(_items.Count == 0)">
                        @S["PlayAll"]
                    </K7Button>
                    <K7Button Variant="outlined"
                               Color="primary"
                               StartIcon="@Phosphor.Shuffle"
                               OnClick="ShuffleAll"
                               Disabled="@(_items.Count == 0)">
                        @S["Shuffle"]
                    </K7Button>
                    <K7IconButton Icon="@Phosphor.Pencil"
                                   OnClick="OpenEditDialog" />
                    <K7IconButton Icon="@Phosphor.Trash" Color="error"
                                   OnClick="ConfirmDelete" />
                </div>
            </div>
        </div>

        @if (_loadingItems)
        {
            <K7ProgressBar Indeterminate="true" />
        }
        else if (_items.Count == 0)
        {
            <div class="d-flex flex-col pa-16">
                <K7Icon Name="music-note" Style="font-size: 48px; opacity: 0.3;" />
                <p Color="secondary">@L["Empty"]</p>
            </div>
        }
        else
        {
            <div class="playlist-tracklist">
                <K7Table Items="_items"
                          TItem="PlaylistItemViewModel"
                          OnRowClick="@(args => OnTrackClick(args))"
                          RowClass="cursor-pointer">
                    <HeaderContent>
                        <th Style="width: 50px;">#</th>
                        <th>@S["Title"]</th>
                        <th>@S["Artist"]</th>
                        <th>@S["Album"]</th>
                        <th Style="width: 80px;">
                            <K7Icon Name="clock" Size="sm" />
                        </th>
                        <th Style="width: 130px;"></th>
                        <th Style="width: 50px;"></th>
                        <th Style="width: 50px;"></th>
                    </HeaderContent>
                    <RowTemplate>
                        <td>
                            @if (context.IsPlaying)
                            {
                                <K7Icon Name="equalizer" Size="sm" Color="primary" />
                            }
                            else
                            {
                                <p class="text-sm" Color="secondary">@(context.Order + 1)</p>
                            }
                        </td>
                        <td>
                            <div class="d-flex align-center">
                                @if (context.CoverUrl is not null)
                                {
                                    <K7Image Src="@context.CoverUrl" Width="36"
                                              ObjectFit="cover" Class="rounded" loading="lazy" />
                                }
                                <span Style="@(context.IsPlaying ? "color: var(--color-accent);" : "")">
                                    @context.Title
                                </span>
                            </div>
                        </td>
                        <td>
                            <p class="text-sm" Color="secondary">@context.ArtistName</p>
                        </td>
                        <td>
                            <p class="text-sm" Color="secondary">@context.AlbumTitle</p>
                        </td>
                        <td>
                            <p class="text-sm" Color="secondary">@FormatTime(context.Duration)</p>
                        </td>
                        <td>
                            <RatingStars MediaId="context.MediaId" Value="context.UserRating" Size="sm" />
                        </td>
                        <td>
                            <TrackContextMenu Track="BuildQueueItem(context)" />
                        </td>
                        <td>
                            <span @onclick:stopPropagation="true">
                                <K7IconButton Icon="@Phosphor.X" Size="sm" Color="error"
                                               OnClick="() => RemoveItem(context)" />
                            </span>
                        </td>
                    </RowTemplate>
                </K7Table>
            </div>
        }
    </div>
}
else if (_loading)
{
    <div class="d-flex flex-col pa-16">
        <K7Spinner />
    </div>
}
