@page "/smart-playlists/{Id}"
@using K7.Shared.Dtos.Entities.Playlists
@inject IPlaylistService K7ServerService
@inject IK7ServerService ApiClient
@inject IStringLocalizer<SmartPlaylistDetail> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@(_smartPlaylist?.Title ?? "Smart Playlist")</PageTitle>

@if (_smartPlaylist is not null)
{
    <div class="playlist-detail-page">
        <div class="playlist-header">
            <div class="playlist-header-cover">
                <div class="playlist-cover-placeholder-large">
                    <K7Icon Name="sparkle" Style="font-size: 64px; opacity: 0.3;" />
                </div>
            </div>
            <div class="playlist-header-info">
                <p class="text-overline">@L["Header"]</p>
                <h4>@_smartPlaylist.Title</h4>

                @if (!string.IsNullOrEmpty(_smartPlaylist.Description))
                {
                    <p class="text-sm mt-1" Color="secondary">@_smartPlaylist.Description</p>
                }

                <div class="d-flex mt-1">
                    <p class="text-sm" Color="secondary">
                        @_smartPlaylist.Rules.Count règle@(_smartPlaylist.Rules.Count > 1 ? "s" : "")
                        · @_smartPlaylist.ItemCount @S["Tracks"]
                    </p>
                    @if (_smartPlaylist.LastEvaluatedAt.HasValue)
                    {
                        <p class="text-sm" Color="secondary">
                            · Évalué @FormatRelativeTime(_smartPlaylist.LastEvaluatedAt.Value)
                        </p>
                    }
                </div>

                <div class="d-flex mt-3">
                    <K7Button Variant="filled" Color="primary"
                               StartIcon="@Phosphor.Play"
                               OnClick="PlayAll" Disabled="@(_items.Count == 0)">
                        @S["PlayAll"]
                    </K7Button>
                    <K7Button Variant="outlined" Color="primary"
                               StartIcon="@Phosphor.Shuffle"
                               OnClick="ShuffleAll" Disabled="@(_items.Count == 0)">
                        @S["Shuffle"]
                    </K7Button>
                    <K7Button Variant="outlined" Color="secondary"
                               StartIcon="@Phosphor.ArrowClockwise"
                               OnClick="EvaluateAsync" Disabled="_evaluating">
                        @if (_evaluating)
                        {
                            <K7Spinner Size="sm" />
                            <text>@L["Evaluating"]</text>
                        }
                        else
                        {
                            <text>@L["Reevaluate"]</text>
                        }
                    </K7Button>
                    <button type="button" class="k7-icon-btn" @onclick="OpenEditDialog"><i class="ph ph-pencil"></i></button>
                    <button type="button" class="k7-icon-btn" @onclick="ConfirmDelete"><i class="ph ph-trash"></i></button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_rulesDescription))
        {
            <div class="surface ma-4 pa-3">
                <div class="d-flex">
                    <K7Icon Name="funnel" Size="sm" Color="secondary" />
                    <p class="text-sm" Color="secondary">@_rulesDescription</p>
                </div>
            </div>
        }

        @if (_loadingItems)
        {
            <K7ProgressBar Indeterminate="true" />
        }
        else if (_items.Count == 0)
        {
            <div class="d-flex flex-col pa-16">
                <K7Icon Name="music-note" Style="font-size: 48px; opacity: 0.3;" />
                <p Color="secondary">@L["NoResults"]</p>
            </div>
        }
        else
        {
            <div class="playlist-tracklist">
                <K7Table Items="_items"
                          TItem="SmartPlaylistItemViewModel" OnRowClick="@(args => OnTrackClick(args))" RowClass="cursor-pointer">
                    <HeaderContent>
                        <th Style="width: 50px;">#</th>
                        <th>@S["Title"]</th>
                        <th>@S["Artist"]</th>
                        <th>@S["Album"]</th>
                        <th Style="width: 80px;"><K7Icon Name="clock" Size="sm" /></th>
                        <th Style="width: 130px;"></th>
                        <th Style="width: 50px;"></th>
                    </HeaderContent>
                    <RowTemplate>
                        <td>
                            @if (context.IsPlaying)
                            {
                                <K7Icon Name="equalizer" Size="sm" Color="primary" />
                            }
                            else
                            {
                                <p class="text-sm" Color="secondary">@(context.Order + 1)</p>
                            }
                        </td>
                        <td>
                            <div class="d-flex align-center">
                                @if (context.CoverUrl is not null)
                                {
                                    <K7Image Src="@context.CoverUrl" Width="36"
                                              ObjectFit="cover" Class="rounded" loading="lazy" />
                                }
                                <span Style="@(context.IsPlaying ? "color: var(--color-accent);" : "")">
                                    @context.Title
                                </span>
                            </div>
                        </td>
                        <td><p class="text-sm" Color="secondary">@context.ArtistName</p></td>
                        <td><p class="text-sm" Color="secondary">@context.AlbumTitle</p></td>
                        <td><p class="text-sm" Color="secondary">@FormatTime(context.Duration)</p></td>
                        <td>
                            <RatingStars MediaId="context.MediaId" Value="context.UserRating" Size="sm" />
                        </td>
                        <td>
                            <TrackContextMenu Track="BuildQueueItem(context)" />
                        </td>
                    </RowTemplate>
                </K7Table>
            </div>
        }
    </div>
}
else if (_loading)
{
    <div class="d-flex flex-col pa-16">
        <K7Spinner />
    </div>
}
