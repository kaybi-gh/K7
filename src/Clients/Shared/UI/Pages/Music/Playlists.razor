@page "/playlists"
@using K7.Shared.Dtos.Entities.Playlists
@inject IPlaylistService K7ServerService
@inject IK7ServerService ApiClient
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Playlists> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@L["PageTitle"]</PageTitle>

<BrowseView TItem="LitePlaylistDto"
              Items="_playlists"
              Loading="_loading"
              PersistenceKey="playlists"
              DefaultItemWidth="200"
              DefaultSpacing="8"
              GridItemAspectRatio="1.3f">
    <ToolbarContent>
        <h5>@L["PageTitle"]</h5>
        <div class="flex-1"></div>
        <K7Menu>
            <ActivatorContent>
                <K7Button Variant="outlined" Color="primary" StartIcon="lightbulb">@L["Presets"]</K7Button>
            </ActivatorContent>
            <ChildContent>
                <K7MenuItem OnClick="() => CreatePreset(Preset.RecentlyAdded)">@L["PresetRecentlyAdded"]</K7MenuItem>
                <K7MenuItem OnClick="() => CreatePreset(Preset.MostPlayed)">@L["PresetMostPlayed"]</K7MenuItem>
                <K7MenuItem OnClick="() => CreatePreset(Preset.NeverPlayed)">@L["PresetNeverPlayed"]</K7MenuItem>
                <K7MenuItem OnClick="() => CreatePreset(Preset.HighlyRated)">@L["PresetHighlyRated"]</K7MenuItem>
                <K7MenuItem OnClick="() => CreatePreset(Preset.RecentlyPlayed)">@L["PresetRecentlyPlayed"]</K7MenuItem>
            </ChildContent>
        </K7Menu>
        <K7Menu>
            <ActivatorContent>
                <K7Button Variant="filled" Color="primary" StartIcon="plus">@L["NewMenu"]</K7Button>
            </ActivatorContent>
            <ChildContent>
                <K7MenuItem Icon="queue" OnClick="OpenCreatePlaylistDialog">Playlist</K7MenuItem>
                <K7MenuItem Icon="sparkle" OnClick="OpenCreateSmartPlaylistDialog">@L["SmartPlaylist"]</K7MenuItem>
            </ChildContent>
        </K7Menu>
    </ToolbarContent>
    <EmptyContent>
        <div class="d-flex flex-col pa-16">
            <K7Icon Name="music-notes-simple" Style="font-size: 64px; opacity: 0.3;" />
            <h6 Color="default" Style="opacity: 0.5;">@L["None"]</h6>
            <p class="text-sm" Color="secondary">@L["EmptyHint"]</p>
        </div>
    </EmptyContent>
    <GridTemplate Context="playlist">
        <div class="k7-card k7-card--outlined playlist-card" tabindex="0" role="button" @onclick="() => GoToPlaylist(playlist)" Style="cursor: pointer;">
            <div class="k7-card-content">
                <div class="d-flex flex-col">
                    @if (playlist.CoverPicture is not null)
                    {
                        <K7Image Src="@GetCoverUrl(playlist)"
                                  Width="120"
                                  ObjectFit="cover"
                                  Class="rounded"
                                  loading="lazy" />
                    }
                    else
                    {
                        <div class="playlist-cover-placeholder">
                            <K7Icon Name="@(playlist.IsSmartPlaylist ? "sparkle" : "music-notes-simple")"
                                     Style="font-size: 48px; opacity: 0.3;" />
                        </div>
                    }
                    <div class="d-flex align-center">
                        <p class="text-subtitle1 playlist-title text-center">@playlist.Title</p>
                        @if (playlist.IsSmartPlaylist)
                        {
                            <K7Icon Name="sparkle" Size="sm" Color="secondary" />
                        }
                    </div>
                    <span class="text-caption" Color="secondary">@playlist.ItemCount @S["Tracks"]</span>
                </div>
            </div>
        </div>
    </GridTemplate>
</BrowseView>
