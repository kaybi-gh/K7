@page "/playlists"
@using K7.Shared.Dtos.Entities.Playlists
@inject IPlaylistService K7ServerService
@inject IK7ServerService ApiClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Playlists> L
@inject IStringLocalizer<SharedResource> S
<PageTitle>@L["PageTitle"]</PageTitle>

<BrowseView TItem="LitePlaylistDto"
              Items="_playlists"
              Loading="_loading"
              PersistenceKey="playlists"
              DefaultItemWidth="200"
              DefaultSpacing="8"
              GridItemAspectRatio="1.3f">
    <ToolbarContent>
        <MudText Typo="Typo.h5">@L["PageTitle"]</MudText>
        <MudSpacer />
        <MudMenu Label="@L["Presets"]" Variant="Variant.Outlined" Color="Color.Primary"
                 StartIcon="@Icons.Material.Filled.Lightbulb" Dense="true">
            <MudMenuItem OnClick="() => CreatePreset(Preset.RecentlyAdded)">@L["PresetRecentlyAdded"]</MudMenuItem>
            <MudMenuItem OnClick="() => CreatePreset(Preset.MostPlayed)">@L["PresetMostPlayed"]</MudMenuItem>
            <MudMenuItem OnClick="() => CreatePreset(Preset.NeverPlayed)">@L["PresetNeverPlayed"]</MudMenuItem>
            <MudMenuItem OnClick="() => CreatePreset(Preset.HighlyRated)">@L["PresetHighlyRated"]</MudMenuItem>
            <MudMenuItem OnClick="() => CreatePreset(Preset.RecentlyPlayed)">@L["PresetRecentlyPlayed"]</MudMenuItem>
        </MudMenu>
        <MudMenu Label="@L["NewMenu"]" Variant="Variant.Filled" Color="Color.Primary"
                 StartIcon="@Icons.Material.Filled.Add" Dense="true">
            <MudMenuItem Icon="@Icons.Material.Filled.QueueMusic" OnClick="OpenCreatePlaylistDialog">Playlist</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.AutoAwesome" OnClick="OpenCreateSmartPlaylistDialog">@L["SmartPlaylist"]</MudMenuItem>
        </MudMenu>
    </ToolbarContent>
    <EmptyContent>
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-16">
            <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 64px; opacity: 0.3;" />
            <MudText Typo="Typo.h6" Color="Color.Default" Style="opacity: 0.5;">@L["None"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["EmptyHint"]</MudText>
        </MudStack>
    </EmptyContent>
    <GridTemplate Context="playlist">
        <MudCard Outlined="true" Class="playlist-card" tabindex="0" @onclick="() => GoToPlaylist(playlist)" @onkeydown="(e) => OnPlaylistKeyDown(e, playlist)" Style="cursor: pointer;">
            <MudCardContent>
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    @if (playlist.CoverPicture is not null)
                    {
                        <MudImage Src="@GetCoverUrl(playlist)"
                                  Width="120" Height="120"
                                  ObjectFit="ObjectFit.Cover"
                                  Class="rounded"
                                  loading="lazy" />
                    }
                    else
                    {
                        <div class="playlist-cover-placeholder">
                            <MudIcon Icon="@(playlist.IsSmartPlaylist ? Icons.Material.Filled.AutoAwesome : Icons.Material.Filled.QueueMusic)"
                                     Style="font-size: 48px; opacity: 0.3;" />
                        </div>
                    }
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="playlist-title">@playlist.Title</MudText>
                        @if (playlist.IsSmartPlaylist)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Color="Color.Secondary" />
                        }
                    </MudStack>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@playlist.ItemCount @S["Tracks"]</MudText>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </GridTemplate>
</BrowseView>
