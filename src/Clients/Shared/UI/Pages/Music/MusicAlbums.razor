@page "/music/albums"
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject IStringLocalizer<MusicAlbums> L
<PageTitle>@L["PageTitle"]</PageTitle>

<BrowseView TItem="AlbumViewModel"
              Items="_albums"
              Loading="_loading"
              PersistenceKey="music-albums"
              DefaultItemWidth="160"
              DefaultSpacing="6"
              GridItemAspectRatio="1.5f">
    <ToolbarContent>
        <h5>@L["PageTitle"]</h5>
        <div class="flex-1"></div>
        <K7TextField TValue="string"
                      @bind-Value="_searchText"
                      Placeholder="@L["SearchPlaceholder"]"
                      Variant="outlined"
                      Adornment="start"
                      AdornmentIcon="@Phosphor.MagnifyingGlass"
                      DebounceInterval="400"
                      OnDebounceIntervalElapsed="OnSearchChanged"
                      Style="max-width: 300px;" />
    </ToolbarContent>
    <LoadingContent>
        <div class="grid">
            @for (var i = 0; i < 12; i++)
            {
                <div>
                    <div class="surface">
                        <K7Skeleton />
                        <K7Skeleton />
                        <K7Skeleton />
                    </div>
                </div>
            }
        </div>
    </LoadingContent>
    <EmptyContent>
        <div class="d-flex flex-col pa-16">
            <K7Icon Name="vinyl-record" Style="font-size: 64px; opacity: 0.3;" />
            <h6 Color="default" Style="opacity: 0.5;">@L["None"]</h6>
        </div>
    </EmptyContent>
    <GridTemplate Context="album">
        <a href="@($"/music/albums/{album.Id}")" class="album-card-link">
            <div class="surface album-card">
                @if (album.CoverUrl is not null)
                {
                    <K7Image Src="@album.CoverUrl"
                              Alt="@album.Title"
                              Width="160"
                              ObjectFit="cover"
                              Class="album-cover"
                              loading="lazy" />
                }
                else
                {
                    <div class="album-cover-placeholder">
                        <K7Icon Name="vinyl-record"
                                 Style="font-size: 48px; opacity: 0.3;" />
                    </div>
                }
                <p class="text-subtitle2 mt-2 album-title">@album.Title</p>
                @if (!string.IsNullOrEmpty(album.Artist))
                {
                    <span class="text-caption album-artist"  Color="secondary" >@album.Artist</span>
                }
            </div>
        </a>
    </GridTemplate>
</BrowseView>
