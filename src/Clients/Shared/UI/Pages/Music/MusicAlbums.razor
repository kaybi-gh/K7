@page "/music/albums"
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject IStringLocalizer<MusicAlbums> L
<PageTitle>@L["PageTitle"]</PageTitle>

<BrowseView TItem="AlbumViewModel"
              Items="_albums"
              Loading="_loading"
              PersistenceKey="music-albums"
              DefaultItemWidth="160"
              DefaultSpacing="6"
              GridItemAspectRatio="1.5f">
    <ToolbarContent>
        <MudText Typo="Typo.h5">@L["PageTitle"]</MudText>
        <MudSpacer />
        <MudTextField T="string"
                      @bind-Value="_searchText"
                      Placeholder="@L["SearchPlaceholder"]"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      DebounceInterval="400"
                      OnDebounceIntervalElapsed="OnSearchChanged"
                      Margin="Margin.Dense"
                      Style="max-width: 300px;" />
    </ToolbarContent>
    <LoadingContent>
        <MudGrid Style="max-width:100%;" Spacing="6" Justify="Justify.FlexStart" Class="pa-4">
            @for (var i = 0; i < 12; i++)
            {
                <MudItem>
                    <MudPaper Style="width: 160px;" Elevation="0">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="160px" Height="160px" Class="rounded-lg" />
                        <MudSkeleton Width="90%" Class="mt-2" />
                        <MudSkeleton Width="60%" />
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </LoadingContent>
    <EmptyContent>
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-16">
            <MudIcon Icon="@Icons.Material.Outlined.Album" Style="font-size: 64px; opacity: 0.3;" />
            <MudText Typo="Typo.h6" Color="Color.Default" Style="opacity: 0.5;">@L["None"]</MudText>
        </MudStack>
    </EmptyContent>
    <GridTemplate Context="album">
        <a href="@($"/music/albums/{album.Id}")" class="album-card-link">
            <MudPaper Class="album-card" Elevation="0">
                @if (album.CoverUrl is not null)
                {
                    <MudImage Src="@album.CoverUrl"
                              Alt="@album.Title"
                              Width="160" Height="160"
                              ObjectFit="ObjectFit.Cover"
                              Class="album-cover"
                              loading="lazy" />
                }
                else
                {
                    <div class="album-cover-placeholder">
                        <MudIcon Icon="@Icons.Material.Outlined.Album"
                                 Style="font-size: 48px; opacity: 0.3;" />
                    </div>
                }
                <MudText Typo="Typo.subtitle2" Class="mt-2 album-title">@album.Title</MudText>
                @if (!string.IsNullOrEmpty(album.Artist))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="album-artist">@album.Artist</MudText>
                }
            </MudPaper>
        </a>
    </GridTemplate>
</BrowseView>
