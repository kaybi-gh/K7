@page "/settings/social"
@layout SettingsLayout
@using K7.Server.Domain.Enums
@using K7.Shared.Dtos.Federation.Social
@inject IStringLocalizer<SettingsSocialPage> L
@inject IStringLocalizer<SharedResource> S
@inject IReviewService ReviewService
@inject IK7Snackbar Snackbar

<PageTitle>@L["Title"]</PageTitle>

<h4>@L["Title"]</h4>

@if (_loading)
{
    <K7ProgressBar Indeterminate="true" />
}
else
{
    <div class="settings-form-page">
        <div class="settings-form-page__body pa-4 d-flex flex-col gap-4">
            <K7Alert Severity="K7Severity.Info" Variant="outlined" NoIcon="true">
                @L["FederationDirectPeersNote"]
            </K7Alert>

            <section class="settings-section d-flex flex-col gap-3">
                <h6 class="mb-0">@L["ShareTitle"]</h6>
                @RenderShareRow(L["Reviews"], FederationContentType.Reviews, () => _privacy.Share.Reviews, v => _privacy.Share.Reviews = v)
                @RenderShareRow(L["Collections"], FederationContentType.Collections, () => _privacy.Share.Collections, v => _privacy.Share.Collections = v)
                @RenderShareRow(L["Playlists"], FederationContentType.Playlists, () => _privacy.Share.Playlists, v => _privacy.Share.Playlists = v)
                @RenderShareRow(L["SmartPlaylists"], FederationContentType.SmartPlaylists, () => _privacy.Share.SmartPlaylists, v => _privacy.Share.SmartPlaylists = v)
                @RenderShareRow(L["PlaybackHistory"], FederationContentType.PlaybackHistory, () => _privacy.Share.PlaybackHistory, v => _privacy.Share.PlaybackHistory = v)
            </section>

            <hr class="k7-divider" />

            <section class="settings-section d-flex flex-col gap-3">
                <h6 class="mb-0">@L["ViewTitle"]</h6>
                <K7Switch @bind-Value="_reviewPreferences.BlurReviewsForUnwatchedMedia" Label="@L["BlurReviewsForUnwatchedMedia"]" />
                @RenderViewRow(L["Reviews"], FederationContentType.Reviews, () => _privacy.View.Reviews, v => _privacy.View.Reviews = v)
                @RenderViewRow(L["Collections"], FederationContentType.Collections, () => _privacy.View.Collections, v => _privacy.View.Collections = v)
                @RenderViewRow(L["Playlists"], FederationContentType.Playlists, () => _privacy.View.Playlists, v => _privacy.View.Playlists = v)
                @RenderViewRow(L["SmartPlaylists"], FederationContentType.SmartPlaylists, () => _privacy.View.SmartPlaylists, v => _privacy.View.SmartPlaylists = v)
                @RenderViewRow(L["PlaybackHistory"], FederationContentType.PlaybackHistory, () => _privacy.View.PlaybackHistory, v => _privacy.View.PlaybackHistory = v)
            </section>
        </div>

        <K7SettingsActionBar IsDirty="IsDirty"
                             IsSaving="_saving"
                             ShowResetToDefaults="false"
                             OnSave="SaveAsync"
                             OnCancel="CancelChanges" />
    </div>
}

@code {
    private RenderFragment RenderShareRow(
        string label,
        FederationContentType contentType,
        Func<VisibilityScope> getter,
        Action<VisibilityScope> setter) => __builder =>
    {
        var value = getter();
        <K7VisibilityScopeSelect Label="@label" Value="value" ValueChanged="@(v => { setter(v); OnFormChanged(); })" />
        if (value == VisibilityScope.SpecificPeople)
        {
            <FederationVisibilityGrantsEditor ContentType="contentType" @bind-Grants="_shareGrants" />
        }
    };

    private RenderFragment RenderViewRow(
        string label,
        FederationContentType contentType,
        Func<VisibilityScope> getter,
        Action<VisibilityScope> setter) => __builder =>
    {
        var value = getter();
        <K7VisibilityScopeSelect Label="@label" Value="value" ValueChanged="@(v => { setter(v); OnFormChanged(); })" />
        if (value == VisibilityScope.SpecificPeople)
        {
            <FederationVisibilityGrantsEditor ContentType="contentType" @bind-Grants="_viewGrants" />
        }
    };
}
