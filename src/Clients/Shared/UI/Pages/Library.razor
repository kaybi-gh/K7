@page "/library/{id}"
@using K7.Server.Domain.Enums
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject ILibraryService LibraryService
@inject IStringLocalizer<Library> L
@inject IStringLocalizer<SharedResource> S

<PageTitle>@string.Format(L["PageTitle"].Value, Id)</PageTitle>

<BrowseView TItem="MediaCardViewModel"
              Items="MediaCards"
              Loading="_loading"
              PersistenceKey="@($"library-{Id}")"
              DefaultItemWidth="160"
              DefaultSpacing="6"
              GridItemAspectRatio="1.8f">
    <ToolbarContent>
        <span>@string.Format(L["ItemCount"], MediaCards.Count)</span>
        @if (_availableMediaTypes.Count > 1)
        {
            @foreach (var mt in _availableMediaTypes)
            {
                var mediaType = mt;
                <K7Chip Value="@mt" Variant="@(_selectedMediaType.Equals(mt) ? "filled" : "outlined")" Color="primary" Text="@GetMediaTypeLabel(mt)" OnClick="() => OnMediaTypeFilterChanged(mediaType)" />
            }
        }
    </ToolbarContent>
    <GridTemplate Context="item">
        <MediaCard Model="item" Variant="@GetVariant(item)" Href="@GetItemHref(item)" OverlayEnabled="true" ProgressEnabled="true" WatchedStatusEnabled="true" FooterVisible="true" />
    </GridTemplate>
    <TableHeaderContent>
        <th>@L["Title"]</th>
        <th>@L["Status"]</th>
    </TableHeaderContent>
    <TableRowTemplate Context="item">
        <tr tabindex="0" role="button" @onclick="() => NavigateToItem(item)" @onkeydown="(e) => OnRowKeyDown(e, item)">
            <td>
                <div class="library-table-title">
                    @if (!string.IsNullOrEmpty(item.PictureUrl))
                    {
                        <K7Image Src="@item.PictureUrl" Alt="@item.Title" Width="40" ObjectFit="cover" Class="rounded" loading="lazy" />
                    }
                    <p class="text-sm">@item.Title</p>
                </div>
            </td>
            <td>
                @if (item.Watched)
                {
                    <K7Icon Name="check-circle" Color="success" Size="sm" />
                }
            </td>
        </tr>
    </TableRowTemplate>
    <ListTemplate Context="item">
        <a href="@GetItemHref(item)" class="library-list-item">
            @if (!string.IsNullOrEmpty(item.PictureUrl))
            {
                <K7Image Src="@item.PictureUrl" Alt="@item.Title" Width="40" ObjectFit="cover" Class="rounded" loading="lazy" />
            }
            <div class="library-list-info">
                <p>@item.Title</p>
                @if (!string.IsNullOrEmpty(item.AdditionalInformations))
                {
                    <span class="text-caption" Color="secondary">@item.AdditionalInformations</span>
                }
            </div>
            @if (item.Watched)
            {
                <K7Icon Name="check-circle" Color="success" Size="sm" />
            }
        </a>
    </ListTemplate>
</BrowseView>

