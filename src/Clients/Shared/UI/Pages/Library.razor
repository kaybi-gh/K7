@page "/library/{id}"
@inject IMediaService k7ServerService
@inject IK7ServerService apiClient
@inject ILibraryService libraryService
@inject IStringLocalizer<Library> L

<PageTitle>@string.Format(L["PageTitle"].Value, Id)</PageTitle>

<BrowseView TItem="MediaCardViewModel"
              Items="MediaCards"
              Loading="_loading"
              PersistenceKey="@($"library-{Id}")"
              DefaultItemWidth="160"
              DefaultSpacing="6"
              GridItemAspectRatio="1.8f">
    <ToolbarContent>
        <span>@MediaCards.Count items</span>
        <MudIconButton Icon="@Icons.Material.Outlined.SortByAlpha" />
        <MudIconButton Icon="@Icons.Material.Outlined.FilterList" />
    </ToolbarContent>
    <GridTemplate Context="item">
        <MediaCard Model="item" Href="@GetItemHref(item)" OverlayEnabled="true" ProgressEnabled="true" WatchedStatusEnabled="true" FooterVisible="true" />
    </GridTemplate>
    <TableHeaderContent>
        <th>@L["Title"]</th>
        <th>@L["Status"]</th>
    </TableHeaderContent>
    <TableRowTemplate Context="item">
        <tr @onclick="() => NavigateToItem(item)">
            <td>
                <div class="library-table-title">
                    @if (!string.IsNullOrEmpty(item.PictureUrl))
                    {
                        <MudImage Src="@item.PictureUrl" Alt="@item.Title" Width="40" Height="60" ObjectFit="ObjectFit.Cover" Class="rounded" loading="lazy" />
                    }
                    <MudText Typo="Typo.body2">@item.Title</MudText>
                </div>
            </td>
            <td>
                @if (item.Watched)
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                }
            </td>
        </tr>
    </TableRowTemplate>
    <ListTemplate Context="item">
        <a href="@GetItemHref(item)" class="library-list-item">
            @if (!string.IsNullOrEmpty(item.PictureUrl))
            {
                <MudImage Src="@item.PictureUrl" Alt="@item.Title" Width="40" Height="60" ObjectFit="ObjectFit.Cover" Class="rounded" loading="lazy" />
            }
            <div class="library-list-info">
                <MudText Typo="Typo.body1">@item.Title</MudText>
                @if (!string.IsNullOrEmpty(item.AdditionalInformations))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.AdditionalInformations</MudText>
                }
            </div>
            @if (item.Watched)
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
            }
        </a>
    </ListTemplate>
</BrowseView>

