@page "/settings/general"
@layout SettingsLayout
@inject ThemeService ThemeService
@inject IDeviceService DeviceService
@inject IK7ServerService ApiClient
@inject IStringLocalizer<Settings> L
@inject IStringLocalizer<SharedResource> S
@inject IK7DialogService DialogService
@inject IServerConnectionService ServerConnectionService
@inject IUserAdminService UserService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<PageTitle>@L["GeneralPageTitle"]</PageTitle>

<h4 class="mb-4">@L["GeneralPageTitle"]</h4>

<div class="pa-4">
    <K7Select TValue="ThemeDefinition" Label="@L["Theme"]" @bind-Value="@ThemeService.Theme" ToStringFunc="@(t => t?.Name)">
        @foreach (var theme in Themes.Collection)
        {
            <K7SelectItem Value="@theme" Text="@theme?.Name">@theme?.Name</K7SelectItem>
        }
    </K7Select>

    <K7LanguageSelect Value="@_currentCulture" ValueChanged="OnCultureChanged" Label="@L["Language"]" Languages="SupportedLanguages.Interface" Class="mt-4" />

    @if (DeviceService.GetClientType() == Server.Domain.Enums.ClientType.Web)
    {
        <K7TextField @bind-Value="@_backendUrl" Label="@L["ServerUrl"]" ReadOnly="true" Variant="text" />
    }
    else
    {
        <K7TextField @bind-Value="@_backendUrl" Label="@L["ServerUrl"]" ReadOnly="true" Variant="text" Adornment="end" AdornmentIcon="@Phosphor.Trash" OnAdornmentClick="ChangeBackendUrl" />
    }
</div>
