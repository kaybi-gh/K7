@page "/linkdevice"
@layout Layout.EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<PageTitle>Device Activation - K7</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="d-flex align-center justify-center" Style="min-height:80vh;">
    <MudPaper Class="pa-4 pa-sm-8" Elevation="4" Style="width:100%; max-width:600px;">
        <MudStack Spacing="4" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Outlined.Tv" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h5" Align="Align.Center">Sign in to K7</MudText>

            @if (_loading)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Requesting device code...</MudText>
                </MudStack>
            }
            else if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-2" Style="width:100%;">
                    @_error
                </MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="StartDeviceCodeFlowAsync">
                    Try Again
                </MudButton>
            }
            else if (_authorized)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mt-2" Style="width:100%;">
                    Device authorized! You are now signed in.
                </MudAlert>
            }
            else if (_deviceCode is not null)
            {
                <MudDivider Class="my-2" Style="width:100%;" />

                <MudGrid Justify="Justify.Center" Spacing="4">
                    <MudItem xs="12" sm="6">
                        <MudStack Spacing="2" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center">
                                1. Using a browser on another device, visit:
                            </MudText>
                            <MudText Typo="Typo.h6" Color="Color.Primary" Align="Align.Center">
                                @_displayUri
                            </MudText>

                            <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center" Class="mt-4">
                                2. And enter the code:
                            </MudText>
                            <MudPaper Class="pa-3" Elevation="0" Style="background: var(--mud-palette-surface); border-radius: 8px; width:100%;">
                                <MudText Typo="Typo.h4" Align="Align.Center"
                                         Style="letter-spacing:0.2em; font-weight:bold;">
                                    @_deviceCode.UserCode
                                </MudText>
                            </MudPaper>
                        </MudStack>
                    </MudItem>

                    <MudItem xs="12" sm="1" Class="d-flex align-center justify-center">
                        <MudText Typo="Typo.h6" Color="Color.Secondary">OR</MudText>
                    </MudItem>

                    <MudItem xs="12" sm="5">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center">
                                Scan the QR code below
                            </MudText>
                            <div id="device-qr" style="background:white; padding:12px; border-radius:8px; display:inline-block;"></div>
                        </MudStack>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-2" Style="width:100%;" />

                <MudStack AlignItems="AlignItems.Center" Spacing="2" Style="width:100%;">
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="width:100%;" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Waiting for authorization...</MudText>
                </MudStack>
            }
        </MudStack>
    </MudPaper>
</MudContainer>
