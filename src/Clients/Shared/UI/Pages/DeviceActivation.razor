@page "/linkdevice"
@layout EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject IStringLocalizer<DeviceActivation> L

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="container">
    <div class="surface pa-4 pa-sm-8">
        <div class="d-flex flex-col">
            <K7Icon Name="television" Size="lg" Color="primary" />
            <h5 class="text-center">@L["Title"]</h5>

            @if (_loading)
            {
                <div class="d-flex flex-col">
                    <K7Spinner />
                    <p class="text-sm color-secondary">@L["Activating"]</p>
                </div>
            }
            else if (_error is not null)
            {
                <K7Alert Severity="K7Severity.Error" Variant="filled" Class="mt-2 w-full">
                    @_error
                </K7Alert>
                <K7Button Variant="filled" Color="primary" OnClick="StartDeviceCodeFlowAsync">
                    @L["Activate"]
                </K7Button>
            }
            else if (_authorized)
            {
                <K7Alert Severity="K7Severity.Success" Variant="filled" Class="mt-2 w-full">
                    @L["ActivationSuccess"]
                </K7Alert>
            }
            else if (_deviceCode is not null)
            {
                <hr class="k7-divider my-2" />

                <div class="grid">
                    <div>
                        <div class="d-flex flex-col">
                            <p class="text-center color-secondary">
                                @L["Instructions"]
                            </p>
                            <h6 class="text-center color-primary">
                                @_displayUri
                            </h6>

                            <p class="mt-4 text-center color-secondary">
                                @L["CodeLabel"]
                            </p>
                            <div class="surface pa-3">
                                <h4 class="text-center"
                                         style="letter-spacing:0.2em; font-weight:bold;">
                                    @_deviceCode.UserCode
                                </h4>
                            </div>
                        </div>
                    </div>

                    <div>
                        <h6 class="color-secondary">OR</h6>
                    </div>

                    <div>
                        <div class="d-flex flex-col">
                            <p class="text-center color-secondary">
                                @L["ScanQrCode"]
                            </p>
                            <div id="device-qr" style="background:white; padding:12px; border-radius:8px; display:inline-block;"></div>
                        </div>
                    </div>
                </div>

                <hr class="k7-divider my-2" />

                <div class="d-flex flex-col" style="width:100%;">
                    <K7ProgressBar Indeterminate="true" />
                    <p class="text-sm color-secondary">@L["Activating"]</p>
                </div>
            }
        </div>
    </div>
</div>
