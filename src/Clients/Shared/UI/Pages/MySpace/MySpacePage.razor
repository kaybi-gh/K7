@page "/my-space"
@layout MySpaceLayout
@inject IStringLocalizer<MySpacePage> L
@inject NavigationManager NavigationManager
@inject IDeviceService DeviceService

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="my-space-hub page-scrollable">
    <div class="my-space-cards">
        <K7CategoryCard Title="@L["Playlists"]"
                         Description="@L["PlaylistsDesc"]"
                         Icon="@Phosphor.Queue"
                         GradientStart="rgba(80,20,80,0.85)"
                         GradientEnd="rgba(20,20,40,0.85)"
                         IconColor="rgba(120,40,120,0.6)"
                         OnClick="@(() => NavigationManager.NavigateTo("/my-space/playlists"))" />

        <K7CategoryCard Title="@L["Collections"]"
                         Description="@L["CollectionsDesc"]"
                         Icon="@Phosphor.BookmarkSimple"
                         GradientStart="rgba(20,60,80,0.85)"
                         GradientEnd="rgba(10,20,40,0.85)"
                         IconColor="rgba(30,80,120,0.6)"
                         OnClick="@(() => NavigationManager.NavigateTo("/my-space/collections"))" />

        <K7CategoryCard Title="@L["Stats"]"
                         Description="@L["StatsDesc"]"
                         Icon="@Phosphor.ChartBar"
                         GradientStart="rgba(20,80,40,0.85)"
                         GradientEnd="rgba(10,20,20,0.85)"
                         IconColor="rgba(30,120,60,0.6)"
                         OnClick="@(() => NavigationManager.NavigateTo("/my-space/stats"))" />

        <K7CategoryCard Title="@L["History"]"
                         Description="@L["HistoryDesc"]"
                         Icon="@Phosphor.ClockCounterClockwise"
                         GradientStart="rgba(80,50,20,0.85)"
                         GradientEnd="rgba(30,20,10,0.85)"
                         IconColor="rgba(140,90,30,0.6)"
                         OnClick="@(() => NavigationManager.NavigateTo("/my-space/history"))" />

        @if (DeviceService.GetClientType() != ClientType.Web)
        {
            <K7CategoryCard Title="@L["Downloads"]"
                             Description="@L["DownloadsDesc"]"
                             Icon="@Phosphor.DownloadSimple"
                             GradientStart="rgba(20,20,80,0.85)"
                             GradientEnd="rgba(10,10,30,0.85)"
                             IconColor="rgba(40,40,140,0.6)"
                             OnClick="@(() => NavigationManager.NavigateTo("/my-space/downloads"))" />
        }
    </div>
</div>
