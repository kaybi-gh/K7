@page "/my-space/reviews"
@layout MySpaceLayout
@using K7.Clients.Shared.Enums
@using K7.Clients.Shared.UI.Components.Dialogs
@using K7.Clients.Shared.UI.Helpers
@using K7.Server.Domain.Enums
@using K7.Shared.Dtos.Federation.Social
@inject IStringLocalizer<MySpaceReviewsPage> L
@inject IStringLocalizer<SharedResource> S
@inject IStringLocalizer<MediaReviewDialog> ReviewDialogL

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="my-space-reviews-page">
<BrowseView TItem="SocialUserReviewViewDto"
            Items="_filteredReviews"
            Loading="_loading"
            PersistenceKey="my-space-reviews"
            Class="my-space-library-browse my-space-reviews-browse"
            DefaultItemWidth="400"
            DefaultSpacing="24"
            GridItemAspectRatio="@((float?)null)"
            SingleColumnOnMobile="true"
            ListItemHeight="264"
            @ref="_browseView">
    <ToolbarContent>
        <h5>@L["PageTitle"]</h5>
        <div class="flex-1"></div>
        @if (_mediaTypeOptions.Count > 1)
        {
            <K7ButtonGroup TValue="MediaType?"
                           Options="_mediaTypeOptions"
                           Value="_mediaTypeFilter"
                           ValueChanged="OnMediaTypeFilterChanged"
                           AriaLabel="@L["MediaTypeFilter"]" />
        }
        <K7Select TValue="ReviewOrderingOption" Class="library-toolbar-sort" Value="_selectedSort" ValueChanged="OnSortChanged">
            @foreach (var opt in MySpaceReviewsBrowseSort.Options)
            {
                <K7SelectItem Value="@opt" Text="@GetSortLabel(opt)">@GetSortLabel(opt)</K7SelectItem>
            }
        </K7Select>
        <K7ResultCount Count="_filteredReviews.Count" />
    </ToolbarContent>
    <EmptyContent>
        @if (_allReviews.Count == 0)
        {
            <K7EmptyState Icon="@Phosphor.ChatCircleText" Title="@L["Empty"]" />
        }
        else
        {
            <div class="browse-view-empty">
                <K7Icon Icon="@Phosphor.MagnifyingGlass" Style="font-size: 48px; opacity: 0.3;" />
                <p class="text-secondary">@S["NoResults"]</p>
            </div>
        }
    </EmptyContent>
    <GridTemplate Context="review">
        <MySpaceReviewCard Review="review"
                           OnEdit="() => EditReviewAsync(review)"
                           OnDelete="() => DeleteReviewAsync(review)" />
    </GridTemplate>
    <ListTemplate Context="review">
        <div class="my-space-review-list-item">
            <MySpaceReviewCard Review="review"
                               Compact="true"
                               OnEdit="() => EditReviewAsync(review)"
                               OnDelete="() => DeleteReviewAsync(review)" />
        </div>
    </ListTemplate>
</BrowseView>
</div>
