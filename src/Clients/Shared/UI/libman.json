{
  "version": "3.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "provider": "jsdelivr",
      "library": "embla-carousel@8.6.0",
      "destination": "wwwroot/dist/embla-carousel/",
      "files": [
        "embla-carousel.umd.js"
      ]
    },
    {
      "library": "qrcodejs@1.0.0",
      "destination": "wwwroot/dist/qrcodejs/",
      "files": [
        "qrcode.min.js"
      ]
    },
    {
      "provider": "jsdelivr",
      "library": "@fontsource/epilogue@5.0.8",
      "destination": "wwwroot/lib/fonts/epilogue",
      "files": [
        "latin-700.css",
        "latin-900.css",
        "files/epilogue-latin-700-normal.woff2",
        "files/epilogue-latin-900-normal.woff2"
      ]
    },
    {
      "provider": "jsdelivr",
      "library": "@fontsource/manrope@5.0.8",
      "destination": "wwwroot/lib/fonts/manrope",
      "files": [
        "latin-400.css",
        "latin-500.css",
        "latin-700.css",
        "files/manrope-latin-400-normal.woff2",
        "files/manrope-latin-500-normal.woff2",
        "files/manrope-latin-700-normal.woff2"
      ]
    },
    {
      "provider": "jsdelivr",
      "library": "@phosphor-icons/web@2.1.2",
      "destination": "wwwroot/dist/phosphor-icons/",
      "files": [
        "src/regular/style.css",
        "src/regular/Phosphor.woff2",
        "src/fill/style.css",
        "src/fill/Phosphor-Fill.woff2",
        "src/bold/style.css",
        "src/bold/Phosphor-Bold.woff2",
        "src/thin/style.css",
        "src/thin/Phosphor-Thin.woff2",
        "src/light/style.css",
        "src/light/Phosphor-Light.woff2",
        "src/duotone/style.css",
        "src/duotone/Phosphor-Duotone.woff2"
      ]
    }
  ]
}
