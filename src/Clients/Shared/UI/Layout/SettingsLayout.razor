@inherits LayoutComponentBase
@layout MainLayout
@inject IStringLocalizer<SettingsLayout> L
@inject IDeviceService DeviceService

<SidebarLayout Title="@L["Title"]">
    <SidebarContent>
        <nav class="page-sidebar-nav">
            @if (!_isGuest)
            {
                <SidebarNavLink Href="/settings/account" Title="@L["Account"]" Icon="@Phosphor.UserCircle" />
                <SidebarNavLink Href="/settings/shared-profiles" Title="@L["SharedProfiles"]" Icon="@Phosphor.UsersThree" />
            }
            <SidebarNavLink Href="/settings/general" Title="@L["Interface"]" Icon="@Phosphor.SlidersHorizontal" />

            @if (!_isGuest)
            {
                <SidebarNavGroup Title="@L["GroupMyContent"]" Icon="@Phosphor.Stack" Routes="@MyContentRoutes">
                    <NavLink class="nav-link focusable" href="/settings/libraries">
                        <span class="nav-icon"><K7Icon Icon="@Phosphor.Books" /></span>
                        <span class="nav-label">@L["Libraries"]</span>
                    </NavLink>
                    <NavLink class="nav-link focusable" href="/settings/home">
                        <span class="nav-icon"><K7Icon Icon="@Phosphor.House" /></span>
                        <span class="nav-label">@L["Home"]</span>
                    </NavLink>
                    <NavLink class="nav-link focusable" href="/settings/hidden">
                        <span class="nav-icon"><K7Icon Icon="@Phosphor.EyeSlash" /></span>
                        <span class="nav-label">@L["Hidden"]</span>
                    </NavLink>
                </SidebarNavGroup>

                <SidebarNavGroup Title="@L["GroupPlayback"]" Icon="@Phosphor.Play" Routes="@PlaybackRoutes">
                    <NavLink class="nav-link focusable" href="/settings/video-playback">
                        <span class="nav-icon"><K7Icon Icon="@Phosphor.Play" /></span>
                        <span class="nav-label">@L["VideoPlayback"]</span>
                    </NavLink>
                    <NavLink class="nav-link focusable" href="/settings/audio-player">
                        <span class="nav-icon"><K7Icon Icon="@Phosphor.MusicNotes" /></span>
                        <span class="nav-label">@L["AudioPlayer"]</span>
                    </NavLink>
                </SidebarNavGroup>

                @if (DeviceService.GetClientType() == ClientType.Native)
                {
                    <SidebarNavLink Href="/settings/offline" Title="@L["Offline"]" Icon="@Phosphor.CloudArrowDown" />
                }
            }

            <SidebarNavLink Href="/settings/about" Title="@L["About"]" Icon="@Phosphor.Info" />
        </nav>
    </SidebarContent>
    <ChildContent>
        <div class="page-content">
            @Body
        </div>
    </ChildContent>
</SidebarLayout>

@code {
    private static readonly string[] MyContentRoutes = ["/settings/libraries", "/settings/home", "/settings/hidden"];
    private static readonly string[] PlaybackRoutes = ["/settings/video-playback", "/settings/audio-player"];
}
