@inherits LayoutComponentBase
@layout MainLayout
@inject IStringLocalizer<SettingsLayout> L

<SidebarLayout Title="@L["Title"]">
    <SidebarContent>
        <nav class="page-sidebar-nav">
            <NavLink class="nav-link focusable" href="/settings/general">
                <span class="nav-icon"><K7Icon Icon="@Phosphor.Gear" /></span>
                <span class="nav-label">@L["General"]</span>
            </NavLink>
            <NavLink class="nav-link focusable" href="/settings/libraries">
                <span class="nav-icon"><K7Icon Icon="@Phosphor.Books" /></span>
                <span class="nav-label">@L["Libraries"]</span>
            </NavLink>
            <NavLink class="nav-link focusable" href="/settings/home">
                <span class="nav-icon"><K7Icon Icon="@Phosphor.House" /></span>
                <span class="nav-label">@L["Home"]</span>
            </NavLink>
            <NavLink class="nav-link focusable" href="/settings/hidden">
                <span class="nav-icon"><K7Icon Icon="@Phosphor.EyeSlash" /></span>
                <span class="nav-label">@L["Hidden"]</span>
            </NavLink>
            <NavLink class="nav-link focusable" href="/settings/video-player">
                <span class="nav-icon"><K7Icon Icon="@Phosphor.Play" /></span>
                <span class="nav-label">@L["VideoPlayer"]</span>
            </NavLink>
            <NavLink class="nav-link focusable" href="/settings/track-selection">
                <span class="nav-icon"><K7Icon Icon="@Phosphor.Translate" /></span>
                <span class="nav-label">@L["TrackSelection"]</span>
            </NavLink>
            <NavLink class="nav-link focusable" href="/settings/offline">
                <span class="nav-icon"><K7Icon Icon="@Phosphor.CloudArrowDown" /></span>
                <span class="nav-label">@L["Offline"]</span>
            </NavLink>
        </nav>
    </SidebarContent>
    <ChildContent>
        <div class="page-content">
            @Body
        </div>
    </ChildContent>
</SidebarLayout>
