@inject IStringLocalizer<SidebarLayout> L

<div class="page-with-sidebar @(_desktopCollapsed ? "page-with-sidebar--rail" : "")">
    <header class="sidebar-mobile-topbar">
        <button class="sidebar-mobile-toggle focusable" @onclick="ToggleSidebar" aria-label="@L["MobileMenu"]">
            <K7Icon Icon="@(_sidebarOpen ? Phosphor.X : Phosphor.List)" />
        </button>
        <span class="sidebar-mobile-title">@Title</span>
    </header>

    <CascadingValue Value="_sidebarContext">
        <aside class="page-sidebar @GetSidebarClass()" data-sn-section="sidebar-nav" data-sn-enter="last-focused" data-sn-restrict="self-first">
            <div class="page-sidebar-header">
                @if (!_desktopCollapsed)
                {
                    <div class="page-sidebar-title">@Title</div>
                }
                @if (_showDesktopCollapseToggle)
                {
                    <button type="button"
                            class="page-sidebar-collapse-toggle focusable"
                            aria-label="@(_desktopCollapsed ? L["ExpandSidebar"] : L["CollapseSidebar"])"
                            aria-expanded="@(!_desktopCollapsed)"
                            @onclick="ToggleDesktopCollapse"
                            @onclick:stopPropagation="true">
                        <K7Icon Icon="@(_desktopCollapsed ? Phosphor.CaretRight : Phosphor.CaretLeft)" />
                    </button>
                }
            </div>
            <div class="page-sidebar-scroll">
                @SidebarContent
            </div>
        </aside>

        <main class="page-sidebar-body @(_sidebarOpen ? "sidebar-body-hidden" : "")" data-sn-section="sidebar-content" data-sn-enter="last-focused" data-sn-restrict="self-first">
            @ChildContent
        </main>
    </CascadingValue>
</div>
