@inherits LayoutComponentBase
@inject Microsoft.JSInterop.IJSRuntime JS
@inject IStringLocalizer<EmptyLayout> L

<div class="empty-layout">
    <K7ErrorBoundary>
        <ChildContent>
            @Body
        </ChildContent>
        <ErrorContent>
            <div class="error-state">
                <p style="font-size:var(--text-lg);font-weight:600;color:var(--color-text-primary)">@L["UnexpectedError"]</p>
                <button class="k7-btn k7-btn--filled k7-btn--primary mt-4" onclick="location.reload()">@L["Reload"]</button>
            </div>
        </ErrorContent>
    </K7ErrorBoundary>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("K7.dismissPreload");
        }
    }
}

<K7SnackbarHost />

<div id="blazor-error-ui">
    @L["UnhandledError"]
    <a href="." class="reload">@L["Reload"]</a>
    <span class="dismiss">&#x2715;</span>
</div>
