@inherits LayoutComponentBase
@inject IStringLocalizer<EmptyLayout> L

<div class="empty-layout">
    <K7ErrorBoundary>
        <ChildContent>
            @Body
        </ChildContent>
        <ErrorContent>
            <div class="error-state">
                <p class="error-state-title">@L["UnexpectedError"]</p>
                <button class="k7-btn k7-btn--filled k7-btn--primary mt-4" onclick="location.reload()">@L["Reload"]</button>
            </div>
        </ErrorContent>
    </K7ErrorBoundary>
</div>

<K7SnackbarHost />

<div id="blazor-error-ui">
    @L["UnhandledError"]
    <a href="." class="reload">@L["Reload"]</a>
    <span class="dismiss">&#x2715;</span>
</div>
