@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@inject ThemeService ThemeService
@inject SidebarService SidebarService
@inject K7.Clients.Shared.Services.K7HubClient K7HubClient
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IFeatureAccessService FeatureAccess
@inject AudioPlaybackProgressTracker AudioProgressTracker
@inject IServiceProvider Services
@inject K7.Clients.Shared.Services.SyncPlayPlaybackHandler SyncPlayHandler
@inject IK7ServerService K7ServerService
@inject IStringLocalizer<MainLayout> L

<div class="app-shell">
    @if (_showOverlay)
    {
        <div class="reconnection-overlay">
            <div class="reconnection-animation" @ref="_reconnectAnimationContainer"></div>
            <p class="mt-4" style="font-size:var(--text-lg);font-weight:600">@L["Reconnecting"]</p>
            <p class="mt-2" style="color:var(--color-text-secondary)">@L["ReconnectingDescription"]</p>
        </div>
    }

    <AppNav />

    <main class="app-main">
        <MediaPlayer />
        <div class="mini-player-dock">
            <MiniMusicPlayer />
        </div>
        <FullScreenMusicPlayer />
        <SyncPlayListener />
        <div class="page-viewport">
            <K7ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent>
                    <div class="error-state">
                        <K7Icon Name="warning-circle" Size="xl" class="error-icon" />
                        <p style="font-size:var(--text-lg);font-weight:600">@L["UnexpectedError"]</p>
                        <p style="color:var(--color-text-secondary)">@L["UnexpectedErrorDescription"]</p>
                        <button class="btn btn--primary mt-4" @onclick="Recover">@L["Retry"]</button>
                    </div>
                </ErrorContent>
            </K7ErrorBoundary>
        </div>
    </main>
</div>

<K7DialogHost />
<K7SnackbarHost />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>