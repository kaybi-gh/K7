@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@inject ThemeService ThemeService
@inject SidebarService SidebarService
@inject K7.Clients.Shared.Services.K7HubClient K7HubClient
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IFeatureAccessService FeatureAccess
@inject AudioPlaybackProgressTracker AudioProgressTracker
@inject IServiceProvider Services
@inject K7.Clients.Shared.Services.SyncPlayPlaybackHandler SyncPlayHandler
@inject IK7ServerService K7ServerService
@inject IServerInfoService ServerInfoService
@using K7.Clients.Shared.UI.Components.FeedHub
@inject IStringLocalizer<MainLayout> L


<div class="app-shell">
    @if (_showOverlay)
    {
        <div class="reconnection-overlay">
            <div class="reconnection-animation" @ref="_reconnectAnimationContainer"></div>
            <p class="mt-4 reconnection-overlay-title">@L["Reconnecting"]</p>
            <p class="mt-2 reconnection-overlay-description">@L["ReconnectingDescription"]</p>
        </div>
    }

    <AppNav />

    <main class="app-main">
        <MediaPlayer />
        <div class="mini-player-dock">
            <MiniMusicPlayer />
        </div>
        <FullScreenMusicPlayer />
        <SyncPlayListener />
        <div class="page-viewport">
            <FeedHubPageHost />
            <div class="page-route @(FeedHub.IsEnabled && FeedHub.IsHubRouteActive ? "page-route--hub-delegated" : null)">
                <K7ErrorBoundary @ref="_errorBoundary">
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent>
                        <div class="error-state">
                            <K7Icon Name="warning-circle"  IconSize="@K7IconSize.Xl" class="error-icon" />
                            <p class="error-state-title">@L["UnexpectedError"]</p>
                            <p class="error-state-description">@L["UnexpectedErrorDescription"]</p>
                            <button class="k7-btn k7-btn--filled k7-btn--primary mt-4 focusable" @onclick="Recover">@L["Retry"]</button>
                        </div>
                    </ErrorContent>
                </K7ErrorBoundary>
            </div>
        </div>
    </main>
</div>

<K7DialogHost />
<K7SnackbarHost />
<MediaCardContextMenuHost />
<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>