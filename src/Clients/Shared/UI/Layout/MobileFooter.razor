@using K7.Shared.Dtos.Entities
@using K7.Server.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@inject ILibraryService K7ServerService
@inject NavigationManager NavigationManager
@inject ICustomAuthenticationStateProvider CustomAuthenticationStateProvider
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDeviceService DeviceService
@inject IStringLocalizer<MobileFooter> L

<div class="mobile-footer">
    <div class="mobile-footer-bar">
        <a href="/" class="mobile-footer-btn" title="@L["Home"]">
            <K7Icon Icon="@Phosphor.House" />
        </a>
        <button class="mobile-footer-btn" @onclick="ToggleLibraryDrawer" title="@L["Libraries"]">
            <K7Icon Icon="@Phosphor.VideoCamera" />
        </button>
        <a href="/" class="mobile-footer-btn mobile-footer-btn--logo" title="K7">
            <K7Icon Icon="@Phosphor.Hurricane" Size="lg" />
        </a>
        <button class="mobile-footer-btn" @onclick="ToggleMusicDrawer" title="@L["Music"]">
            <K7Icon Icon="@Phosphor.MusicNotes" />
        </button>
        <button class="mobile-footer-btn" @onclick="ToggleMenuDrawer" title="@L["Menu"]">
            <K7Icon Icon="@Phosphor.List" />
        </button>
    </div>
</div>

@if (IsAnyDrawerOpen)
{
    <div class="bottom-sheet-backdrop open" @onclick="CloseDrawers"></div>
}

<div class="bottom-sheet @(_libraryDrawerOpen ? "open" : "")">
    <div class="bottom-sheet-header">
        <span class="bottom-sheet-title">@L["Libraries"]</span>
        <button class="btn-icon" @onclick="CloseDrawers"><K7Icon Icon="@Phosphor.X" /></button>
    </div>
    <nav class="bottom-sheet-nav">
        @foreach (var library in _libraries)
        {
            <NavLink @key="library.Id" class="nav-link" href="@($"/library/{library.Id}")" @onclick="CloseDrawers">
                <span class="nav-icon"><K7Icon Name="@GetLibraryIcon(library.MediaType)" /></span>
                <span class="nav-label">@library.Title</span>
            </NavLink>
        }
    </nav>
</div>

<div class="bottom-sheet @(_musicDrawerOpen ? "open" : "")">
    <div class="bottom-sheet-header">
        <span class="bottom-sheet-title">@L["Music"]</span>
        <button class="btn-icon" @onclick="CloseDrawers"><K7Icon Icon="@Phosphor.X" /></button>
    </div>
    <nav class="bottom-sheet-nav">
        <NavLink class="nav-link" href="/music/artists" @onclick="CloseDrawers">
            <span class="nav-icon"><K7Icon Icon="@Phosphor.User" /></span>
            <span class="nav-label">@L["Artists"]</span>
        </NavLink>
        <NavLink class="nav-link" href="/music/albums" @onclick="CloseDrawers">
            <span class="nav-icon"><K7Icon Icon="@Phosphor.VinylRecord" /></span>
            <span class="nav-label">@L["Albums"]</span>
        </NavLink>
        <NavLink class="nav-link" href="/music/tracks" @onclick="CloseDrawers">
            <span class="nav-icon"><K7Icon Icon="@Phosphor.MusicNote" /></span>
            <span class="nav-label">@L["Tracks"]</span>
        </NavLink>
        <AuthorizeView Roles="User,Administrator">
            <NavLink class="nav-link" href="/playlists" @onclick="CloseDrawers">
                <span class="nav-icon"><K7Icon Icon="@Phosphor.Queue" /></span>
                <span class="nav-label">@L["Playlists"]</span>
            </NavLink>
        </AuthorizeView>
        <NavLink class="nav-link" href="/music/radio" @onclick="CloseDrawers">
            <span class="nav-icon"><K7Icon Icon="@Phosphor.Radio" /></span>
            <span class="nav-label">@L["Radio"]</span>
        </NavLink>
        <AuthorizeView Roles="User,Administrator">
            <NavLink class="nav-link" href="/music/stats" @onclick="CloseDrawers">
                <span class="nav-icon"><K7Icon Icon="@Phosphor.ChartBar" /></span>
                <span class="nav-label">@L["Stats"]</span>
            </NavLink>
        </AuthorizeView>
    </nav>
</div>

<div class="bottom-sheet @(_menuDrawerOpen ? "open" : "")">
    <div class="bottom-sheet-header">
        <AuthorizeView>
            <Authorized>
                <div style="display:flex;align-items:center;gap:var(--space-3)">
                    <div class="avatar">
                        @(context.User.Identity?.Name?[0].ToString().ToUpperInvariant() ?? "?")
                        <span class="connection-badge connection-badge--@_badgeClass" title="@_badgeTitle"></span>
                    </div>
                    <span class="bottom-sheet-title">@context.User.Identity?.Name</span>
                </div>
            </Authorized>
            <NotAuthorized>
                <span class="bottom-sheet-title">@L["Menu"]</span>
            </NotAuthorized>
        </AuthorizeView>
        <button class="btn-icon" @onclick="CloseDrawers"><K7Icon Icon="@Phosphor.X" /></button>
    </div>
    <nav class="bottom-sheet-nav">
        <AuthorizeView>
            <NavLink class="nav-link" href="/settings" @onclick="CloseDrawers">
                <span class="nav-icon"><K7Icon Icon="@Phosphor.Gear" /></span>
                <span class="nav-label">@L["Settings"]</span>
            </NavLink>
        </AuthorizeView>
        <AuthorizeView Roles="Administrator">
            <NavLink class="nav-link" href="/admin" @onclick="CloseDrawers">
                <span class="nav-icon"><K7Icon Icon="@Phosphor.ShieldCheck" /></span>
                <span class="nav-label">@L["Admin"]</span>
            </NavLink>
        </AuthorizeView>
        <AuthorizeView>
            <Authorized>
                @if (DeviceService.GetClientType() != ClientType.Web)
                {
                    <button class="nav-link" style="width:100%;background:transparent;border:none;font:inherit;text-align:left;cursor:pointer" @onclick="SwitchUser">
                        <span class="nav-icon"><K7Icon Icon="@Phosphor.UserSwitch" /></span>
                        <span class="nav-label">@L["SwitchUser"]</span>
                    </button>
                }
                <button class="nav-link" style="width:100%;background:transparent;border:none;font:inherit;text-align:left;cursor:pointer;color:var(--color-error)" @onclick="Logout">
                    <span class="nav-icon"><K7Icon Icon="@Phosphor.SignOut" /></span>
                    <span class="nav-label">@L["Logout"]</span>
                </button>
            </Authorized>
            <NotAuthorized>
                <button class="nav-link" style="width:100%;background:transparent;border:none;font:inherit;text-align:left;cursor:pointer" @onclick="Login">
                    <span class="nav-icon"><K7Icon Icon="@Phosphor.SignIn" /></span>
                    <span class="nav-label">@L["Login"]</span>
                </button>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>
