@page "/settings"
@using System.Security.Claims
@inject ThemeService ThemeService
@inject IDeviceService DeviceService
@inject IK7ServerService K7ServerService
@inject IDialogService DialogService
@inject ILocalUserService LocalUserService
@inject AuthenticationStateProvider AuthenticationStateProvider
<PageTitle>Settings</PageTitle>

<MudSwitch @bind-Value="@ThemeService.DarkModeEnabled" Color="Color.Primary" Class="ma-4" T="bool" Label="Dark mode" />
<MudSelect T="ThemeWrapper" Label="Theme" @bind-Value="@ThemeService.ThemeWrapper">
    @foreach (var themeWrapper in Themes.Collection)
    {
        <MudSelectItem Value="@themeWrapper">@themeWrapper?.Name</MudSelectItem>
    }
</MudSelect>

@if (DeviceService.GetClientType() == Server.Domain.Enums.ClientType.Web)
{
    <MudTextField @bind-Value="@_backendUrl" Label="K7 server URL" ReadOnly="true" Variant="Variant.Text" />
}
else
{
    <MudTextField @bind-Value="@_backendUrl" Label="K7 server URL" ReadOnly="true" Variant="Variant.Text" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Delete" OnAdornmentClick="ChangeBackendUrl" />
}

<MudText>FormFactor: @_deviceType</MudText>
<MudText>HDR: @_hdrSupport</MudText>

<MudDivider Class="my-4" />
<MudText Typo="Typo.h6" Class="mb-2">PIN</MudText>
@if (_hasPin)
{
    <MudText Typo="Typo.body2" Class="mb-2">A PIN is set on your account.</MudText>
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ChangePin">Change PIN</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="RemovePin">Remove PIN</MudButton>
    </MudStack>
}
else
{
    <MudText Typo="Typo.body2" Class="mb-2">No PIN is set. A PIN protects your account access on shared devices.</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SetPin">Set a PIN</MudButton>
}
@if (_pinError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mt-2">@_pinError</MudAlert>
}
@if (_pinSuccess is not null)
{
    <MudAlert Severity="Severity.Success" Class="mt-2">@_pinSuccess</MudAlert>
}

<MudExpansionPanels>
    <MudExpansionPanel Text="Supported Codecs" MaxHeight="1000">
        <ul>
            @if (_supportedMediaFormats != null)
            {
                foreach (var supportedMediaFormat in _supportedMediaFormats)
                {
                    <li>@supportedMediaFormat.Id</li>
                }
            }
            else
            {
                <p>Loading...</p>
            }
        </ul>
    </MudExpansionPanel>
</MudExpansionPanels>
