@inject NavigationManager Navigation
@inject ILocalUserService LocalUserService

@code {
    protected override void OnInitialized()
    {
        var users = LocalUserService.GetAll();
        var target = users.Count > 0 ? "select-user" : "sign-in";
        Navigation.NavigateTo($"{target}?returnUrl={Uri.EscapeDataString(Navigation.Uri)}");
    }
}
