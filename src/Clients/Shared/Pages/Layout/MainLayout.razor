@inherits LayoutComponentBase
@inject ThemeService ThemeService

<MudThemeProvider Theme="@ThemeService.ThemeWrapper.Theme" IsDarkMode=@ThemeService.DarkModeEnabled />
<MudPopoverProvider />
<MudDialogProvider />
<VideoPlayer />

<MudBreakpointProvider>
    <MudHidden Breakpoint="Breakpoint.SmAndUp">
        <MudLayout Class="mobile-layout">
            <MudMainContent>
                @Body
            </MudMainContent>
            <MobileFooter />
        </MudLayout>
    </MudHidden>

    <MudHidden Breakpoint="Breakpoint.Xs">
        <MudLayout>
            <Sidebar />
            <MudMainContent>
                @Body
            </MudMainContent>
        </MudLayout>
    </MudHidden>
</MudBreakpointProvider>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>