@using K7.Shared.Dtos.Entities
@using K7.Server.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@inject IK7ServerService K7ServerService
@inject NavigationManager NavigationManager
@inject ICustomAuthenticationStateProvider CustomAuthenticationStateProvider
@inject IDeviceService DeviceService

<div class="mobile-footer">
    <MudAppBar Style="z-index:10;" Bottom="true" Fixed="true" Dense="false" Elevation="1">
        <MudStack Row="true" Style="width:100%;" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <div class="mobile-footer-button">
                <MudIconButton Href="/" Size="Size.Medium" Icon="@Icons.Material.Filled.Home" Color="Color.Inherit" />
            </div>
            <div class="mobile-footer-button">
                <MudIconButton Size="Size.Medium" Icon="@Icons.Material.Outlined.VideoLibrary" OnClick="ToggleLibraryDrawer" Color="Color.Inherit" />
            </div>
            <div class="application-logo">
                <MudIconButton Href="/" Color="Color.Primary" Size="Size.Large" Icon="@Icons.Material.Rounded.Cyclone" />
            </div>
            <div class="mobile-footer-button">
                <MudIconButton Size="Size.Medium" Icon="@Icons.Material.Filled.MusicNote" OnClick="ToggleMusicDrawer" Color="Color.Inherit" />
            </div>
            <div class="mobile-footer-button">
                <MudIconButton Size="Size.Medium" Icon="@Icons.Material.Outlined.Menu" OnClick="ToggleMenuDrawer" Color="Color.Inherit" />
            </div>
        </MudStack>
    </MudAppBar>

    <MudDrawer @bind-Open="_libraryDrawerOpen" Height="100%" Width="100%" Anchor="Anchor.Bottom" Elevation="1" Variant="@DrawerVariant.Temporary">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Libraries</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            @foreach (var library in _libraries)
            {
                <MudNavLink Href="@($"/library/{library.Id}")" Match="NavLinkMatch.All" Icon="@GetLibraryIcon(library.MediaType)" OnClick="CloseDrawers">@library.Title</MudNavLink>
            }
        </MudNavMenu>
    </MudDrawer>

    <MudDrawer @bind-Open="_musicDrawerOpen" Height="100%" Width="100%" Anchor="Anchor.Bottom" Elevation="1" Variant="@DrawerVariant.Temporary">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Music</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/music/artists" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Person" OnClick="CloseDrawers">Artists</MudNavLink>
            <MudNavLink Href="/music/albums" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Album" OnClick="CloseDrawers">Albums</MudNavLink>
            <MudNavLink Href="/music/tracks" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AudioFile" OnClick="CloseDrawers">Tracks</MudNavLink>
            <AuthorizeView Roles="User,Administrator">
                <MudNavLink Href="/playlists" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.QueueMusic" OnClick="CloseDrawers">Playlists</MudNavLink>
            </AuthorizeView>
            <MudNavLink Href="/music/radio" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Radio" OnClick="CloseDrawers">Radio</MudNavLink>
            <AuthorizeView Roles="User,Administrator">
                <MudNavLink Href="/music/stats" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.BarChart" OnClick="CloseDrawers">Stats</MudNavLink>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>

    <MudDrawer @bind-Open="_menuDrawerOpen" Height="100%" Width="100%" Anchor="Anchor.Bottom" Elevation="1" Variant="@DrawerVariant.Temporary">
        <MudDrawerHeader>
            <AuthorizeView>
                <Authorized>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudAvatar Color="Color.Primary">@context.User.Identity?.Name?[0]</MudAvatar>
                        <MudText Typo="Typo.h6">@context.User.Identity?.Name</MudText>
                    </MudStack>
                </Authorized>
                <NotAuthorized>
                    <MudText Typo="Typo.h6">Menu</MudText>
                </NotAuthorized>
            </AuthorizeView>
        </MudDrawerHeader>
        <MudNavMenu>
            <AuthorizeView>
                <MudNavLink Href="/settings" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Settings" OnClick="CloseDrawers">Settings</MudNavLink>
            </AuthorizeView>
            <AuthorizeView Roles="Administrator">
                <MudNavLink Href="/admin" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AdminPanelSettings" OnClick="CloseDrawers">Admin</MudNavLink>
            </AuthorizeView>
            <AuthorizeView>
                <Authorized>
                    @if (DeviceService.GetClientType() != ClientType.Web)
                    {
                        <MudNavLink Icon="@Icons.Material.Filled.SwitchAccount" OnClick="SwitchUser">Switch User</MudNavLink>
                    }
                    <MudNavLink Icon="@Icons.Material.Filled.Logout" OnClick="Logout">Logout</MudNavLink>
                </Authorized>
                <NotAuthorized>
                    <MudNavLink Icon="@Icons.Material.Filled.Login" OnClick="Login">Login</MudNavLink>
                </NotAuthorized>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>
</div>
