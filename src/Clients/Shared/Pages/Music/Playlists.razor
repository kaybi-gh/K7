@page "/playlists"
@using K7.Shared.Dtos.Entities.Playlists
@inject IK7ServerService K7ServerService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
<PageTitle>Playlists</PageTitle>

<MudStack Row="true" Style="width: 100%" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="pa-4">
    <MudText Typo="Typo.h5">Playlists</MudText>
    <MudStack Row="true" Spacing="2">
        <MudMenu Label="Presets" Variant="Variant.Outlined" Color="Color.Primary"
                 StartIcon="@Icons.Material.Filled.Lightbulb" Dense="true">
            <MudMenuItem OnClick="() => CreatePreset(Preset.RecentlyAdded)">Ajouts récents</MudMenuItem>
            <MudMenuItem OnClick="() => CreatePreset(Preset.MostPlayed)">Les plus écoutés</MudMenuItem>
            <MudMenuItem OnClick="() => CreatePreset(Preset.NeverPlayed)">Jamais écoutés</MudMenuItem>
            <MudMenuItem OnClick="() => CreatePreset(Preset.HighlyRated)">Mieux notés</MudMenuItem>
            <MudMenuItem OnClick="() => CreatePreset(Preset.RecentlyPlayed)">Écoutés récemment</MudMenuItem>
        </MudMenu>
        <MudMenu Label="Nouvelle playlist" Variant="Variant.Filled" Color="Color.Primary"
                 StartIcon="@Icons.Material.Filled.Add" Dense="true">
            <MudMenuItem Icon="@Icons.Material.Filled.QueueMusic" OnClick="OpenCreatePlaylistDialog">Playlist</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.AutoAwesome" OnClick="OpenCreateSmartPlaylistDialog">Smart Playlist</MudMenuItem>
        </MudMenu>
    </MudStack>
</MudStack>

@if (_loading)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-16">
        <MudProgressCircular Indeterminate="true" />
    </MudStack>
}
else if (_playlists.Count == 0)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-16">
        <MudIcon Icon="@Icons.Material.Outlined.QueueMusic" Style="font-size: 64px; opacity: 0.3;" />
        <MudText Typo="Typo.h6" Color="Color.Default" Style="opacity: 0.5;">Aucune playlist</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Créez votre première playlist pour organiser vos morceaux.</MudText>
    </MudStack>
}
else
{
    <div class="pa-4">
        <MudGrid Spacing="4">
            @foreach (var playlist in _playlists)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Outlined="true" Class="playlist-card" @onclick="() => GoToPlaylist(playlist)" Style="cursor: pointer;">
                        <MudCardContent>
                            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                                @if (playlist.CoverPicture is not null)
                                {
                                    <MudImage Src="@GetCoverUrl(playlist)"
                                              Width="120" Height="120"
                                              ObjectFit="ObjectFit.Cover"
                                              Class="rounded" />
                                }
                                else
                                {
                                    <div class="playlist-cover-placeholder">
                                        <MudIcon Icon="@(playlist.IsSmartPlaylist ? Icons.Material.Filled.AutoAwesome : Icons.Material.Filled.QueueMusic)"
                                                 Style="font-size: 48px; opacity: 0.3;" />
                                    </div>
                                }
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="playlist-title">@playlist.Title</MudText>
                                    @if (playlist.IsSmartPlaylist)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Color="Color.Secondary" />
                                    }
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@playlist.ItemCount morceaux</MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </div>
}
