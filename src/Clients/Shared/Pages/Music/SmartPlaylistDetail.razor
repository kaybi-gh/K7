@page "/smart-playlists/{Id}"
@using K7.Shared.Dtos.Entities.Playlists
@inject IK7ServerService K7ServerService
<PageTitle>@(_smartPlaylist?.Title ?? "Smart Playlist")</PageTitle>

@if (_smartPlaylist is not null)
{
    <div class="playlist-detail-page">
        <div class="playlist-header">
            <div class="playlist-header-cover">
                <div class="playlist-cover-placeholder-large">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="font-size: 64px; opacity: 0.3;" />
                </div>
            </div>
            <div class="playlist-header-info">
                <MudText Typo="Typo.overline">Smart Playlist</MudText>
                <MudText Typo="Typo.h4">@_smartPlaylist.Title</MudText>

                @if (!string.IsNullOrEmpty(_smartPlaylist.Description))
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">@_smartPlaylist.Description</MudText>
                }

                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mt-1">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_smartPlaylist.Rules.Count règle@(_smartPlaylist.Rules.Count > 1 ? "s" : "")
                        · @_smartPlaylist.ItemCount morceaux
                    </MudText>
                    @if (_smartPlaylist.LastEvaluatedAt.HasValue)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            · Évalué @FormatRelativeTime(_smartPlaylist.LastEvaluatedAt.Value)
                        </MudText>
                    }
                </MudStack>

                <MudStack Row="true" Spacing="2" Class="mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="PlayAll" Disabled="@(_items.Count == 0)">
                        Tout lire
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Shuffle"
                               OnClick="ShuffleAll" Disabled="@(_items.Count == 0)">
                        Aléatoire
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="EvaluateAsync" Disabled="_evaluating">
                        @if (_evaluating)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                            <text>Évaluation...</text>
                        }
                        else
                        {
                            <text>Réévaluer</text>
                        }
                    </MudButton>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" OnClick="OpenEditDialog" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="ConfirmDelete" />
                </MudStack>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_rulesDescription))
        {
            <MudPaper Outlined="true" Class="ma-4 pa-3">
                <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" Color="Color.Secondary" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_rulesDescription</MudText>
                </MudStack>
            </MudPaper>
        }

        @if (_loadingItems)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4" />
        }
        else if (_items.Count == 0)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-16">
                <MudIcon Icon="@Icons.Material.Outlined.MusicNote" Style="font-size: 48px; opacity: 0.3;" />
                <MudText Typo="Typo.body1" Color="Color.Secondary">Aucun résultat — modifiez les règles ou réévaluez</MudText>
            </MudStack>
        }
        else
        {
            <div class="playlist-tracklist">
                <MudTable Items="_items" Dense="true" Hover="true" Elevation="0"
                          T="SmartPlaylistItemViewModel" OnRowClick="OnTrackClick" RowClass="cursor-pointer">
                    <HeaderContent>
                        <MudTh Style="width: 50px;">#</MudTh>
                        <MudTh>Titre</MudTh>
                        <MudTh>Artiste</MudTh>
                        <MudTh>Album</MudTh>
                        <MudTh Style="width: 80px;"><MudIcon Icon="@Icons.Material.Outlined.AccessTime" Size="Size.Small" /></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            @if (context.IsPlaying)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Equalizer" Size="Size.Small" Color="Color.Primary" />
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@(context.Order + 1)</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                @if (context.CoverUrl is not null)
                                {
                                    <MudImage Src="@context.CoverUrl" Width="36" Height="36"
                                              ObjectFit="ObjectFit.Cover" Class="rounded" />
                                }
                                <MudText Style="@(context.IsPlaying ? "color: var(--mud-palette-primary);" : "")">
                                    @context.Title
                                </MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd><MudText Typo="Typo.body2" Color="Color.Secondary">@context.ArtistName</MudText></MudTd>
                        <MudTd><MudText Typo="Typo.body2" Color="Color.Secondary">@context.AlbumTitle</MudText></MudTd>
                        <MudTd><MudText Typo="Typo.body2" Color="Color.Secondary">@FormatTime(context.Duration)</MudText></MudTd>
                    </RowTemplate>
                </MudTable>
            </div>
        }
    </div>
}
else if (_loading)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-16">
        <MudProgressCircular Indeterminate="true" />
    </MudStack>
}
