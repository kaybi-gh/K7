@page "/library/{id}"
@inject IMediaServerService mediaServerService
<PageTitle>Library @Id</PageTitle>

<MudGrid Style="max-width:100%;" Spacing="0" Justify="Justify.SpaceEvenly">
    @foreach (var item in MediaItems)
    {
        <MudItem Class="ma-2">
            <MediaPoster MediaItem="item" />
        </MudItem>
    }
</MudGrid>


