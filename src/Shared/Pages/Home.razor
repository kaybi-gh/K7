@page "/"
<PageTitle>Home</PageTitle>

<HorizontalScrollableStack Title="All">
    @foreach (var item in @MediaItemServiceMock.All)
    {
        <HorizontalScrollableStackItem>
            <MediaPoster MediaItem="@item" OverlayEnabled="true" ProgressEnabled="true" WatchedStatusEnabled="true" FooterVisible="true"/>
        </HorizontalScrollableStackItem>
    }
</HorizontalScrollableStack>

