@page "/"
@inject IMediaServerService mediaServerService
<PageTitle>Home</PageTitle>

<HorizontalScrollableStack Title="RealItems">
    @foreach (var item in realItems)
    {
        <HorizontalScrollableStackItem>
            <MediaPoster MediaItem="@item" OverlayEnabled="true" ProgressEnabled="true" WatchedStatusEnabled="true" FooterVisible="true"/>
        </HorizontalScrollableStackItem>
    }
</HorizontalScrollableStack>

<HorizontalScrollableStack Title="All">
    @foreach (var item in @MediaItemServiceMock.All)
    {
        <HorizontalScrollableStackItem>
            <MediaPoster MediaItem="@item" OverlayEnabled="true" ProgressEnabled="true" WatchedStatusEnabled="true" FooterVisible="true"/>
        </HorizontalScrollableStackItem>
    }
</HorizontalScrollableStack>

<HorizontalScrollableStack Title="Bond, James Bond">
    @foreach (var item in @MediaItemServiceMock.JamesBond)
    {
        <HorizontalScrollableStackItem>
            <MediaPoster MediaItem="@item" OverlayEnabled="true" ProgressEnabled="true" WatchedStatusEnabled="true" FooterVisible="true"/>
        </HorizontalScrollableStackItem>
    }
</HorizontalScrollableStack>

<HorizontalScrollableStack Title="No daddyyyyy">
    @foreach (var item in @MediaItemServiceMock.StarWars)
    {
        <HorizontalScrollableStackItem>
            <MediaPoster MediaItem="@item" OverlayEnabled="true" ProgressEnabled="true" WatchedStatusEnabled="true" FooterVisible="true"/>
        </HorizontalScrollableStackItem>
    }
</HorizontalScrollableStack>

@code {
    List<MediaItem> realItems = [];
    protected override async Task OnInitializedAsync()
    {
        var test = await mediaServerService.GetMediasAsync(new GetMediasWithPaginationQuery()
        {
            PageNumber = 1,
            PageSize = 50
        });

        foreach (var item in test.Items)
        {
            if (item is MovieDto movie)
            {
                realItems.Add(new MediaItem()
                {
                    Id = movie.Id.ToString(),
                    Title = movie.Title,
                    AdditionalInformations = movie.ReleaseDate.Value.Year.ToString(),
                        PosterPicture = $"{mediaServerService.GetBaseUrl()}{movie.Pictures?.FirstOrDefault(p => p.Type == MetadataPictureType.Poster)?.Uri?.OriginalString}"
                });
            }
        }
    }
}