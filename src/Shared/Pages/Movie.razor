@page "/movies/{id}"
<PageTitle>@_movie?.Title</PageTitle>

<div class="background" style="--background-picture: url(@_movie!.BackgroundPicture)" />


<MudStack Row="true" Class="mx-4">
    <MediaItemPoster MediaItem="@_movie" />
    <MudStack>
        <MudText Typo="Typo.h4">@_movie!.Title</MudText>
        <MudStack Row="true">
            <MudText Typo="Typo.caption">@_movie!.AdditionalInformations</MudText>
            <MudText Typo="Typo.caption">@_movie!.Duration</MudText>
        </MudStack>
        <MudStack Row="true">
            <MudRating SelectedValue="@_movie!.Rating" />
        </MudStack>
        <MudStack Row="true">
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PlayArrow" Color="Color.Primary">Play</MudButton>
            <MudIconButton Icon="@Icons.Material.Filled.LocalMovies" aria-label="trailer"></MudIconButton>
            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" aria-label="mark-as-shown"></MudIconButton>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit"></MudIconButton>
            <MudIconButton Icon="@Icons.Material.Filled.MoreHoriz" aria-label="more-actions"></MudIconButton>
        </MudStack>
        <MudText>@_movie!.Synopsis</MudText>
    </MudStack>
</MudStack>
