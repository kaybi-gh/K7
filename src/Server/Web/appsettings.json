{
  "BaseUrl": "https://localhost:5001",
  "Database": {
    "Provider": "Postgres",
    "UserID": "postgres",
    "Password": "",
    "Server": "localhost",
    "Port": 5432,
    "Name": ""
  },
  "Authentication": {
    "Local": {
      "SignInEnabled": true,
      "RegistrationEnabled": true
    },
    "Oidc": {
      "Enabled": false,
      "AutomaticAccountCreation": true,
      "DisplayName": "",
      "Authority": "",
      "ClientId": "",
      "ClientSecret": "",
      "Scopes": "openid,profile"
    }
  },
  "Security": {
    "ForceHttps": true
  },
  "Paths": {
    "Config": "config",
    "Metadatas": "metadatas",
    "Logs": "logs",
    "Transcoding": "transcoding",
    "FFMpegBinaryFolder": "",
    "EssentiaBinaryPath": "essentia_streaming_extractor_music"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "OpenIddict": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
