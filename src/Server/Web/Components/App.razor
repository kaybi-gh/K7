<!DOCTYPE html>
@using K7.Server.Application.Common.Interfaces
@using K7.Server.Domain.Settings
@using Microsoft.Extensions.DependencyInjection
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#131821" />
    <title>K7</title>
    <base href="/" />

    <link rel="stylesheet" href="@Assets["_content/K7.Clients.Shared.UI/app.css"]" />
    <link rel="stylesheet" href="@Assets["K7.Server.Web.styles.css"]" />
    <link rel="stylesheet" href="@Assets["css/auth.css"]" />
    <link rel="stylesheet" href="@Assets["dist/video.js/video-js.min.css"]" />
    <ImportMap />
    <link rel="icon" type="image/svg+xml" href="@Assets["_content/K7.Clients.Shared.UI/assets/favicon.svg"]" />
    <HeadOutlet @rendermode="PageRenderMode" />
</head>

<body>
    @if (PageRenderMode is not null)
    {
        <div id="preload">
            <div class="preload-content">
                <div id="preload-animation" class="preload-animation"></div>
            </div>
        </div>
    }
    <Routes @rendermode="PageRenderMode" />

    <script>window.__K7_DEFAULT_THEME__ = "@_defaultTheme";</script>
    <script src="@Assets["_content/K7.Clients.Shared.UI/js/theme.js"]"></script>
    <script src="@Assets["_content/K7.Clients.Shared.UI/dist/lottie/build/player/lottie_light.min.js"]"></script>
    <script>
        if (window.lottie) {
            lottie.loadAnimation({
                container: document.getElementById('preload-animation'),
                renderer: 'svg',
                loop: true,
                autoplay: true,
                path: '_content/K7.Clients.Shared.UI/animations/splash.json'
            });
        }
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["_content/K7.Clients.Shared.UI/js/lottie-interop.js"]"></script>
    <script>K7.Lottie.preload('_content/K7.Clients.Shared.UI/animations/splash.json');</script>
    <script src="@Assets["_content/K7.Clients.Shared.UI/dist/embla-carousel/embla-carousel.umd.js"]"></script>
    <script src="@Assets["_content/K7.Clients.Shared.UI/lib/js-spatial-navigation/spatial_navigation.js"]"></script>
    <script src="@Assets["_content/K7.Clients.Shared.UI/js/navigation.js"]"></script>
    <script src="@Assets["_content/K7.Clients.Shared.UI/dist/qrcodejs/qrcode.min.js"]"></script>
    <script src="@Assets["_content/K7.Clients.Shared.UI/js/qrcode.js"]"></script>
    <script src="@Assets["dist/bowser/es5.min.js"]"></script>
    <script src="@Assets["dist/video.js/video.min.js"]"></script>
    <script src="@Assets["js/videoplayer.js"]"></script>
    <script src="@Assets["js/audioplayer.js"]"></script>
    <script src="@Assets["js/deviceUtils.js"]"></script>
    <script src="@Assets["js/castplayer.js"]"></script>
    <script src="https://www.gstatic.com/cv/js/sender/v1/cast_sender.js?loadCastFramework=1"></script>
    <script>
        window.blazorCulture = {
            get: () => window.localStorage.getItem('BlazorCulture'),
            set: (value) => {
                window.localStorage.setItem('BlazorCulture', value);
                document.cookie = `.AspNetCore.Culture=c=${value}|uic=${value};path=/;max-age=31536000;samesite=lax`;
            }
        };
    </script>
</body>

</html>

@code {
    [Inject]
    private IServiceScopeFactory ScopeFactory { get; set; } = default!;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private string _defaultTheme = "default-dark";

    protected override async Task OnInitializedAsync()
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var serverSettings = scope.ServiceProvider.GetRequiredService<IServerSettingsService>();
        _defaultTheme = await serverSettings.GetAsync(ServerSettingKeys.DefaultTheme) ?? "default-dark";
    }

    private IComponentRenderMode? PageRenderMode => HttpContext.Request.Path.StartsWithSegments("/login")
        || HttpContext.Request.Path.StartsWithSegments("/Account")
        || HttpContext.Request.Path.StartsWithSegments("/setup")
        || HttpContext.Request.Path.StartsWithSegments("/welcome")
        || HttpContext.Request.Path.StartsWithSegments("/link")
        || HttpContext.Request.Path.StartsWithSegments("/auth")
        ? null
        : new InteractiveWebAssemblyRenderMode(false);
}