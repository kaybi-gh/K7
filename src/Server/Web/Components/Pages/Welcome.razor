@page "/welcome"
@layout K7.Server.Web.Components.Pages.Setup.SetupLayout
@using K7.Server.Application.Common.Interfaces
@using K7.Server.Domain.Constants
@using K7.Server.Infrastructure.Database.Context.Identity
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject IApplicationDbContext DbContext
@inject ISetupService SetupService
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject K7.Server.Web.Components.Account.IdentityRedirectManager RedirectManager
@inject IStringLocalizer<Welcome> L

<PageTitle>@L["PageTitle"] - K7</PageTitle>

<div class="auth-card">
    <div class="auth-card-header">
        <h1 class="auth-title">K7</h1>
        <p class="auth-subtitle">@L["ChooseHow"]</p>
    </div>
    <div class="auth-card-body">
        <hr class="auth-divider" />
        <div class="auth-form-stack">
            <a href="@_loginUrl" style="text-decoration:none;">
                <button class="k7-btn k7-btn--filled" style="width:100%;">@L["SignIn"]</button>
            </a>

            @if (_guestEnabled)
            {
                <EditForm Model="_guestModel" method="post" OnValidSubmit="ContinueAsGuest" FormName="guest">
                    <button type="submit" class="k7-btn k7-btn--outlined" style="width:100%;">@L["ContinueAsGuest"]</button>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    private bool _guestEnabled;
    private string _loginUrl = "/Account/Login";
    private object _guestModel = new();

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            var user = HttpContext.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                RedirectManager.RedirectTo(ReturnUrl ?? "/");
                return;
            }
        }

        _guestEnabled = await IsGuestActiveAsync();

        _loginUrl = !string.IsNullOrEmpty(ReturnUrl)
            ? Navigation.GetUriWithQueryParameters("/Account/Login",
                new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl })
            : "/Account/Login";

        if (!_guestEnabled)
        {
            RedirectManager.RedirectTo(_loginUrl);
            return;
        }
    }

    private async Task ContinueAsGuest()
    {
        var guestUser = await UserManager.FindByNameAsync(Roles.Guest);
        await SignInManager.SignInAsync(guestUser!, isPersistent: false);
        RedirectManager.RedirectTo(ReturnUrl ?? "/");
    }

    private async Task<bool> IsGuestActiveAsync()
    {
        var guestIdentity = await UserManager.FindByNameAsync(Roles.Guest);
        if (guestIdentity is null) return false;

        var guestDomainUser = await DbContext.Users
            .AsNoTracking()
            .FirstOrDefaultAsync(u => u.IdentityUserId == guestIdentity.Id);

        return guestDomainUser?.IsActive == true;
    }
}
