@page "/welcome"
@attribute [ExcludeFromInteractiveRouting]
@layout K7.Server.Web.Components.Pages.Auth.AuthLayout
@using K7.Server.Domain.Constants
@using K7.Server.Infrastructure.Configuration
@using K7.Server.Infrastructure.Database.Context.Data
@using K7.Server.Infrastructure.Database.Context.Identity
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Navigation
@inject K7.Server.Web.Components.Account.IdentityRedirectManager RedirectManager
@inject IOptions<AuthenticationConfiguration> AuthConfig
@inject IStringLocalizer<Welcome> L

<PageTitle>@L["PageTitle"]</PageTitle>

<div class="auth-card">
    <div class="auth-card-header">
        <h1 class="auth-title">K7</h1>
        <p class="auth-subtitle">@L["ChooseHow"]</p>
    </div>
    <div class="auth-card-body">
        <hr class="auth-divider" />
        <div class="auth-form-stack">
            <a href="@_signInUrl" style="text-decoration:none;">
                <button type="button" class="k7-btn k7-btn--filled focusable" data-initial-focus style="width:100%;">
                    @L["SignIn"]
                </button>
            </a>

            @if (_guestEnabled)
            {
                <EditForm Model="_guestModel" method="post" OnValidSubmit="ContinueAsGuest" FormName="guest">
                    <button type="submit" class="k7-btn k7-btn--outlined focusable" style="width:100%;">@L["ContinueAsGuest"]</button>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    private bool _guestEnabled;
    private AuthenticationConfiguration _auth = new();
    private string _signInUrl = "/sign-in";
    private object _guestModel = new();

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            var user = HttpContext.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                RedirectManager.RedirectTo(ReturnUrl ?? "/");
                return;
            }
        }

        _auth = AuthConfig.Value;
        _guestEnabled = await IsGuestActiveAsync();

        var returnUrl = ReturnUrl ?? "/";
        var oidcLoginUrl = Navigation.GetUriWithQueryParameters("/api/authentication/login",
            new Dictionary<string, object?> { ["returnUrl"] = returnUrl });
        _signInUrl = _auth.Oidc.Enabled && !_auth.Local.SignInEnabled
            ? oidcLoginUrl
            : Navigation.GetUriWithQueryParameters("/sign-in",
                new Dictionary<string, object?> { ["ReturnUrl"] = returnUrl });

        if (!_guestEnabled)
        {
            var target = _auth.Local.SignInEnabled
                ? _signInUrl
                : _auth.Oidc.Enabled ? oidcLoginUrl : null;

            if (target is not null)
            {
                if (HttpMethods.IsGet(HttpContext.Request.Method) && !HttpContext.Response.HasStarted)
                {
                    HttpContext.Response.Redirect(target);
                    return;
                }

                RedirectManager.RedirectTo(target);
                return;
            }
        }
    }

    private async Task ContinueAsGuest()
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        var signInManager = scope.ServiceProvider.GetRequiredService<SignInManager<ApplicationUser>>();

        var guestUser = await userManager.FindByNameAsync(Roles.Guest);
        await signInManager.SignInAsync(guestUser!, isPersistent: false);
        RedirectManager.RedirectTo(ReturnUrl ?? "/");
    }

    private async Task<bool> IsGuestActiveAsync()
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var dbContext = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

        return await dbContext.Set<ApplicationUser>()
            .AsNoTracking()
            .Where(identity => identity.UserName == Roles.Guest)
            .Join(
                dbContext.Users.AsNoTracking(),
                identity => identity.Id,
                domain => domain.IdentityUserId,
                (_, domain) => domain.IsActive)
            .FirstOrDefaultAsync();
    }
}
