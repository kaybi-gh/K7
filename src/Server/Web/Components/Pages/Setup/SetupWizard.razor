@page "/setup"
@layout SetupLayout
@using K7.Server.Application.Common.Interfaces
@using K7.Server.Infrastructure.Configuration
@using K7.Server.Infrastructure.Database.Context.Identity
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@inject ISetupService SetupService
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject K7.Server.Web.Components.Account.IdentityRedirectManager RedirectManager
@inject IOptions<AuthenticationConfiguration> AuthConfig
@inject IStringLocalizer<SetupWizard> L

<PageTitle>@L["PageTitle"] - K7</PageTitle>

<div class="auth-card">
    <div class="auth-card-header">
        <h1 class="auth-title">@L["WelcomeTitle"]</h1>
        <p class="auth-subtitle">@L["CreateAdmin"]</p>
    </div>
    <div class="auth-card-body">
        <hr class="auth-divider" />

        @if (!string.IsNullOrEmpty(_statusMessage))
        {
            <div class="auth-alert auth-alert--error" style="margin-bottom:1rem;">@_statusMessage</div>
        }

        <EditForm Model="Input" method="post" OnValidSubmit="OnSubmitAsync" FormName="setup">
            <DataAnnotationsValidator />
            <ValidationSummary class="auth-alert auth-alert--error" role="alert" />
            <div class="auth-form-stack">
                <div class="auth-form-field">
                    <label>@L["Email"]</label>
                    <InputText @bind-Value="Input!.Email" type="email" class="auth-input focusable" placeholder="@L["EmailPlaceholder"]" autocomplete="email" aria-required="true" autofocus />
                    <ValidationMessage For="@(() => Input!.Email)" class="auth-validation" />
                </div>

                <div class="auth-form-field">
                    <label>@L["Password"]</label>
                    <div class="auth-input-row">
                        <InputText @bind-Value="Input!.Password" id="pw-setup" type="password" class="auth-input focusable" placeholder="@L["PasswordPlaceholder"]" autocomplete="new-password" aria-required="true" />
                        <button type="button" class="auth-input-action focusable" onclick="togglePw('pw-setup')" aria-label="@L["ShowPassword"]"><i class="ph ph-eye"></i></button>
                    </div>
                    <ValidationMessage For="@(() => Input!.Password)" class="auth-validation" />
                </div>

                <div class="auth-form-field">
                    <label>@L["ConfirmPassword"]</label>
                    <div class="auth-input-row">
                        <InputText @bind-Value="Input!.ConfirmPassword" id="pw-confirm-setup" type="password" class="auth-input focusable" placeholder="@L["PasswordPlaceholder"]" autocomplete="new-password" aria-required="true" />
                        <button type="button" class="auth-input-action focusable" onclick="togglePw('pw-confirm-setup')" aria-label="@L["ShowPassword"]"><i class="ph ph-eye"></i></button>
                    </div>
                    <ValidationMessage For="@(() => Input!.ConfirmPassword)" class="auth-validation" />
                </div>

                <button type="submit" class="k7-btn k7-btn--filled focusable" style="width:100%;">@L["CompleteSetup"]</button>
            </div>
        </EditForm>

        @if (_externalProviders.Length > 0)
        {
            <p class="auth-or">@L["Or"]</p>
            <form action="/account/performsetupexternallogin" method="post" style="width: 100%;">
                <AntiforgeryToken />
                <div class="auth-form-stack">
                    @foreach (var provider in _externalProviders)
                    {
                        <button class="k7-btn k7-btn--outlined focusable" style="width:100%;" name="provider" value="@provider.Name" type="submit">
                            @L["CreateAdminWith", provider.DisplayName ?? provider.Name]
                        </button>
                    }
                </div>
            </form>
        }
    </div>
</div>

<script>
    function togglePw(id) {
        var el = document.getElementById(id);
        if (el) el.type = el.type === 'password' ? 'text' : 'password';
    }
</script>
