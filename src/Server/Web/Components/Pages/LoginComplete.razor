@page "/auth/complete"
@layout K7.Server.Web.Components.Pages.Setup.SetupLayout
@attribute [AllowAnonymous]
@inject IStringLocalizer<LoginComplete> L

<PageTitle>@L["PageTitle"] - K7</PageTitle>

<div class="auth-card">
    <div class="auth-card-body">
        <div class="auth-form-stack" style="align-items:center;">
            @if (_isError)
            {
                <i class="ph ph-x-circle auth-icon auth-icon--error"></i>
                <h2 class="auth-title">@_title</h2>
                <div class="auth-alert auth-alert--error" style="width:100%;">@_message</div>
            }
            else
            {
                <i class="ph ph-check-circle auth-icon auth-icon--success"></i>
                <h2 class="auth-title">@_title</h2>
                <div class="auth-alert auth-alert--success" style="width:100%;">@_message</div>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "status")]
    public string? Status { get; set; }

    private string _title = "";
    private string _message = "";
    private bool _isError;

    protected override void OnInitialized()
    {
        (_title, _message, _isError) = Status?.ToLowerInvariant() switch
        {
            "denied" => (L["DeniedTitle"].Value, L["DeniedMessage"].Value, true),
            "error" => (L["ErrorTitle"].Value, L["ErrorMessage"].Value, true),
            _ => (L["SuccessTitle"].Value, L["SuccessMessage"].Value, false)
        };
    }
}
