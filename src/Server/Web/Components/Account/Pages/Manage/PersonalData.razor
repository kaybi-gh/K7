@page "/Account/Manage/PersonalData"

@inject IdentityUserAccessor UserAccessor
@inject IStringLocalizer<PersonalData> L

<PageTitle>@L["PageTitle"]</PageTitle>

<h3 class="auth-section-title">@L["Title"]</h3>

<StatusMessage />

<div class="auth-form-stack">
    <p>@L["Description"]</p>
    <div class="auth-alert auth-alert--warning">@L["DeleteWarning"]</div>
    <form action="Account/Manage/DownloadPersonalData" method="post">
        <AntiforgeryToken />
        <button type="submit" class="k7-btn k7-btn--filled" style="width:100%;">@L["Download"]</button>
    </form>
    <a href="Account/Manage/DeletePersonalData" style="color:var(--color-error)">@L["Delete"]</a>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _ = await UserAccessor.GetRequiredUserAsync(HttpContext);
    }
}
