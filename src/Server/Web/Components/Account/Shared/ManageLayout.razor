@inherits LayoutComponentBase
@layout K7.Clients.Shared.UI.Pages.Layout.EmptyLayout

@inject IStringLocalizer<ManageLayout> L

<MudText Typo="Typo.h3" GutterBottom="true">@L["Title"]</MudText>

<MudGrid>
    <MudItem xs="12" md="5">
        <MudText Typo="Typo.h6" GutterBottom="true">@L["Subtitle"]</MudText>
        <ManageNavMenu />
    </MudItem>
    <MudItem xs="12" md="7">
        @Body
    </MudItem>
</MudGrid>
