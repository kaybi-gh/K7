# Copy to .env next to docker-compose.yaml and set a strong password:
# cp .env.example .env

POSTGRES_PASSWORD=change-me

# Optional Postgres settings (defaults match docker-compose.yaml):
# POSTGRES_USER=postgres
# POSTGRES_DB=K7
# POSTGRES_PORT=5432

# Optional: match host UID/GID to media volume ownership (container defaults to 911)
# PUID=1000
# PGID=1000

# Required before issuing API keys (HMAC secret mixed into key hashes).
# Changing it invalidates all existing API keys.
SECURITY__APIKEYS__HASHSECRET=change-me-to-a-long-random-string
# Or file secret: SECURITY__APIKEYS__HASHSECRET__FILE=/run/secrets/api_keys_hash_secret

# Sample compose defaults to false (HTTP on :8080). Set true behind a TLS reverse
# proxy - private Docker/LAN proxies are trusted by default. See docs/admin/configuration.md.
# SECURITY__FORCEHTTPS=false
